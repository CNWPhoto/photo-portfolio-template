# ══════════════════════════════════════════════════════════════════════════
# ROOT .env — used by the Astro site
# (Studio has its own studio/.env.example)
# ══════════════════════════════════════════════════════════════════════════

# ── Sanity project (required) ─────────────────────────────────────────────
# Found at sanity.io/manage → your project → project ID
PUBLIC_SANITY_PROJECT_ID=hx5xgigp
PUBLIC_SANITY_DATASET=production

# ── Visual Editing / Presentation (required for draft preview) ────────────

# Viewer token — create at sanity.io/manage → API → Tokens → Add API token
# Role: "Viewer". Used to read drafts AND to validate the ephemeral
# preview secret that Sanity Presentation generates on each open.
SANITY_API_READ_TOKEN=

# Origin of the Sanity Studio that will iframe this site.
# Local dev: http://localhost:3333
# Deployed:  https://<project>.sanity.studio (or custom studio domain)
# Used by stega to encode document links into rendered strings.
SANITY_STUDIO_URL=http://localhost:3333
