# Sanity read token — required for draft preview mode
# Create one at https://sanity.io/manage → project → API → Tokens → Add API token (Viewer role)
SANITY_API_READ_TOKEN=

# Preview secret — any random string shared between this site and Sanity Studio
# Generate one with: openssl rand -hex 32
SANITY_PREVIEW_SECRET=

# Used by Sanity Studio to know where to open the preview iframe
# In development: http://localhost:4321
# In production: your deployed site URL
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
