# ── Sanity project (required) ─────────────────────────────────────────────────
# Found at sanity.io/manage → your project → project ID
PUBLIC_SANITY_PROJECT_ID=

# The dataset to query — almost always "production"
PUBLIC_SANITY_DATASET=production

# ── Sanity preview (required for draft preview mode) ──────────────────────────
# Create at sanity.io/manage → API → Tokens → Add API token (Viewer role)
SANITY_API_READ_TOKEN=

# Any random string — shared between this site and Sanity Studio
# Generate one with: openssl rand -hex 32
SANITY_PREVIEW_SECRET=

# Where Sanity Studio opens the live-preview iframe
# Development: http://localhost:4321
# Production:  https://yourclientdomain.com
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
