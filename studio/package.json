{
  "name": "photo-portfolio-template",
  "private": true,
  "version": "1.0.0",
  "main": "package.json",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "dotenv -e .env -- sanity dev",
    "start": "dotenv -e .env -- sanity start",
    "build": "dotenv -e .env -- sanity build",
    "deploy": "dotenv -e .env -- sanity deploy",
    "deploy-all": "node scripts/deploy-all-studios.js",
    "migrate-all": "node scripts/migrate-all-datasets.js",
    "check-drift": "node scripts/check-client-drift.js",
    "deploy-graphql": "dotenv -e .env -- sanity graphql deploy",
    "seed": "dotenv -e .env -- sanity exec scripts/seed.js --with-user-token",
    "seed:replace": "dotenv -e .env -- sanity exec scripts/seed.js --with-user-token -- --replace",
    "seed:ai-instructions": "dotenv -e .env -- sanity exec scripts/ai-instructions/seed.js --with-user-token",
    "blackbird:overlay": "dotenv -e .env -- sanity exec scripts/blackbird-overlay.js --with-user-token",
    "onboard:overlay": "dotenv -e .env -- sanity exec scripts/onboard/60-overlay.js --with-user-token --",
    "onboard:blog": "dotenv -e .env -- sanity exec scripts/onboard/65-blog-import.js --with-user-token --"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@sanity/assist": "^6.1.10",
    "@sanity/vision": "^6.3.0",
    "react": "^19.1",
    "react-dom": "^19.1",
    "sanity": "^6.3.0",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.28",
    "prettier": "^3.5",
    "typescript": "^5.8"
  },
  "prettier": {
    "semi": false,
    "printWidth": 100,
    "bracketSpacing": false,
    "singleQuote": true
  }
}
