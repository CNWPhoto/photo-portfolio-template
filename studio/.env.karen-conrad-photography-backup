# ── Karen Conrad Photography ──
# Restore via: cp studio/.env.karen-conrad-photography-backup studio/.env
# Then: cd studio && npm run deploy (if you need to redeploy her Studio)

SANITY_STUDIO_PROJECT_ID=   # TODO: fill after Phase 1.1 (Sanity project created in her org)
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_HOST=karen-conrad-photography
SANITY_STUDIO_TITLE=Karen Conrad Photography

# Initial preview URL points at her Worker's *.workers.dev subdomain. The
# `<acct>` segment is her CF account's worker subdomain — fill it in after
# Phase 2.1 (CF admin invite accepted). Live site stays on her current
# karenconradphotography.com until she's ready to migrate, so this preview
# URL is what the hosted Studio iframes during the build phase.
# When DNS flips (Phase 3), update to the canonical custom domain and
# re-run `cd studio && npm run deploy` to rebake.
SANITY_STUDIO_PREVIEW_URL=https://karen-conrad-photography.<acct>.workers.dev

# Pinned by 30-studio-deploy.js after the first deploy. Leave blank now —
# Sanity creates the app and prints the appId; the script captures it back
# into this file.
SANITY_STUDIO_APP_ID=

# AI Assist plugin on by default during the trial month.
# Remove this line and redeploy Studio if Karen opts out after the trial.
SANITY_STUDIO_AI_ASSIST=true
