# Sanity project to connect Studio to. Override per client.
# Find these in the client's sanity.io dashboard.
SANITY_STUDIO_PROJECT_ID=hx5xgigp
SANITY_STUDIO_DATASET=production

# Origin of the Astro site that Studio Presentation will load in its iframe.
# Local dev: http://localhost:4321
# Deployed:  https://<client-domain> (production) or a preview URL
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
