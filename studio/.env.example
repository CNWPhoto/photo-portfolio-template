# Sanity project to connect Studio to. Override per client.
# Find these in the client's sanity.io dashboard.
SANITY_STUDIO_PROJECT_ID=hx5xgigp
SANITY_STUDIO_DATASET=production

# Subdomain for the hosted Studio (<host>.sanity.studio). Set per client
# before running `npm run deploy`. Must be globally unique across Sanity.
# Example: smith-photography -> https://smith-photography.sanity.studio
SANITY_STUDIO_HOST=cnw-photo-demo

# Display title shown in the Studio navbar. Keep blank for the generic
# template name; override per client (e.g. "Coola Creative").
SANITY_STUDIO_TITLE=

# Application ID for the hosted Studio. Leave UNSET for the first deploy
# of a fresh client project — Sanity will create a new application and
# print the generated appId in the CLI output. Paste that value here so
# subsequent `npm run deploy` runs skip the "Create new / attach existing"
# prompt and stay non-interactive.
SANITY_STUDIO_APP_ID=

# Origin of the Astro site that Studio Presentation will load in its iframe.
# Local dev: http://localhost:4321
# Deployed:  https://<client-domain> (production) or a preview URL
# IMPORTANT: flip this to the production URL before `npm run deploy`,
# then back to localhost:4321 for continued local dev. The preview URL
# is baked into the hosted Studio bundle at deploy time.
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
