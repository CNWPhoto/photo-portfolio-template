---
import { buildSrc } from '../lib/image';
import { renderBody, renderParagraphs, isPortableText } from '../lib/portableText.js';

const { whyChooseSection, theme } = Astro.props;

const bgUrl = whyChooseSection?.backgroundImage
  ? buildSrc(whyChooseSection.backgroundImage, 2000)
  : 'https://images.pexels.com/photos/1629781/pexels-photo-1629781.jpeg?auto=compress&cs=tinysrgb&w=2000';

const headingRaw = whyChooseSection?.heading ?? '';
const heading = headingRaw
  .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  .replace(/\n/g, '<br />');
const bodyHTML = isPortableText(whyChooseSection?.body)
  ? renderBody(whyChooseSection.body, { className: 'why__body' })
  : renderParagraphs([
      whyChooseSection?.bodyFirst  ?? '',
      whyChooseSection?.bodySecond ?? '',
    ], { className: 'why__body' });
const ctaText    = whyChooseSection?.ctaText    ?? '';
const ctaLink    = whyChooseSection?.ctaLink    ?? '#';
const caption    = whyChooseSection?.caption    ?? '';
---

<section
	class="why"
	id="why-choose"
	data-theme={theme || undefined}
>
	<!-- Fixed background image — section acts as a viewport cutout -->
	<div class="why__image-full" style={`background-image: url('${bgUrl}')`} aria-hidden="true"></div>

	<!-- Two-column content below -->
	<hr />
	<div class="why__inner">
		<div class="why__heading-col reveal">
			<h2 class="why__heading" set:html={heading} />
		</div>

		<div class="why__content-col reveal reveal-delay-2">
			<div set:html={bodyHTML} />
			<a href={ctaLink} class="why__cta">{ctaText}</a>
			{caption && <p class="why__caption">{caption}</p>}
		</div>
	</div>
</section>

<style>
	.why {
		padding-top: 0;
		padding-bottom: 0;
	}

	/* Section acts as a viewport cutout; image is pinned in place */
	.why__image-full {
		width: 100%;
		height: 65vh;
		min-height: 420px;
		background-attachment: fixed;
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}

	/* Two-column text section */
	.why__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 6rem 3rem 7rem;
		align-items: start;
	}

	.why__heading-col {
		border-left: 2px solid var(--accent);
		padding-left: 1.5rem;
	}

	.why__heading {
		font-size: var(--why-heading-size, clamp(2rem, 4vw, 3.25rem));
		color: var(--text);
		line-height: 1.18;
		letter-spacing: -0.01em;
	}

	.why__content-col {
		padding-top: 0.5rem;
	}

	.why__body {
		font-style: normal;
		font-size: 18px;
		line-height: 1.85;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.why__cta {
		display: inline-block;
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--text);
		padding: 0.8rem 1.75rem;
		margin-top: 1.5rem;
		margin-bottom: 1.75rem;
	}

	.why__cta:hover {
		background: var(--text);
		color: var(--bg);
	}

	.why__caption {
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		letter-spacing: 0.04em;
		color: var(--muted-light);
		font-style: normal;
	}

	@media (max-width: 900px) {
		.why__inner {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			padding: 4rem 1.5rem 5rem;
		}
	}
</style>

