---
import { buildSrc } from '../lib/image';

const { soloHeroImage, whyChooseSection, theme } = Astro.props;

const bgUrl = soloHeroImage?.image ? buildSrc(soloHeroImage.image, 2000) : '';

// Content — Sanity values with hardcoded fallbacks
const headingRaw = whyChooseSection?.heading ?? 'Why Choose\nPet Photography?';
// Escape HTML entities before injecting <br> so Sanity text can't inject markup
const heading = headingRaw
  .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  .replace(/\n/g, '<br />');
const bodyFirst  = whyChooseSection?.bodyFirst  ?? 'Working with a photographer who genuinely loves dogs makes all the difference. I understand how dogs move, what makes them light up, and how to draw out the personality that makes yours irreplaceable.';
const bodySecond = whyChooseSection?.bodySecond ?? 'Sessions are always unhurried, never stressful, and filled with play. My clients return session after session — not just for the images, but for the experience of watching their dog be completely, joyfully themselves.';
const ctaText    = whyChooseSection?.ctaText    ?? 'Get in Touch';
const ctaLink    = whyChooseSection?.ctaLink    ?? '/contact';
const caption    = whyChooseSection?.caption    ?? 'Serving Denver, Boulder, and surrounding areas.';
---

<section
	class="why"
	id="why-choose"
	data-theme={theme || undefined}
>
	<!-- Fixed background image — section acts as a viewport cutout -->
	<div class="why__image-full" style={`background-image: url('${bgUrl}')`} aria-hidden="true"></div>

	<!-- Two-column content below -->
	<hr />
	<div class="why__inner">
		<div class="why__heading-col reveal">
			<h2 class="why__heading" set:html={heading} />
		</div>

		<div class="why__content-col reveal reveal-delay-2">
			<p class="why__body">{bodyFirst}</p>
			{bodySecond && <p class="why__body">{bodySecond}</p>}
			<a href={ctaLink} class="why__cta">{ctaText}</a>
			{caption && <p class="why__caption">{caption}</p>}
		</div>
	</div>
</section>

<style>
	.why {
		padding-top: 0;
		padding-bottom: 0;
	}

	/* Section acts as a viewport cutout; image is pinned in place */
	.why__image-full {
		width: 100%;
		height: 65vh;
		min-height: 420px;
		background-attachment: fixed;
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}

	/* Two-column text section */
	.why__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 6rem 3rem 7rem;
		align-items: start;
	}

	.why__heading-col {
		border-left: 2px solid var(--accent);
		padding-left: 1.5rem;
	}

	.why__heading {
		font-size: var(--why-heading-size, clamp(2rem, 4vw, 3.25rem));
		color: var(--text);
		line-height: 1.18;
		letter-spacing: -0.01em;
	}

	.why__content-col {
		padding-top: 0.5rem;
	}

	.why__body {
		font-style: normal;
		font-size: 18px;
		line-height: 1.85;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.why__cta {
		display: inline-block;
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--text);
		padding: 0.8rem 1.75rem;
		margin-top: 1.5rem;
		margin-bottom: 1.75rem;
	}

	.why__cta:hover {
		background: var(--text);
		color: var(--bg);
	}

	.why__caption {
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		letter-spacing: 0.04em;
		color: var(--muted-light);
		font-style: normal;
	}

	@media (max-width: 900px) {
		.why__inner {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			padding: 4rem 1.5rem 5rem;
		}
	}
</style>

