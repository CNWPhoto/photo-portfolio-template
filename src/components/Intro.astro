---
import SanityImage from '../components/SanityImage.astro';

const { bio, approachText, profilePhoto, theme = 'classic-cream' } = Astro.props;

const bodyText = bio ?? "Every session is crafted entirely around your dog's unique personality. We find the light, the location, and the moments that tell their story — the tilt of a head, a full-speed sprint, a quiet glance."; // TODO:NICHE
const approachBodyText = approachText ?? 'No forced poses. No rushed timelines. Just you, your dog, and the kind of photography that makes people stop and say "that\'s exactly them."'; // TODO:NICHE
---

<section class="intro" id="about" data-theme={theme}>
	<div class="intro__image">
		{profilePhoto && (
			<SanityImage
				image={profilePhoto}
				sizes="(max-width: 900px) 100vw, 50vw"
			/>
		)}
	</div>

	<div class="intro__content">
		<div class="intro__text-wrap">
			<p class="intro__eyebrow">Welcome</p>
			<p class="intro__body">{bodyText}</p>
			<p class="intro__body">{approachBodyText}</p>
			<a href="/experience" class="intro__link">Learn about the experience &rarr;</a>
		</div>
	</div>
</section>

<style>
	.intro {
		display: grid;
		grid-template-columns: 1fr 1fr;
		padding: 0;
		border-top: 1px solid var(--border);
	}

	.intro__image {
		overflow: hidden;
		min-height: 600px;
	}

	.intro__image :global(.intro__img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
	}

	.intro__content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 60px 64px;
		background: var(--bg);
	}

	.intro__text-wrap {
		max-width: 440px;
	}

	.intro__eyebrow {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.65rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 20px;
	}

	.intro__body {
		font-style: italic;
		font-size: 1rem;
		line-height: 1.9;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.intro__body em {
		font-style: normal;
		color: var(--accent);
	}

	.intro__link {
		display: inline-block;
		font-style: normal;
		font-size: 0.875rem;
		letter-spacing: 0.05em;
		color: var(--accent);
		text-decoration: none;
		margin-top: 1rem;
		border-bottom: 1px solid var(--accent);
		padding-bottom: 1px;
	}

	.intro__link:hover {
		opacity: 0.7;
	}

	@media (max-width: 900px) {
		.intro {
			grid-template-columns: 1fr;
		}

		.intro__image :global(.intro__img) {
			height: 55vw;
			min-height: 320px;
		}

		.intro__content {
			padding: 4rem 2rem;
		}

		.intro__text-wrap {
			max-width: none;
		}
	}
</style>
