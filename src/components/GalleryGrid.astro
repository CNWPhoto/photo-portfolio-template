---
// Masonry grid + lightbox — shared between /portfolio and
// /portfolio/<slug>. Takes pre-normalized image objects
// ({ src, fullSrc, alt, w, h }) so the page decides what to urlFor.

interface GalleryImage {
  src: string;
  fullSrc: string;
  alt: string;
  w: number;
  h: number;
}

interface Props {
  images: GalleryImage[];
  galleryColumns?: number;
}

const { images, galleryColumns = 3 } = Astro.props;
const lbImages = images.map(({ fullSrc, alt }) => ({ src: fullSrc, alt }));

// Per-column flex containers + GREEDY shortest-column distribution.
// CSS `columns` rebalances by content height and on small galleries
// (e.g. 4 images in 3 columns) packs them 2+2+0, leaving an empty
// trailing column. CSS Grid forces uniform row heights, defeating the
// masonry look. Per-column flex containers give both: natural aspect
// ratios AND every column used. Distribution is greedy-by-height, not
// round-robin: each image goes to the currently shortest column,
// measured by cumulative aspect ratio (all columns share equal width,
// so rendered height ∝ h/w). Round-robin by index piled tall portraits
// into one column by luck of ordering — up to ~1150px of blank space
// under the short columns on real client galleries. Clamp column count
// to image count so 2 images in a 3-col layout renders as 2 columns.
const effectiveCols = Math.max(1, Math.min(galleryColumns, images.length || 1));
const columnBuckets: GalleryImage[][] = Array.from({ length: effectiveCols }, () => []);
const colHeights = new Array(effectiveCols).fill(0);
images.forEach((img) => {
  let shortest = 0;
  for (let c = 1; c < effectiveCols; c++) if (colHeights[c] < colHeights[shortest]) shortest = c;
  columnBuckets[shortest].push(img);
  colHeights[shortest] += img.h && img.w ? img.h / img.w : 1;
});
---

<div class="portfolio__grid" style={`--gallery-columns: ${effectiveCols}`}>
  {columnBuckets.map((bucket) => (
    <div class="portfolio__col">
      {bucket.map((img) => {
        const i = images.indexOf(img);
        return (
          <div class={`portfolio__item reveal-fade reveal-delay-${Math.min((i % 5) + 1, 5)}`}>
            <img
              src={img.src}
              alt={img.alt}
              width={img.w}
              height={img.h}
              loading="lazy"
              decoding="async"
              class="portfolio__img"
              data-index={i}
            />
          </div>
        );
      })}
    </div>
  ))}
</div>

<!-- Lightbox -->
<div class="lb" id="lb" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button class="lb__close" id="lb-close" aria-label="Close lightbox">&#x2715;</button>
  <button class="lb__arrow lb__prev" id="lb-prev" aria-label="Previous image">&#x2039;</button>
  <div class="lb__img-wrap">
    <img class="lb__img" id="lb-img" src="" alt="" />
  </div>
  <button class="lb__arrow lb__next" id="lb-next" aria-label="Next image">&#x203A;</button>
</div>

<script define:vars={{ lbImages }}>
  const lb     = document.getElementById('lb');
  const lbImg  = document.getElementById('lb-img');
  const lbPrev = document.getElementById('lb-prev');
  const lbNext = document.getElementById('lb-next');
  const lbClose = document.getElementById('lb-close');

  let current = 0;

  function open(index) {
    current = index;
    show();
  }

  function show() {
    const { src, alt } = lbImages[current];
    lbImg.style.opacity = '0';
    lbImg.alt = alt;
    lbImg.onload = () => { lbImg.style.opacity = '1'; };
    lbImg.src = src;
    if (lbImg.complete && lbImg.naturalWidth) lbImg.style.opacity = '1';
    lb.setAttribute('aria-hidden', 'false');
    lb.classList.add('lb--open');
    document.body.style.overflow = 'hidden';
    lbPrev.style.display = lbImages.length > 1 ? '' : 'none';
    lbNext.style.display = lbImages.length > 1 ? '' : 'none';
    [current - 1, current + 1].forEach((i) => {
      const idx = (i + lbImages.length) % lbImages.length;
      if (idx !== current) { const pre = new Image(); pre.src = lbImages[idx].src; }
    });
  }

  function close() {
    lb.classList.remove('lb--open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(() => { lbImg.src = ''; }, 300);
  }

  function prev() { current = (current - 1 + lbImages.length) % lbImages.length; show(); }
  function next() { current = (current + 1) % lbImages.length; show(); }

  document.querySelectorAll('.portfolio__img').forEach((img) => {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', () => open(Number(img.dataset.index)));
  });

  lbClose.addEventListener('click', close);
  lbPrev.addEventListener('click', prev);
  lbNext.addEventListener('click', next);

  lb.addEventListener('click', (e) => {
    if (e.target === lb) close();
  });

  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('lb--open')) return;
    if (e.key === 'Escape')      close();
    if (e.key === 'ArrowLeft')   prev();
    if (e.key === 'ArrowRight')  next();
  });

  // Responsive redistribution. The server renders at the desktop column
  // count (round-robin). At narrower viewports the row of columns would
  // either get too thin or show items out of reading order, so re-bucket
  // the items on resize using the breakpoint-appropriate column count.
  const grid = document.querySelector('.portfolio__grid');
  if (grid) {
    const desktopCols = Math.max(1, parseInt(getComputedStyle(grid).getPropertyValue('--gallery-columns')) || 3);
    // DOM order is column-major (server renders per-column buckets), so
    // sort by the original image index to re-bucket in reading order.
    const items = Array.from(grid.querySelectorAll('.portfolio__item')).sort(
      (a, b) =>
        Number(a.querySelector('img')?.dataset.index ?? 0) -
        Number(b.querySelector('img')?.dataset.index ?? 0),
    );
    const itemCount = items.length;
    // Template for JS-created columns. document.createElement('div') +
    // className loses Astro's scoped-style attribute (data-astro-cid-*),
    // so the scoped .portfolio__col rules (flex-direction, the 15px
    // vertical gap) silently don't apply to re-bucketed columns.
    // cloneNode(false) copies the server-rendered element with ALL its
    // attributes and no children.
    const colTemplate = grid.querySelector('.portfolio__col');

    function targetCols() {
      const w = window.innerWidth;
      if (w <= 480) return 1;
      if (w <= 900) return Math.min(2, itemCount || 1);
      return Math.min(desktopCols, itemCount || 1);
    }

    function redistribute(cols) {
      grid.innerHTML = '';
      const buckets = Array.from({ length: cols }, () =>
        colTemplate ? (colTemplate.cloneNode(false)) : document.createElement('div'));
      buckets.forEach((b) => { b.className = 'portfolio__col'; grid.appendChild(b); });
      // Greedy shortest-column by cumulative aspect ratio — mirrors the
      // server-side distribution so breakpoint changes don't reintroduce
      // the round-robin imbalance (blank space under short columns).
      const heights = new Array(cols).fill(0);
      items.forEach((item) => {
        const img = item.querySelector('img');
        const w = Number(img?.getAttribute('width')) || 1;
        const h = Number(img?.getAttribute('height')) || 1;
        let shortest = 0;
        for (let c = 1; c < cols; c++) if (heights[c] < heights[shortest]) shortest = c;
        buckets[shortest].appendChild(item);
        heights[shortest] += h / w;
      });
      grid.style.setProperty('--gallery-columns', String(cols));
    }

    let currentCols = desktopCols;
    function maybeRedistribute() {
      const next = targetCols();
      if (next !== currentCols) { currentCols = next; redistribute(next); }
    }
    maybeRedistribute();
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(maybeRedistribute, 100);
    });
  }
</script>

<style>
  /* Flex row of fixed-share columns — each column stacks its images
     vertically with their natural aspect ratio. True masonry without
     either of the CSS-only failure modes: no rebalancing into empty
     trailing columns, no uniform row heights. */
  .portfolio__grid {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    width: 100%;
    box-sizing: border-box;
    margin: 0;
    padding: 1.5rem 15px 0;
  }

  .portfolio__col {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .portfolio__item {
    overflow: hidden;
  }

  .portfolio__item img {
    width: 100%;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .portfolio__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .portfolio__item:hover img {
    transform: scale(1.03);
  }

  /* ── Lightbox ─────────────────────────────────────────── */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.92);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }

  .lb--open {
    opacity: 1;
    pointer-events: all;
  }

  .lb__img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: calc(100vw - 140px);
    max-height: calc(100vh - 60px);
  }

  .lb__img {
    display: block;
    max-width: 100%;
    max-height: calc(100vh - 60px);
    object-fit: contain;
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.6);
    transition: opacity 0.25s ease;
  }

  .lb__close {
    position: fixed;
    top: 1.25rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.18s, transform 0.18s;
    z-index: 2;
  }

  .lb__close:hover {
    color: #fff;
    transform: scale(1.15);
  }

  .lb__arrow {
    position: fixed;
    top: calc(50% - 26px);
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.8);
    font-size: 2.5rem;
    line-height: 1;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.18s, color 0.18s, background 0.18s, transform 0.18s;
    z-index: 2;
  }

  .lb__arrow:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.7);
    color: #fff;
    transform: scale(1.08);
  }

  .lb__prev { left: 1.25rem; }
  .lb__next { right: 1.25rem; }

  @media (max-width: 900px) {
    .lb__img-wrap { max-width: calc(100vw - 100px); }
  }

  @media (max-width: 480px) {
    .lb__arrow { width: 40px; height: 40px; font-size: 2rem; }
    .lb__prev { left: 0.5rem; }
    .lb__next { right: 0.5rem; }
    .lb__img-wrap { max-width: calc(100vw - 80px); }
  }
</style>
