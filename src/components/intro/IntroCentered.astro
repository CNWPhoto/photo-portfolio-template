---
import SanityImage from '../../components/SanityImage.astro';
import { renderBody, renderParagraphs, isPortableText } from '../../lib/portableText.js';

const { welcomeSection, theme } = Astro.props;

const eyebrow = welcomeSection?.eyebrow ?? '';
const bodyHTML = isPortableText(welcomeSection?.bodyRich)
	? renderBody(welcomeSection.bodyRich, { className: 'icentered__body' })
	: renderParagraphs([
		welcomeSection?.body          ?? '',
		welcomeSection?.bodySecondary ?? '',
	], { className: 'icentered__body' });
---

<section class="icentered" id="about" data-theme={theme || undefined}>
	<div class="icentered__text">
		{eyebrow && <p class="icentered__eyebrow">{eyebrow}</p>}
		<div class="icentered__body-wrap" set:html={bodyHTML} />
		<a href="/experience" class="icentered__link">Learn about the experience &rarr;</a>
	</div>

	<div class="icentered__image">
		{welcomeSection?.image
			? <SanityImage
				image={welcomeSection.image}
				sizes="(max-width: 900px) 100vw, 60vw"
			/>
			: <img
				src="https://images.pexels.com/photos/1108099/pexels-photo-1108099.jpeg?auto=compress&cs=tinysrgb&w=1400"
				alt=""
				loading="lazy"
			/>
		}
	</div>
</section>

<style>
	.icentered {
		border-top: 1px solid var(--border);
	}

	/* ── Centered text block ── */
	.icentered__text {
		max-width: 760px;
		margin: 0 auto;
		padding: 7rem 3rem 5rem;
		text-align: center;
	}

	.icentered__eyebrow {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.725rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 2.5rem;
	}

	.icentered__body-wrap {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-bottom: 2.5rem;
	}

	.icentered__body {
		font-style: italic;
		font-size: clamp(1.125rem, 2vw, 1.3125rem);
		line-height: 1.78;
		color: var(--text);
	}

	.icentered__body em {
		font-style: normal;
		color: var(--accent);
	}

	.icentered__link {
		display: inline-block;
		font-style: normal;
		font-size: 0.875rem;
		letter-spacing: 0.05em;
		color: var(--accent);
		text-decoration: none;
		border-bottom: 1px solid var(--accent);
		padding-bottom: 1px;
	}

	.icentered__link:hover { opacity: 0.7; }

	/* ── Full-width image below ── */
	.icentered__image {
		width: 100%;
		overflow: hidden;
	}

	.icentered__image :global(.icentered__img) {
		width: 100%;
		height: 55vw;
		max-height: 700px;
		min-height: 340px;
		object-fit: cover;
		object-position: center 40%;
		display: block;
	}

	@media (max-width: 768px) {
		.icentered__text { padding: 5rem 1.5rem 4rem; }
	}
</style>
