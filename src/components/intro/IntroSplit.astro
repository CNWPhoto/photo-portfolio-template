---
const { welcomeSection, urlFor, theme } = Astro.props;

// TODO:NICHE — fallback photo and text are dog/pet-specific; replace for your niche
const photoSrc =
	welcomeSection?.image && urlFor
		? urlFor(welcomeSection.image).width(1200).auto('format').url()
		: 'https://images.pexels.com/photos/825949/pexels-photo-825949.jpeg?auto=compress&cs=tinysrgb&w=800&h=1100&fit=crop';
const photoAlt = welcomeSection?.image?.alt ?? 'Dog portrait in natural light'; // TODO:NICHE

const eyebrow = welcomeSection?.eyebrow || '';
const bodyText = welcomeSection?.body || 'Dog photography sessions that focus on personality, connection, and comfort.'; // TODO:NICHE
const bodySecondary = welcomeSection?.bodySecondary || 'Whether you\'re celebrating a new puppy or capturing your dog just as they are now, each session is designed to feel relaxed and fun—for both of you.'; // TODO:NICHE
const ctaText = welcomeSection?.ctaText || '';
---

<section class="isplit" id="about" data-theme={theme || undefined}>
	<div class="isplit__content">
		<div class="isplit__text-wrap">
			{eyebrow && <p class="isplit__eyebrow">{eyebrow}</p>}
			<p class="isplit__body">{bodyText}</p>
			<p class="isplit__body">{bodySecondary}</p>
			{ctaText && <a class="isplit__link" href="/experience">{ctaText}</a>}
		</div>
	</div>

	<div class="isplit__image">
		<img src={photoSrc} alt={photoAlt} loading="lazy" />
	</div>
</section>

<style>
	.isplit {
		display: grid;
		grid-template-columns: 1fr 1fr;
		height: 550px;
		padding: 0;
		border-top: 1px solid var(--border);
	}

	.isplit__image {
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.isplit__image img {
		height: 100%;
		width: auto;
		display: block;
	}

	.isplit__content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
		padding: 60px 64px;
		background: var(--bg-alt);
	}

	.isplit__text-wrap { max-width: 384px; }

	.isplit__eyebrow {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.65rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 20px;
	}

	.isplit__body {
		font-style: italic;
		font-size: 1rem;
		line-height: 1.9;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.isplit__body em {
		font-style: normal;
		color: var(--accent);
	}

	.isplit__link {
		display: inline-block;
		font-style: normal;
		font-size: 0.875rem;
		letter-spacing: 0.05em;
		color: var(--accent);
		text-decoration: none;
		margin-top: 1rem;
		border-bottom: 1px solid var(--accent);
		padding-bottom: 1px;
		transition: opacity 0.2s;
	}

	.isplit__link:hover { opacity: 0.7; }

	@media (max-width: 900px) {
		.isplit { grid-template-columns: 1fr; }
		.isplit__image { order: -1; }
		.isplit__image img { height: 60vw; min-height: 240px; }
		.isplit__content { padding: 4rem 2rem; align-items: flex-start; text-align: left; }
		.isplit__text-wrap { max-width: none; }
	}
</style>
