---
import SanityImage from '../../components/SanityImage.astro';
import { renderBody, renderParagraphs, isPortableText } from '../../lib/portableText.js';

const { welcomeSection, theme } = Astro.props;

const eyebrow = welcomeSection?.eyebrow ?? '';
const bodyHTML = isPortableText(welcomeSection?.bodyRich)
	? renderBody(welcomeSection.bodyRich, { className: 'isplit__body' })
	: renderParagraphs([
		welcomeSection?.body          ?? '',
		welcomeSection?.bodySecondary ?? '',
	], { className: 'isplit__body' });
const ctaText = welcomeSection?.ctaText ?? '';
const ctaLink = welcomeSection?.ctaLink ?? '#';
---

<section
	class="isplit"
	id="about"
	data-theme={theme || undefined}
>
	<div class="isplit__content">
		<div class="isplit__text-wrap">
			{eyebrow && <p class="isplit__eyebrow reveal reveal-delay-1">{eyebrow}</p>}
			<div class="isplit__body-wrap reveal reveal-delay-2" set:html={bodyHTML} />
			{ctaText && <a class="isplit__link reveal reveal-delay-4" href={ctaLink}>{ctaText}</a>}
		</div>
	</div>

	<div class="isplit__image reveal-fade">
		{welcomeSection?.image
			? <SanityImage
				image={welcomeSection.image}
				sizes="(max-width: 900px) 100vw, 50vw"
				class="isplit__img"
			/>
			: <img
				src="https://images.pexels.com/photos/1108099/pexels-photo-1108099.jpeg?auto=compress&cs=tinysrgb&w=1200"
				alt=""
				class="isplit__img"
				loading="lazy"
			/>
		}
	</div>
</section>

<style>
	.isplit {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 550px;
		padding: 0;
		border-top: 1px solid var(--border);
	}

	.isplit__image {
		overflow: hidden;
		height: 100%;
	}

	.isplit__image :global(.isplit__img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	.isplit__content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: flex-end;
		padding: 60px 64px;
		background: var(--bg-alt);
	}

	.isplit__text-wrap {
		max-width: 440px;
		text-align: right;
		padding-right: 75px;
	}

	.isplit__eyebrow {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: var(--isplit-eyebrow-size, 0.65rem);
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 20px;
		text-align: right;
	}

	.isplit__body {
		font-size: var(--isplit-body-size, 1.32rem);
		line-height: 1.43;
		color: var(--text);
		margin-bottom: 1.5rem;
		text-align: right;
	}

	.isplit__body em {
		font-style: normal;
		color: var(--accent);
	}

	.isplit__link {
		display: block;
		font-style: italic;
		font-size: var(--isplit-link-size, 1rem);
		letter-spacing: 0.01em;
		color: var(--accent);
		text-decoration: none;
		border-bottom: none;
		padding-bottom: 0;
		margin-top: 1.5rem;
		text-align: right;
	}

	@media (max-width: 900px) {
		.isplit { grid-template-columns: 1fr; }
		.isplit__image { order: -1; }
		.isplit__image :global(.isplit__img) { height: 60vw; min-height: 240px; }
		.isplit__content { padding: 4rem 2rem; align-items: center; text-align: center; }
		.isplit__text-wrap { max-width: none; padding-right: 0; text-align: center; }
		.isplit__eyebrow { text-align: center; }
		.isplit__body { text-align: center; }
		.isplit__link { text-align: center; }
	}
</style>
