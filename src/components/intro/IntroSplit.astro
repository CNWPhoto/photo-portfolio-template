---
import { sanityImg, sanitySrcset } from '../../utils/imageUrl';

const { welcomeSection, urlFor, theme, overrides } = Astro.props;

// TODO:NICHE — fallback photo and text are dog/pet-specific; replace for your niche
const photoBase = welcomeSection?.image && urlFor ? urlFor(welcomeSection.image).url() : null;
const photoFallback = 'https://images.pexels.com/photos/825949/pexels-photo-825949.jpeg?auto=compress&cs=tinysrgb&w=1600';
const photoAlt = welcomeSection?.image?.alt ?? 'Dog portrait in natural light'; // TODO:NICHE

const eyebrow = welcomeSection?.eyebrow || 'Every Session is Unique';
const bodyText = welcomeSection?.body || 'Dog photography sessions that focus on personality, connection, and comfort.'; // TODO:NICHE
const bodySecondary = welcomeSection?.bodySecondary || 'Whether you\'re celebrating a new puppy or capturing your dog just as they are now, each session is designed to feel relaxed and fun—for both of you.'; // TODO:NICHE
const ctaText = welcomeSection?.ctaText || 'See the Experience →';
const ctaLink = welcomeSection?.ctaLink || '/experience';
---

<section
	class="isplit"
	id="about"
	data-theme={theme || undefined}
	style={[
		overrides?.isplitBodySize ? `--isplit-body-size: ${overrides.isplitBodySize}` : '',
		overrides?.isplitEyebrowSize ? `--isplit-eyebrow-size: ${overrides.isplitEyebrowSize}` : '',
		overrides?.isplitLinkSize ? `--isplit-link-size: ${overrides.isplitLinkSize}` : '',
	].filter(Boolean).join('; ') || undefined}
>
	<div class="isplit__content">
		<div class="isplit__text-wrap">
			{eyebrow && <p class="isplit__eyebrow reveal reveal-delay-1">{eyebrow}</p>}
			<p class="isplit__body reveal reveal-delay-2">{bodyText}</p>
			<p class="isplit__body reveal reveal-delay-3">{bodySecondary}</p>
			{ctaText && <a class="isplit__link reveal reveal-delay-4" href={ctaLink}>{ctaText}</a>}
		</div>
	</div>

	<div class="isplit__image reveal-fade">
		{photoBase
			? <img
					src={sanityImg(photoBase, 1600, 85)}
					srcset={sanitySrcset(photoBase, [800, 1200, 1600, 2400], 85)}
					sizes="(max-width: 900px) 100vw, 50vw"
					alt={photoAlt}
					loading="lazy" decoding="async"
				/>
			: <img src={photoFallback} alt={photoAlt} loading="lazy" decoding="async" />
		}
	</div>
</section>

<style>
	.isplit {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 550px;
		padding: 0;
		border-top: 1px solid var(--border);
	}

	.isplit__image {
		overflow: hidden;
	}

	.isplit__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	.isplit__content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: flex-start;
		text-align: left;
		padding: 60px 64px;
		background: var(--bg-alt);
	}

	.isplit__text-wrap { max-width: 440px; }

	.isplit__eyebrow {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: var(--isplit-eyebrow-size, 0.65rem);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 20px;
	}

	.isplit__body {
		font-style: italic;
		font-size: var(--isplit-body-size, 1.1rem);
		line-height: 1.9;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.isplit__body em {
		font-style: normal;
		color: var(--accent);
	}

	.isplit__link {
		display: inline-block;
		font-style: italic;
		font-size: var(--isplit-link-size, 1rem);
		letter-spacing: 0.01em;
		color: #c9702a;
		text-decoration: none;
		border-bottom: none;
		padding-bottom: 0;
		margin-top: 1.5rem;
		transition: opacity 0.2s, letter-spacing 0.25s;
	}

	.isplit__link:hover { opacity: 1; letter-spacing: 0.04em; }

	@media (max-width: 900px) {
		.isplit { grid-template-columns: 1fr; }
		.isplit__image { order: -1; }
		.isplit__image img { height: 60vw; min-height: 240px; }
		.isplit__content { padding: 4rem 2rem; align-items: flex-start; text-align: left; }
		.isplit__text-wrap { max-width: none; }
	}
</style>
