---
import SanityImage from '../components/SanityImage.astro';
import { buildSrc, buildSrcset } from '../lib/image';

const { testimonials: sanityTestimonials, theme = 'classic-cream' } = Astro.props;

const testimonials = sanityTestimonials?.length
	? sanityTestimonials.map((t: any) => ({
			image: t.photo ?? null,
			photoSrc: t.photo ? buildSrc(t.photo, 700) : '',
			photoSrcset: t.photo ? buildSrcset(t.photo, [350, 700, 1050]) : '',
			photoAlt: t.photo?.alt ?? '',
			quote: t.quote ?? '',
			name: t.clientName ?? '',
			pet: t.clientSubjectName ?? '',
	  }))
	: [];
---

<section class="testimonials" id="testimonials" data-theme={theme}>
	<hr />
	<div class="testimonials__inner" id="testimonialsInner">
		<div class="testimonials__image-col" id="testimonialsImgWrap">
			{testimonials[0]?.image && (
				<SanityImage
					image={testimonials[0].image}
					sizes="(max-width: 900px) 100vw, 40vw"
			/>
			)}
		</div>

		<div class="testimonials__content">
			<p class="testimonials__label">Kind Words from Kind Clients</p>
			<hr class="testimonials__rule" />

			<div id="testimonialsQuote">
				<blockquote class="testimonials__quote" id="quoteText">
					&ldquo;{testimonials[0].quote}&rdquo;
				</blockquote>
				<p class="testimonials__attribution">
					<span id="quoteName">{testimonials[0].name}</span>
					<span class="testimonials__sep">&mdash;</span>
					<span id="quotePet">{testimonials[0].pet}</span>
				</p>
			</div>

			<div class="testimonials__nav">
				<span class="testimonials__count">
					<span id="currentIdx">1</span> / {testimonials.length}
				</span>
				<button class="testimonials__arrow" id="testimonialPrev" aria-label="Previous testimonial"
					>&#8592;</button
				>
				<button class="testimonials__arrow" id="testimonialNext" aria-label="Next testimonial"
					>&#8594;</button
				>
			</div>
		</div>
	</div>
</section>

<!-- Testimonial data for JS -->
<script
	type="application/json"
	id="testimonialsData"
	set:text={JSON.stringify(testimonials)}
></script>

<style>
	.testimonials {
		border-top: none;
	}

	.testimonials__inner {
		display: grid;
		grid-template-columns: 5fr 6fr;
		min-height: 78vh;
	}

	.testimonials__image-col {
		overflow: hidden;
	}

	.testimonials__image-col img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
		transition: opacity 0.4s ease;
	}

	.testimonials__content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 6rem 6rem 6rem 5.5rem;
		background: var(--bg-alt);
	}

	.testimonials__label {
		font-style: italic;
		font-size: 1.875rem;
		line-height: 1.25;
		color: var(--text);
		margin-bottom: 2rem;
	}

	.testimonials__rule {
		margin-bottom: 2.5rem;
	}

	.testimonials__quote {
		font-style: italic;
		font-size: 1.125rem;
		line-height: 1.8;
		color: var(--text);
		margin: 0 0 2rem;
		transition: opacity 0.3s ease;
	}

	.testimonials__attribution {
		font-style: normal;
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
		display: flex;
		align-items: center;
		gap: 0.625rem;
	}

	.testimonials__sep {
		color: var(--border);
	}

	.testimonials__nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.testimonials__count {
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		letter-spacing: 0.08em;
		color: var(--muted-light);
		margin-right: auto;
	}

	.testimonials__arrow {
		background: none;
		border: 1px solid var(--border);
		color: var(--text);
		font-family: var(--font-sans);
		font-size: 1rem;
		width: 42px;
		height: 42px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.testimonials__arrow:hover {
		border-color: var(--text);
	}

	.testimonials__arrow:disabled {
		opacity: 0.3;
		cursor: default;
	}

	@media (max-width: 900px) {
		.testimonials__inner {
			grid-template-columns: 1fr;
		}

		.testimonials__image-col img {
			height: 55vw;
			min-height: 300px;
		}

		.testimonials__content {
			padding: 4rem 2rem;
		}
	}
</style>

<script>
	const data: Array<{
		photoSrc: string;
		photoSrcset: string;
		photoAlt: string;
		quote: string;
		name: string;
		pet: string;
	}> = JSON.parse(document.getElementById('testimonialsData')!.textContent!);

	const imgWrap = document.getElementById('testimonialsImgWrap');
	const quoteText = document.getElementById('quoteText')!;
	const quoteName = document.getElementById('quoteName')!;
	const quotePet = document.getElementById('quotePet')!;
	const currentIdx = document.getElementById('currentIdx')!;
	const prevBtn = document.getElementById('testimonialPrev') as HTMLButtonElement;
	const nextBtn = document.getElementById('testimonialNext') as HTMLButtonElement;

	let idx = 0;

	function render(i: number, direction: 'prev' | 'next' | null = null) {
		const t = data[i];
		quoteText.style.opacity = '0';
		if (imgWrap) imgWrap.style.opacity = '0';

		setTimeout(() => {
			if (imgWrap) {
				let imgEl = imgWrap.querySelector('img');
				if (t.photoSrc) {
					if (!imgEl) { imgEl = document.createElement('img'); imgWrap.appendChild(imgEl); }
					imgEl.src = t.photoSrc;
					imgEl.srcset = t.photoSrcset || '';
					imgEl.alt = t.photoAlt;
				} else if (imgEl) {
					imgEl.remove();
				}
			}
			quoteText.textContent = `\u201C${t.quote}\u201D`;
			quoteName.textContent = t.name;
			quotePet.textContent = t.pet;
			currentIdx.textContent = String(i + 1);

			quoteText.style.opacity = '1';
			if (imgWrap) imgWrap.style.opacity = '1';
		}, 280);

		prevBtn.disabled = i === 0;
		nextBtn.disabled = i === data.length - 1;
	}

	prevBtn.addEventListener('click', () => {
		if (idx > 0) render(--idx, 'prev');
	});
	nextBtn.addEventListener('click', () => {
		if (idx < data.length - 1) render(++idx, 'next');
	});

	// init state
	prevBtn.disabled = true;
</script>
