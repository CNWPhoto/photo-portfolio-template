---
const { testimonials: sanityTestimonials, urlFor, theme, overrides } = Astro.props;

// TODO:NICHE — fallback testimonials reference dogs; update for your niche
// photoBase: Sanity CDN base URL (no params) — used to build srcset
// photoUrl:  direct URL (Pexels fallbacks only) — used when photoBase is absent
const fallback = [
	{
		photoBase: '',
		photoUrl: 'https://images.pexels.com/photos/1108099/pexels-photo-1108099.jpeg?auto=compress&cs=tinysrgb&w=800&h=1200&fit=crop',
		photoAlt: 'Golden retriever in warm afternoon light', // TODO:NICHE
		quote: "Hazel captured something in Biscuit that we'd been trying to capture ourselves for years. Every single image is breathtaking. We have them printed throughout our home and can't stop looking at them.", // TODO:NICHE
		client: 'Sarah & Tom K.',
	},
	{
		photoBase: '',
		photoUrl: 'https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=800&h=1200&fit=crop',
		photoAlt: 'Dog exploring outdoors with a stick', // TODO:NICHE
		quote: "I was skeptical that Penny would cooperate for even five minutes. Hazel had her completely at ease within seconds. The patience and genuine love for dogs she brings to every session is unlike anything I've experienced.", // TODO:NICHE
		client: 'Marcus R.',
	},
	{
		photoBase: '',
		photoUrl: 'https://images.pexels.com/photos/825949/pexels-photo-825949.jpeg?auto=compress&cs=tinysrgb&w=800&h=1200&fit=crop',
		photoAlt: 'Dog portrait in natural light', // TODO:NICHE
		quote: "Three sessions in and each gallery is more beautiful than the last. Hazel has a gift for capturing the soul of a dog — not just their face, but everything that makes them who they are.", // TODO:NICHE
		client: 'Jess & Olivia M.',
	},
];

const testimonials =
	sanityTestimonials?.length && urlFor
		? sanityTestimonials.map((t: any) => ({
				photoBase: t.image ? urlFor(t.image).url() : '',
				photoUrl: '',
				photoAlt: t.image?.alt ?? '',
				quote: t.testimonial ?? '',
				client: t.client ?? '',
		  }))
		: fallback;
---

<section
	class="tslider"
	id="testimonials"
	data-theme={theme || undefined}
	style={overrides?.tsliderQuoteSize ? `--tslider-quote-size: ${overrides.tsliderQuoteSize}` : undefined}
>
	<div class="tslider__inner">
		<div class="tslider__image-col reveal-fade">
			<div class="tslider__image-wrap">
				<img
					id="tsliderImg"
					src={testimonials[0].photoBase
						? `${testimonials[0].photoBase}?w=800&auto=format&fit=max&q=85`
						: testimonials[0].photoUrl}
					srcset={testimonials[0].photoBase
						? `${testimonials[0].photoBase}?w=400&auto=format&fit=max&q=85 400w, ${testimonials[0].photoBase}?w=800&auto=format&fit=max&q=85 800w, ${testimonials[0].photoBase}?w=1200&auto=format&fit=max&q=85 1200w`
						: undefined}
					sizes="(max-width: 900px) 30vw, 200px"
					alt={testimonials[0].photoAlt}
					loading="lazy" decoding="async"
				/>
			</div>
		</div>

		<div class="tslider__content reveal reveal-delay-2">
			<blockquote class="tslider__quote" id="tsliderQuote">
				&ldquo;{testimonials[0].quote}&rdquo;
			</blockquote>
			<p class="tslider__attribution" id="tsliderClient">{testimonials[0].client}</p>

			<div class="tslider__nav">
				<span class="tslider__count">
					<span id="tsliderIdx">1</span> / {testimonials.length}
				</span>
				<button class="tslider__arrow" id="tsliderPrev" aria-label="Previous testimonial">&#8592;</button>
				<button class="tslider__arrow" id="tsliderNext" aria-label="Next testimonial">&#8594;</button>
			</div>
		</div>
	</div>
</section>

<style>
	.tslider {
		padding: 0;
		margin-top: 100px;
		margin-bottom: 100px;
	}

	.tslider__inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 3rem;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 150px;
	}

	.tslider__image-col {
		flex-shrink: 0;
	}

	.tslider__image-wrap {
		width: 300px;
		height: 450px;
		overflow: hidden;
		flex-shrink: 0;
	}

	.tslider__image-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
		transition: opacity 0.4s ease;
	}

	.tslider__content {
		max-width: 480px;
	}

	.tslider__quote {
		font-style: italic;
		font-size: var(--tslider-quote-size, 1.25rem);
		line-height: 1.8;
		color: var(--text);
		margin: 0 0 2rem;
		transition: opacity 0.3s ease;
	}

	.tslider__attribution {
		font-style: normal;
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.tslider__nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: 2.5rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.tslider__count {
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		letter-spacing: 0.08em;
		color: var(--muted-light);
		margin-right: auto;
	}

	.tslider__arrow {
		background: none;
		border: 1px solid var(--border);
		color: var(--text);
		font-family: var(--font-sans);
		font-size: 1rem;
		width: 42px;
		height: 42px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.tslider__arrow:hover:not(:disabled) { border-color: var(--text); }
	.tslider__arrow:disabled { opacity: 0.3; cursor: default; }

	@media (max-width: 900px) {
		.tslider__inner {
			flex-direction: column;
			align-items: flex-start;
			gap: 2.5rem;
			padding: 0 1.5rem;
		}
		.tslider__image-wrap { width: 100%; height: 70vw; max-height: 400px; }
		.tslider__content { max-width: none; }
	}
</style>

<script define:vars={{ testimonials }}>
	const imgEl    = document.getElementById('tsliderImg');
	const quoteEl  = document.getElementById('tsliderQuote');
	const clientEl = document.getElementById('tsliderClient');
	const idxEl    = document.getElementById('tsliderIdx');
	const prevBtn  = document.getElementById('tsliderPrev');
	const nextBtn  = document.getElementById('tsliderNext');

	const data = testimonials;
	let idx = 0;

	function render(i) {
		const t = data[i];
		if (!t) return;

		quoteEl.style.opacity = '0';
		imgEl.style.opacity = '0';

		setTimeout(function() {
			if (t.photoBase) {
				imgEl.src = t.photoBase + '?w=800&auto=format&fit=max&q=85';
				imgEl.srcset = [
					t.photoBase + '?w=400&auto=format&fit=max&q=85 400w',
					t.photoBase + '?w=800&auto=format&fit=max&q=85 800w',
					t.photoBase + '?w=1200&auto=format&fit=max&q=85 1200w',
				].join(', ');
			} else if (t.photoUrl) {
				imgEl.src = t.photoUrl;
				imgEl.srcset = '';
			}
			imgEl.alt = t.photoAlt || '';
			quoteEl.textContent = '\u201C' + t.quote + '\u201D';
			clientEl.textContent = t.client;
			idxEl.textContent = String(i + 1);
			quoteEl.style.opacity = '1';
			imgEl.style.opacity = '1';
		}, 280);

		prevBtn.disabled = i === 0;
		nextBtn.disabled = i === data.length - 1;
	}

	prevBtn.addEventListener('click', function() {
		if (idx > 0) { idx--; render(idx); }
	});
	nextBtn.addEventListener('click', function() {
		if (idx < data.length - 1) { idx++; render(idx); }
	});

	prevBtn.disabled = true;
	nextBtn.disabled = data.length <= 1;
</script>
