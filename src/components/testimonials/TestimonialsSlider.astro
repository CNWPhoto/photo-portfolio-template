---
import SanityImage from '../../components/SanityImage.astro';
import { buildSrc, buildSrcset } from '../../lib/image';

const { testimonials: sanityTestimonials, theme, overrides } = Astro.props;

const testimonials = sanityTestimonials?.length
	? sanityTestimonials.map((t: any) => ({
			image: t.image ?? null,
			photoSrc: t.image ? buildSrc(t.image, 800) : '',
			photoSrcset: t.image ? buildSrcset(t.image, [400, 800, 1200]) : '',
			photoAlt: t.image?.alt ?? '',
			quote: t.testimonial ?? '',
			client: t.client ?? '',
	  }))
	: [];
---

<section
	class="tslider"
	id="testimonials"
	data-theme={theme || undefined}
	style={overrides?.tsliderQuoteSize ? `--tslider-quote-size: ${overrides.tsliderQuoteSize}` : undefined}
>
	<div class="tslider__inner">
		<div class="tslider__image-col reveal-fade">
			<div class="tslider__image-wrap" id="tsliderImgWrap">
				{testimonials[0]?.image && (
					<SanityImage
						image={testimonials[0].image}
						sizes="(max-width: 900px) 30vw, 200px"
						class="tslider__img"
					/>
				)}
			</div>
		</div>

		<div class="tslider__content reveal reveal-delay-2">
			<blockquote class="tslider__quote" id="tsliderQuote">
				&ldquo;{testimonials[0]?.quote}&rdquo;
			</blockquote>
			<p class="tslider__attribution" id="tsliderClient">{testimonials[0]?.client}</p>

			<div class="tslider__nav">
				<span class="tslider__count">
					<span id="tsliderIdx">1</span> / {testimonials.length}
				</span>
				<button class="tslider__arrow" id="tsliderPrev" aria-label="Previous testimonial">&#8592;</button>
				<button class="tslider__arrow" id="tsliderNext" aria-label="Next testimonial">&#8594;</button>
			</div>
		</div>
	</div>
</section>

<style>
	.tslider {
		padding: 0;
		margin-top: 100px;
		margin-bottom: 100px;
	}

	.tslider__inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 3rem;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 150px;
	}

	.tslider__image-col {
		flex-shrink: 0;
	}

	.tslider__image-wrap {
		width: 300px;
		height: 450px;
		overflow: hidden;
		flex-shrink: 0;
	}

	.tslider__image-wrap :global(.tslider__img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
		transition: opacity 0.4s ease;
	}

	.tslider__content {
		max-width: 480px;
	}

	.tslider__quote {
		font-style: italic;
		font-size: var(--tslider-quote-size, 1.25rem);
		line-height: 1.8;
		color: var(--text);
		margin: 0 0 2rem;
		transition: opacity 0.3s ease;
	}

	.tslider__attribution {
		font-style: normal;
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.tslider__nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: 2.5rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.tslider__count {
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		letter-spacing: 0.08em;
		color: var(--muted-light);
		margin-right: auto;
	}

	.tslider__arrow {
		background: none;
		border: 1px solid var(--border);
		color: var(--text);
		font-family: var(--font-sans);
		font-size: 1rem;
		width: 42px;
		height: 42px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.tslider__arrow:hover:not(:disabled) { border-color: var(--text); }
	.tslider__arrow:disabled { opacity: 0.3; cursor: default; }

	@media (max-width: 900px) {
		.tslider__inner {
			flex-direction: column;
			align-items: center;
			gap: 2.5rem;
			padding: 0 1.5rem;
		}
		.tslider__image-col { width: 100%; display: flex; justify-content: center; }
		.tslider__image-wrap { width: 80%; height: 90vw; max-height: 500px; }
		.tslider__content { max-width: none; width: 100%; }
	}
</style>

<script define:vars={{ testimonials }}>
	const imgWrap  = document.getElementById('tsliderImgWrap');
	const quoteEl  = document.getElementById('tsliderQuote');
	const clientEl = document.getElementById('tsliderClient');
	const idxEl    = document.getElementById('tsliderIdx');
	const prevBtn  = document.getElementById('tsliderPrev');
	const nextBtn  = document.getElementById('tsliderNext');

	const data = testimonials;
	let idx = 0;

	function render(i) {
		const t = data[i];
		if (!t) return;

		quoteEl.style.opacity = '0';
		if (imgWrap) imgWrap.style.opacity = '0';

		setTimeout(function() {
			if (imgWrap) {
				if (t.photoSrc) {
					let imgEl = imgWrap.querySelector('img');
					if (!imgEl) {
						imgEl = document.createElement('img');
						imgWrap.appendChild(imgEl);
					}
					imgEl.src = t.photoSrc;
					imgEl.srcset = t.photoSrcset || '';
					imgEl.sizes = '(max-width: 900px) 30vw, 200px';
					imgEl.alt = t.photoAlt || '';
				} else {
					const imgEl = imgWrap.querySelector('img');
					if (imgEl) imgEl.remove();
				}
				imgWrap.style.opacity = '1';
			}
			quoteEl.textContent = '\u201C' + t.quote + '\u201D';
			clientEl.textContent = t.client;
			idxEl.textContent = String(i + 1);
			quoteEl.style.opacity = '1';
		}, 280);

		prevBtn.disabled = i === 0;
		nextBtn.disabled = i === data.length - 1;
	}

	prevBtn.addEventListener('click', function() {
		if (idx > 0) { idx--; render(idx); }
	});
	nextBtn.addEventListener('click', function() {
		if (idx < data.length - 1) { idx++; render(idx); }
	});

	prevBtn.disabled = true;
	nextBtn.disabled = data.length <= 1;
</script>
