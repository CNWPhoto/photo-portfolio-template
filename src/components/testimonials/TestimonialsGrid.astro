---
import SanityImage from '../../components/SanityImage.astro';

const { testimonials: sanityTestimonials, theme } = Astro.props;

const testimonials = sanityTestimonials?.length
	? sanityTestimonials.slice(0, 3).map((t: any) => ({
			image: t.image ?? null,
			photoAlt: t.image?.alt ?? '',
			quote: t.testimonial ?? '',
			name: t.client ?? '',
			pet: '',
	  }))
	: [];
---

<section class="tgrid" id="testimonials" data-theme={theme || undefined}>
	<hr />
	<div class="tgrid__inner">
		<p class="tgrid__label">Kind Words from Kind Clients</p>
		<div class="tgrid__cards">
			{testimonials.map((t) => (
				<div class="tgrid__card">
					{t.image && (
						<div class="tgrid__photo-wrap">
							<SanityImage
								image={t.image}
								sizes="(max-width: 900px) 30vw, 200px"
								class="tgrid__photo"
							/>
						</div>
					)}
					<blockquote class="tgrid__quote">&ldquo;{t.quote}&rdquo;</blockquote>
					<p class="tgrid__attribution">
						<span class="tgrid__name">{t.name}</span>
						{t.pet && (
							<>
								<span class="tgrid__sep">&mdash;</span>
								<span class="tgrid__pet">{t.pet}</span>
							</>
						)}
					</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.tgrid {
		padding: 6rem 0 7rem;
	}

	.tgrid__inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 3rem;
	}

	.tgrid__label {
		font-style: italic;
		font-size: clamp(1.5rem, 3vw, 2.25rem);
		line-height: 1.25;
		color: var(--text);
		text-align: center;
		margin-bottom: 4rem;
	}

	.tgrid__cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.tgrid__card {
		background: var(--bg-alt);
		padding: 2.5rem 2rem;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.tgrid__photo-wrap {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		overflow: hidden;
		margin-bottom: 1.75rem;
		flex-shrink: 0;
	}

	.tgrid__photo {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.tgrid__quote {
		font-style: italic;
		font-size: 1rem;
		line-height: 1.8;
		color: var(--text);
		margin: 0 0 1.5rem;
		flex: 1;
	}

	.tgrid__attribution {
		font-style: normal;
		font-family: var(--font-sans);
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.tgrid__sep { color: var(--border); }

	@media (max-width: 900px) {
		.tgrid__cards { grid-template-columns: 1fr; }
		.tgrid__inner { padding: 0 1.5rem; }
	}

	@media (min-width: 601px) and (max-width: 900px) {
		.tgrid__cards { grid-template-columns: repeat(2, 1fr); }
	}
</style>
