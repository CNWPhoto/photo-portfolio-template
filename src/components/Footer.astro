---
const { theme = 'classic-cream', siteName = 'Pet Photography' } = Astro.props;

const [_footerRes, _socialRes, _siteRes] = await Promise.all([
  fetch(
    `https://hx5xgigp.api.sanity.io/v2023-05-03/data/query/production?query=${encodeURIComponent(`*[_type == "footerSettings" && _id == "footerSettings"][0]{ newsletterEmbed, menu, footerPhoto { asset { _ref } } }`)}`,
    { cache: 'no-store' }
  ),
  fetch(
    `https://hx5xgigp.api.sanity.io/v2023-05-03/data/query/production?query=${encodeURIComponent(`*[_type == "socialSettings" && _id == "socialSettings"][0]{ instagram, facebook, youtube, tiktok, custom }`)}`,
    { cache: 'no-store' }
  ),
  fetch(
    `https://hx5xgigp.api.sanity.io/v2023-05-03/data/query/production?query=${encodeURIComponent(`*[_type == "siteSettings" && _id == "siteSettings"][0]{ photographerName }`)}`,
    { cache: 'no-store' }
  ),
]);
const { result: footerData } = await _footerRes.json();
const { result: socialData } = await _socialRes.json();
const { result: siteData }   = await _siteRes.json();

const newsletterEmbed  = footerData?.newsletterEmbed || '';
const photographerName = siteData?.photographerName || siteName;

// Footer portrait photo URL
let footerPhotoUrl = '';
const photoRef = footerData?.footerPhoto?.asset?._ref;
if (photoRef) {
  const id = photoRef.replace('image-', '').replace(/-([a-zA-Z0-9]+)$/, '.$1');
  footerPhotoUrl = `https://cdn.sanity.io/images/hx5xgigp/production/${id}`;
}

// Social links — only include platforms with a URL filled in
const socialLinks = [
  { label: 'Instagram', url: socialData?.instagram },
  { label: 'Facebook',  url: socialData?.facebook },
  { label: 'YouTube',   url: socialData?.youtube },
  { label: 'TikTok',    url: socialData?.tiktok },
  socialData?.custom?.label && socialData?.custom?.url
    ? { label: socialData.custom.label, url: socialData.custom.url }
    : null,
].filter(Boolean).filter(s => s?.url);

// Menu links — fall back to showing all pages with default labels
const menuDef = footerData?.menu;
const menuLinks = [
  { key: 'home',       href: '/',            default: 'Home' },
  { key: 'about',      href: '/about',       default: 'About' },
  { key: 'experience', href: '/experience',  default: 'Experience' },
  { key: 'portfolio',  href: '/portfolio',   default: 'Portfolio' },
  { key: 'blog',       href: '/blog',        default: 'Blog' },
  { key: 'contact',    href: '/contact',     default: 'Contact' },
].filter(item => menuDef ? menuDef[item.key]?.enabled !== false : true)
 .map(item => ({ href: item.href, label: menuDef?.[item.key]?.label || item.default }));

const year = new Date().getFullYear();
---

<footer class="footer" id="contact">
	<!-- Wordmark: constrained width, right-aligned above the photo column -->
	<div class="footer__wordmark-row">
		<span class="footer__wordmark">{siteName}</span>
	</div>

	<hr />

	<!-- Columns: left nav columns + right portrait photo (always rendered) -->
	<div class="footer__cols">
		<div class="footer__left">
			{socialLinks.length > 0 && (
				<div class="footer__col">
					<p class="footer__col-label">Social</p>
					<ul class="footer__list">
						{socialLinks.map(link => (
							<li><a href={link.url} target="_blank" rel="noopener">{link.label}</a></li>
						))}
					</ul>
				</div>
			)}

			<div class="footer__col">
				<p class="footer__col-label">Menu</p>
				<ul class="footer__list footer__list--2col">
					{menuLinks.map(link => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
				</ul>
			</div>

			{newsletterEmbed && (
				<div class="footer__col">
					<p class="footer__col-label">Newsletter</p>
					<Fragment set:html={newsletterEmbed} />
				</div>
			)}
		</div>

		<div class="footer__right">
			<div class="footer__photo-col">
				{footerPhotoUrl
					? <img src={footerPhotoUrl} alt={siteName} loading="lazy" decoding="async" />
					: <span class="footer__photo-placeholder">Your Photo Here</span>
				}
			</div>
		</div>
	</div>

	<hr />

	<!-- Copyright -->
	<div class="footer__legal">
		<p>&copy; {year} {photographerName}. All rights reserved.</p>
		<p>
			<a href="#">Privacy Policy</a> &middot; <a href="#">Terms</a>
		</p>
	</div>

</footer>

<style>
	.footer {
		background: var(--bg);
		color: var(--text);
	}

	/* Constrain all rows to site width */
	.footer__wordmark-row,
	.footer__cols,
	.footer__legal {
		max-width: 1100px;
		margin-left: auto;
		margin-right: auto;
		box-sizing: border-box;
	}

	/* Wordmark: right-aligned, right padding matches photo column width */
	.footer__wordmark-row {
		padding: 4rem 0 0;
		text-align: right;
	}

	.footer__wordmark {
		font-family: var(--font-body, 'Jost', system-ui, sans-serif);
		font-variant: normal;
		font-style: normal;
		font-weight: 500;
		font-size: 2rem;
		letter-spacing: 0.06em;
		white-space: nowrap;
		color: var(--text);
	}

	/* Outer grid: left nav columns + right photo panel (always present) */
	.footer__cols {
		display: grid;
		grid-template-columns: 1fr 280px;
		align-items: start;
		padding-left: 0;
		padding-right: 0;
	}

	/* Left: menu pinned to 275px, remaining space for social/newsletter */
	.footer__left {
		display: grid;
		grid-template-columns: 275px 1fr;
	}

	.footer__left:has(.footer__col:nth-child(3)) {
		grid-template-columns: 1fr 1fr 1fr;
	}

	.footer__col {
		padding: 3rem 2rem 3.5rem 0;
	}

	.footer__col:last-child {
		padding-right: 0;
	}

	.footer__col + .footer__col {
		border-left: 1px solid var(--border);
		padding-left: 2rem;
	}

	.footer__col-label {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--muted-light);
		margin-bottom: 1.5rem;
	}

	.footer__list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer__list--2col {
		display: grid;
		grid-template-columns: 1fr 1fr;
		column-gap: 1.5rem;
		row-gap: 0.75rem;
	}

	.footer__list a {
		font-style: italic;
		font-size: 1rem;
		color: var(--text);
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer__list a:hover {
		color: var(--accent);
	}

	/* Right photo panel — always rendered, full height */
	.footer__right {
		align-self: stretch;
		border-left: 1px solid var(--border);
		display: flex;
		flex-direction: column;
		overflow: hidden;
		min-height: 240px;
	}

	.footer__photo-col {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--bg-alt, color-mix(in srgb, var(--bg) 85%, var(--text)));
	}

	.footer__photo-col img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
	}

	.footer__photo-placeholder {
		font-family: var(--font-sans);
		font-size: 0.65rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--muted);
	}

	/* Legal row */
	.footer__legal {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1.5rem;
		padding-bottom: 1.5rem;
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		font-style: normal;
		color: var(--muted-light);
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.footer__legal a {
		color: var(--muted-light);
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer__legal a:hover {
		color: var(--accent);
	}

	@media (max-width: 900px) {
		.footer__wordmark-row,
		.footer__cols,
		.footer__legal {
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}

		.footer__wordmark-row {
			padding-top: 2.5rem;
		}

		.footer__cols {
			grid-template-columns: 1fr;
		}

		.footer__left {
			grid-template-columns: 1fr;
		}

		.footer__left:has(.footer__col:nth-child(3)) {
			grid-template-columns: 1fr;
		}

		.footer__col {
			padding: 2rem 0;
			border-left: none !important;
			border-top: 1px solid var(--border);
		}

		.footer__col:first-child {
			border-top: none;
		}

		.footer__col + .footer__col {
			padding-left: 0;
		}

		.footer__right {
			border-left: none;
			border-top: 1px solid var(--border);
			min-height: 240px;
		}
	}
</style>
