---
import { toHTML } from '@portabletext/to-html';
import { getClient, urlFor } from '../lib/sanity.js';
import { stegaClean } from '@sanity/client/stega';
import { createDataAttribute } from '@sanity/visual-editing/create-data-attribute';

const { siteName = 'Pet Photography', blogEnabled = true } = Astro.props;

// In Sanity Presentation mode, attach a data-sanity attribute to the
// footer root so editors get a click-to-edit overlay that opens
// footerSettings. Pairs with the logo (siteSettings) and nav header
// (navSettings) data-sanity attributes in Nav.astro.
const isPreview = Astro.locals.isPreview ?? false;
const footerSanityAttr = isPreview
  ? createDataAttribute({ id: 'footerSettings', type: 'footerSettings', path: 'links' }).toString()
  : null;

// Use the preview client when the editor is in Presentation mode so draft
// edits to footerSettings / socialSettings / siteSettings (e.g. the
// photographer name in the copyright line) appear in the iframe without
// having to publish. Stega-clean the results below so the draft markers
// don't create extra click-to-edit overlays on every footer link.
const client = getClient(isPreview, (Astro.locals as any).runtime?.env);
const [footerDataRaw, socialDataRaw, siteDataRaw] = await Promise.all([
  client.fetch(`*[_type == "footerSettings" && _id == "footerSettings"][0]{
    links[] { label, url, enabled, openInNewTab },
    middleColumn {
      enabled, label, note,
      "embed": embed->{ name, rawHtml, containerWidth, containerHeight }
    },
    legalLinks
  }`),
  client.fetch(`*[_type == "socialSettings" && _id == "socialSettings"][0]{ instagram, facebook, youtube, tiktok, custom }`),
  client.fetch(`*[_type == "siteSettings" && _id == "siteSettings"][0]{ photographerName, logoType, logoImage }`),
]);

const footerData = footerDataRaw ? stegaClean(footerDataRaw) : null;
const socialData = socialDataRaw ? stegaClean(socialDataRaw) : null;
const siteData   = siteDataRaw ? stegaClean(siteDataRaw) : null;

const photographerName = siteData?.photographerName || siteName;

// Match nav-level logo behavior: when the siteSettings logoType is
// 'image' and a logoImage asset is set, render the image in the
// footer wordmark slot. Otherwise fall back to the site name text,
// which flows and wraps within the footer right column.
const footerLogoType  = siteData?.logoType || 'text';
const footerLogoImage = siteData?.logoImage ?? null;
const footerLogoUrl   = footerLogoType === 'image' && footerLogoImage?.asset
  ? urlFor(footerLogoImage).height(96).auto('format').url()
  : null;

// Middle column — embed reference takes priority over the text note
const middleCol      = footerData?.middleColumn ?? null;
const middleEnabled  = middleCol?.enabled !== false;
const middleLabel    = middleCol?.label || null;
const middleEmbed    = middleCol?.embed?.rawHtml || null;
const middleNoteRaw  = middleCol?.note || null;
const middleNoteHTML = middleNoteRaw ? toHTML(middleNoteRaw) : null;
const showMiddleCol  = middleEnabled && !!(middleEmbed || middleNoteHTML);

// Social links — only include platforms with a URL filled in
const socialLinks = [
  { label: 'Instagram', url: socialData?.instagram },
  { label: 'Facebook',  url: socialData?.facebook },
  { label: 'YouTube',   url: socialData?.youtube },
  { label: 'TikTok',    url: socialData?.tiktok },
  socialData?.custom?.label && socialData?.custom?.url
    ? { label: socialData.custom.label, url: socialData.custom.url }
    : null,
].filter(Boolean).filter(s => s?.url);

// Icon SVG paths per platform
const icons: Record<string, string> = {
  Instagram: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>`,
  Facebook:  `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  YouTube:   `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58a2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>`,
  TikTok:    `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.22 6.22 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>`,
};
const defaultIcon = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`;

// Free-form footer links. When the editor hasn't configured any yet,
// fall back to the same default set the legacy footer used so a fresh
// install renders sensibly out of the box.
const defaultFooterLinks = [
  { label: 'Home',       href: '/' },
  { label: 'About',      href: '/about' },
  { label: 'Experience', href: '/experience' },
  { label: 'Portfolio',  href: '/portfolio' },
  { label: 'Blog',       href: '/blog' },
  { label: 'Contact',    href: '/contact' },
];

const configuredLinks = (footerData?.links ?? [])
  .filter((l: any) => l.enabled !== false)
  .map((l: any) => ({ label: l.label, href: l.url, openInNewTab: !!l.openInNewTab }));

const menuLinks = (configuredLinks.length > 0 ? configuredLinks : defaultFooterLinks)
  .filter((l: any) => blogEnabled || l.href !== '/blog');

const legalLinks = footerData?.legalLinks ?? null;
const showPrivacy = legalLinks?.privacyPolicy?.enabled && legalLinks?.privacyPolicy?.url;
const showTerms   = legalLinks?.terms?.enabled && legalLinks?.terms?.url;
const privacyLabel = legalLinks?.privacyPolicy?.label || 'Privacy Policy';
const termsLabel   = legalLinks?.terms?.label || 'Terms';
const privacyUrl   = legalLinks?.privacyPolicy?.url || '#';
const termsUrl     = legalLinks?.terms?.url || '#';

const year = new Date().getFullYear();
---

<footer class="footer" id="contact" data-sanity={footerSanityAttr}>
	<hr />

	<!-- Columns: left nav + right wordmark/social -->
	<div class="footer__cols">
		<div class="footer__left">
			<div class="footer__col">
				<ul class="footer__list footer__list--2col">
					{menuLinks.map((link: any) => (
						<li>
							<a
								href={link.href}
								target={link.openInNewTab ? '_blank' : undefined}
								rel={link.openInNewTab ? 'noopener noreferrer' : undefined}
							>{link.label}</a>
						</li>
					))}
				</ul>
			</div>

			{showMiddleCol && (
				<div class="footer__col">
					{middleLabel && <p class="footer__col-label">{middleLabel}</p>}
					{middleEmbed
						? <Fragment set:html={middleEmbed} />
						: <div class="footer__note"><Fragment set:html={middleNoteHTML} /></div>
					}
				</div>
			)}
		</div>

		<div class="footer__right">
			{footerLogoUrl
				? <img src={footerLogoUrl} alt={siteName} class="footer__wordmark-img" decoding="async" loading="lazy" />
				: <span class="footer__wordmark">{siteName}</span>}
			{socialLinks.length > 0 && (
				<div class="footer__social-row">
					{socialLinks.map(link => (
						<a
							href={link.url}
							class="footer__social-icon"
							target="_blank"
							rel="noopener noreferrer"
							aria-label={link.label}
						>
							<Fragment set:html={icons[link.label] ?? defaultIcon} />
						</a>
					))}
				</div>
			)}
		</div>
	</div>

	<hr />

	<!-- Copyright -->
	<div class="footer__legal">
		<p>&copy; {year} {photographerName}. All rights reserved.</p>
		{(showPrivacy || showTerms) && (
			<p>
				{showPrivacy && <a href={privacyUrl}>{privacyLabel}</a>}
				{showPrivacy && showTerms && <span> &middot; </span>}
				{showTerms && <a href={termsUrl}>{termsLabel}</a>}
			</p>
		)}
	</div>

</footer>

<style>
	.footer {
		background: var(--bg);
		color: var(--text);
		position: relative;
	}

	.footer__wordmark {
		font-family: var(--font-serif, Georgia, serif);
		font-style: italic;
		font-weight: 700;
		/* Scales down further than the old clamp so a long site name
		   can shrink to fit the 280px right column without overflowing
		   into neighboring content. */
		font-size: clamp(1rem, 2.2vw, 2rem);
		/* Tight line-height — halved from the default ~1.2 so wrapped
		   site names stack compactly instead of looking double-spaced. */
		line-height: 1.1;
		letter-spacing: 0.01em;
		color: var(--text);
		/* Wrap long names onto multiple lines rather than overflowing. */
		overflow-wrap: break-word;
		word-break: break-word;
		max-width: 100%;
		display: block;
	}

	.footer__wordmark-img {
		display: block;
		max-width: 100%;
		max-height: 48px;
		width: auto;
		height: auto;
	}

	/* Social icons: horizontal row under wordmark */
	.footer__social-row {
		display: flex;
		flex-direction: row;
		gap: 12px;
		margin-top: 0.75rem;
	}

	.footer__social-icon {
		color: var(--muted);
		display: flex;
		align-items: center;
		transition: color 0.2s;
	}

	.footer__social-icon:hover {
		color: var(--accent);
	}

	/* Outer grid: left nav columns + right photo panel */
	.footer__cols {
		max-width: 1100px;
		margin-left: auto;
		margin-right: auto;
		padding: 0 3rem;
		box-sizing: border-box;
		display: grid;
		grid-template-columns: 1fr 280px;
		align-items: stretch;
	}

	/* Left: single col by default, splits if newsletter present */
	.footer__left {
		display: grid;
		grid-template-columns: 1fr;
	}

	.footer__left:has(.footer__col:nth-child(2)) {
		grid-template-columns: 1fr 1fr;
	}

	.footer__col {
		padding: 2rem 2rem 2rem 0;
	}

	.footer__col:last-child {
		padding-right: 0;
	}

	.footer__col + .footer__col {
		border-left: 1px solid var(--border);
		padding-left: 2rem;
	}

	.footer__col-label {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--muted-light);
		margin-bottom: 1.5rem;
	}

	.footer__list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer__list--2col {
		display: grid;
		grid-template-columns: 1fr 1fr;
		column-gap: 1.5rem;
		row-gap: 0.5rem;
	}

	.footer__list a {
		font-style: italic;
		font-size: 1rem;
		color: var(--text);
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer__list a:hover {
		color: var(--accent);
	}

	.footer__note {
		font-size: 0.9375rem;
		line-height: 1.7;
		color: var(--muted);
	}

	.footer__note a {
		color: var(--accent);
		text-decoration: none;
	}

	.footer__note a:hover {
		text-decoration: underline;
	}

	/* Right panel — wordmark + social, centered vertically */
	.footer__right {
		border-left: 1px solid var(--border);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 2.5rem 1.5rem;
		text-align: center;
	}

	/* Legal row */
	.footer__legal {
		max-width: 1100px;
		margin-left: auto;
		margin-right: auto;
		padding: 24px 3rem;
		box-sizing: border-box;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		font-style: normal;
		color: var(--muted-light);
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.footer__legal a {
		color: var(--muted-light);
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer__legal a:hover {
		color: var(--accent);
	}

	@media (max-width: 900px) {

		.footer__cols {
			padding-left: 1.5rem;
			padding-right: 1.5rem;
			grid-template-columns: 1fr;
		}

		.footer__left {
			grid-template-columns: 1fr;
		}

		.footer__left:has(.footer__col:nth-child(2)) {
			grid-template-columns: 1fr;
		}

		.footer__col {
			padding: 2rem 0;
			border-left: none !important;
			border-top: 1px solid var(--border);
		}

		.footer__col:first-child {
			border-top: none;
		}

		.footer__col + .footer__col {
			padding-left: 0;
		}

		.footer__col {
			text-align: center;
		}

		.footer__list--2col {
			justify-items: center;
		}

		.footer__right {
			border-left: none;
			border-top: 1px solid var(--border);
			padding-left: 0;
			justify-content: flex-start;
			padding-top: 1.5rem;
			padding-bottom: 1rem;
		}

		.footer__legal {
			padding: 1.5rem;
		}
	}
</style>
