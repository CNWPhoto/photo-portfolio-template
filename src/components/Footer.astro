---
const { theme = 'classic-cream', siteName = 'Pet Photography' } = Astro.props;

const [_footerRes, _socialRes] = await Promise.all([
  fetch(
    `https://hx5xgigp.api.sanity.io/v2023-05-03/data/query/production?query=${encodeURIComponent(`*[_type == "footerSettings" && _id == "footerSettings"][0]{ newsletterEmbed, menu }`)}`,
    { cache: 'no-store' }
  ),
  fetch(
    `https://hx5xgigp.api.sanity.io/v2023-05-03/data/query/production?query=${encodeURIComponent(`*[_type == "socialSettings" && _id == "socialSettings"][0]{ instagram, facebook, youtube, tiktok, custom }`)}`,
    { cache: 'no-store' }
  ),
]);
const { result: footerData } = await _footerRes.json();
const { result: socialData } = await _socialRes.json();
const newsletterEmbed = footerData?.newsletterEmbed || '';

// Social links — only include platforms with a URL filled in
const socialLinks = [
  { label: 'Instagram', url: socialData?.instagram },
  { label: 'Facebook',  url: socialData?.facebook },
  { label: 'YouTube',   url: socialData?.youtube },
  { label: 'TikTok',    url: socialData?.tiktok },
  socialData?.custom?.label && socialData?.custom?.url
    ? { label: socialData.custom.label, url: socialData.custom.url }
    : null,
].filter(Boolean).filter(s => s?.url);

// Menu links — fall back to showing all pages with default labels
const menuDef = footerData?.menu;
const menuLinks = [
  { key: 'home',       href: '/',            default: 'Home' },
  { key: 'about',      href: '/about',       default: 'About' },
  { key: 'experience', href: '/experience',  default: 'Experience' },
  { key: 'portfolio',  href: '/portfolio',   default: 'Portfolio' },
  { key: 'blog',       href: '/blog',        default: 'Blog' },
  { key: 'contact',    href: '/contact',     default: 'Contact' },
].filter(item => menuDef ? menuDef[item.key]?.enabled !== false : true)
 .map(item => ({ href: item.href, label: menuDef?.[item.key]?.label || item.default }));
const year = new Date().getFullYear();
---

<footer class="footer" id="contact">
	<!-- Top: site name wordmark -->
	<div class="footer__wordmark-row">
		<span class="footer__wordmark">{siteName}</span>
	</div>

	<hr />

	<!-- Columns: Social (if any links set) + Menu + Newsletter (if embed set) -->
	<div class="footer__cols">
		{socialLinks.length > 0 && (
			<div class="footer__col">
				<p class="footer__col-label">Social</p>
				<ul class="footer__list">
					{socialLinks.map(link => (
						<li><a href={link.url} target="_blank" rel="noopener">{link.label}</a></li>
					))}
				</ul>
			</div>
		)}

		<div class="footer__col">
			<p class="footer__col-label">Menu</p>
			<ul class="footer__list footer__list--2col">
				{menuLinks.map(link => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</div>

		{newsletterEmbed && (
			<div class="footer__col">
				<p class="footer__col-label">Newsletter</p>
				<Fragment set:html={newsletterEmbed} />
			</div>
		)}
	</div>

	<hr />

	<!-- Copyright -->
	<div class="footer__legal">
		{/* TODO:NICHE — studio name in copyright */}
		<p>&copy; {year} Pet Photography. All rights reserved.</p>
		<p>
			<a href="#">Privacy Policy</a> &middot; <a href="#">Terms</a>
		</p>
	</div>

</footer>

<style>
	.footer {
		background: var(--bg);
		color: var(--text);
	}

	/* Wordmark row */
	.footer__wordmark-row {
		padding: 4rem 3rem 0;
		text-align: right;
	}

	.footer__wordmark {
		font-family: var(--font-body, 'Jost', system-ui, sans-serif);
		font-variant: normal;
		font-style: normal;
		font-weight: 500;
		font-size: 2rem;
		letter-spacing: 0.06em;
		color: var(--text);
	}

	/* Three columns */
	.footer__cols {
		display: grid;
		grid-template-columns: 1fr;
		padding: 3.5rem 3rem;
		max-width: 1100px;
		margin: 0 auto;
	}

	.footer__cols:has(.footer__col:nth-child(2)) {
		grid-template-columns: 1fr 1fr;
	}

	.footer__cols:has(.footer__col:nth-child(3)) {
		grid-template-columns: 1fr 1fr 1fr;
	}

	.footer__col {
		padding: 0 3rem;
	}

	.footer__col:first-child {
		padding-left: 0;
	}

	.footer__col:last-child {
		padding-right: 0;
	}

	.footer__col + .footer__col {
		border-left: 1px solid var(--border);
	}

	.footer__col-label {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--muted-light);
		margin-bottom: 1.5rem;
	}

	.footer__list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer__list--2col {
		display: grid;
		grid-template-columns: 1fr 1fr;
		column-gap: 1.5rem;
		row-gap: 0.75rem;
	}

	.footer__list a {
		font-style: italic;
		font-size: 1rem;
		color: var(--text);
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer__list a:hover {
		color: var(--accent);
	}


	/* Legal row */
	.footer__legal {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.5rem 3rem;
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		font-style: normal;
		color: var(--muted-light);
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.footer__legal a {
		color: var(--muted-light);
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer__legal a:hover {
		color: var(--accent);
	}

	@media (max-width: 900px) {
		.footer__cols {
			grid-template-columns: 1fr;
			padding: 2.5rem 1.5rem;
		}

		.footer__col {
			padding: 2rem 0;
			border-left: none !important;
			border-top: 1px solid var(--border);
		}

		.footer__col:first-child {
			border-top: none;
		}

		.footer__wordmark-row,
		.footer__legal {
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}

	}
</style>
