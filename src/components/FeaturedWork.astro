---
const photos = [
	{ id: '1254140', alt: 'Brown and white dog portrait', wide: true },
	{ id: '2607544', alt: 'Dog gazing into the distance', wide: false },
	{ id: '220938', alt: 'Fluffy white puppy close-up', wide: false },
	{ id: '333083', alt: 'Dog exploring an open field', wide: false },
	{ id: '1805164', alt: 'Playful dog outdoors', wide: false },
	{ id: '164186', alt: 'Dog bathed in golden light', wide: true },
];
---

<section class="work" id="work">
	<div class="work__inner">
		<div class="work__header">
			<p class="work__eyebrow">Portfolio</p>
			<h2 class="work__heading">Featured Work</h2>
			<p class="work__sub">
				A curated collection of sessions — each one a story waiting to be told.
			</p>
		</div>

		<div class="work__grid">
			{
				photos.map((photo) => (
					<div class={`work__item${photo.wide ? ' work__item--wide' : ''}`}>
						<img
							src={`https://images.pexels.com/photos/${photo.id}/pexels-photo-${photo.id}.jpeg?auto=compress&cs=tinysrgb&w=800`}
							alt={photo.alt}
							loading="lazy" decoding="async"
						/>
					</div>
				))
			}
		</div>

		<div class="work__footer">
			<a href="#" class="work__link">View Full Portfolio &rarr;</a>
		</div>
	</div>
</section>

<style>
	.work {
		padding: 6rem 2rem;
	}

	.work__inner {
		max-width: 1100px;
		margin: 0 auto;
	}

	.work__header {
		text-align: center;
		margin-bottom: 3.5rem;
	}

	.work__eyebrow {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1rem;
	}

	.work__heading {
		font-size: clamp(2rem, 3.5vw, 2.75rem);
		color: var(--text);
		margin-bottom: 1rem;
	}

	.work__sub {
		font-size: 1.0625rem;
		color: var(--muted);
		max-width: 480px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.work__grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.75rem;
	}

	.work__item {
		overflow: hidden;
		border-radius: 3px;
		aspect-ratio: 4 / 3;
		background: var(--accent-faint);
	}

	.work__item--wide {
		grid-column: span 2;
	}

	.work__item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.work__item:hover img {
		transform: scale(1.05);
	}

	.work__footer {
		margin-top: 2.5rem;
		text-align: center;
	}

	.work__link {
		font-size: 0.9375rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		color: var(--text);
		text-decoration: none;
		border-bottom: 1.5px solid var(--accent);
		padding-bottom: 2px;
	}

	.work__link:hover {
		color: var(--accent);
	}

	@media (max-width: 768px) {
		.work__grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.work__item--wide {
			grid-column: span 1;
		}
	}
</style>
