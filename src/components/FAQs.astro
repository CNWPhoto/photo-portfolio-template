---
const { faqs: sanityFaqs, theme } = Astro.props;

const faqs = (sanityFaqs ?? []).map((f: any) => ({ q: f.question, a: f.answer }));
---

<section
	class="faqs"
	id="faqs"
	data-theme={theme || undefined}
>
	<div class="faqs__inner">
		<div class="faqs__label-col" aria-hidden="true">
			<span class="faqs__label">FAQs</span>
		</div>

		<div class="faqs__content">
			<div class="faqs__list">
				{
					faqs.map((faq, i) => (
						<div class={`faqs__item reveal reveal-delay-${Math.min(i + 1, 5)}`}>
							<h3 class="faqs__question">{faq.q}</h3>
							<blockquote class="faqs__answer">{faq.a}</blockquote>
						</div>
					))
				}
			</div>

			<div class="faqs__footer reveal">
				<a href="/experience#faqs" class="faqs__link">View all FAQs &rarr;</a>
			</div>
		</div>
	</div>
</section>

<style>
	.faqs {
		padding-top: 0;
		padding-bottom: 7rem;
	}

	.faqs__inner {
		display: grid;
		grid-template-columns: 100px 1fr;
		padding: 5rem 3rem 0;
		max-width: 1100px;
		margin: 0 auto;
		gap: 2rem;
	}

	/* Rotated label */
	.faqs__label-col {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.faqs__label {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: clamp(2rem, 3.5vw, 3.25rem);
		letter-spacing: 0.1em;
		color: var(--border);
		writing-mode: vertical-lr;
		transform: rotate(180deg);
		white-space: nowrap;
		user-select: none;
	}

	/* FAQ list */
	.faqs__list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.faqs__item {
		padding: 2.5rem 0;
		border-bottom: 1px solid var(--border);
	}

	.faqs__item:first-child {
		border-top: none;
	}

	.faqs__question {
		font-size: var(--faqs-question-size, 1.5rem);
		font-weight: 500;
		color: var(--text);
		margin-bottom: 1.25rem;
		letter-spacing: -0.01em;
	}

	.faqs__answer {
		margin: 0;
		padding: 0 0 0 1.75rem;
		border-left: 2px solid var(--accent);
		font-style: normal;
		font-size: var(--faqs-answer-size, 1.125rem);
		line-height: 1.78;
		color: var(--muted);
	}

	/* Footer link */
	.faqs__footer {
		padding-top: 2.5rem;
	}

	.faqs__link {
		font-style: italic;
		font-size: 1rem;
		color: var(--accent);
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.faqs__inner {
			grid-template-columns: 1fr;
			padding: 0 1.5rem 0;
		}

		.faqs__label-col {
			display: flex;
			align-items: center;
			justify-content: center;
			padding-top: 3rem;
		}

		.faqs__label {
			writing-mode: horizontal-tb;
			transform: none;
			font-size: clamp(1.6rem, 6vw, 2.25rem);
			text-align: center;
		}
	}
</style>
