---
import SanityImage from '../components/SanityImage.astro';

const { heroImages, heroCaption, theme } = Astro.props;

const heading = heroCaption?.nicheKeyword || 'Denver Dog Photographer'; // TODO:NICHE
const tagline  = heroCaption?.tagline      || 'Natural, stress-free dog portraits for your best friend.'; // TODO:NICHE
---

<section
	class="hero"
	data-theme={theme || undefined}
>
	<div class="hero__viewport">
		<div class="hero__track" id="heroTrack">
			{heroImages?.length && heroImages.map((img: any, i: number) => (
				<SanityImage
					image={img}
					sizes="100vw"
					loading={i === 0 ? 'eager' : 'lazy'}
					class="hero__img"
				/>
			))}
		</div>

		<button class="hero__arrow hero__arrow--prev" id="heroPrev" aria-label="Previous image">
			&#8249;
		</button>
		<button class="hero__arrow hero__arrow--next" id="heroNext" aria-label="Next image">
			&#8250;
		</button>
	</div>

	<div class="hero__caption">
		<h1 class="hero__heading">{heading}</h1>
		<p class="hero__sub">{tagline}</p>
	</div>
</section>

<style>
	/* Full-bleed: zero out the global section padding */
	.hero {
		padding-top: 0;
		padding-bottom: 0;
	}

	/* ── Viewport: clips overflow, anchors arrows ── */
	.hero__viewport {
		position: relative;
		width: 100%;
		height: 60vh;
		min-height: 400px;
		overflow: hidden;
	}

	/* ── Track: flex row, driven by translateX ── */
	.hero__track {
		display: flex;
		gap: 15px;
		height: 100%;
		transition: transform 0.5s ease;
		will-change: transform;
	}

	/* ── Images: fill container height, natural width, never compress ── */
	.hero__track :global(.hero__img) {
		height: 100%;
		width: auto;
		flex-shrink: 0;
		display: block;
		max-width: unset;
		object-fit: unset;
	}

	/* ── Arrows ── */
	.hero__arrow {
		position: absolute;
		top: calc(50% - 24px);
		z-index: 10;
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0.32);
		border: none;
		color: var(--white);
		font-size: 2rem;
		line-height: 1;
		cursor: pointer;
		user-select: none;
		transition: background 0.2s;
	}

	.hero__arrow:hover {
		background: rgba(0, 0, 0, 0.55);
		transform: translateY(-1px);
	}

	.hero__arrow--prev { left: 1.25rem; }
	.hero__arrow--next { right: 1.25rem; }

	/* ── Caption ── */
	.hero__caption {
		text-align: center;
		padding: 4rem 2rem 4.5rem;
		border-top: 1px solid var(--border);
	}

	.hero__heading {
		font-size: var(--hero-heading-size, clamp(2.5rem, 5.5vw, 4.25rem));
		color: var(--text);
		margin-bottom: 1.25rem;
		letter-spacing: -0.01em;
	}

	.hero__sub {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: var(--hero-sub-size, 0.75rem);
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--muted);
	}
</style>

<script>
	const track   = document.getElementById('heroTrack') as HTMLElement;
	const vpEl    = track.parentElement as HTMLElement;
	const prevBtn = document.getElementById('heroPrev') as HTMLButtonElement;
	const nextBtn = document.getElementById('heroNext') as HTMLButtonElement;

	const NUM_REAL  = 5;
	const NUM_CLONE = 2; // clones prepended and appended

	// Clone last NUM_CLONE real images and prepend
	const realImgs = Array.from(track.querySelectorAll('img')) as HTMLImageElement[];
	const clonesBefore = realImgs.slice(-NUM_CLONE).map((img) => img.cloneNode(true) as HTMLImageElement);
	const clonesAfter  = realImgs.slice(0, NUM_CLONE).map((img) => img.cloneNode(true) as HTMLImageElement);

	clonesBefore.reverse().forEach((cl) => track.prepend(cl));
	clonesAfter.forEach((cl) => track.append(cl));

	// Full imgs array: [clone…, real…, clone…]
	const imgs = Array.from(track.querySelectorAll('img')) as HTMLImageElement[];
	// Start at first real image (index = NUM_CLONE)
	let current = NUM_CLONE;

	// Left edge of image[i] in track-space (sum of widths + gaps, unaffected by transform)
	function imageLeft(i: number): number {
		let left = 0;
		for (let j = 0; j < i; j++) {
			left += imgs[j].offsetWidth + 15;
		}
		return left;
	}

	// translateX that centers image[i] in the viewport
	function centerOffset(i: number): number {
		const vpW  = vpEl.offsetWidth;
		const imgW = imgs[i].offsetWidth;
		return imageLeft(i) + imgW / 2 - vpW / 2;
	}

	function goTo(idx: number) {
		current = idx;
		track.style.transition = '';
		track.style.transform  = `translateX(${-centerOffset(current)}px)`;
	}

	function silentGoTo(idx: number) {
		current = idx;
		track.style.transition = 'none';
		track.style.transform  = `translateX(${-centerOffset(current)}px)`;
		track.getBoundingClientRect(); // force reflow so browser registers the jump
		track.style.transition = ''; // restore CSS transition
	}

	function advance(dir: number) {
		current += dir;
		track.style.transition = 'transform 0.5s ease';
		track.style.transform  = `translateX(${-centerOffset(current)}px)`;
	}

	// After animated transition, silently jump to real equivalent if in clone zone
	track.addEventListener('transitionend', () => {
		if (current >= NUM_CLONE + NUM_REAL) {
			silentGoTo(current - NUM_REAL);
		} else if (current < NUM_CLONE) {
			silentGoTo(current + NUM_REAL);
		}
	});

	prevBtn.addEventListener('click', () => advance(-1));
	nextBtn.addEventListener('click', () => advance(1));

	// Debounced resize: image widths change with 70vh viewport height
	let resizeTimer: ReturnType<typeof setTimeout>;
	window.addEventListener('resize', () => {
		clearTimeout(resizeTimer);
		resizeTimer = setTimeout(() => goTo(current), 100);
	});

	// Run after full load for accurate offsetWidth; also run immediately for cached images
	window.addEventListener('load', () => goTo(NUM_CLONE));
	goTo(NUM_CLONE);
</script>
