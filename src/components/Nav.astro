---
import { urlFor } from '../lib/sanity.js';
import { resolveLink } from '../lib/links.js';
import { createDataAttribute } from '@sanity/visual-editing/create-data-attribute';

const {
	siteName = 'Pet Photography',
	logoType = 'text',
	logoImage = null,
	navVariant = 'classic',
	navLinks = null,
	blogEnabled = true,
	stickyNav = false,
} = Astro.props;

// Sticky is now a pure opt-in toggle for every variant — including
// transparent. Editors who want the scroll-solidify effect on a
// transparent nav can flip Sticky navigation on; otherwise the nav
// overlays the hero and scrolls away with the page like any other
// in-flow header.
const isStickyEffective = stickyNav;

// In Sanity Presentation mode, attach data-sanity attributes to the logo
// and the nav root so editors get click-to-edit overlays for siteSettings
// (logo → siteName) and navSettings (header → links). These are the only
// two click targets in the nav region — overlays elsewhere are suppressed
// because every other string flows through stegaClean() in Layout.astro.
const isPreview = Astro.locals.isPreview ?? false;
const logoSanityAttr = isPreview
	? createDataAttribute({ id: 'siteSettings', type: 'siteSettings', path: 'siteName' }).toString()
	: null;
const navSanityAttr = isPreview
	? createDataAttribute({ id: 'navSettings', type: 'navSettings', path: 'links' }).toString()
	: null;

const showImageLogo = logoType === 'image' && logoImage;

// Default links used when nothing is configured in Sanity yet
const defaultLinks = [
	{ label: 'Experience', url: '/experience', enabled: true, openInNewTab: false, isButton: false, linkType: 'external' },
	{ label: 'Portfolio',  url: '/portfolio',  enabled: true, openInNewTab: false, isButton: false, linkType: 'external' },
	{ label: 'About',      url: '/about',      enabled: true, openInNewTab: false, isButton: false, linkType: 'external' },
	{ label: 'Blog',       url: '/blog',       enabled: true, openInNewTab: false, isButton: false, linkType: 'external' },
	{ label: 'Inquire',    url: '/contact',    enabled: true, openInNewTab: false, isButton: true,  linkType: 'external' },
];

// Normalize each link: compute resolved href, normalize children.
// Pass [Astro.url.hostname] so resolveLink strips the origin from any
// absolute URL that accidentally points at this same host — keeps the
// rendered href portable across custom domains.
const selfHostnames = [Astro.url.hostname];
const normalizeLink = (l: any) => {
	const href = resolveLink(l, selfHostnames) || l?.url || '#';
	const children = Array.isArray(l?.children)
		? l.children.map((c: any) => ({ ...c, href: resolveLink(c, selfHostnames) || c?.url || '#' }))
		: [];
	return { ...l, href, children, hasChildren: children.length > 0 };
};

const links = (navLinks ?? defaultLinks)
	.filter((l: any) => l.enabled !== false)
	.filter((l: any) => blogEnabled || (l?.url !== '/blog' && l?.internalRef?.slug !== 'blog'))
	.map(normalizeLink);

// Split variant: divide links evenly left and right of the centered logo.
// Both the plain 'split' variant and the new 'transparent-split' variant
// use the split layout; only the visual treatment (opaque vs overlay)
// differs between them.
const isSplit = navVariant === 'split' || navVariant === 'transparent-split';
const splitMid = Math.floor(links.length / 2);
const leftLinks  = isSplit ? links.slice(0, splitMid) : [];
const rightLinks = isSplit ? links.slice(splitMid)    : links;
---

<header class="nav" data-variant={navVariant} data-sticky={isStickyEffective ? 'true' : undefined} data-sanity={navSanityAttr}>
	<div class="nav__inner">
		{isSplit && (
			<nav aria-label="Main navigation left" class="nav__left-nav">
				<ul class="nav__links nav__links--left">
					{leftLinks.map((link: any) => (
						<li class:list={['nav__item', link.hasChildren && 'nav__item--has-dropdown']}>
							{link.hasChildren ? (
								<>
									<button
										type="button"
										class="nav__link nav__dropdown-trigger"
										aria-haspopup="true"
										aria-expanded="false"
										data-nav-dropdown
									>
										{link.label}
										<span class="nav__caret" aria-hidden="true">&#9662;</span>
									</button>
									<ul class="nav__dropdown" role="menu">
										{link.children.map((c: any) => (
											<li role="none">
												<a
													role="menuitem"
													href={c.href}
													target={c.openInNewTab ? '_blank' : undefined}
													rel={c.openInNewTab ? 'noopener noreferrer' : undefined}
												>{c.label}</a>
											</li>
										))}
									</ul>
								</>
							) : (
								<a
									href={link.href}
									class={link.isButton ? 'nav__link nav__inquire' : 'nav__link'}
									style={link.isButton && link.ctaColor ? `--nav-cta-color: ${link.ctaColor}` : undefined}
									target={link.openInNewTab ? '_blank' : undefined}
									rel={link.openInNewTab ? 'noopener noreferrer' : undefined}
								>{link.label}</a>
							)}
						</li>
					))}
				</ul>
			</nav>
		)}
		{showImageLogo
			? <a href="/" class="nav__logo nav__logo--image" data-sanity={logoSanityAttr}><img src={urlFor(logoImage).height(96).auto('format').url()} alt={siteName} class="nav__logo-img" decoding="async" /></a>
			: <a href="/" class="nav__logo" data-sanity={logoSanityAttr}>{siteName}</a>
		}
		<nav aria-label="Main navigation">
			<ul class={`nav__links${isSplit ? ' nav__links--right' : ''}`}>
				{rightLinks.map((link: any) => (
					<li class:list={['nav__item', link.hasChildren && 'nav__item--has-dropdown']}>
						{link.hasChildren ? (
							<>
								<button
									type="button"
									class="nav__link nav__dropdown-trigger"
									aria-haspopup="true"
									aria-expanded="false"
									data-nav-dropdown
								>
									{link.label}
									<span class="nav__caret" aria-hidden="true">&#9662;</span>
								</button>
								<ul class="nav__dropdown" role="menu">
									{link.children.map((c: any) => (
										<li role="none">
											<a
												role="menuitem"
												href={c.href}
												target={c.openInNewTab ? '_blank' : undefined}
												rel={c.openInNewTab ? 'noopener noreferrer' : undefined}
											>{c.label}</a>
										</li>
									))}
								</ul>
							</>
						) : (
							<a
								href={link.href}
								class={link.isButton ? 'nav__link nav__inquire' : 'nav__link'}
								target={link.openInNewTab ? '_blank' : undefined}
								rel={link.openInNewTab ? 'noopener noreferrer' : undefined}
							>{link.label}</a>
						)}
					</li>
				))}
			</ul>
		</nav>

		<button
			class="nav__hamburger"
			id="navHamburger"
			aria-label="Open navigation menu"
			aria-expanded="false"
			aria-controls="navOverlay"
		>
			<span class="nav__hamburger-bar"></span>
			<span class="nav__hamburger-bar"></span>
			<span class="nav__hamburger-bar"></span>
		</button>
	</div>
</header>

<!-- Mobile overlay -->
<div class="nav__overlay" id="navOverlay" aria-hidden="true" role="dialog" aria-label="Navigation menu">
	<div class="nav__overlay-inner">
		<button
			class="nav__overlay-close"
			id="navOverlayClose"
			aria-label="Close navigation menu"
		>
			<span aria-hidden="true">&times;</span>
		</button>
		{showImageLogo
			? <a href="/" class="nav__overlay-logo nav__overlay-logo--image"><img src={urlFor(logoImage).height(96).auto('format').url()} alt={siteName} class="nav__logo-img" decoding="async" /></a>
			: <a href="/" class="nav__overlay-logo">{siteName}</a>
		}
		<nav aria-label="Mobile navigation">
			<ul class="nav__overlay-links">
				{links.map((link: any) => (
					<li>
						<a
							href={link.href}
							class={link.isButton ? 'nav__overlay-inquire' : ''}
							style={link.isButton && link.ctaColor ? `--nav-cta-color: ${link.ctaColor}` : undefined}
							target={link.openInNewTab ? '_blank' : undefined}
							rel={link.openInNewTab ? 'noopener noreferrer' : undefined}
						>{link.label}</a>
						{link.hasChildren && (
							<ul class="nav__overlay-sublinks">
								{link.children.map((c: any) => (
									<li>
										<a
											href={c.href}
											target={c.openInNewTab ? '_blank' : undefined}
											rel={c.openInNewTab ? 'noopener noreferrer' : undefined}
										>{c.label}</a>
									</li>
								))}
							</ul>
						)}
					</li>
				))}
			</ul>
		</nav>
	</div>
</div>

<style>
	/* ═══════════════════════════════════════
	   BASE NAV (shared by all variants)
	   Non-transparent variants render in normal flow. The transparent
	   variants opt into sticky positioning on their own (see below)
	   so they stay pinned on every page; classic / centered / split
	   stay non-sticky as before.
	═══════════════════════════════════════ */
	.nav {
		position: relative;
		z-index: 100;
		background: var(--bg);
		box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
		transition: background 0.3s ease, box-shadow 0.3s ease;
	}

	.nav__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 20px 1.5rem;
	}

	.nav__logo {
		font-family: var(--font-serif, Georgia, serif);
		font-style: normal;
		font-size: 2rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		color: var(--text);
		text-decoration: none;
		white-space: nowrap;
		transition: opacity 0.2s, color 0.3s;
	}

	.nav__logo:hover { opacity: 0.7; }

	.nav__logo--image {
		display: flex;
		align-items: center;
	}

	.nav__logo-img {
		display: block;
		max-height: 48px;
		width: auto;
	}

	.nav__links {
		display: flex;
		align-items: center;
		gap: 2.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.nav__item { position: relative; }

	.nav__links .nav__link,
	.nav__links a {
		font-family: var(--font-body, system-ui, sans-serif);
		font-style: normal;
		font-size: 1.125rem;
		font-weight: 400;
		color: var(--text);
		text-decoration: none;
		letter-spacing: 0.1em;
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		transition: color 0.2s;
	}

	.nav__links .nav__link:not(.nav__inquire),
	.nav__links a:not(.nav__inquire) {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
	}

	.nav__links .nav__link:not(.nav__inquire)::after,
	.nav__links a:not(.nav__inquire)::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -2px;
		width: 0;
		height: 1px;
		background-color: var(--accent);
		transition: width 0.25s ease;
	}

	.nav__links .nav__link:not(.nav__inquire):hover,
	.nav__links a:not(.nav__inquire):hover {
		color: var(--accent);
	}

	.nav__links .nav__link:not(.nav__inquire):hover::after,
	.nav__links a:not(.nav__inquire):hover::after { width: 100%; }

	.nav__caret {
		font-size: 0.65em;
		line-height: 1;
		transition: transform 0.2s;
	}
	.nav__item--has-dropdown .nav__dropdown-trigger[aria-expanded='true'] .nav__caret {
		transform: rotate(180deg);
	}

	/* ── Dropdown panel ─────────────────────── */
	.nav__dropdown {
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translate(-50%, 8px);
		min-width: 200px;
		background: var(--bg);
		border: 1px solid var(--border);
		box-shadow: 0 12px 28px rgba(0, 0, 0, 0.1);
		padding: 0.75rem 0;
		margin: 0;
		list-style: none;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		z-index: 110;
		transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
	}
	.nav__item--has-dropdown:hover .nav__dropdown,
	.nav__item--has-dropdown .nav__dropdown-trigger[aria-expanded='true'] + .nav__dropdown {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transform: translate(-50%, 0);
	}
	.nav__dropdown li { display: block; }
	.nav__dropdown a {
		display: block;
		padding: 0.6rem 1.25rem;
		font-size: 0.95rem;
		letter-spacing: 0.06em;
		color: var(--text);
		text-decoration: none;
		white-space: nowrap;
		transition: background 0.2s, color 0.2s;
	}
	.nav__dropdown a:hover {
		background: var(--bg-alt);
		color: var(--accent);
	}
	@media (prefers-reduced-motion: reduce) {
		.nav__dropdown {
			transition: opacity 0.01s, visibility 0.01s;
			transform: translate(-50%, 0);
		}
	}

	.nav__inquire {
		color: var(--nav-cta-color, var(--accent)) !important;
		transition: color 0.2s, transform 0.2s, letter-spacing 0.25s;
	}

	.nav__inquire:hover { transform: translateY(-1px); letter-spacing: 0.08em; }

	/* ── Hamburger button (hidden on desktop) ── */
	.nav__hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 6px;
		margin: -6px;
	}

	.nav__hamburger-bar {
		display: block;
		width: 24px;
		height: 1.5px;
		background: var(--text);
		transition: opacity 0.2s, background 0.3s;
	}

	.nav__hamburger:hover .nav__hamburger-bar {
		opacity: 0.6;
	}

	/* ── Overlay (hidden by default) ── */
	.nav__overlay {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 200;
		background: var(--bg);
		opacity: 0;
		transition: opacity 0.25s ease;
	}

	.nav__overlay.nav__overlay--open {
		opacity: 1;
	}

	.nav__overlay-inner {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: flex-start;
		height: 100%;
		padding: 4rem 2rem 4rem 2.5rem;
		max-width: 480px;
	}

	.nav__overlay-close {
		position: absolute;
		top: 1.5rem;
		right: 1.5rem;
		background: none;
		border: none;
		cursor: pointer;
		font-family: var(--font-body, system-ui, sans-serif);
		font-size: 2rem;
		font-weight: 300;
		line-height: 1;
		color: var(--muted);
		padding: 6px;
		transition: color 0.2s, transform 0.2s;
	}

	.nav__overlay-close:hover {
		color: var(--text);
		transform: rotate(90deg);
	}

	.nav__overlay-logo {
		font-family: var(--font-serif, Georgia, serif);
		font-style: normal;
		font-size: clamp(1.5rem, 5vw, 2rem);
		font-weight: 700;
		color: var(--text);
		text-decoration: none;
		display: block;
		margin-bottom: 2.5rem;
	}

	.nav__overlay-logo--image {
		display: flex;
		align-items: center;
	}

	.nav__overlay-links {
		display: flex;
		flex-direction: column;
		gap: 0;
		width: 100%;
	}

	.nav__overlay-links li {
		border-bottom: 1px solid var(--border);
	}

	.nav__overlay-links li:first-child {
		border-top: 1px solid var(--border);
	}

	.nav__overlay-links a {
		display: block;
		font-family: var(--font-heading, Georgia, serif);
		font-style: italic;
		font-size: clamp(1.75rem, 5vw, 2.5rem);
		font-weight: normal;
		color: var(--text);
		text-decoration: none;
		letter-spacing: -0.01em;
		padding: 1rem 0;
		transition: color 0.2s, padding-left 0.25s;
	}

	.nav__overlay-links a:hover {
		color: var(--accent);
		padding-left: 0.5rem;
	}

	.nav__overlay-inquire {
		color: var(--nav-cta-color, var(--accent)) !important;
	}

	/* Mobile sub-links inside the hamburger overlay */
	.nav__overlay-sublinks {
		list-style: none;
		margin: 0 0 0.75rem 1.25rem;
		padding: 0;
	}
	.nav__overlay-sublinks li { border: none; }
	.nav__overlay-sublinks a {
		display: block;
		font-family: var(--font-body, system-ui, sans-serif);
		font-style: normal;
		font-size: 1rem;
		letter-spacing: 0.08em;
		padding: 0.5rem 0 0.5rem 1rem;
		border-left: 1px solid var(--border);
		color: var(--muted);
	}
	.nav__overlay-sublinks a:hover {
		color: var(--accent);
		padding-left: 1.25rem;
	}

	/* ═══════════════════════════════════════
	   VARIANT: CENTERED
	   Logo centered at top, links centered below
	═══════════════════════════════════════ */
	.nav[data-variant='centered'] .nav__inner {
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 1.25rem 1.5rem 1rem;
	}

	.nav[data-variant='centered'] .nav__logo {
		order: 1;
	}

	.nav[data-variant='centered'] nav {
		order: 2;
	}

	.nav[data-variant='centered'] .nav__links {
		gap: 2rem;
	}

	.nav[data-variant='centered'] .nav__hamburger {
		/* shown via compact JS, placed absolutely so it doesn't shift layout */
		position: absolute;
		right: 1.5rem;
		top: 50%;
		transform: translateY(-50%);
	}

	/* ═══════════════════════════════════════
	   VARIANT: TRANSPARENT
	   Starts clear over hero, fills in on scroll.
	   Gated on body[data-hero-overlay='true'] which a small inline
	   script below sets when the page's first <main> child is a
	   hero--image-full section. On pages without that pattern, the
	   attribute is absent and the transparent variant falls through
	   to the default opaque .nav styling — avoiding white text sitting
	   invisibly on a bg-colored page.
	   (The CSS :has() approach needs to cross component scopes, which
	   Astro's scoped-CSS compiler can't safely rewrite inside :has().)
	═══════════════════════════════════════ */
	/* Sticky gate — pure opt-in. Editors flip Sticky navigation on in
	   navSettings for any variant (including transparent); the attribute
	   lands on the <header> at render. Transparent variants are NOT
	   force-sticky anymore — non-sticky transparent overlays the hero
	   and scrolls away with the page. */
	.nav[data-sticky='true'] {
		position: sticky;
		top: 0;
	}

	/* Overlay treatment (transparent bg, no shadow) only when there's
	   a hero behind it. On non-hero pages the base opaque background
	   applies, keeping text legible. */
	:global(body[data-hero-overlay='true']) .nav[data-variant^='transparent'] {
		background: transparent;
		box-shadow: none;
	}

	/* transparent state: white text/bars so it reads over hero imagery */
	:global(body[data-hero-overlay='true']) .nav[data-variant^='transparent']:not(.nav--scrolled) .nav__logo,
	:global(body[data-hero-overlay='true']) .nav[data-variant^='transparent']:not(.nav--scrolled) .nav__links a,
	:global(body[data-hero-overlay='true']) .nav[data-variant^='transparent']:not(.nav--scrolled) .nav__links .nav__link {
		color: var(--white);
	}

	:global(body[data-hero-overlay='true']) .nav[data-variant^='transparent']:not(.nav--scrolled) .nav__links a:not(.nav__inquire)::after,
	:global(body[data-hero-overlay='true']) .nav[data-variant^='transparent']:not(.nav--scrolled) .nav__links .nav__link:not(.nav__inquire)::after {
		background-color: var(--white);
	}

	:global(body[data-hero-overlay='true']) .nav[data-variant^='transparent']:not(.nav--scrolled) .nav__hamburger-bar {
		background: var(--white);
	}

	/* scrolled state: opaque background returns (only meaningful when
	   the overlay mode was active in the first place) */
	:global(body[data-hero-overlay='true']) .nav[data-variant^='transparent'].nav--scrolled {
		background: var(--bg);
		box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
	}

	/* ═══════════════════════════════════════
	   VARIANT: SPLIT
	   Logo centered; links balanced left and right
	═══════════════════════════════════════ */
	.nav[data-variant$='split'] .nav__inner {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		grid-template-areas: 'left logo right';
		align-items: center;
		padding: 20px 1.5rem;
	}

	.nav[data-variant$='split'] .nav__left-nav {
		grid-area: left;
		display: flex;
		justify-content: flex-end;
	}

	.nav[data-variant$='split'] .nav__logo {
		grid-area: logo;
		margin: 0 2rem;
		text-align: center;
	}

	.nav[data-variant$='split'] nav:not(.nav__left-nav) {
		grid-area: right;
	}

	.nav[data-variant$='split'] .nav__links--left {
		justify-content: flex-end;
	}

	.nav[data-variant$='split'] .nav__links--right {
		justify-content: flex-start;
	}

	/* Hamburger sits in the right grid area in compact state */
	.nav[data-variant$='split'] .nav__hamburger {
		grid-area: right;
		justify-self: end;
	}

	/* Compact: collapse to logo-left, hamburger-right */
	.nav[data-variant$='split'].nav--compact .nav__inner {
		display: flex;
		justify-content: space-between;
	}

	.nav[data-variant$='split'].nav--compact .nav__logo {
		margin: 0 1rem 0 0;
	}

	.nav[data-variant$='split'].nav--compact .nav__left-nav {
		display: none;
	}

	/* ═══════════════════════════════════════
	   COMPACT STATE (JS-driven, all variants)
	═══════════════════════════════════════ */

	/* Logo shrinks fluidly so it never crowds the hamburger button */
	.nav--compact .nav__logo {
		font-size: clamp(0.9rem, 4.5vw, 2rem);
		min-width: 0;
		flex-shrink: 1;
		margin-right: 1rem;
	}

	.nav--compact .nav__links {
		display: none;
	}

	.nav--compact .nav__hamburger {
		display: flex;
		flex-shrink: 0;
	}

	/* Reset centered column layout in compact state */
	.nav[data-variant='centered'].nav--compact .nav__inner {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding: 20px 1.5rem;
	}

	.nav[data-variant='centered'].nav--compact .nav__hamburger {
		position: static;
		transform: none;
	}

	/* The overlay div is a SIBLING of <header class="nav"> in the DOM,
	   not a descendant — so the compact-state rule has to use the
	   subsequent-sibling combinator, not the descendant combinator, for
	   the overlay to actually become displayable on tablet widths
	   (769–1024px) where the hard @media (max-width: 768px) fallback
	   below doesn't fire but .nav--compact is active. */
	.nav.nav--compact ~ .nav__overlay {
		display: block;
		pointer-events: none;
	}

	.nav.nav--compact ~ .nav__overlay.nav__overlay--open {
		pointer-events: auto;
	}

	/* Hard fallback if JS is unavailable */
	@media (max-width: 768px) {
		.nav__inner    { padding: 20px 1.5rem; }
		.nav__logo     { font-size: clamp(0.9rem, 4.5vw, 2rem); min-width: 0; flex-shrink: 1; margin-right: 1rem; }
		.nav__links    { display: none; }
		.nav__hamburger { display: flex; flex-shrink: 0; }
		.nav__overlay  { display: block; pointer-events: none; }
		.nav__overlay.nav__overlay--open { pointer-events: auto; }

		/* centered: revert to row on mobile */
		.nav[data-variant='centered'] .nav__inner {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}
		.nav[data-variant='centered'] .nav__hamburger {
			position: static;
			transform: none;
		}

		/* split: revert to flex row on mobile */
		.nav[data-variant$='split'] .nav__inner {
			display: flex;
			justify-content: space-between;
		}
		.nav[data-variant$='split'] .nav__logo { margin: 0 1rem 0 0; }
		.nav[data-variant$='split'] .nav__left-nav { display: none; }
	}
</style>

<script>
	const navHeader = document.querySelector('.nav') as HTMLElement;
	const hamburger = document.getElementById('navHamburger') as HTMLButtonElement;
	const overlay   = document.getElementById('navOverlay') as HTMLElement;
	const closeBtn  = document.getElementById('navOverlayClose') as HTMLButtonElement;
	const logo      = navHeader.querySelector('.nav__logo') as HTMLElement;
	const linksEl   = navHeader.querySelector('.nav__links') as HTMLElement;
	const leftNavEl = navHeader.querySelector('.nav__left-nav') as HTMLElement | null;
	const variant   = navHeader.dataset.variant || 'classic';
	const isSticky  = navHeader.dataset.sticky === 'true';

	// ── Transparent variants: solidify on scroll (covers plain
	// 'transparent' and the new 'transparent-split' combined variant).
	// Gated on Sticky — a non-sticky transparent nav scrolls out of view,
	// so the opaque flip would just be a flash as it leaves the viewport.
	if ((variant === 'transparent' || variant === 'transparent-split') && isSticky) {
		const onScroll = () => {
			if (window.scrollY > 60) {
				navHeader.classList.add('nav--scrolled');
			} else {
				navHeader.classList.remove('nav--scrolled');
			}
		};
		window.addEventListener('scroll', onScroll, { passive: true });
		onScroll(); // run on load
	}

	// ── Dynamic gap checker (classic & centered variants) ─────────────
	// Temporarily restores desktop state (invisible) to measure the true
	// gap between logo and nav links, then applies .nav--compact if < 50px.
	function checkLayout() {
		const wasCompact = navHeader.classList.contains('nav--compact');
		navHeader.classList.remove('nav--compact');

		// Make links temporarily visible-but-hidden so we can measure them
		const showHide = (el: HTMLElement | null, show: boolean) => {
			if (el) el.style.cssText = show
				? 'display:flex!important;visibility:hidden!important;pointer-events:none!important;'
				: '';
		};

		showHide(linksEl, true);
		if (leftNavEl) showHide(leftNavEl, true);

		let gap: number;

		if (variant === 'centered') {
			const linksRect = linksEl.getBoundingClientRect();
			gap = linksRect.width < window.innerWidth - 48 ? 100 : -1;
		} else if (variant === 'split' || variant === 'transparent-split') {
			// Check if the inner grid overflows the nav width
			const inner = navHeader.querySelector('.nav__inner') as HTMLElement;
			gap = inner.scrollWidth <= inner.clientWidth + 2 ? 100 : -1;
		} else {
			const logoRect  = logo.getBoundingClientRect();
			const linksRect = linksEl.getBoundingClientRect();
			gap = linksRect.left - logoRect.right;
		}

		showHide(linksEl, false);
		if (leftNavEl) showHide(leftNavEl, false);

		// Keep --nav-height in sync so the transparent hero pull-up stays accurate
		document.documentElement.style.setProperty('--nav-height', navHeader.offsetHeight + 'px');

		if (gap < 50) {
			navHeader.classList.add('nav--compact');
		}

		if (wasCompact && !navHeader.classList.contains('nav--compact')) {
			overlay.classList.remove('nav__overlay--open');
			overlay.setAttribute('aria-hidden', 'true');
			hamburger.setAttribute('aria-expanded', 'false');
			document.body.style.overflow = '';
		}
	}

	const ro = new ResizeObserver(checkLayout);
	ro.observe(document.documentElement);
	checkLayout();

	// ── Hamburger open / close ────────────────────────────────────────
	function openMenu() {
		overlay.classList.add('nav__overlay--open');
		overlay.setAttribute('aria-hidden', 'false');
		hamburger.setAttribute('aria-expanded', 'true');
		document.body.style.overflow = 'hidden';
		closeBtn.focus();
	}

	function closeMenu() {
		overlay.classList.remove('nav__overlay--open');
		overlay.setAttribute('aria-hidden', 'true');
		hamburger.setAttribute('aria-expanded', 'false');
		document.body.style.overflow = '';
		hamburger.focus();
	}

	hamburger.addEventListener('click', openMenu);
	closeBtn.addEventListener('click', closeMenu);

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && overlay.classList.contains('nav__overlay--open')) closeMenu();
	});

	overlay.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));

	// ── Desktop dropdown menus ────────────────────────────────────────
	// Hover already toggles via CSS; this script handles click + ARIA +
	// keyboard. ESC closes the open dropdown, clicking outside closes,
	// and pressing Enter/Space on the trigger toggles open state.
	const dropdownTriggers = navHeader.querySelectorAll<HTMLButtonElement>('[data-nav-dropdown]');

	function closeAllDropdowns() {
		dropdownTriggers.forEach((t) => t.setAttribute('aria-expanded', 'false'));
	}

	dropdownTriggers.forEach((trigger) => {
		trigger.addEventListener('click', (e) => {
			e.stopPropagation();
			const expanded = trigger.getAttribute('aria-expanded') === 'true';
			closeAllDropdowns();
			trigger.setAttribute('aria-expanded', expanded ? 'false' : 'true');
		});
	});

	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		if (!target.closest('.nav__item--has-dropdown')) closeAllDropdowns();
	});

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') closeAllDropdowns();
	});
</script>
