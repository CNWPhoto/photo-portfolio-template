---
import { urlFor } from '../lib/sanity.js';
const { siteName = 'Pet Photography', logoType = 'text', logoImage = null } = Astro.props;
const showImageLogo = logoType === 'image' && logoImage;
---

<header class="nav">
	<div class="nav__inner">
		{showImageLogo
			? <a href="/" class="nav__logo nav__logo--image"><img src={urlFor(logoImage).height(96).auto('format').url()} alt={siteName} class="nav__logo-img" /></a>
			: <a href="/" class="nav__logo">{siteName}</a>
		}
		<nav aria-label="Main navigation">
			<ul class="nav__links">
				<li><a href="/experience">Experience</a></li>
				<li><a href="/portfolio">Portfolio</a></li>
				<li><a href="/about">About</a></li>
				<li><a href="/blog">Blog</a></li>
				<li><a href="/contact" class="nav__inquire">Inquire</a></li>
			</ul>
		</nav>
	</div>
</header>

<style>
	.nav {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--bg);
		box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
	}

	.nav__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 24px 75px;
	}

	.nav__logo {
		font-family: var(--font-body, system-ui, sans-serif);
		font-style: normal;
		font-size: 2rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		color: var(--text);
		text-decoration: none;
		white-space: nowrap;
		transition: opacity 0.2s;
	}

	.nav__logo:hover { opacity: 0.7; }

	.nav__logo--image {
		display: flex;
		align-items: center;
	}

	.nav__logo-img {
		display: block;
		max-height: 48px;
		width: auto;
	}

	.nav__links {
		display: flex;
		align-items: center;
		gap: 2.5rem;
	}

	.nav__links a {
		font-family: var(--font-body, system-ui, sans-serif);
		font-style: normal;
		font-size: 1.125rem;
		font-weight: 400;
		color: var(--text);
		text-decoration: none;
		letter-spacing: 0.1em;
		transition: color 0.2s;
	}

	.nav__links a:not(.nav__inquire) {
		position: relative;
		transition: color 0.2s, transform 0.2s;
	}

	.nav__links a:not(.nav__inquire)::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -2px;
		width: 0;
		height: 1px;
		background: currentColor;
		transition: width 0.25s ease;
	}

	.nav__links a:not(.nav__inquire):hover {
		color: var(--accent);
		transform: translateY(-1px);
	}

	.nav__links a:not(.nav__inquire):hover::after { width: 100%; }

	.nav__inquire {
		color: var(--accent) !important;
		transition: color 0.2s, transform 0.2s, letter-spacing 0.25s;
	}

	.nav__inquire:hover { transform: translateY(-1px); letter-spacing: 0.08em; }

	@media (max-width: 768px) {
		.nav__inner {
			padding: 20px 1.5rem;
		}

		.nav__links {
			gap: 1.5rem;
		}

		.nav__links li:nth-child(-n + 2) {
			display: none;
		}
	}
</style>
