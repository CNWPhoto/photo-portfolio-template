---
import { urlFor } from '../lib/sanity.js';
const { siteName = 'Pet Photography', logoType = 'text', logoImage = null } = Astro.props;
const showImageLogo = logoType === 'image' && logoImage;
---

<header class="nav">
	<div class="nav__inner">
		{showImageLogo
			? <a href="/" class="nav__logo nav__logo--image"><img src={urlFor(logoImage).height(96).auto('format').url()} alt={siteName} class="nav__logo-img" decoding="async" /></a>
			: <a href="/" class="nav__logo">{siteName}</a>
		}
		<nav aria-label="Main navigation">
			<ul class="nav__links">
				<li><a href="/experience">Experience</a></li>
				<li><a href="/portfolio">Portfolio</a></li>
				<li><a href="/about">About</a></li>
				<li><a href="/blog">Blog</a></li>
				<li><a href="/contact" class="nav__inquire">Inquire</a></li>
			</ul>
		</nav>

		<button
			class="nav__hamburger"
			id="navHamburger"
			aria-label="Open navigation menu"
			aria-expanded="false"
			aria-controls="navOverlay"
		>
			<span class="nav__hamburger-bar"></span>
			<span class="nav__hamburger-bar"></span>
			<span class="nav__hamburger-bar"></span>
		</button>
	</div>
</header>

<!-- Mobile overlay -->
<div class="nav__overlay" id="navOverlay" aria-hidden="true" role="dialog" aria-label="Navigation menu">
	<div class="nav__overlay-inner">
		<button
			class="nav__overlay-close"
			id="navOverlayClose"
			aria-label="Close navigation menu"
		>
			<span aria-hidden="true">&times;</span>
		</button>
		<nav aria-label="Mobile navigation">
			<ul class="nav__overlay-links">
				<li><a href="/experience">Experience</a></li>
				<li><a href="/portfolio">Portfolio</a></li>
				<li><a href="/about">About</a></li>
				<li><a href="/blog">Blog</a></li>
				<li><a href="/contact" class="nav__overlay-inquire">Inquire</a></li>
			</ul>
		</nav>
	</div>
</div>

<style>
	.nav {
		position: relative;
		z-index: 100;
		background: var(--bg);
		box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
	}

	.nav__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 20px 1.5rem;
	}

	.nav__logo {
		font-family: var(--font-body, system-ui, sans-serif);
		font-style: normal;
		font-size: 2rem;
		font-weight: 500;
		letter-spacing: 0.048em;
		color: var(--text);
		text-decoration: none;
		white-space: nowrap;
		transition: opacity 0.2s;
	}

	.nav__logo:hover { opacity: 0.7; }

	.nav__logo--image {
		display: flex;
		align-items: center;
	}

	.nav__logo-img {
		display: block;
		max-height: 48px;
		width: auto;
	}

	.nav__links {
		display: flex;
		align-items: center;
		gap: 2.5rem;
	}

	.nav__links a {
		font-family: var(--font-body, system-ui, sans-serif);
		font-style: normal;
		font-size: 1.125rem;
		font-weight: 400;
		color: var(--text);
		text-decoration: none;
		letter-spacing: 0.1em;
		transition: color 0.2s;
	}

	.nav__links a:not(.nav__inquire) {
		position: relative;
		transition: color 0.2s, transform 0.2s;
	}

	.nav__links a:not(.nav__inquire)::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -2px;
		width: 0;
		height: 1px;
		background-color: var(--accent);
		transition: width 0.25s ease;
	}

	.nav__links a:not(.nav__inquire):hover {
		color: var(--accent);
		transform: translateY(-1px);
	}

	.nav__links a:not(.nav__inquire):hover::after { width: 100%; }

	.nav__inquire {
		color: var(--accent) !important;
		transition: color 0.2s, transform 0.2s, letter-spacing 0.25s;
	}

	.nav__inquire:hover { transform: translateY(-1px); letter-spacing: 0.08em; }

	/* ── Hamburger button (hidden on desktop) ── */
	.nav__hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 6px;
		margin: -6px;
	}

	.nav__hamburger-bar {
		display: block;
		width: 24px;
		height: 1.5px;
		background: var(--text);
		transition: opacity 0.2s;
	}

	.nav__hamburger:hover .nav__hamburger-bar {
		opacity: 0.6;
	}

	/* ── Overlay (hidden by default) ── */
	.nav__overlay {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 200;
		background: var(--bg);
		opacity: 0;
		transition: opacity 0.25s ease;
	}

	.nav__overlay.nav__overlay--open {
		opacity: 1;
	}

	.nav__overlay-inner {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: flex-start;
		height: 100%;
		padding: 4rem 2rem 4rem 2.5rem;
		max-width: 480px;
	}

	.nav__overlay-close {
		position: absolute;
		top: 1.5rem;
		right: 1.5rem;
		background: none;
		border: none;
		cursor: pointer;
		font-family: var(--font-body, system-ui, sans-serif);
		font-size: 2rem;
		font-weight: 300;
		line-height: 1;
		color: var(--muted);
		padding: 6px;
		transition: color 0.2s, transform 0.2s;
	}

	.nav__overlay-close:hover {
		color: var(--text);
		transform: rotate(90deg);
	}

	.nav__overlay-links {
		display: flex;
		flex-direction: column;
		gap: 0;
		width: 100%;
	}

	.nav__overlay-links li {
		border-bottom: 1px solid var(--border);
	}

	.nav__overlay-links li:first-child {
		border-top: 1px solid var(--border);
	}

	.nav__overlay-links a {
		display: block;
		font-family: var(--font-heading, Georgia, serif);
		font-style: italic;
		font-size: clamp(1.75rem, 5vw, 2.5rem);
		font-weight: normal;
		color: var(--text);
		text-decoration: none;
		letter-spacing: -0.01em;
		padding: 1rem 0;
		transition: color 0.2s, padding-left 0.25s;
	}

	.nav__overlay-links a:hover {
		color: var(--accent);
		padding-left: 0.5rem;
	}

	.nav__overlay-inquire {
		color: var(--accent) !important;
	}

	/* ── Compact state: triggered by JS class or media-query fallback ──
	   JS adds .nav--compact whenever the gap between logo and links
	   drops below 50px, regardless of viewport width.
	   The @media block below is a no-JS / very-small-screen safety net. */

	.nav--compact .nav__inner {
		padding: 20px 1.5rem;
	}

	/* Logo shrinks fluidly so it never crowds the hamburger button.
	   margin-right keeps at least 1rem breathing room before the icon. */
	.nav--compact .nav__logo {
		font-size: clamp(0.9rem, 4.5vw, 2rem);
		min-width: 0;
		flex-shrink: 1;
		margin-right: 1rem;
	}

	.nav--compact .nav__links {
		display: none;
	}

	.nav--compact .nav__hamburger {
		display: flex;
		flex-shrink: 0;
	}

	.nav--compact .nav__overlay {
		display: block;
		pointer-events: none;
	}

	.nav--compact .nav__overlay.nav__overlay--open {
		pointer-events: auto;
	}

	/* Hard fallback if JS is unavailable */
	@media (max-width: 768px) {
		.nav__inner    { padding: 20px 1.5rem; }
		.nav__logo     { font-size: clamp(0.9rem, 4.5vw, 2rem); min-width: 0; flex-shrink: 1; margin-right: 1rem; }
		.nav__links    { display: none; }
		.nav__hamburger { display: flex; flex-shrink: 0; }
		.nav__overlay  { display: block; pointer-events: none; }
		.nav__overlay.nav__overlay--open { pointer-events: auto; }
	}
</style>

<script>
	const navHeader = document.querySelector('.nav') as HTMLElement;
	const hamburger = document.getElementById('navHamburger') as HTMLButtonElement;
	const overlay   = document.getElementById('navOverlay') as HTMLElement;
	const closeBtn  = document.getElementById('navOverlayClose') as HTMLButtonElement;
	const logo      = navHeader.querySelector('.nav__logo') as HTMLElement;
	const links     = navHeader.querySelector('.nav__links') as HTMLElement;

	// ── Dynamic gap checker ───────────────────────────────────────────
	// Temporarily restores desktop state (invisible) to measure the true
	// gap between logo and nav links, then applies .nav--compact if < 50px.
	// ResizeObserver fires before paint so there's no visible flash.
	function checkLayout() {
		// Snapshot current compact state, then remove it for measurement
		const wasCompact = navHeader.classList.contains('nav--compact');
		navHeader.classList.remove('nav--compact');

		// Force links visible-but-hidden so getBoundingClientRect works
		links.style.cssText = 'display:flex!important;visibility:hidden!important;pointer-events:none!important;';

		const logoRight  = logo.getBoundingClientRect().right;
		const linksLeft  = links.getBoundingClientRect().left;
		const gap        = linksLeft - logoRight;

		// Restore links to their natural state before deciding
		links.style.cssText = '';

		if (gap < 50) {
			navHeader.classList.add('nav--compact');
		}
		// If gap >= 50, compact class stays removed (desktop layout)

		// If the menu was open and we switched back to desktop, close it cleanly
		if (wasCompact && !navHeader.classList.contains('nav--compact')) {
			overlay.classList.remove('nav__overlay--open');
			overlay.setAttribute('aria-hidden', 'true');
			hamburger.setAttribute('aria-expanded', 'false');
			document.body.style.overflow = '';
		}
	}

	const ro = new ResizeObserver(checkLayout);
	ro.observe(document.documentElement);
	checkLayout(); // run immediately on load

	// ── Hamburger open / close ────────────────────────────────────────
	function openMenu() {
		overlay.classList.add('nav__overlay--open');
		overlay.setAttribute('aria-hidden', 'false');
		hamburger.setAttribute('aria-expanded', 'true');
		document.body.style.overflow = 'hidden';
		closeBtn.focus();
	}

	function closeMenu() {
		overlay.classList.remove('nav__overlay--open');
		overlay.setAttribute('aria-hidden', 'true');
		hamburger.setAttribute('aria-expanded', 'false');
		document.body.style.overflow = '';
		hamburger.focus();
	}

	hamburger.addEventListener('click', openMenu);
	closeBtn.addEventListener('click', closeMenu);

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && overlay.classList.contains('nav__overlay--open')) closeMenu();
	});

	overlay.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
</script>
