---
import { paletteToStyle } from '../../lib/palette.js';
import { renderHeading } from '../../lib/heading.js';
import { resolveLink } from '../../lib/links.js';
import { renderBody, isPortableText } from '../../lib/portableText.js';
import { buildSrc } from '../../lib/image';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, palette } = Astro.props;
const style = paletteToStyle(palette);

const FALLBACK_BG =
  'https://images.pexels.com/photos/1629781/pexels-photo-1629781.jpeg?auto=compress&cs=tinysrgb&w=2000';

const image = section?.image ?? null;
const bgUrl = image?.asset ? buildSrc(image, 2000) : FALLBACK_BG;

const headingHTML = renderHeading(section?.heading || '');
const bodyHTML = isPortableText(section?.body)
  ? renderBody(section.body, { className: 'why__body' })
  : '';
const ctaText = section?.ctaText || '';
const ctaHref = resolveLink(section?.ctaLink, [Astro.url.hostname]) || '#';
const caption = section?.caption || '';
const eyebrow = section?.eyebrow || '';
const textContainer = section?.textContainer || 'default';
const overlayOpacity = (section?.overlayOpacity ?? 30) / 100;
const height = section?.height || 'tall';
const parallax = !!section?.parallax;

const isImageOnly = textContainer === 'image-only';
const cardPlacement = section?.cardPlacement === 'right' ? 'right' : 'left';
---

{isImageOnly ? (
  <section
    class:list={['fbi-imgonly', `fbi-imgonly--${height}`]}
    data-section-type="fullBleedImageSection"
    data-parallax={parallax ? 'true' : 'false'}
    id={section?.sectionId || undefined}
    style={style}
  >
    <div class="fbi-imgonly__img" style={`background-image:url('${bgUrl}')`} aria-hidden="true" />
  </section>
) : (
  <section
    class:list={['fbi', `fbi--${height}`]}
    data-section-type="fullBleedImageSection"
    data-parallax={parallax ? 'true' : 'false'}
    data-card-placement={cardPlacement}
    id={section?.sectionId || undefined}
    style={style}
  >
    <div class="fbi__bg" style={`background-image:url('${bgUrl}')`} aria-hidden="true"></div>
    <div class="fbi__overlay" style={`background:rgba(0,0,0,${overlayOpacity})`} aria-hidden="true"></div>
    <div class="fbi__box">
      {eyebrow && <p class="fbi__label reveal reveal-delay-1">{eyebrow}</p>}
      {headingHTML && <h2 class="fbi__heading reveal reveal-delay-2" set:html={headingHTML} />}
      {bodyHTML && <div class="fbi__body-wrap reveal reveal-delay-3" set:html={bodyHTML} />}
      {ctaText && ctaHref && <a href={ctaHref} class="fbi__btn reveal reveal-delay-4">{ctaText}</a>}
      {caption && <p class="fbi__caption reveal reveal-delay-5">{caption}</p>}
    </div>
  </section>
)}

<style>
  /* ══ Image-only variant — full-bleed background image, no text,
     no vertical padding so neighboring sections butt up flush. ══ */
  .fbi-imgonly {
    padding: 0 !important;
    margin: 0;
    background: var(--bg);
    color: var(--text);
  }
  .fbi-imgonly__img {
    width: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .fbi-imgonly--medium .fbi-imgonly__img { height: 50vh; min-height: 320px; }
  .fbi-imgonly--tall .fbi-imgonly__img { height: 75vh; min-height: 480px; }
  .fbi-imgonly--viewport .fbi-imgonly__img { height: 100vh; min-height: 560px; }
  .fbi-imgonly[data-parallax='true'] .fbi-imgonly__img {
    background-attachment: fixed;
  }
  @media (max-width: 900px) {
    .fbi-imgonly[data-parallax='true'] .fbi-imgonly__img {
      background-attachment: scroll;
    }
  }

  /* ── Overlay Card variant ── */
  .fbi {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0 !important;
    background: var(--bg);
    color: var(--text);
    overflow: hidden;
  }
  .fbi--medium { min-height: 520px; }
  .fbi--tall { min-height: 680px; }
  .fbi--viewport { min-height: 100vh; }

  .fbi__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .fbi[data-parallax='true'] .fbi__bg {
    background-attachment: fixed;
  }
  @media (max-width: 900px) {
    .fbi[data-parallax='true'] .fbi__bg {
      background-attachment: scroll;
    }
  }
  .fbi__overlay {
    position: absolute;
    inset: 0;
  }

  .fbi__box {
    position: relative;
    z-index: 1;
    background: var(--bg);
    max-width: 460px;
    margin: calc(4rem + 50px) 0 calc(4rem + 50px) 6vw;
    padding: 3.5rem;
  }
  /* Right-aligned variant: flips the horizontal offset. Same dimensions,
     same padding, just anchored to the opposite edge. Section is flex +
     align-items: center already, so pushing the box right is a margin
     swap. */
  .fbi[data-card-placement='right'] .fbi__box {
    margin-left: auto;
    margin-right: 6vw;
  }
  .fbi__label {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .fbi__heading {
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .fbi__body-wrap :global(.why__body),
  .fbi__body-wrap :global(p) {
    font-style: italic;
    font-size: 1rem;
    line-height: 1.82;
    color: var(--text);
    margin-bottom: 1.25rem;
  }
  .fbi__body-wrap :global(p:last-child) {
    margin-bottom: 2rem;
  }
  .fbi__btn {
    display: inline-block;
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    border: 1px solid var(--text);
    padding: 0.7rem 1.75rem;
  }
  .fbi__caption {
    font-family: var(--font-sans, var(--font-body));
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: var(--muted-light);
    font-style: normal;
    margin: 1.25rem 0 0;
  }

  @media (max-width: 900px) {
    .fbi,
    .fbi--medium,
    .fbi--tall,
    .fbi--viewport {
      display: block;
      min-height: 0;
    }
    .fbi__bg {
      position: relative;
      inset: auto;
      width: 100%;
      height: 55vh;
      min-height: 320px;
    }
    .fbi__overlay {
      inset: 0 0 auto 0;
      height: 55vh;
      min-height: 320px;
    }
    .fbi__box {
      margin: 0;
      padding: 2.5rem 1.5rem 3rem;
      max-width: none;
    }
  }
</style>
