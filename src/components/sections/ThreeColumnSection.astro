---
import SanityImage from '../SanityImage.astro';
import { paletteToStyle } from '../../lib/palette.js';
import { renderHeading } from '../../lib/heading.js';
import { renderBody } from '../../lib/portableText.js';
import { resolveLink } from '../../lib/links.js';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, isFirst = false, palette } = Astro.props;
const style = paletteToStyle(palette);

const FALLBACK_IDS = ['1108099', '2253275', '825949'];
const fallbackUrl = (id: string) =>
  `https://images.pexels.com/photos/${id}/pexels-photo-${id}.jpeg?auto=compress&cs=tinysrgb&w=800`;

const eyebrow = section?.eyebrow || '';
const heading = renderHeading(section?.heading || '');
const variant = section?.variant || 'image-cards';
const alignment = section?.alignment || 'left';
const columnWidths = section?.columnWidths || 'equal';
const sideLabel = section?.verticalSideLabel || '';
// Render however many cards the editor added. Three-up grid wraps to new
// rows automatically when count > 3 (4 → 3+1, 6 → 3+3, 7 → 3+3+1, etc.).
// No upper cap; if an editor adds 12 cards we render 12 cards.
const columns = (section?.columns || []).filter(Boolean);
const cardCount = columns.length;

// Vertical centering is only applied when the editor has explicitly
// hidden media on at least one column — that's the signal they're
// intentionally mixing column heights (e.g. image-text-image with a
// short text middle). All-image / all-icon / all-number sections keep
// top-alignment so existing layouts on Carla / demo are unchanged.
const hasMixedMedia = columns.some((col: any) => col?.hideMedia);

const HeadingTag = isFirst ? 'h1' : 'h2';
---

<section
  class:list={['section', 'threecol', `threecol--${variant}`, hasMixedMedia && 'threecol--mixed-media']}
  data-section-type="threeColumnSection"
  data-spacing={section?.spacing || 'normal'}
  data-alignment={alignment}
  data-column-widths={columnWidths}
  data-card-count={cardCount}
  id={section?.sectionId || undefined}
  style={style}
>
  <div class="threecol__outer">
    {sideLabel && (
      <div class="threecol__label-col" aria-hidden="true">
        <span class="threecol__side-label">{sideLabel}</span>
      </div>
    )}

    <div class="threecol__inner">
      {(eyebrow || heading) && (
        <div class="threecol__head">
          {eyebrow && <p class="threecol__eyebrow">{eyebrow}</p>}
          {heading && <HeadingTag class="threecol__heading" set:html={heading} />}
        </div>
      )}

      <div class="threecol__grid">
        {columns.map((col: any, i: number) => {
          const colImg = col?.image ?? null;
          const colBody = renderBody(col?.body, { className: 'threecol__col-body' });
          // Cycle delay 1-2-3 per row so multi-row grids keep the staggered
          // reveal feel (instead of running off the end at reveal-delay-4+).
          const delayClass = `reveal-delay-${(i % 3) + 1}`;
          const colCtaText = col?.ctaText || '';
          const colCtaHref = resolveLink(col?.ctaLink, [Astro.url.hostname]);
          const hideMedia = !!col?.hideMedia;
          return (
            <div class:list={['threecol__col', 'reveal', delayClass, hideMedia && 'threecol__col--no-media']}>
              {!hideMedia && variant === 'image-cards' && (
                <div class="threecol__img-wrap">
                  {colImg
                    ? <SanityImage image={colImg} sizes="288px" loading="lazy" class="threecol__img" />
                    : <img src={fallbackUrl(FALLBACK_IDS[i])} alt="" loading="lazy" class="threecol__img" />}
                </div>
              )}
              {!hideMedia && variant === 'icon-cards' && col?.icon && (
                <div class="threecol__icon" aria-hidden="true">{col.icon}</div>
              )}
              {!hideMedia && variant === 'numbered-steps' && (
                <div class="threecol__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</div>
              )}
              {col?.title && <h3 class="threecol__title">{col.title}</h3>}
              {colBody && <div class="threecol__body" set:html={colBody} />}
              {colCtaText && colCtaHref && (
                <a href={colCtaHref} class="threecol__link">
                  {colCtaText}<span class="threecol__link-arrow" aria-hidden="true">&rarr;</span>
                </a>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .threecol {
    background: var(--bg);
    color: var(--text);
    position: relative;
    /* Default = normal section padding. The !important is kept (it guards
       against inherited section resets), so the data-spacing overrides below
       must also be !important to win. */
    padding: var(--section-pad-normal) 0 !important;
  }
  /* Respect the Vertical Padding field (data-spacing) — see palette.css tokens. */
  .threecol[data-spacing='narrow'] { padding-block: var(--section-pad-narrow) !important; }
  .threecol[data-spacing='compact'] { padding-block: var(--section-pad-compact) !important; }
  .threecol[data-spacing='spacious'] { padding-block: var(--section-pad-spacious) !important; }

  .threecol__outer {
    display: grid;
    grid-template-columns: 100px 1fr;
    padding: 0 3rem;
    max-width: 1265px;
    margin: 0 auto;
    gap: 2rem;
  }
  .threecol:not(:has(.threecol__label-col)) .threecol__outer {
    grid-template-columns: 1fr;
  }

  .threecol__label-col {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  /* vertical-lr + 180° rotate is the crisp pattern; rotating horizontal
     text via transform: rotate(-90deg) triggers subpixel raster blur on
     retina. Canonical pattern documented in the page-builder-spec. */
  .threecol__side-label {
    font-family: var(--font-heading, var(--font-serif));
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2rem, 3.2vw, 3rem);
    letter-spacing: 0.05em;
    color: var(--text);
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    white-space: nowrap;
    user-select: none;
  }

  .threecol__inner {
    padding: 0;
  }
  .threecol__head { margin-bottom: 1.5rem; text-align: center; }

  .threecol__eyebrow {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.85rem;
  }
  .threecol__heading {
    font-size: clamp(1.85rem, 3.5vw, 2.85rem);
    line-height: 1.2;
    color: var(--text);
    margin: 0;
  }

  .threecol__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 2.5rem;
    /* Slightly larger row gap so wrapped rows have visual separation
       distinct from the inter-column gap. Single-row layouts never see
       this since there's no second row to apply it to. */
    row-gap: 4rem;
    padding-top: 2.75rem;
  }
  /* No heading/eyebrow → the head isn't rendered, so the grid is the first
     child. Drop the top padding (meant to clear the head) so a heading-less
     row — e.g. the trust badges — sits vertically centered, not top-heavy. */
  .threecol__inner > .threecol__grid:first-child {
    padding-top: 0;
  }
  /* Vertical centering only when the editor has hidden media on at
     least one column — signal that they're intentionally mixing
     heights. A text-only column then sits with its midline at the
     same height as the centerlines of flanking image columns.
     Sections where every column has the same media kind keep top
     alignment, preserving existing client layouts. */
  .threecol--mixed-media .threecol__grid {
    align-items: center;
  }

  /* Editorial proportions. Default 'equal' keeps the existing 1fr 1fr 1fr.
     Wide-middle is for image-text-image with a longer center column;
     wide-outer is the inverse for visual-feature-with-detail layouts.
     Scoped to wider viewports so the mobile single-column stack still
     wins at <= 900px (the 1fr override below has lower specificity than
     this attribute selector, hence the explicit min-width gate).
     Asymmetric layouts only make sense when there's a single row of
     exactly 3 cards — gated on data-card-count='3' so 4+ card sections
     always wrap as equal-width rows of three. */
  @media (min-width: 901px) {
    .threecol[data-column-widths='wide-middle'][data-card-count='3'] .threecol__grid {
      grid-template-columns: 1fr 2fr 1fr;
    }
    .threecol[data-column-widths='wide-outer'][data-card-count='3'] .threecol__grid {
      grid-template-columns: 2fr 1fr 2fr;
    }
  }

  .threecol__col {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .threecol[data-alignment='center'] .threecol__col {
    text-align: center;
    align-items: center;
  }

  .threecol__img-wrap {
    overflow: hidden;
    margin-bottom: 1.5rem;
    width: 288px;
    max-width: 100%;
    aspect-ratio: 1;
  }
  .threecol__img-wrap img,
  .threecol__img-wrap :global(.threecol__img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-image);
  }
  .threecol__img-wrap:hover img,
  .threecol__img-wrap:hover :global(.threecol__img) { transform: scale(1.04); }

  .threecol__icon {
    font-size: 2.25rem;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }
  .threecol__num {
    font-family: var(--font-heading, var(--font-serif));
    font-style: italic;
    font-size: 3.25rem;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 1rem;
  }
  .threecol__title {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.84rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-dark, var(--accent));
    font-weight: 600;
    margin: 0 0 1rem;
  }
  .threecol__body :global(p),
  .threecol__body :global(.threecol__col-body) {
    font-size: 0.9375rem;
    line-height: 1.78;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .threecol__link {
    align-self: flex-start;
    font-style: italic;
    font-size: 1rem;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.01em;
    margin-top: 0.25rem;
  }
  .threecol[data-alignment='center'] .threecol__link {
    align-self: center;
  }
  .threecol__link-arrow {
    display: inline-block;
    margin-left: 0.35em;
    transition: transform 0.2s ease;
  }
  .threecol__link:hover .threecol__link-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .threecol__outer {
      grid-template-columns: 1fr;
      padding: 0 1.5rem;
    }
    .threecol:has(.threecol__heading) .threecol__label-col {
      display: none;
    }
    .threecol__label-col {
      overflow: visible;
      padding-top: 3rem;
    }
    .threecol__side-label {
      writing-mode: horizontal-tb;
      transform: none;
      font-size: clamp(1.6rem, 6vw, 2.25rem);
      text-align: center;
    }
    .threecol__grid {
      grid-template-columns: 1fr;
      padding-top: 2rem;
    }
    .threecol__col {
      align-items: center;
      text-align: center;
      max-width: 520px;
      margin: 0 auto;
    }
    .threecol__img-wrap {
      width: 100%;
      max-width: 520px;
    }
    .threecol__title {
      font-size: 0.9rem;
    }
    .threecol__body {
      max-width: 420px;
      margin: 0 auto;
    }
    .threecol__body :global(p),
    .threecol__body :global(.threecol__col-body) {
      font-size: 1.0625rem;
      line-height: 1.7;
    }
    .threecol__link {
      font-size: 1.0625rem;
    }
    .threecol[data-alignment='center'] .threecol__link,
    .threecol__link {
      align-self: center;
    }
  }
</style>
