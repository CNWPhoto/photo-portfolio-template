---
import SanityImage from '../SanityImage.astro';
import { paletteToStyle } from '../../lib/palette.js';
import { resolveLink } from '../../lib/links.js';
import { renderBody, isPortableText } from '../../lib/portableText.js';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, isFirst = false, palette } = Astro.props;
const style = paletteToStyle(palette);

const FALLBACK_IMG =
  'https://images.pexels.com/photos/1108099/pexels-photo-1108099.jpeg?auto=compress&cs=tinysrgb&w=1200';

const imageLayout = section?.imageLayout || 'image-right';
const eyebrow = section?.eyebrow || '';
const heading = section?.heading || '';
const ctaText = section?.ctaText || '';
const ctaHref = resolveLink(section?.ctaLink);
const sideLabel = section?.verticalSideLabel || '';

const bodyHTML = isPortableText(section?.body)
  ? renderBody(section.body, { className: 'isplit__body' })
  : '';

const image = section?.image ?? null;
---

<section
  class:list={['isplit', `isplit--${imageLayout}`]}
  data-section-type="splitSection"
  id={section?.sectionId || undefined}
  style={style}
>
  {sideLabel && <div class="isplit__side-label" aria-hidden="true">{sideLabel}</div>}

  <div class="isplit__content">
    <div class="isplit__text-wrap">
      {eyebrow && <p class="isplit__eyebrow reveal reveal-delay-1">{eyebrow}</p>}
      {heading && <h2 class="isplit__heading">{heading}</h2>}
      {bodyHTML && <div class="isplit__body-wrap reveal reveal-delay-2" set:html={bodyHTML} />}
      {ctaText && ctaHref && (
        <a class="isplit__link reveal reveal-delay-4" href={ctaHref}>{ctaText}</a>
      )}
    </div>
  </div>

  <div class="isplit__image reveal-fade">
    {image
      ? <SanityImage
          image={image}
          sizes="(max-width: 900px) 100vw, 50vw"
          loading={isFirst ? 'eager' : 'lazy'}
          class="isplit__img"
        />
      : <img src={FALLBACK_IMG} alt="" class="isplit__img" loading="lazy" />
    }
  </div>
</section>

<style>
  .isplit {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 550px;
    padding: 0 !important;
    border-top: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    position: relative;
  }

  /* image-right (default) — text on the left, image on the right */
  .isplit--image-right .isplit__content { order: 1; }
  .isplit--image-right .isplit__image   { order: 2; }
  /* image-left — image on the left, text on the right */
  .isplit--image-left .isplit__image    { order: 1; }
  .isplit--image-left .isplit__content  { order: 2; }
  .isplit--image-left .isplit__content { align-items: flex-start; }
  .isplit--image-left .isplit__text-wrap { text-align: left; padding-right: 0; padding-left: 75px; }
  .isplit--image-left .isplit__eyebrow,
  .isplit--image-left .isplit__body,
  .isplit--image-left .isplit__link { text-align: left; }

  .isplit__image {
    overflow: hidden;
    height: 100%;
  }

  .isplit__image :global(.isplit__img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s var(--ease-image);
  }
  .isplit__image:hover :global(.isplit__img) { transform: scale(1.04); }

  .isplit__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    padding: 60px 64px;
    background: var(--bg-alt);
  }

  .isplit__text-wrap {
    max-width: 440px;
    text-align: right;
    padding-right: 75px;
  }

  .isplit__eyebrow {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    text-align: right;
  }

  .isplit__heading {
    font-size: clamp(1.85rem, 3.5vw, 2.85rem);
    color: var(--text);
    line-height: 1.2;
    margin: 0 0 1.25rem;
    text-align: right;
  }

  .isplit__body-wrap :global(.isplit__body) {
    font-size: 1.32rem;
    line-height: 1.43;
    color: var(--text);
    margin-bottom: 1.5rem;
    text-align: right;
  }

  .isplit__body-wrap :global(.isplit__body em) {
    font-style: normal;
    color: var(--accent);
  }

  .isplit__link {
    display: block;
    font-style: italic;
    font-size: 1rem;
    letter-spacing: 0.01em;
    color: var(--accent);
    text-decoration: none;
    margin-top: 1.5rem;
    text-align: right;
  }

  .isplit__side-label {
    position: absolute;
    top: 50%;
    left: 1rem;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: left center;
    font-family: var(--font-sans, var(--font-body));
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--muted-light);
    z-index: 2;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .isplit { grid-template-columns: 1fr; min-height: 0; }
    .isplit--image-right .isplit__image,
    .isplit--image-left .isplit__image { order: -1; height: 60vw; min-height: 240px; }
    .isplit__content {
      padding: 4rem 2rem;
      align-items: center;
      text-align: center;
    }
    .isplit__text-wrap,
    .isplit--image-left .isplit__text-wrap {
      max-width: none;
      padding-right: 0;
      padding-left: 0;
      text-align: center;
    }
    .isplit__eyebrow,
    .isplit__heading,
    .isplit__body-wrap :global(.isplit__body),
    .isplit__link { text-align: center; }
    .isplit__side-label { display: none; }
  }
</style>
