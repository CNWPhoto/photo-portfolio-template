---
import SanityImage from '../SanityImage.astro';
import ImagePlaceholder from '../ImagePlaceholder.astro';
import { paletteToStyle } from '../../lib/palette.js';
import { stegaClean } from '@sanity/client/stega';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, isFirst = false, palette } = Astro.props;
const style = paletteToStyle(palette);

// Empty gallery → six palette placeholders (never stock photos — P1 #8).
// Varied aspect ratios keep masonry/carousel layouts looking deliberate.
const PLACEHOLDER_RATIOS = ['1/1', '4/5', '3/2', '4/5', '1/1', '3/2'];

const eyebrow = section?.eyebrow || '';
const heading = section?.heading || '';
// Stega-clean control fields that drive class names and JS comparisons —
// invisible preview markers would silently break `layout === 'carousel'`
// and similar branches.
const layout = stegaClean(section?.layout) || 'grid-3';
const gap = stegaClean(section?.gap) || 'normal';
const carouselHeight = stegaClean(section?.carouselHeight) || 'standard';
const lightbox = section?.lightbox !== false;
const images = section?.images || [];
const useFallback = images.length === 0;
const itemList: any[] = useFallback ? PLACEHOLDER_RATIOS.map((ratio) => ({ _fallback: true, ratio })) : images;

// Masonry mode uses round-robin distribution across N flex columns
// (same approach as the /portfolio gallery). CSS Grid + grid-auto-flow
// either crops to uniform rows or leaves empty cells on small galleries —
// per-column flex containers give true variable-aspect masonry AND
// guaranteed even distribution across all columns.
const isMasonry = layout === 'masonry';
const isCarousel = layout === 'carousel';
const masonryCols = 3;
const effectiveCols = isMasonry
  ? Math.max(1, Math.min(masonryCols, itemList.length || 1))
  : 0;
const buckets: any[][] = isMasonry
  ? Array.from({ length: effectiveCols }, () => [])
  : [];
if (isMasonry) {
  itemList.forEach((item, i) => buckets[i % effectiveCols].push(item));
}

// Carousel gap in pixels — keyed off the same Tight/Normal/Loose field
// used by grid + masonry, so editors only learn one spacing knob. Read by
// the slider script via data-carousel-gap to compute per-image offsets.
const CAROUSEL_GAP_PX: Record<string, number> = { tight: 8, normal: 16, loose: 28 };
const carouselGapPx = CAROUSEL_GAP_PX[gap] ?? CAROUSEL_GAP_PX.normal;

const HeadingTag = isFirst ? 'h1' : 'h2';
---

<section
  class:list={[
    'section',
    'gallery',
    `gallery--${layout}`,
    `gallery--gap-${gap}`,
    isCarousel && `gallery--carousel-height-${carouselHeight}`,
  ]}
  data-section-type="galleryGridSection"
  data-spacing={section?.spacing || 'normal'}
  data-lightbox={!isCarousel && lightbox ? 'true' : 'false'}
  id={section?.sectionId || undefined}
  style={style}
>
  <div class="gallery__inner">
    {(eyebrow || heading) && (
      <div class="gallery__head">
        {eyebrow && <p class="gallery__eyebrow">{eyebrow}</p>}
        {heading && <HeadingTag class="gallery__heading">{heading}</HeadingTag>}
      </div>
    )}

    {isCarousel ? (
      <div class="gallery__carousel-viewport">
        <div
          class="gallery__carousel-track"
          data-gallery-carousel-track
          data-carousel-gap={carouselGapPx}
          style={`gap: ${carouselGapPx}px`}
        >
          {useFallback
            ? PLACEHOLDER_RATIOS.map((ratio) => (
                <ImagePlaceholder class="gallery__carousel-img" aspectRatio={ratio} size="h" />
              ))
            : images.map((img: any, i: number) => (
                <SanityImage
                  image={img}
                  sizes="60vw"
                  loading={i === 0 && isFirst ? 'eager' : 'lazy'}
                  class="gallery__carousel-img"
                />
              ))
          }
        </div>

        <button
          class="gallery__carousel-arrow gallery__carousel-arrow--prev"
          data-gallery-carousel-prev
          aria-label="Previous image"
        >&#8249;</button>
        <button
          class="gallery__carousel-arrow gallery__carousel-arrow--next"
          data-gallery-carousel-next
          aria-label="Next image"
        >&#8250;</button>
      </div>
    ) : (
      <div class="gallery__grid" style={isMasonry ? `--gallery-columns: ${effectiveCols}` : undefined}>
        {isMasonry
          ? buckets.map((bucket) => (
              <div class="gallery__col">
                {bucket.map((item: any) => (
                  item._fallback
                    ? <figure class="gallery__item">
                        <div class="gallery__item-inner">
                          <ImagePlaceholder class="gallery__img" aspectRatio={item.ratio} size="w" />
                        </div>
                      </figure>
                    : <figure class="gallery__item">
                        <div class="gallery__item-inner">
                          <SanityImage
                            image={item}
                            sizes="(max-width:900px) 100vw, 33vw"
                            loading="lazy"
                            class="gallery__img"
                          />
                        </div>
                        {item?.caption && <figcaption class="gallery__caption">{item.caption}</figcaption>}
                      </figure>
                ))}
              </div>
            ))
          : useFallback
            ? PLACEHOLDER_RATIOS.map(() => (
                <figure class="gallery__item">
                  <div class="gallery__item-inner">
                    <ImagePlaceholder class="gallery__img" />
                  </div>
                </figure>
              ))
            : images.map((img: any, i: number) => (
                <figure class="gallery__item">
                  <div class="gallery__item-inner">
                    <SanityImage
                      image={img}
                      sizes="(max-width:900px) 100vw, 33vw"
                      loading={i === 0 && isFirst ? 'eager' : 'lazy'}
                      class="gallery__img"
                    />
                  </div>
                  {img?.caption && <figcaption class="gallery__caption">{img.caption}</figcaption>}
                </figure>
              ))
        }
      </div>
    )}
  </div>
</section>

<style>
  .gallery {
    background: var(--bg);
    color: var(--text);
  }
  .gallery__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding-inline: 1.5rem;
  }
  .gallery__head { text-align: center; margin-bottom: 2.5rem; }
  .gallery__eyebrow {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.85rem;
  }
  .gallery__heading {
    font-size: clamp(1.85rem, 3.5vw, 2.85rem);
    line-height: 1.2;
    color: var(--text);
    margin: 0;
  }

  .gallery__grid {
    display: grid;
  }
  .gallery--grid-2 .gallery__grid { grid-template-columns: repeat(2, 1fr); }
  .gallery--grid-3 .gallery__grid { grid-template-columns: repeat(3, 1fr); }
  .gallery--grid-4 .gallery__grid { grid-template-columns: repeat(4, 1fr); }

  /* Masonry overrides the grid display entirely — flex row of column
     stacks, so each column flows top-to-bottom at natural aspect ratios
     without uniform row heights or empty trailing cells. */
  .gallery--masonry .gallery__grid {
    display: flex;
    align-items: flex-start;
  }
  /* The column divs are recreated by the redistribute script on resize,
     so they don't carry Astro's scope attribute. Gap-related styles
     therefore live on the items (which ARE scoped and merely re-parented
     between columns) — see the .gallery--masonry .gallery__item rules
     below. The column itself only needs layout primitives. */
  .gallery--masonry .gallery__col {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .gallery--gap-tight .gallery__grid { gap: 0.5rem; }
  .gallery--gap-normal .gallery__grid { gap: 1rem; }
  .gallery--gap-loose .gallery__grid { gap: 1.75rem; }

  /* Vertical spacing between stacked items in masonry columns. Lives on
     the items (preserved by the redistribute script) rather than the
     column container (which is unscoped after the script runs). */
  .gallery--masonry.gallery--gap-tight  .gallery__item { margin-bottom: 0.5rem; }
  .gallery--masonry.gallery--gap-normal .gallery__item { margin-bottom: 1rem; }
  .gallery--masonry.gallery--gap-loose  .gallery__item { margin-bottom: 1.75rem; }
  .gallery--masonry .gallery__item:last-child { margin-bottom: 0; }

  .gallery__item { margin: 0; }
  .gallery__item-inner {
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }
  .gallery--masonry .gallery__item-inner { aspect-ratio: auto; }

  .gallery__item-inner :global(.gallery__img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-image);
  }
  .gallery__item-inner:hover :global(.gallery__img) { transform: scale(1.04); }

  .gallery__caption {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .gallery--grid-3 .gallery__grid,
    .gallery--grid-4 .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .gallery--grid-2 .gallery__grid,
    .gallery--grid-3 .gallery__grid,
    .gallery--grid-4 .gallery__grid {
      grid-template-columns: 1fr;
    }
  }

  /* ══════════ Carousel variant ══════════
     Mechanics ported from HeroSection's slider: viewport clips, track is a
     flex row of auto-width images at a fixed height, clones are prepended
     and appended at runtime so the loop is seamless. Gap comes from the
     editor's Tight/Normal/Loose field, applied inline and read back by the
     script for offset math. Two height options match the schema: standard
     (480px) and tall (640px). */
  .gallery--carousel .gallery__inner {
    max-width: none;
    padding-inline: 0;
  }
  .gallery--carousel .gallery__head {
    max-width: 1400px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .gallery__carousel-viewport {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .gallery--carousel-height-standard .gallery__carousel-viewport {
    height: 480px;
  }
  .gallery--carousel-height-tall .gallery__carousel-viewport {
    height: 640px;
  }

  .gallery__carousel-track {
    display: flex;
    /* gap is set inline from carouselGapPx so the script can read the
       same value via dataset and compute precise per-image offsets. */
    height: 100%;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .gallery__carousel-track :global(.gallery__carousel-img) {
    height: 100%;
    width: auto;
    flex-shrink: 0;
    display: block;
    max-width: unset;
    object-fit: unset;
  }

  .gallery__carousel-arrow {
    position: absolute;
    top: calc(50% - 24px);
    z-index: 10;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.32);
    border: none;
    color: var(--white, #fff);
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    user-select: none;
    transition: background 0.2s;
  }
  .gallery__carousel-arrow:hover { background: rgba(0, 0, 0, 0.55); }
  .gallery__carousel-arrow--prev { left: 1.25rem; }
  .gallery__carousel-arrow--next { right: 1.25rem; }

  /* Carousel keeps its desktop height on mobile-ish viewports, but trim a
     bit so the tall variant doesn't dominate small screens. */
  @media (max-width: 900px) {
    .gallery--carousel-height-standard .gallery__carousel-viewport { height: 360px; }
    .gallery--carousel-height-tall .gallery__carousel-viewport { height: 480px; }
    .gallery--carousel .gallery__head { padding-inline: 1.25rem; }
  }
</style>

<script>
  // Masonry galleries need responsive redistribution: 3 cols on desktop,
  // 2 on tablet, 1 on mobile. Re-buckets the .gallery__item nodes into
  // the right number of .gallery__col containers on load and resize.
  document.querySelectorAll<HTMLElement>('.gallery--masonry .gallery__grid').forEach((grid) => {
    const items = Array.from(grid.querySelectorAll<HTMLElement>('.gallery__item'));
    const itemCount = items.length;
    if (!itemCount) return;

    // Template for JS-created columns. document.createElement('div') +
    // className loses Astro's scoped-style attribute (data-astro-cid-*),
    // so the scoped .gallery__col rules (flex sizing, column direction)
    // silently don't apply to re-bucketed columns. cloneNode(false) copies
    // the server-rendered element with ALL its attributes and no children.
    // (Same fix as GalleryGrid.astro / the /portfolio masonry.)
    const colTemplate = grid.querySelector<HTMLElement>('.gallery__col');

    function targetCols() {
      const w = window.innerWidth;
      if (w <= 560) return 1;
      if (w <= 900) return Math.min(2, itemCount);
      return Math.min(3, itemCount);
    }

    function redistribute(cols: number) {
      grid.innerHTML = '';
      const colEls = Array.from({ length: cols }, () => {
        const el = (colTemplate ? colTemplate.cloneNode(false) : document.createElement('div')) as HTMLElement;
        el.className = 'gallery__col';
        grid.appendChild(el);
        return el;
      });
      items.forEach((item, i) => colEls[i % cols].appendChild(item));
      grid.style.setProperty('--gallery-columns', String(cols));
    }

    let currentCols = -1;
    function maybeRedistribute() {
      const next = targetCols();
      if (next !== currentCols) { currentCols = next; redistribute(next); }
    }
    maybeRedistribute();

    let timer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(timer);
      timer = setTimeout(maybeRedistribute, 100);
    });
  });

  // ── Gallery carousel ────────────────────────────────────────────────
  // Mechanics ported verbatim from HeroSection's slider. Two differences:
  //   1. Gap is dynamic (read from track.dataset.carouselGap) instead of a
  //      hardcoded 15px, so editors' Tight/Normal/Loose choice is honored.
  //   2. Selector uses `data-gallery-carousel-track` to avoid colliding
  //      with the hero on pages that contain both.
  document.querySelectorAll<HTMLElement>('[data-gallery-carousel-track]').forEach((track) => {
    const viewport = track.parentElement as HTMLElement;
    const section = track.closest('section') as HTMLElement;
    const prevBtn = section.querySelector('[data-gallery-carousel-prev]') as HTMLButtonElement | null;
    const nextBtn = section.querySelector('[data-gallery-carousel-next]') as HTMLButtonElement | null;
    const trackGap = parseInt(track.dataset.carouselGap || '15', 10);

    const NUM_CLONE = 2;
    // Placeholders (.img-ph) are divs, not imgs — the slider math only needs
    // offsetWidth, so both participate.
    const realImgs = Array.from(track.querySelectorAll('img, .img-ph')) as HTMLElement[];
    const NUM_REAL = realImgs.length;
    if (NUM_REAL < 2) return;

    const clonesBefore = realImgs.slice(-NUM_CLONE).map((img) => img.cloneNode(true) as HTMLElement);
    const clonesAfter = realImgs.slice(0, NUM_CLONE).map((img) => img.cloneNode(true) as HTMLElement);
    clonesBefore.reverse().forEach((cl) => track.prepend(cl));
    clonesAfter.forEach((cl) => track.append(cl));

    const imgs = Array.from(track.querySelectorAll('img, .img-ph')) as HTMLElement[];
    let current = NUM_CLONE;

    const imageLeft = (i: number) => {
      let left = 0;
      for (let j = 0; j < i; j++) left += imgs[j].offsetWidth + trackGap;
      return left;
    };
    const centerOffset = (i: number) =>
      imageLeft(i) + imgs[i].offsetWidth / 2 - viewport.offsetWidth / 2;

    const goTo = (i: number) => {
      current = i;
      track.style.transition = '';
      track.style.transform = `translateX(${-centerOffset(current)}px)`;
    };
    const silentGoTo = (i: number) => {
      current = i;
      track.style.transition = 'none';
      track.style.transform = `translateX(${-centerOffset(current)}px)`;
      track.getBoundingClientRect();
      track.style.transition = '';
    };
    const advance = (dir: number) => {
      current += dir;
      track.style.transition = 'transform 0.5s ease';
      track.style.transform = `translateX(${-centerOffset(current)}px)`;
    };

    track.addEventListener('transitionend', () => {
      if (current >= NUM_CLONE + NUM_REAL) silentGoTo(current - NUM_REAL);
      else if (current < NUM_CLONE) silentGoTo(current + NUM_REAL);
    });

    prevBtn?.addEventListener('click', () => advance(-1));
    nextBtn?.addEventListener('click', () => advance(1));

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => goTo(current), 100);
    });
    window.addEventListener('load', () => goTo(NUM_CLONE));
    goTo(NUM_CLONE);
  });
</script>
