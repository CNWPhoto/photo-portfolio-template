---
import { paletteToStyle } from '../../lib/palette.js';
import { renderBody } from '../../lib/portableText.js';
import { resolveLink } from '../../lib/links.js';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, isFirst = false, palette } = Astro.props;
const style = paletteToStyle(palette);

const eyebrow = section?.eyebrow || '';
const heading = section?.heading || '';
const bodyHTML = renderBody(section?.body, { className: 'richtext__p' });
const textAlign = section?.textAlignment || 'left';
const maxWidth = section?.maxWidth || 'default';
const ctaText = section?.ctaText || '';
const ctaHref = resolveLink(section?.ctaLink, [Astro.url.hostname]);

const HeadingTag = isFirst ? 'h1' : 'h2';
---

<section
  class:list={['section', 'richtext', `richtext--mw-${maxWidth}`]}
  data-section-type="richTextSection"
  data-spacing={section?.spacing || 'normal'}
  data-text-align={textAlign}
  id={section?.sectionId || undefined}
  style={style}
>
  <div class="richtext__wrap">
    {eyebrow && <p class="richtext__eyebrow reveal reveal-delay-1">{eyebrow}</p>}
    {heading && <HeadingTag class="richtext__heading">{heading}</HeadingTag>}
    {bodyHTML && <div class="richtext__body reveal reveal-delay-2" set:html={bodyHTML} />}
    {ctaText && ctaHref && (
      <div class="richtext__footer reveal reveal-delay-3">
        <a class="richtext__cta" href={ctaHref}>{ctaText}</a>
      </div>
    )}
  </div>
</section>

<style>
  .richtext {
    background: var(--bg);
    color: var(--text);
  }
  .richtext__wrap {
    margin: 0 auto;
    padding-inline: 1.5rem;
  }
  .richtext--mw-narrow .richtext__wrap { max-width: 600px; }
  .richtext--mw-default .richtext__wrap { max-width: 760px; }
  .richtext--mw-wide .richtext__wrap { max-width: 1100px; }

  .richtext[data-text-align='center'] .richtext__wrap { text-align: center; }

  .richtext__eyebrow {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1rem;
  }
  .richtext__heading {
    font-size: clamp(1.85rem, 3.5vw, 2.85rem);
    line-height: 1.2;
    color: var(--text);
    margin: 0 0 1.5rem;
  }
  .richtext__body :global(p),
  .richtext__body :global(.richtext__p) {
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 1.25rem;
  }
  .richtext__body :global(h2) {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin: 2.25rem 0 1rem;
  }
  .richtext__body :global(h3) {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    margin: 1.75rem 0 0.75rem;
  }
  .richtext__body :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--muted);
  }
  .richtext__body :global(ul),
  .richtext__body :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .richtext__body :global(li) {
    line-height: 1.7;
    margin: 0.4rem 0;
  }
  .richtext__body :global(a) {
    color: var(--accent);
    text-decoration: underline;
  }

  /* Optional rectangular button. Mirrors .ctaband__cta — same palette
     variables, same metrics — and inherits the global lift-on-hover
     transition from Layout.astro's [class*="__cta"]:hover rule.
     Wrapper avoids the __cta / __btn / __button substrings: the global
     interaction rule uses [class*="__cta"] etc, which would match a
     wrapper named `__cta-wrap` and cause the entire wrapper width to
     lift on hover instead of just the button itself. */
  .richtext__footer {
    margin-top: 2rem;
  }
  .richtext[data-text-align='center'] .richtext__footer { text-align: center; }

  .richtext__cta {
    display: inline-block;
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--btn-text);
    background: var(--btn-bg);
    padding: 1rem 2.25rem;
    white-space: nowrap;
  }
</style>
