---
import SanityImage from '../SanityImage.astro';
import { paletteToStyle } from '../../lib/palette.js';
import { resolveLink } from '../../lib/links.js';
import { stegaClean } from '@sanity/client/stega';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, isFirst = false, palette } = Astro.props;
const style = paletteToStyle(palette);

// Control fields used in class names, CSS attribute selectors, and JS
// equality checks must be stega-cleaned — the preview client injects
// invisible Unicode markers into every string, which silently break
// `variant === 'image-full'` comparisons and `[data-text-position='top-right']`
// selectors. Content fields (heading, subheading, eyebrow, ctaText) keep
// their markers so visual-editing overlays still work.
const variant = stegaClean(section?.variant) || 'slider';
const eyebrow = section?.eyebrow || '';
const heading = section?.heading || '';
const subheading = section?.subheading || '';
const ctaText = section?.ctaText || '';
const ctaHref = stegaClean(resolveLink(section?.ctaLink));
const heightMode = stegaClean(section?.heightMode) || 'auto';
const stickyBackground = !!section?.stickyBackground;
const overlayOpacity = (section?.overlayOpacity ?? 30) / 100;
const textPosition = stegaClean(section?.textPosition) || 'center-center';
const textAlignment = stegaClean(section?.textAlignment) || 'center';

const FALLBACK_HERO_IDS = ['1108099', '2253275', '825949', '1805164', '3726314'];
const pexelsUrl = (id: string, w = 1600) =>
  `https://images.pexels.com/photos/${id}/pexels-photo-${id}.jpeg?auto=compress&cs=tinysrgb&w=${w}`;

const sanityImages = section?.images ?? [];
const useFallback = sanityImages.length === 0;
const firstImage = sanityImages[0] ?? null;
---

<section
  class:list={['hero', `hero--${variant}`, `hero--height-${heightMode}`, stickyBackground && 'hero--sticky']}
  data-section-type="heroSection"
  data-text-align={textAlignment}
  data-text-position={textPosition}
  id={stegaClean(section?.sectionId) || undefined}
  style={style}
>
  {variant === 'slider' && (
    <>
      <div class="hero__viewport">
        <div class="hero__track" data-hero-track>
          {useFallback
            ? FALLBACK_HERO_IDS.map((id, i) => (
                <img
                  src={pexelsUrl(id)}
                  alt=""
                  loading={i === 0 && isFirst ? 'eager' : 'lazy'}
                  fetchpriority={i === 0 && isFirst ? 'high' : undefined}
                  class="hero__img"
                />
              ))
            : sanityImages.map((img: any, i: number) => (
                <SanityImage
                  image={img}
                  sizes="100vw"
                  loading={i === 0 && isFirst ? 'eager' : 'lazy'}
                  class="hero__img"
                />
              ))
          }
        </div>

        <button class="hero__arrow hero__arrow--prev" data-hero-prev aria-label="Previous image">
          &#8249;
        </button>
        <button class="hero__arrow hero__arrow--next" data-hero-next aria-label="Next image">
          &#8250;
        </button>
      </div>

      {(eyebrow || heading || subheading) && (
        <div class="hero__caption">
          {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
          {heading && <h1 class="hero__heading">{heading}</h1>}
          {subheading && <p class="hero__sub">{subheading}</p>}
          {ctaText && ctaHref && (
            <a class="hero__cta" href={ctaHref}>{ctaText}</a>
          )}
        </div>
      )}
    </>
  )}

  {variant === 'image-full' && (
    <div class="hero__bg">
      {firstImage
        ? <SanityImage image={firstImage} sizes="100vw" loading={isFirst ? 'eager' : 'lazy'} class="hero__bg-img" />
        : <img src={pexelsUrl(FALLBACK_HERO_IDS[0], 2000)} alt="" loading={isFirst ? 'eager' : 'lazy'} class="hero__bg-img" />}
      <div class="hero__bg-overlay" style={`background:rgba(0,0,0,${overlayOpacity})`} aria-hidden="true"></div>
      {(eyebrow || heading || subheading || ctaText) && (
        <div class="hero__overlay-content">
          {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
          {heading && <h1 class="hero__heading hero__heading--overlay">{heading}</h1>}
          {subheading && <p class="hero__sub hero__sub--overlay">{subheading}</p>}
          {ctaText && ctaHref && <a class="hero__cta" href={ctaHref}>{ctaText}</a>}
        </div>
      )}
    </div>
  )}

  {variant === 'image-right' && (
    <div class="hero__split">
      <div class="hero__split-content">
        {(eyebrow || heading || subheading || ctaText) && (
          <div class="hero__split-text">
            {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
            {heading && <h1 class="hero__heading">{heading}</h1>}
            {subheading && <p class="hero__sub">{subheading}</p>}
            {ctaText && ctaHref && <a class="hero__cta" href={ctaHref}>{ctaText}</a>}
          </div>
        )}
      </div>
      <div class="hero__split-image">
        {firstImage
          ? <SanityImage image={firstImage} sizes="(max-width:900px) 100vw, 50vw" loading={isFirst ? 'eager' : 'lazy'} class="hero__split-img" />
          : <img src={pexelsUrl(FALLBACK_HERO_IDS[0])} alt="" loading={isFirst ? 'eager' : 'lazy'} class="hero__split-img" />}
      </div>
    </div>
  )}
</section>

<style>
  /* ── Reset section padding for the hero (always full-bleed) ── */
  .hero {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    background: var(--bg);
    color: var(--text);
  }

  .hero--sticky {
    position: sticky;
    top: 0;
    z-index: 0;
    height: 75vh;
  }

  /* ══════════ Slider variant — ported verbatim from legacy Hero.astro ══════════ */
  .hero--slider .hero__viewport {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
  }
  .hero--slider.hero--height-tall .hero__viewport {
    height: 75vh;
    min-height: 480px;
  }
  .hero--slider.hero--height-fullscreen .hero__viewport {
    height: 100vh;
    min-height: 560px;
  }

  .hero__track {
    display: flex;
    gap: 15px;
    height: 100%;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .hero__track :global(.hero__img) {
    height: 100%;
    width: auto;
    flex-shrink: 0;
    display: block;
    max-width: unset;
    object-fit: unset;
  }

  .hero__arrow {
    position: absolute;
    top: calc(50% - 24px);
    z-index: 10;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.32);
    border: none;
    color: var(--white, #fff);
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    user-select: none;
    transition: background 0.2s;
  }
  .hero__arrow:hover { background: rgba(0, 0, 0, 0.55); }
  .hero__arrow--prev { left: 1.25rem; }
  .hero__arrow--next { right: 1.25rem; }

  .hero__caption {
    text-align: center;
    padding: 4rem 2rem 4.5rem;
    border-top: 1px solid var(--border);
  }

  .hero__heading {
    font-size: clamp(2.5rem, 5.5vw, 4.25rem);
    color: var(--text);
    margin: 0 0 1.25rem;
    letter-spacing: -0.01em;
  }

  .hero__sub {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }

  .hero__eyebrow {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1rem;
  }

  .hero__cta {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--btn-text);
    background: var(--btn-bg);
    padding: 0.95rem 2rem;
    border: 1px solid var(--btn-bg);
    transition: background 0.2s, color 0.2s;
  }

  /* ══════════ image-full variant (used on /experience) ══════════ */
  .hero--image-full .hero__bg {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .hero--image-full.hero--height-auto .hero__bg { height: 60vh; min-height: 400px; }
  .hero--image-full.hero--height-tall .hero__bg { height: 75vh; min-height: 480px; }
  .hero--image-full.hero--height-fullscreen .hero__bg { height: 100vh; min-height: 560px; }

  .hero__bg :global(.hero__bg-img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero__bg-overlay { position: absolute; inset: 0; }
  .hero__overlay-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: var(--white, #fff);
    padding: 2rem;
    pointer-events: none;
  }
  .hero__overlay-content .hero__cta { pointer-events: auto; }
  .hero__heading--overlay {
    color: var(--white, #fff);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
    line-height: 1.05;
  }
  .hero__sub--overlay {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.906rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
  }

  /* ── Text position grid (image-full variant) ── */
  .hero--image-full[data-text-position^='top'] .hero__overlay-content { justify-content: flex-start; }
  .hero--image-full[data-text-position^='bottom'] .hero__overlay-content { justify-content: flex-end; }
  .hero--image-full[data-text-position$='-left'] .hero__overlay-content { align-items: flex-start; text-align: left; }
  .hero--image-full[data-text-position$='-right'] .hero__overlay-content { align-items: flex-end; text-align: right; }

  .hero--image-full[data-text-position='top-right'] .hero__overlay-content {
    max-width: 580px;
    margin-left: auto;
    padding: 150px 4rem 4rem 3rem;
  }
  .hero--image-full[data-text-position='top-left'] .hero__overlay-content {
    max-width: 580px;
    margin-right: auto;
    padding: 150px 3rem 4rem 4rem;
  }
  .hero--image-full[data-text-position='bottom-right'] .hero__overlay-content {
    max-width: 560px;
    margin-left: auto;
    padding: 3.5rem 4rem;
  }
  .hero--image-full[data-text-position='bottom-right'] .hero__heading--overlay {
    font-size: clamp(2.875rem, 6.9vw, 5.75rem);
    font-weight: 600;
  }
  .hero--image-full[data-text-position='bottom-left'] .hero__overlay-content {
    max-width: 560px;
    margin-right: auto;
    padding: 3.5rem 4rem;
  }

  /* ── Gradient overlay — darkens toward text side ── */
  .hero--image-full[data-text-position$='-right']:not([data-text-position^='bottom']) .hero__bg-overlay {
    background: linear-gradient(to right, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.6) 100%) !important;
  }
  .hero--image-full[data-text-position$='-left']:not([data-text-position^='bottom']) .hero__bg-overlay {
    background: linear-gradient(to left, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.6) 100%) !important;
  }

  /* ══════════ image-right variant ══════════ */
  .hero--image-right .hero__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 60vh;
  }
  .hero--image-right .hero__split-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem;
    background: var(--bg-alt);
  }
  .hero--image-right .hero__split-image { overflow: hidden; }
  .hero--image-right .hero__split-image :global(.hero__split-img) {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  @media (max-width: 900px) {
    .hero__caption { padding: 3rem 1.25rem 3.5rem; }
    .hero--image-right .hero__split { grid-template-columns: 1fr; }
    .hero--image-right .hero__split-image { height: 60vw; min-height: 280px; }

    .hero--image-full[data-text-position='top-right'] .hero__overlay-content,
    .hero--image-full[data-text-position='top-left'] .hero__overlay-content {
      max-width: none;
      padding: 80px 1.5rem 2rem;
      text-align: left;
      align-items: flex-start;
    }
    .hero--image-full[data-text-position='bottom-right'] .hero__overlay-content,
    .hero--image-full[data-text-position='bottom-left'] .hero__overlay-content {
      max-width: none;
      padding: 2rem 1.5rem;
      text-align: left;
      align-items: flex-start;
    }
    .hero--image-full[data-text-position$='-right'] .hero__bg-overlay,
    .hero--image-full[data-text-position$='-left'] .hero__bg-overlay {
      background: rgba(0, 0, 0, 0.48) !important;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-hero-track]').forEach((trackEl) => {
    const track = trackEl as HTMLElement;
    const viewport = track.parentElement as HTMLElement;
    const section = track.closest('section') as HTMLElement;
    const prevBtn = section.querySelector('[data-hero-prev]') as HTMLButtonElement | null;
    const nextBtn = section.querySelector('[data-hero-next]') as HTMLButtonElement | null;

    const NUM_CLONE = 2;
    const realImgs = Array.from(track.querySelectorAll('img')) as HTMLImageElement[];
    const NUM_REAL = realImgs.length;
    if (NUM_REAL < 2) return;

    const clonesBefore = realImgs.slice(-NUM_CLONE).map((img) => img.cloneNode(true) as HTMLImageElement);
    const clonesAfter = realImgs.slice(0, NUM_CLONE).map((img) => img.cloneNode(true) as HTMLImageElement);
    clonesBefore.reverse().forEach((cl) => track.prepend(cl));
    clonesAfter.forEach((cl) => track.append(cl));

    const imgs = Array.from(track.querySelectorAll('img')) as HTMLImageElement[];
    let current = NUM_CLONE;

    const imageLeft = (i: number) => {
      let left = 0;
      for (let j = 0; j < i; j++) left += imgs[j].offsetWidth + 15;
      return left;
    };
    const centerOffset = (i: number) =>
      imageLeft(i) + imgs[i].offsetWidth / 2 - viewport.offsetWidth / 2;

    const goTo = (i: number) => {
      current = i;
      track.style.transition = '';
      track.style.transform = `translateX(${-centerOffset(current)}px)`;
    };
    const silentGoTo = (i: number) => {
      current = i;
      track.style.transition = 'none';
      track.style.transform = `translateX(${-centerOffset(current)}px)`;
      track.getBoundingClientRect();
      track.style.transition = '';
    };
    const advance = (dir: number) => {
      current += dir;
      track.style.transition = 'transform 0.5s ease';
      track.style.transform = `translateX(${-centerOffset(current)}px)`;
    };

    track.addEventListener('transitionend', () => {
      if (current >= NUM_CLONE + NUM_REAL) silentGoTo(current - NUM_REAL);
      else if (current < NUM_CLONE) silentGoTo(current + NUM_REAL);
    });

    prevBtn?.addEventListener('click', () => advance(-1));
    nextBtn?.addEventListener('click', () => advance(1));

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => goTo(current), 100);
    });
    window.addEventListener('load', () => goTo(NUM_CLONE));
    goTo(NUM_CLONE);
  });
</script>
