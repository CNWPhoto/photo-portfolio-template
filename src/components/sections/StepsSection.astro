---
import { paletteToStyle } from '../../lib/palette.js';
import { resolveLink } from '../../lib/links.js';
import { renderBody, isPortableText } from '../../lib/portableText.js';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, palette } = Astro.props;
const style = paletteToStyle(palette);

const eyebrow = section?.eyebrow || '';
const heading = section?.heading || '';
const ctaText = section?.ctaText || '';
const ctaHref = resolveLink(section?.ctaLink, [Astro.url.hostname]);
const steps = section?.steps || [];

// Render each step body once
const stepsRendered = steps.map((step: any, i: number) => ({
  number: step?.stepNumber || String(i + 1).padStart(2, '0'),
  title: step?.title || '',
  bodyHTML: isPortableText(step?.body) ? renderBody(step.body, { className: 'hcols__step-body' }) : '',
}));
---

<section
  class="hcols"
  data-section-type="stepsSection"
  id={section?.sectionId || 'how-it-works'}
  style={style}
>
  <hr />
  <div class="hcols__inner">
    <div class="hcols__header">
      {heading && <h2 class="hcols__heading">{heading}</h2>}
      {eyebrow && <p class="hcols__sub">{eyebrow}</p>}
    </div>

    <div class="hcols__steps">
      {stepsRendered.map((step) => (
        <div class="hcols__step">
          <div class="hcols__step-rule" />
          <p class="hcols__step-num">{step.number}</p>
          <h3 class="hcols__step-label">{step.title}</h3>
          {step.bodyHTML && <div class="hcols__step-body-wrap" set:html={step.bodyHTML} />}
        </div>
      ))}
    </div>

    {ctaText && ctaHref && (
      <div class="hcols__footer">
        <a href={ctaHref} class="hcols__link">{ctaText} &rarr;</a>
      </div>
    )}
  </div>
</section>

<style>
  .hcols {
    padding-top: 0 !important;
    padding-bottom: 7rem !important;
    background: var(--bg);
    color: var(--text);
  }

  .hcols__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 3rem;
    text-align: center;
  }

  .hcols__header { padding: 5.5rem 0 4.5rem; }

  .hcols__heading {
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: var(--text);
    margin: 0 0 1.25rem;
    letter-spacing: -0.01em;
  }

  .hcols__sub {
    font-size: 1.0625rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.6;
    margin: 0;
  }

  .hcols__sub em {
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.95em;
    color: var(--accent);
  }

  .hcols__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    text-align: left;
  }

  .hcols__step { padding-top: 2rem; }

  .hcols__step-rule {
    width: 100%;
    height: 1px;
    background: var(--border);
    margin-bottom: 1.75rem;
  }

  .hcols__step-num {
    font-family: var(--font-sans, var(--font-body));
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .hcols__step-label {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text);
    margin: 0 0 1.25rem;
    font-weight: 600;
  }

  .hcols__step-body-wrap :global(.hcols__step-body),
  .hcols__step-body-wrap :global(p) {
    font-style: normal;
    font-size: 0.9375rem;
    line-height: 1.78;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .hcols__footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    text-align: right;
  }

  .hcols__link {
    font-style: italic;
    font-size: 1rem;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .hcols__link:hover { opacity: 0.7; }

  @media (max-width: 768px) {
    .hcols__inner { padding: 0 1.5rem; }
    .hcols__steps { grid-template-columns: 1fr; gap: 2rem; }
    .hcols__footer { text-align: center; }
  }
</style>
