---
import SanityImage from '../SanityImage.astro';
import { paletteToStyle } from '../../lib/palette.js';
import { resolveLink } from '../../lib/links.js';
import { renderBody } from '../../lib/portableText.js';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, isFirst = false, palette } = Astro.props;
const style = paletteToStyle(palette);

const eyebrow = section?.eyebrow || '';
const heading = section?.heading || '';
const variant = section?.variant || 'stacked';
const steps = section?.steps || [];
const ctaText = section?.ctaText || '';
const ctaHref = resolveLink(section?.ctaLink);

const HeadingTag = isFirst ? 'h1' : 'h2';
---

<section
  class:list={['section', 'steps', `steps--${variant}`]}
  data-section-type="stepsSection"
  data-spacing={section?.spacing || 'normal'}
  id={section?.sectionId || undefined}
  style={style}
>
  <div class="steps__inner">
    {(eyebrow || heading) && (
      <div class="steps__head">
        {eyebrow && <p class="steps__eyebrow">{eyebrow}</p>}
        {heading && <HeadingTag class="steps__heading">{heading}</HeadingTag>}
      </div>
    )}

    <ol class="steps__list">
      {steps.map((step: any, i: number) => {
        const stepNumber = step?.stepNumber || String(i + 1).padStart(2, '0');
        const stepBody = renderBody(step?.body, { className: 'steps__body' });
        const delayClass = `reveal-delay-${Math.min(i + 1, 5)}`;
        return (
          <li class:list={['steps__item', 'reveal', delayClass]}>
            <div class="steps__num" aria-hidden="true">{stepNumber}</div>
            <div class="steps__content">
              {step?.title && <h3 class="steps__title">{step.title}</h3>}
              {stepBody && <div class="steps__body-wrap" set:html={stepBody} />}
            </div>
          </li>
        );
      })}
    </ol>

    {ctaText && ctaHref && (
      <div class="steps__cta-wrap reveal reveal-delay-3">
        <a class="steps__cta" href={ctaHref}>{ctaText}</a>
      </div>
    )}
  </div>
</section>

<style>
  .steps {
    background: var(--bg);
    color: var(--text);
  }
  .steps__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding-inline: 1.5rem;
  }
  .steps__head { text-align: center; margin-bottom: 3rem; }
  .steps__eyebrow {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.85rem;
  }
  .steps__heading {
    font-size: clamp(1.85rem, 3.5vw, 2.85rem);
    line-height: 1.2;
    color: var(--text);
    margin: 0;
  }

  .steps__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ── Stacked variant ── */
  .steps--stacked .steps__list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .steps--stacked .steps__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  /* ── Timeline variant ── */
  .steps--timeline .steps__list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    border-left: 2px solid var(--accent);
    padding-left: 2rem;
    margin-left: 1rem;
  }
  .steps--timeline .steps__item { position: relative; }
  .steps--timeline .steps__num {
    position: absolute;
    left: -3.5rem;
    top: 0;
  }

  /* ── Horizontal cards variant ── */
  .steps--horizontal-cards .steps__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .steps--horizontal-cards .steps__item {
    background: var(--bg-alt);
    padding: 2rem 1.75rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .steps__num {
    font-family: var(--font-heading, var(--font-serif));
    font-style: italic;
    font-size: 2.5rem;
    line-height: 1;
    color: var(--accent);
  }
  .steps__title {
    font-size: 1.35rem;
    line-height: 1.3;
    color: var(--text);
    margin: 0 0 0.75rem;
  }
  .steps__body-wrap :global(.steps__body),
  .steps__body-wrap :global(p) {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--muted);
    margin: 0 0 0.6rem;
  }

  .steps__cta-wrap { margin-top: 3rem; text-align: center; }
  .steps__cta {
    display: inline-block;
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--btn-text);
    background: var(--btn-bg);
    padding: 0.95rem 2rem;
  }

  @media (max-width: 900px) {
    .steps--horizontal-cards .steps__list { grid-template-columns: 1fr; }
  }
</style>
