---
import { paletteToStyle } from '../../lib/palette.js';
import { getClient } from '../../lib/sanity.js';
import { buildSrc, buildSrcset } from '../../lib/image';
import { stegaClean } from '@sanity/client/stega';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, palette } = Astro.props;
const style = paletteToStyle(palette);

// stegaClean on layout so equality checks survive preview-mode markers
const layout = stegaClean(section?.layout) || 'image-slider';
const source = section?.source || 'all';
const maxCount = section?.maxCount || 12;

let raw: any[] = [];
if (source === 'pickSpecific' && section?.testimonials?.length) {
  raw = section.testimonials;
} else {
  const client = getClient(Astro.locals.isPreview);
  raw = await client.fetch(
    `*[_type == "testimonial"] | order(order asc)[0...$max]{
      _id, testimonial, client, starRating, source, sourceUrl, reviewDate,
      image { ..., asset->{ _id, metadata { dimensions { width, height } } } }
    }`,
    { max: maxCount },
  );
}
raw = raw || [];

// Source labels for the "via [Platform]" badge. stegaClean before lookup so
// preview-mode invisible markers don't break the equality check.
const SOURCE_LABELS: Record<string, string> = {
  google: 'Google',
  facebook: 'Facebook',
  yelp: 'Yelp',
  other: 'Online review',
};

function formatReviewDate(d?: string): string {
  if (!d) return '';
  // d is ISO yyyy-mm-dd from Sanity's date type. Parse as UTC to avoid
  // timezone drift pushing it to the previous month.
  const [y, m] = d.split('-');
  if (!y || !m) return '';
  const dt = new Date(Date.UTC(Number(y), Number(m) - 1, 1));
  return dt.toLocaleDateString('en-US', {month: 'long', year: 'numeric', timeZone: 'UTC'});
}

const testimonials = raw.map((t: any) => {
  const src = stegaClean(t?.source) || 'direct';
  const sourceLabel = src !== 'direct' ? SOURCE_LABELS[src] || '' : '';
  const dateLabel = formatReviewDate(t?.reviewDate);
  return {
    image: t?.image ?? null,
    photoSrc: t?.image ? buildSrc(t.image, 800) : '',
    photoSrcset: t?.image ? buildSrcset(t.image, [400, 800, 1200]) : '',
    photoAlt: t?.image?.alt ?? '',
    // stegaClean: these strings get serialized into an inline <script>
    // for the slider AND rendered as text. Uncleaned, the content-source-
    // map watermark (zero-width Unicode) shows as garbage after the quote
    // and client name. Affects every client when CSM is on.
    quote: stegaClean(t?.testimonial) ?? '',
    client: stegaClean(t?.client) ?? '',
    starRating: Number.isFinite(t?.starRating) ? Math.max(0, Math.min(5, t.starRating)) : 0,
    sourceLabel,
    sourceUrl: t?.sourceUrl || '',
    dateLabel,
  };
});

const first = testimonials[0] ?? null;
---

<section
  class:list={['tslider', `tslider--${layout}`]}
  data-section-type="testimonialsSection"
  id={section?.sectionId || 'testimonials'}
  style={style}
>
  {layout === 'two-col-text' ? (
    <div class="tslider__inner tslider__inner--two-col">
      {testimonials.slice(0, 2).map((t, i) => (
        <div class={`tslider__col reveal reveal-delay-${i + 1}`}>
          {t.starRating > 0 && (
            <div class="tslider__stars" aria-label={`${t.starRating} out of 5 stars`}>
              {Array.from({length: 5}).map((_, n) => (
                <span class={n < t.starRating ? 'tslider__star tslider__star--on' : 'tslider__star'} aria-hidden="true">★</span>
              ))}
            </div>
          )}
          <blockquote class="tslider__quote">&ldquo;{t.quote}&rdquo;</blockquote>
          <p class="tslider__attribution">{t.client}</p>
          {t.sourceLabel && (
            <p class="tslider__source">
              via {t.sourceUrl ? (
                <a class="tslider__source-link" href={t.sourceUrl} target="_blank" rel="noopener nofollow">
                  {t.sourceLabel}<span class="tslider__source-arrow" aria-hidden="true">↗</span>
                </a>
              ) : t.sourceLabel}
              {t.dateLabel && <span class="tslider__source-date"> · {t.dateLabel}</span>}
            </p>
          )}
        </div>
      ))}
    </div>
  ) : (
    <div class="tslider__inner">
      <div class="tslider__image-col reveal-fade">
        <div class="tslider__image-wrap" data-tslider-img-wrap>
          {first?.image && (
            <img
              src={first.photoSrc}
              srcset={first.photoSrcset}
              sizes="(max-width: 900px) 30vw, 200px"
              alt={first.photoAlt}
              class="tslider__img"
              loading="lazy"
            />
          )}
        </div>
      </div>

      <div class="tslider__content reveal reveal-delay-2">
        <div
          class="tslider__stars"
          data-tslider-stars
          aria-label={first && first.starRating > 0 ? `${first.starRating} out of 5 stars` : ''}
          hidden={!first || first.starRating === 0}
        >
          {Array.from({length: 5}).map((_, n) => (
            <span class={first && n < first.starRating ? 'tslider__star tslider__star--on' : 'tslider__star'} aria-hidden="true">★</span>
          ))}
        </div>
        <blockquote class="tslider__quote" data-tslider-quote>
          &ldquo;{first?.quote}&rdquo;
        </blockquote>
        <p class="tslider__attribution" data-tslider-client>{first?.client}</p>
        <p
          class="tslider__source"
          data-tslider-source
          hidden={!first?.sourceLabel}
        >
          <span data-tslider-source-prefix>via </span>
          <a
            class="tslider__source-link"
            data-tslider-source-link
            href={first?.sourceUrl || '#'}
            target="_blank"
            rel="noopener nofollow"
            hidden={!first?.sourceUrl}
          >
            <span data-tslider-source-link-label>{first?.sourceLabel}</span><span class="tslider__source-arrow" aria-hidden="true">↗</span>
          </a>
          <span data-tslider-source-plain hidden={!!first?.sourceUrl}>{first?.sourceLabel}</span>
          <span class="tslider__source-date" data-tslider-source-date hidden={!first?.dateLabel}>{first?.dateLabel ? ` · ${first.dateLabel}` : ''}</span>
        </p>

        {testimonials.length > 1 && (
          <div class="tslider__nav">
            <span class="tslider__count">
              <span data-tslider-idx>1</span> / {testimonials.length}
            </span>
            <button class="tslider__arrow" data-tslider-prev aria-label="Previous testimonial">&#8592;</button>
            <button class="tslider__arrow" data-tslider-next aria-label="Next testimonial">&#8594;</button>
          </div>
        )}
      </div>
    </div>
  )}
</section>

<style>
  .tslider {
    padding: 0 !important;
    margin-top: 100px;
    margin-bottom: 100px;
    background: var(--bg);
    color: var(--text);
  }

  .tslider__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 150px;
  }

  .tslider__image-col { flex-shrink: 0; }

  .tslider__image-wrap {
    width: 300px;
    height: 450px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .tslider__image-wrap :global(.tslider__img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: opacity 0.4s ease;
  }

  .tslider__content {
    max-width: 480px;
  }

  .tslider__quote {
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.8;
    color: var(--text);
    margin: 0 0 2rem;
    transition: opacity 0.3s ease;
  }

  .tslider__attribution {
    font-style: normal;
    font-family: var(--font-sans, var(--font-body));
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }

  .tslider__stars {
    display: flex;
    gap: 0.15rem;
    margin: 0 0 1.25rem;
    font-size: 1.05rem;
    line-height: 1;
  }

  .tslider__star {
    color: var(--border);
    transition: color 0.2s ease;
  }
  .tslider__star--on {
    color: var(--text);
  }

  .tslider__source {
    margin: 0.5rem 0 0;
    font-family: var(--font-sans, var(--font-body));
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--muted-light, var(--muted));
  }

  .tslider__source-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: opacity 0.18s ease;
  }
  .tslider__source-link:hover { opacity: 0.7; }

  .tslider__source-arrow {
    display: inline-block;
    margin-left: 0.2em;
    font-size: 0.85em;
    transform: translateY(-1px);
  }

  .tslider__source-date {
    color: inherit;
  }

  .tslider__nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .tslider__count {
    font-family: var(--font-sans, var(--font-body));
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    color: var(--muted-light);
    margin-right: auto;
  }

  .tslider__arrow {
    background: none;
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-sans, var(--font-body));
    font-size: 1rem;
    width: 42px;
    height: 42px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, transform 0.18s;
  }
  .tslider__arrow:hover:not(:disabled) { border-color: var(--text); }
  .tslider__arrow:disabled { opacity: 0.3; cursor: default; }

  /* ── 2-column text-only variant ─────────────────────────────── */
  .tslider__inner--two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .tslider__col {
    max-width: none;
  }

  @media (max-width: 900px) {
    .tslider__inner {
      flex-direction: column;
      align-items: center;
      gap: 2.5rem;
      padding: 0 1.5rem;
    }
    .tslider__image-col { width: 100%; display: flex; justify-content: center; }
    .tslider__image-wrap { width: 80%; height: 90vw; max-height: 500px; }
    .tslider__content { max-width: none; width: 80%; }

    .tslider__inner--two-col {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding: 0 1.5rem;
    }
  }
</style>

<script is:inline define:vars={{ testimonials }}>
  document.querySelectorAll('[data-section-type="testimonialsSection"]').forEach((section) => {
    const imgWrap  = section.querySelector('[data-tslider-img-wrap]');
    const quoteEl  = section.querySelector('[data-tslider-quote]');
    const clientEl = section.querySelector('[data-tslider-client]');
    const starsEl  = section.querySelector('[data-tslider-stars]');
    const sourceEl       = section.querySelector('[data-tslider-source]');
    const sourceLinkEl   = section.querySelector('[data-tslider-source-link]');
    const sourceLabelEl  = section.querySelector('[data-tslider-source-link-label]');
    const sourcePlainEl  = section.querySelector('[data-tslider-source-plain]');
    const sourceDateEl   = section.querySelector('[data-tslider-source-date]');
    const idxEl    = section.querySelector('[data-tslider-idx]');
    const prevBtn  = section.querySelector('[data-tslider-prev]');
    const nextBtn  = section.querySelector('[data-tslider-next]');
    if (!quoteEl || !clientEl) return;

    const data = testimonials;
    if (!data || data.length < 2) return;

    let idx = 0;

    function renderStars(t) {
      if (!starsEl) return;
      const rating = t.starRating || 0;
      if (rating < 1) {
        starsEl.hidden = true;
        return;
      }
      starsEl.hidden = false;
      starsEl.setAttribute('aria-label', rating + ' out of 5 stars');
      const stars = starsEl.querySelectorAll('.tslider__star');
      stars.forEach(function(s, n) {
        s.classList.toggle('tslider__star--on', n < rating);
      });
    }

    function renderSource(t) {
      if (!sourceEl) return;
      if (!t.sourceLabel) {
        sourceEl.hidden = true;
        return;
      }
      sourceEl.hidden = false;
      const hasLink = !!t.sourceUrl;
      if (sourceLinkEl) {
        sourceLinkEl.hidden = !hasLink;
        if (hasLink) {
          sourceLinkEl.href = t.sourceUrl;
          if (sourceLabelEl) sourceLabelEl.textContent = t.sourceLabel;
        }
      }
      if (sourcePlainEl) {
        sourcePlainEl.hidden = hasLink;
        if (!hasLink) sourcePlainEl.textContent = t.sourceLabel;
      }
      if (sourceDateEl) {
        sourceDateEl.hidden = !t.dateLabel;
        sourceDateEl.textContent = t.dateLabel ? ' \u00B7 ' + t.dateLabel : '';
      }
    }

    function render(i) {
      const t = data[i];
      if (!t) return;

      quoteEl.style.opacity = '0';
      if (imgWrap) imgWrap.style.opacity = '0';

      setTimeout(function() {
        if (imgWrap) {
          if (t.photoSrc) {
            let imgEl = imgWrap.querySelector('img');
            if (!imgEl) {
              imgEl = document.createElement('img');
              imgEl.className = 'tslider__img';
              imgWrap.appendChild(imgEl);
            }
            imgEl.src = t.photoSrc;
            imgEl.srcset = t.photoSrcset || '';
            imgEl.sizes = '(max-width: 900px) 30vw, 200px';
            imgEl.alt = t.photoAlt || '';
          } else {
            const imgEl = imgWrap.querySelector('img');
            if (imgEl) imgEl.remove();
          }
          imgWrap.style.opacity = '1';
        }
        quoteEl.textContent = '\u201C' + t.quote + '\u201D';
        clientEl.textContent = t.client;
        renderStars(t);
        renderSource(t);
        if (idxEl) idxEl.textContent = String(i + 1);
        quoteEl.style.opacity = '1';
      }, 280);

      if (prevBtn) prevBtn.disabled = i === 0;
      if (nextBtn) nextBtn.disabled = i === data.length - 1;
    }

    if (prevBtn) prevBtn.addEventListener('click', function() {
      if (idx > 0) { idx--; render(idx); }
    });
    if (nextBtn) nextBtn.addEventListener('click', function() {
      if (idx < data.length - 1) { idx++; render(idx); }
    });

    if (prevBtn) prevBtn.disabled = true;
    if (nextBtn) nextBtn.disabled = data.length <= 1;
  });
</script>
