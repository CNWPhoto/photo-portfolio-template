---
import SanityImage from '../SanityImage.astro';
import { paletteToStyle } from '../../lib/palette.js';
import { resolveLink } from '../../lib/links.js';
import { getClient } from '../../lib/sanity.js';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, palette } = Astro.props;
const style = paletteToStyle(palette);

const ctaText = section?.ctaText || 'View Full Portfolio';
const ctaHref = resolveLink(section?.ctaLink, [Astro.url.hostname]) || '/portfolio';

const FALLBACK_VERTICAL = 'https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=900';
const FALLBACK_HORIZONTAL = 'https://images.pexels.com/photos/825949/pexels-photo-825949.jpeg?auto=compress&cs=tinysrgb&w=1200';

// Pull from the portfolio singleton's images[] array. Find the first image
// that's portrait (vertical) and the first that's landscape (horizontal),
// matching the legacy PortfolioGrid two-image layout.
const client = getClient(false);
const portfolio = await client.fetch(
  `*[_type == "portfolio" && _id == "portfolio"][0]{
    images[] {
      _key, alt, title,
      ...,
      asset->{ _id, metadata { dimensions { width, height, aspectRatio }, lqip } }
    }
  }`,
);
const allImages = (portfolio?.images || []) as any[];

const isPortrait = (img: any) => {
  const d = img?.asset?.metadata?.dimensions;
  return d && d.height > d.width;
};
const verticalImage = allImages.find(isPortrait) || allImages[0] || null;
const horizontalImage =
  allImages.find((img) => img !== verticalImage && !isPortrait(img)) || allImages[1] || null;
---

<section
  class="pgrid"
  data-section-type="featuredPortfolioSection"
  id={section?.sectionId || 'portfolio'}
  style={style}
>
  <div class="pgrid__inner">
    <div class="pgrid__label-col" aria-hidden="true">
      <span class="pgrid__label">Featured</span>
    </div>

    <div class="pgrid__content">
      <div class="pgrid__images">
        <div class="pgrid__img pgrid__img--vertical reveal reveal-delay-1">
          {verticalImage
            ? <SanityImage
                image={verticalImage}
                sizes="(max-width: 900px) 50vw, 35vw"
                loading="lazy"
                class="pgrid__img-el"
              />
            : <img src={FALLBACK_VERTICAL} alt="" class="pgrid__img-el" loading="lazy" />
          }
        </div>
        <div class="pgrid__img pgrid__img--horizontal reveal reveal-delay-2">
          {horizontalImage
            ? <SanityImage
                image={horizontalImage}
                sizes="(max-width: 900px) 50vw, 35vw"
                loading="lazy"
                class="pgrid__img-el"
              />
            : <img src={FALLBACK_HORIZONTAL} alt="" class="pgrid__img-el" loading="lazy" />
          }
        </div>
      </div>

      <div class="pgrid__footer reveal reveal-delay-3">
        <a href={ctaHref} class="pgrid__cta">{ctaText}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .pgrid {
    padding: 100px 0 170px !important;
    background: var(--bg-alt);
    color: var(--text);
  }

  .pgrid__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 3rem;
    display: grid;
    grid-template-columns: 60px 1fr;
    grid-template-rows: 434px auto;
    gap: 0 1.5rem;
  }

  /* Rotated label column */
  .pgrid__label-col {
    grid-row: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .pgrid__label {
    font-family: var(--font-serif, var(--font-heading));
    font-style: italic;
    font-size: clamp(2.25rem, 3.8vw, 3.5rem);
    letter-spacing: 0.04em;
    color: var(--accent-dark);
    writing-mode: horizontal-tb;
    display: block;
    transform: rotate(-90deg);
    transform-origin: center center;
    white-space: nowrap;
    user-select: none;
  }

  /* Two-image side-by-side layout */
  .pgrid__images {
    display: flex;
    height: 434px;
    gap: 1rem;
  }

  .pgrid__img {
    overflow: hidden;
    height: 434px;
  }

  .pgrid__img--vertical { flex: 2; }
  .pgrid__img--horizontal { flex: 3; }

  .pgrid__img :global(.pgrid__img-el) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s var(--ease-image);
  }
  .pgrid__img:hover :global(.pgrid__img-el) { transform: scale(1.03); }

  .pgrid__footer {
    grid-column: 2;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-top: 2rem;
  }

  .pgrid__cta {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    padding: 0.7rem 1.5rem;
  }

  .pgrid__cta:hover {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }

  @media (max-width: 900px) {
    .pgrid__inner {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      padding: 0 1.5rem;
    }
    .pgrid__label-col {
      display: flex;
      justify-content: center;
      padding-bottom: 1.5rem;
    }
    .pgrid__label {
      writing-mode: horizontal-tb;
      transform: none;
      font-size: clamp(1.6rem, 6vw, 2.25rem);
      text-align: center;
    }
    .pgrid__images {
      height: auto;
      flex-direction: column;
      gap: 0.75rem;
    }
    .pgrid__img { height: auto; flex: none; }
    .pgrid__img :global(.pgrid__img-el) { height: 70vw; }
    .pgrid__footer { grid-column: 1; padding-bottom: 0.5rem; }
    .pgrid__cta { display: block; text-align: center; width: 100%; }
  }
</style>
