---
import SanityImage from '../SanityImage.astro';
import { paletteToStyle } from '../../lib/palette.js';
import { resolveLink } from '../../lib/links.js';
import { getClient } from '../../lib/sanity.js';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, palette } = Astro.props;
const style = paletteToStyle(palette);

const eyebrow = section?.eyebrow || 'Featured';
const heading = section?.heading || '';
const showVerticalLabel = section?.showVerticalLabel !== false;
const ctaText = section?.ctaText || 'View Full Portfolio';
const ctaHref = resolveLink(section?.ctaLink, [Astro.url.hostname]) || '/portfolio';

const FALLBACK_VERTICAL = 'https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=900';
const FALLBACK_HORIZONTAL = 'https://images.pexels.com/photos/825949/pexels-photo-825949.jpeg?auto=compress&cs=tinysrgb&w=1200';

// Image source resolution. Editors can override the default Portfolio-
// singleton pull by uploading 1–2 images directly on the section. When
// section.images has assets, those win positionally (slot 0 = vertical,
// slot 1 = horizontal). When empty, fall through to the legacy behavior
// of pulling the first portrait + first landscape from the Portfolio
// singleton's images[] array.
const sectionImages = (section?.images || []).filter((img: any) => img?.asset);
let verticalImage: any = null;
let horizontalImage: any = null;

if (sectionImages.length >= 1) {
  verticalImage = sectionImages[0] || null;
  horizontalImage = sectionImages[1] || null;
} else {
  // Use the preview-aware client so Presentation surfaces the portfolio
  // doc in the "Documents on this page" panel and drafts render in preview.
  const client = getClient(Astro.locals.isPreview, (Astro.locals as any).runtime?.env);
  const portfolio = await client.fetch(
    `*[_type == "portfolio" && _id == "portfolio"][0]{
      images[] {
        _key, alt, title,
        ...,
        asset->{ _id, metadata { dimensions { width, height, aspectRatio }, lqip } }
      }
    }`,
  );
  const allImages = (portfolio?.images || []) as any[];
  const isPortrait = (img: any) => {
    const d = img?.asset?.metadata?.dimensions;
    return d && d.height > d.width;
  };
  verticalImage = allImages.find(isPortrait) || allImages[0] || null;
  horizontalImage =
    allImages.find((img) => img !== verticalImage && !isPortrait(img)) || allImages[1] || null;
}
---

<section
  class="pgrid"
  data-section-type="featuredPortfolioSection"
  id={section?.sectionId || 'portfolio'}
  style={style}
>
  <div class:list={['pgrid__inner', !showVerticalLabel && 'pgrid__inner--no-label']}>
    {showVerticalLabel && (
      <div class="pgrid__label-col" aria-hidden="true">
        <span class="pgrid__label">{eyebrow}</span>
      </div>
    )}

    <div class="pgrid__content">
      {heading && <h2 class="pgrid__heading reveal">{heading}</h2>}
      <div class="pgrid__images">
        <div class="pgrid__img pgrid__img--vertical reveal reveal-delay-1">
          {verticalImage
            ? <SanityImage
                image={verticalImage}
                sizes="(max-width: 900px) 50vw, 35vw"
                loading="lazy"
                class="pgrid__img-el"
              />
            : <img src={FALLBACK_VERTICAL} alt="" class="pgrid__img-el" loading="lazy" />
          }
        </div>
        <div class="pgrid__img pgrid__img--horizontal reveal reveal-delay-2">
          {horizontalImage
            ? <SanityImage
                image={horizontalImage}
                sizes="(max-width: 900px) 50vw, 35vw"
                loading="lazy"
                class="pgrid__img-el"
              />
            : <img src={FALLBACK_HORIZONTAL} alt="" class="pgrid__img-el" loading="lazy" />
          }
        </div>
      </div>
    </div>

    <div class="pgrid__footer reveal reveal-delay-3">
      <a href={ctaHref} class="pgrid__cta">{ctaText}</a>
    </div>
  </div>
</section>

<style>
  /* Tone-aware. Background Tone (Light/Alt/Dark) is resolved into the
     palette by applyBackgroundTone() in the renderer, which swaps --bg
     to the chosen shade — binding here to var(--bg) is what makes the
     Light option actually render light. Previously hardcoded to --bg-alt,
     so Light and Alt looked identical. */
  .pgrid {
    padding: 100px 0 128px !important;
    background: var(--bg);
    color: var(--text);
  }

  .pgrid__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 3rem;
    display: grid;
    grid-template-columns: 90px 1fr;
    grid-template-rows: auto auto;
    gap: 0 2.5rem;
  }

  /* Label hidden — collapse to a single column, re-target the footer
     which otherwise tries to land in the now-nonexistent col 2. */
  .pgrid__inner--no-label {
    grid-template-columns: 1fr;
  }
  .pgrid__inner--no-label .pgrid__footer {
    grid-column: 1;
  }

  /* Rotated label column — spans the content row (1), not the footer row. */
  .pgrid__label-col {
    grid-row: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Use vertical writing-mode + a lossless 180° rotate rather than
     rotating horizontal text with transform: rotate(-90deg), which
     triggers subpixel rasterization blur on retina displays. Same
     pattern used by FaqSection and the page-builder-spec. */
  .pgrid__label {
    font-family: var(--font-serif, var(--font-heading));
    font-style: italic;
    font-size: clamp(2.25rem, 3.8vw, 3.5rem);
    line-height: 1;
    letter-spacing: 0.04em;
    color: var(--accent-dark);
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    white-space: nowrap;
    user-select: none;
  }

  .pgrid__heading {
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 0 0 2rem;
    line-height: 1.2;
  }

  /* Two-image side-by-side layout */
  .pgrid__images {
    display: flex;
    height: 434px;
    gap: 1rem;
  }

  .pgrid__img {
    overflow: hidden;
    height: 434px;
  }

  .pgrid__img--vertical { flex: 2; }
  .pgrid__img--horizontal { flex: 3; }

  .pgrid__img :global(.pgrid__img-el) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s var(--ease-image);
  }
  .pgrid__img:hover :global(.pgrid__img-el) { transform: scale(1.03); }

  .pgrid__footer {
    grid-column: 2;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-top: 2rem;
  }

  .pgrid__cta {
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    padding: 0.7rem 1.5rem;
  }

  .pgrid__cta:hover {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }

  @media (max-width: 900px) {
    .pgrid__inner {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      padding: 0 1.5rem;
    }
    .pgrid__label-col {
      display: flex;
      justify-content: center;
      padding-bottom: 1.5rem;
    }
    .pgrid__label {
      writing-mode: horizontal-tb;
      transform: none;
      font-size: clamp(1.6rem, 6vw, 2.25rem);
      text-align: center;
    }
    .pgrid__images {
      height: auto;
      flex-direction: column;
      gap: 0.75rem;
    }
    .pgrid__img { height: auto; flex: none; }
    .pgrid__img :global(.pgrid__img-el) { height: 70vw; }
    .pgrid__footer { grid-column: 1; padding-bottom: 0.5rem; }
    .pgrid__cta { display: block; text-align: center; width: 100%; }
  }
</style>
