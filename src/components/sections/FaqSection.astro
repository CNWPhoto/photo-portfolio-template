---
import { paletteToStyle } from '../../lib/palette.js';
import { renderBody, isPortableText } from '../../lib/portableText.js';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, palette } = Astro.props;
const style = paletteToStyle(palette);

const sideLabel = section?.verticalSideLabel || 'FAQs';
const layout = section?.layout || 'flat-list';
const faqs = (section?.faqs || []).map((f: any) => ({
  q: f?.question || '',
  aHTML: isPortableText(f?.answer) ? renderBody(f.answer) : '',
}));
---

<section
  class="faqs"
  data-section-type="faqSection"
  data-layout={layout}
  id={section?.sectionId || 'faqs'}
  style={style}
>
  <div class="faqs__inner">
    <div class="faqs__label-col" aria-hidden="true">
      <span class="faqs__label">{sideLabel}</span>
    </div>

    <div class="faqs__content">
      <div class="faqs__list">
        {faqs.map((faq: any, i: number) => (
          <div class:list={['faqs__item', 'reveal', `reveal-delay-${Math.min(i + 1, 5)}`]}>
            {layout === 'accordion' ? (
              <details class="faqs__details">
                <summary class="faqs__question">{faq.q}</summary>
                <div class="faqs__answer" set:html={faq.aHTML} />
              </details>
            ) : (
              <>
                <h3 class="faqs__question">{faq.q}</h3>
                <div class="faqs__answer" set:html={faq.aHTML} />
              </>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faqs {
    padding-top: 0 !important;
    padding-bottom: 7rem !important;
    background: var(--bg);
    color: var(--text);
  }

  .faqs__inner {
    display: grid;
    grid-template-columns: 100px 1fr;
    padding: 5rem 3rem 0;
    max-width: 1100px;
    margin: 0 auto;
    gap: 2rem;
  }

  /* Rotated label */
  .faqs__label-col {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .faqs__label {
    font-family: var(--font-serif, var(--font-heading));
    font-style: italic;
    font-size: clamp(2rem, 3.5vw, 3.25rem);
    letter-spacing: 0.1em;
    color: var(--border);
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    white-space: nowrap;
    user-select: none;
  }

  .faqs__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faqs__item {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .faqs__item:first-child { border-top: none; }

  .faqs__question {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 1.25rem;
    letter-spacing: -0.01em;
    cursor: default;
  }

  .faqs__details > summary {
    list-style: none;
    cursor: pointer;
  }
  .faqs__details > summary::-webkit-details-marker { display: none; }
  .faqs__details[open] > summary { margin-bottom: 1.25rem; }

  .faqs__answer :global(p),
  .faqs__answer :global(blockquote) {
    margin: 0 0 0.75rem;
    padding: 0 0 0 1.75rem;
    border-left: 2px solid var(--accent);
    font-style: normal;
    font-size: 1.125rem;
    line-height: 1.78;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .faqs__inner {
      grid-template-columns: 1fr;
      padding: 0 1.5rem 0;
    }

    .faqs__label-col {
      padding-top: 3rem;
    }

    .faqs__label {
      writing-mode: horizontal-tb;
      transform: none;
      font-size: clamp(1.6rem, 6vw, 2.25rem);
      text-align: center;
    }
  }
</style>
