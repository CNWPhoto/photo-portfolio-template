---
import { paletteToStyle } from '../../lib/palette.js';
import { renderHeading } from '../../lib/heading.js';
import { resolveLink } from '../../lib/links.js';
import { buildSrc } from '../../lib/image';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, isFirst = false, palette } = Astro.props;
const style = paletteToStyle(palette);

const heading = renderHeading(section?.heading || '');
const body = section?.body || '';
const ctaText = section?.ctaText || '';
const ctaHref = resolveLink(section?.ctaLink);
const layout = section?.layout || 'centered';

const bgImage = section?.backgroundImage ?? null;
const bgUrl = bgImage?.asset ? buildSrc(bgImage, 2000) : null;

const HeadingTag = isFirst ? 'h1' : 'h2';
---

<section
  class:list={['section', 'ctaband', `ctaband--${layout}`, bgUrl ? 'ctaband--has-bg' : '']}
  data-section-type="ctaBandSection"
  data-spacing={section?.spacing || 'normal'}
  id={section?.sectionId || undefined}
  style={style}
>
  {bgUrl && (
    <>
      <div class="ctaband__bg" style={`background-image:url('${bgUrl}')`} aria-hidden="true"></div>
      <div class="ctaband__overlay" aria-hidden="true"></div>
    </>
  )}
  <div class="ctaband__inner">
    <div class="ctaband__text reveal">
      {heading && <HeadingTag class="ctaband__heading" set:html={heading} />}
      {body && <p class="ctaband__body">{body}</p>}
    </div>
    {ctaText && ctaHref && (
      <div class="ctaband__cta-wrap reveal reveal-delay-1">
        <a class="ctaband__cta" href={ctaHref}>{ctaText}</a>
      </div>
    )}
  </div>
</section>

<style>
  .ctaband {
    position: relative;
    background: var(--bg-alt);
    color: var(--text);
    overflow: hidden;
  }
  .ctaband--has-bg { color: var(--white, #fff); }
  .ctaband__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  .ctaband__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .ctaband__inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding-inline: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.75rem;
  }
  .ctaband--split-text-left-cta-right .ctaband__inner {
    flex-direction: row;
    justify-content: space-between;
    text-align: left;
    align-items: center;
  }

  .ctaband__heading {
    font-size: clamp(1.85rem, 3.5vw, 2.85rem);
    line-height: 1.18;
    margin: 0 0 0.75rem;
  }
  .ctaband--has-bg .ctaband__heading { color: var(--white, #fff); }
  .ctaband__body {
    font-size: 1.05rem;
    line-height: 1.7;
    color: inherit;
    margin: 0;
    max-width: 560px;
  }
  .ctaband--split-text-left-cta-right .ctaband__body { max-width: none; }

  .ctaband__cta {
    display: inline-block;
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--btn-text);
    background: var(--btn-bg);
    padding: 1rem 2.25rem;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .ctaband--split-text-left-cta-right .ctaband__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
