---
import SanityImage from '../SanityImage.astro';
import { paletteToStyle } from '../../lib/palette.js';
import { renderHeading } from '../../lib/heading.js';
import { resolveLink } from '../../lib/links.js';
import { buildSrc } from '../../lib/image';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, isFirst = false, palette } = Astro.props;
const style = paletteToStyle(palette);

const heading = renderHeading(section?.heading || '');
const body = section?.body || '';
const ctaText = section?.ctaText || '';
const ctaHref = resolveLink(section?.ctaLink, [Astro.url.hostname]);
const layout = section?.layout || 'centered';
const caption = section?.caption || '';

const bgImage = section?.backgroundImage ?? null;
const bgUrl = bgImage?.asset ? buildSrc(bgImage, 2000) : null;
const fgImage = section?.foregroundImage ?? null;

const FALLBACK_BG = 'https://images.pexels.com/photos/3726314/pexels-photo-3726314.jpeg?auto=compress&cs=tinysrgb&w=600&h=750&fit=crop';
const FALLBACK_FG = 'https://images.pexels.com/photos/1254140/pexels-photo-1254140.jpeg?auto=compress&cs=tinysrgb&w=500&h=640&fit=crop';

const isOverlapping = layout === 'overlapping-images';

const HeadingTag = isFirst ? 'h1' : 'h2';
---

{isOverlapping ? (
  <section
    class="section ctaband ctaband--overlapping-images"
    data-section-type="ctaBandSection"
    data-spacing={section?.spacing || 'normal'}
    id={section?.sectionId || undefined}
    style={style}
  >
    <hr />
    <div class="ctaband__oi-inner">
      <div class="ctaband__oi-images">
        <div class="ctaband__oi-back">
          {bgImage
            ? <SanityImage image={bgImage} sizes="(max-width:900px) 100vw, 75vw" loading="lazy" class="ctaband__oi-back-img" />
            : <img src={FALLBACK_BG} alt="" width="600" height="750" loading="lazy" decoding="async" />}
        </div>
      </div>
      <div class="ctaband__oi-content">
        {heading && <HeadingTag class="ctaband__oi-heading reveal reveal-delay-1" set:html={heading} />}
        {body && <p class="ctaband__oi-body reveal reveal-delay-2">{body}</p>}
        {ctaText && ctaHref && <a class="ctaband__oi-btn reveal reveal-delay-3" href={ctaHref}>{ctaText}</a>}
        {caption && <p class="ctaband__oi-caption">{caption}</p>}
      </div>
      <div class="ctaband__oi-front">
        {fgImage
          ? <SanityImage image={fgImage} sizes="(max-width:900px) 80vw, 40vw" loading="lazy" class="ctaband__oi-front-img" />
          : <img src={FALLBACK_FG} alt="" width="500" height="640" loading="lazy" decoding="async" />}
      </div>
    </div>
  </section>
) : (
  <section
    class:list={['section', 'ctaband', `ctaband--${layout}`, bgUrl ? 'ctaband--has-bg' : '']}
    data-section-type="ctaBandSection"
    data-spacing={section?.spacing || 'normal'}
    id={section?.sectionId || undefined}
    style={style}
  >
    {bgUrl && (
      <>
        <div class="ctaband__bg" style={`background-image:url('${bgUrl}')`} aria-hidden="true"></div>
        <div class="ctaband__overlay" aria-hidden="true"></div>
      </>
    )}
    <div class="ctaband__inner">
      <div class="ctaband__text reveal">
        {heading && <HeadingTag class="ctaband__heading" set:html={heading} />}
        {body && <p class="ctaband__body">{body}</p>}
      </div>
      {ctaText && ctaHref && (
        <div class="ctaband__cta-wrap reveal reveal-delay-1">
          <a class="ctaband__cta" href={ctaHref}>{ctaText}</a>
        </div>
      )}
    </div>
  </section>
)}

<style>
  .ctaband {
    position: relative;
    background: var(--bg-alt);
    color: var(--text);
    overflow: hidden;
  }
  .ctaband--has-bg { color: var(--white, #fff); }
  .ctaband__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  .ctaband__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .ctaband__inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding-inline: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.75rem;
  }
  .ctaband--split-text-left-cta-right .ctaband__inner {
    flex-direction: row;
    justify-content: space-between;
    text-align: left;
    align-items: center;
  }

  .ctaband__heading {
    font-size: clamp(1.85rem, 3.5vw, 2.85rem);
    line-height: 1.18;
    margin: 0 0 0.75rem;
  }
  .ctaband--has-bg .ctaband__heading { color: var(--white, #fff); }
  .ctaband__body {
    font-size: 1.05rem;
    line-height: 1.7;
    color: inherit;
    margin: 0;
    max-width: 560px;
  }
  .ctaband--split-text-left-cta-right .ctaband__body { max-width: none; }

  .ctaband__cta {
    display: inline-block;
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--btn-text);
    background: var(--btn-bg);
    padding: 1rem 2.25rem;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .ctaband--split-text-left-cta-right .ctaband__inner {
      flex-direction: column;
      text-align: center;
    }
  }

  /* ── Overlapping Images variant ── */
  .ctaband--overlapping-images {
    background: var(--bg);
    color: var(--text);
    padding: 0 0 7rem;
  }
  .ctaband__oi-inner {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding: 6rem 3rem 7rem;
    min-height: 1020px;
  }

  .ctaband__oi-images {
    position: relative;
    margin-left: 25%;
    height: 900px;
  }
  .ctaband__oi-back {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    overflow: hidden;
    border: 20px solid white;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }
  .ctaband__oi-back img,
  .ctaband__oi-back :global(.ctaband__oi-back-img) {
    width: 100%;
    display: block;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .ctaband__oi-front {
    position: absolute;
    top: calc(6rem + 240px);
    left: 3rem;
    width: 43%;
    overflow: hidden;
    border: 20px solid white;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.14);
  }
  .ctaband__oi-front img,
  .ctaband__oi-front :global(.ctaband__oi-front-img) {
    width: 100%;
    display: block;
    height: 520px;
    object-fit: cover;
  }

  .ctaband__oi-content {
    position: absolute;
    top: calc(6rem + 475px + 100px);
    left: calc(43% + 100px);
    right: 3rem;
  }
  .ctaband__oi-heading {
    font-size: clamp(2.25rem, 4vw, 3.75rem);
    color: var(--text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .ctaband__oi-body {
    font-style: italic;
    font-size: 1.0625rem;
    line-height: 1.82;
    color: var(--text);
    margin-bottom: 2.5rem;
    max-width: 420px;
  }
  .ctaband__oi-btn {
    display: inline-block;
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    border: 1px solid var(--text);
    padding: 0.7rem 1.75rem;
    margin-bottom: 1.5rem;
    transition: background 0.25s, color 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .ctaband__oi-btn:hover {
    background: var(--text);
    color: var(--bg);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
  }
  .ctaband__oi-caption {
    font-family: var(--font-sans, var(--font-body));
    font-size: 0.8125rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  @media (max-width: 900px) {
    .ctaband__oi-inner {
      padding: 4rem 1.5rem 4rem;
      min-height: 0;
    }
    .ctaband__oi-images {
      margin-left: 0;
      height: auto;
    }
    .ctaband__oi-back {
      position: static;
    }
    .ctaband__oi-back img,
    .ctaband__oi-back :global(.ctaband__oi-back-img) {
      height: auto;
      aspect-ratio: 3 / 2;
    }
    .ctaband__oi-front {
      position: static;
      width: 80%;
      margin-top: 2rem;
    }
    .ctaband__oi-front img,
    .ctaband__oi-front :global(.ctaband__oi-front-img) {
      height: auto;
    }
    .ctaband__oi-content {
      position: static;
      width: 100%;
      padding-top: 2.5rem;
    }
  }
</style>
