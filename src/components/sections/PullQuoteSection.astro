---
import { paletteToStyle } from '../../lib/palette.js';

interface Props {
  section: any;
  isFirst?: boolean;
  palette?: any;
}

const { section, palette } = Astro.props;
const style = paletteToStyle(palette);

const quote = section?.quote || '';
const attribution = section?.attribution || '';
const variant = section?.variant || 'centered';
---

<section
  class:list={['section', 'quote', `quote--${variant}`]}
  data-section-type="pullQuoteSection"
  data-spacing={section?.spacing || 'normal'}
  id={section?.sectionId || undefined}
  style={style}
>
  <figure class="quote__figure reveal">
    <blockquote class="quote__text">
      <span class="quote__mark" aria-hidden="true">&ldquo;</span>
      {quote}
      <span class="quote__mark" aria-hidden="true">&rdquo;</span>
    </blockquote>
    {attribution && <figcaption class="quote__attribution reveal reveal-delay-1">— {attribution}</figcaption>}
  </figure>
</section>

<style>
  .quote {
    background: var(--bg);
    color: var(--text);
  }
  .quote__figure {
    margin: 0 auto;
    max-width: 760px;
    padding: 0 1.5rem;
    text-align: center;
  }
  .quote__text {
    font-style: italic;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.4;
    color: var(--text);
    margin: 0;
  }
  .quote__mark { color: var(--accent); }
  .quote__attribution {
    margin-top: 1.5rem;
    font-family: var(--font-sans, var(--font-body));
    font-style: normal;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Variants */
  .quote--bordered-left .quote__figure {
    text-align: left;
    border-left: 3px solid var(--accent);
    padding-left: 1.75rem;
  }
  .quote--italic-large .quote__text {
    font-size: clamp(2rem, 4vw, 3rem);
  }
</style>
