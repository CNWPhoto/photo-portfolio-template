---
import SanityImage from '../../components/SanityImage.astro';

const { galleryImages, theme } = Astro.props;

const sanityImages = galleryImages?.length ? galleryImages.slice(0, 6) : [];
const useFallback = sanityImages.length === 0;
const FALLBACK_MASONRY_IDS = ['1108099', '2253275', '825949', '1805164', '3726314', '1629781'];
const pexelsUrl = (id: string, w = 900) =>
  `https://images.pexels.com/photos/${id}/pexels-photo-${id}.jpeg?auto=compress&cs=tinysrgb&w=${w}`;
---

<section class="pmasonry" id="portfolio" data-theme={theme || undefined}>
	<hr />
	<div class="pmasonry__header">
		<p class="pmasonry__eyebrow">Portfolio</p>
		<h2 class="pmasonry__heading">Recent Work</h2>{/* TODO:NICHE */}
	</div>

	<div class="pmasonry__grid">
		{useFallback
			? FALLBACK_MASONRY_IDS.map((id) => (
				<div class="pmasonry__item">
					<img src={pexelsUrl(id)} alt="" class="pmasonry__img" loading="lazy" />
				</div>
			))
			: sanityImages.map((img: any) => (
				<div class="pmasonry__item">
					<SanityImage
						image={img}
						sizes="(max-width: 600px) 100vw, (max-width: 900px) 50vw, 33vw"
						class="pmasonry__img"
					/>
				</div>
			))
		}
	</div>

	<div class="pmasonry__footer">
		<a href="/portfolio" class="pmasonry__cta">View Full Portfolio</a>
	</div>
</section>

<style>
	.pmasonry { padding: 6rem 0 7rem; }

	.pmasonry__header {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 3rem 3.5rem;
		border-top: 1px solid var(--border);
		padding-top: 5rem;
	}

	.pmasonry__eyebrow {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1rem;
	}

	.pmasonry__heading {
		font-size: clamp(2rem, 4vw, 3.25rem);
		color: var(--text);
		letter-spacing: -0.01em;
	}

	/* CSS columns for true masonry — no JS required */
	.pmasonry__grid {
		columns: 3;
		column-gap: 0.75rem;
		padding: 0 3rem;
		max-width: 1100px;
		margin: 0 auto;
	}

	.pmasonry__item {
		break-inside: avoid;
		margin-bottom: 0.75rem;
		overflow: hidden;
	}

	.pmasonry__item :global(.pmasonry__img) {
		width: 100%;
		display: block;
		transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
			opacity 0.3s ease;
	}

	.pmasonry__item:hover :global(.pmasonry__img) {
		transform: scale(1.03);
		opacity: 0.9;
	}

	.pmasonry__footer {
		max-width: 1100px;
		margin: 2.5rem auto 0;
		padding: 2rem 3rem 0;
		border-top: 1px solid var(--border);
		display: flex;
		justify-content: flex-end;
	}

	.pmasonry__cta {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--text);
		padding: 0.7rem 1.5rem;
		display: inline-block;
	}

	.pmasonry__cta:hover {
		background: var(--text);
		color: var(--bg);
		border-color: var(--text);
	}

	@media (max-width: 900px) {
		.pmasonry__grid { columns: 2; padding: 0 1.5rem; }
		.pmasonry__header { padding-left: 1.5rem; padding-right: 1.5rem; }
		.pmasonry__footer { padding-left: 1.5rem; padding-right: 1.5rem; }
	}

	@media (max-width: 480px) {
		.pmasonry__grid { columns: 1; }
	}
</style>
