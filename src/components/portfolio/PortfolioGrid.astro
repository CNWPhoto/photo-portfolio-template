---
import SanityImage from '../../components/SanityImage.astro';

const { featuredSection, theme } = Astro.props;
---

<section class="pgrid" id="portfolio" data-theme={theme || undefined}>
	<div class="pgrid__inner">

		<div class="pgrid__label-col" aria-hidden="true">
			<span class="pgrid__label">Featured</span>
		</div>

		<div class="pgrid__content">
			<div class="pgrid__images">
				<div class="pgrid__img pgrid__img--vertical reveal reveal-delay-1">
					{featuredSection?.imageVertical && (
						<SanityImage
							image={featuredSection.imageVertical}
							sizes="(max-width: 900px) 50vw, 35vw"
							class="pgrid__img-el"
							displayWidth={600}
							displayHeight={434}
						/>
					)}
				</div>
				<div class="pgrid__img pgrid__img--horizontal reveal reveal-delay-2">
					{featuredSection?.imageHorizontal && (
						<SanityImage
							image={featuredSection.imageHorizontal}
							sizes="(max-width: 900px) 50vw, 35vw"
							class="pgrid__img-el"
							displayWidth={900}
							displayHeight={434}
						/>
					)}
				</div>
			</div>

			<div class="pgrid__footer reveal reveal-delay-3">
				<a href="/portfolio" class="pgrid__cta">View Full Portfolio</a>
			</div>
		</div>

	</div>
</section>

<style>
	.pgrid {
		padding: 100px 0;
		background: var(--bg-alt);
	}

	.pgrid__inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 3rem;
		display: grid;
		grid-template-columns: 60px 1fr;
		grid-template-rows: 434px auto;
		gap: 0 1.5rem;
	}

	/* ── Label column ── */
	.pgrid__label-col {
		grid-row: 1;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.pgrid__label {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: clamp(2.25rem, 3.8vw, 3.5rem);
		letter-spacing: 0.04em;
		color: var(--accent-dark);
		writing-mode: vertical-lr;
		transform: rotate(180deg);
		white-space: nowrap;
		user-select: none;
	}

	/* ── Images ── */
	.pgrid__images {
		display: flex;
		height: 434px;
		gap: 1rem;
	}

	.pgrid__img {
		overflow: hidden;
		height: 434px;
	}

	.pgrid__img--vertical   { flex: 2; }
	.pgrid__img--horizontal { flex: 3; }

	.pgrid__img :global(.pgrid__img-el) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.pgrid__img:hover :global(.pgrid__img-el) { transform: scale(1.03); }

	/* ── Footer ── */
	.pgrid__footer {
		grid-column: 2;
		display: flex;
		justify-content: flex-end;
		align-items: center;
		margin-top: 2rem;
	}

	.pgrid__cta {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--text);
		padding: 0.7rem 1.5rem;
	}

	.pgrid__cta:hover {
		background: var(--text);
		color: var(--bg);
	}

	/* ── Mobile ── */
	@media (max-width: 900px) {
		.pgrid__inner       { grid-template-columns: 1fr; padding: 0 1.5rem; }
		.pgrid__label-col   { display: none; }
		.pgrid__images      { height: auto; flex-direction: column; gap: 0.75rem; }
		.pgrid__img         { height: auto; flex: none; }
		.pgrid__img :global(.pgrid__img-el) { height: 70vw; }
		.pgrid__footer      { grid-column: 1; }
	}
</style>
