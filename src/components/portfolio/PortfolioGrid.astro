---
import { sanityImg, sanitySrcset } from '../../utils/imageUrl';

const { featuredSection, urlFor, theme } = Astro.props;

// TODO:NICHE — fallback images are dog photos; swap for your niche
const verticalBase = featuredSection?.imageVertical && urlFor
	? urlFor(featuredSection.imageVertical).url()
	: null;
const verticalFallback = 'https://images.pexels.com/photos/825949/pexels-photo-825949.jpeg?auto=compress&cs=tinysrgb&w=1200';
const verticalAlt = featuredSection?.imageVertical?.alt ?? 'Dog portrait in warm natural light'; // TODO:NICHE

const horizontalBase = featuredSection?.imageHorizontal && urlFor
	? urlFor(featuredSection.imageHorizontal).url()
	: null;
const horizontalFallback = 'https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=1800';
const horizontalAlt = featuredSection?.imageHorizontal?.alt ?? 'Dog exploring in golden afternoon light'; // TODO:NICHE
---

<section class="pgrid" id="portfolio" data-theme={theme || undefined}>
	<div class="pgrid__inner">

		<div class="pgrid__label-col" aria-hidden="true">
			<span class="pgrid__label">Featured</span>
		</div>

		<div class="pgrid__content">
			<div class="pgrid__images">
				<div class="pgrid__img pgrid__img--vertical reveal reveal-delay-1">
					{verticalBase
						? <img
								src={sanityImg(verticalBase, 1200)}
								srcset={sanitySrcset(verticalBase, [600, 900, 1200, 1800])}
								sizes="(max-width: 900px) 50vw, 35vw"
								alt={verticalAlt}
								loading="lazy" decoding="async"
							/>
						: <img src={verticalFallback} alt={verticalAlt} loading="lazy" decoding="async" />
					}
				</div>
				<div class="pgrid__img pgrid__img--horizontal reveal reveal-delay-2">
					{horizontalBase
						? <img
								src={sanityImg(horizontalBase, 1200)}
								srcset={sanitySrcset(horizontalBase, [600, 900, 1200, 1800])}
								sizes="(max-width: 900px) 50vw, 35vw"
								alt={horizontalAlt}
								loading="lazy" decoding="async"
							/>
						: <img src={horizontalFallback} alt={horizontalAlt} loading="lazy" decoding="async" />
					}
				</div>
			</div>

			<div class="pgrid__footer reveal reveal-delay-3">
				<a href="/portfolio" class="pgrid__cta">View Full Portfolio</a>
			</div>
		</div>

	</div>
</section>

<style>
	.pgrid {
		padding: 100px 0;
		background: var(--bg-alt);
	}

	.pgrid__inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 3rem;
		display: grid;
		grid-template-columns: 60px 1fr;
		grid-template-rows: 434px auto;
		gap: 0 1.5rem;
	}

	/* ── Label column ── */
	.pgrid__label-col {
		grid-row: 1;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.pgrid__label {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: clamp(3rem, 5vw, 4.5rem);
		letter-spacing: 0.04em;
		color: var(--accent-dark);
		writing-mode: vertical-rl;
		transform: rotate(180deg);
		white-space: nowrap;
		user-select: none;
	}

	/* ── Images ── */
	.pgrid__images {
		display: flex;
		height: 434px;
		gap: 1rem;
	}

	.pgrid__img {
		overflow: hidden;
		height: 434px;
	}

	.pgrid__img--vertical   { flex: 2; }
	.pgrid__img--horizontal { flex: 3; }

	.pgrid__img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.pgrid__img:hover img { transform: scale(1.03); }

	/* ── Footer ── */
	.pgrid__footer {
		grid-column: 2;
		display: flex;
		justify-content: flex-end;
		align-items: center;
		margin-top: 2rem;
	}

	.pgrid__cta {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--text);
		padding: 0.7rem 1.5rem;
		transition: background 0.25s, color 0.25s, transform 0.2s, box-shadow 0.25s;
	}

	.pgrid__cta:hover {
		background: var(--text);
		color: var(--bg);
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(26, 39, 68, 0.18);
	}

	/* ── Mobile ── */
	@media (max-width: 900px) {
		.pgrid__inner       { grid-template-columns: 1fr; padding: 0 1.5rem; }
		.pgrid__label-col   { display: none; }
		.pgrid__images      { height: auto; flex-direction: column; gap: 0.75rem; }
		.pgrid__img         { height: auto; flex: none; }
		.pgrid__img img     { height: 70vw; }
		.pgrid__footer      { grid-column: 1; }
	}
</style>
