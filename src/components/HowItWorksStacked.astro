---
const { theme = 'classic-cream' } = Astro.props;

// TODO:NICHE — step body copy references dogs/treats; update for your niche
const steps = [
	{
		label: 'Reach Out',
		body: "Tell me about your dog — their personality, their quirks, what makes them uniquely them. We'll talk through location options, timing, and everything that will make your session perfect.", // TODO:NICHE
	},
	{
		label: 'Your Session',
		body: 'Sessions are completely play-based and led by your dog. There are no forced poses, no stiff backdrops — just natural moments, beautiful light, and a whole lot of treats.', // TODO:NICHE
	},
	{
		label: 'The Images',
		body: 'Within three weeks, your private online gallery arrives. Choose your favorites for fine art prints, heirloom albums, and high-resolution digital downloads.',
	},
];
---

<section class="hstack" id="how-it-works" data-theme={theme}>
	<hr />
	<div class="hstack__inner">
		<div class="hstack__header">
			{/* TODO:NICHE — heading references dogs */}
			<h2 class="hstack__heading">Dog Photography Sessions</h2>
			<p class="hstack__sub">Simple and relaxed sessions you and your dog will <em>love.</em></p>
		</div>

		<div class="hstack__timeline">
			{steps.map((step, i) => (
				<div class="hstack__step">
					<div class="hstack__left">
						<span class="hstack__num">{String(i + 1).padStart(2, '0')}</span>
						{i < steps.length - 1 && <div class="hstack__line" />}
					</div>
					<div class="hstack__right">
						<h3 class="hstack__label">{step.label}</h3>
						<p class="hstack__body">{step.body}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.hstack {
		padding-top: 0;
		padding-bottom: 7rem;
	}

	.hstack__inner {
		max-width: 860px;
		margin: 0 auto;
		padding: 0 3rem;
	}

	.hstack__header {
		padding: 5.5rem 0 5rem;
		text-align: center;
	}

	.hstack__heading {
		font-size: clamp(2rem, 4vw, 3.25rem);
		color: var(--text);
		margin-bottom: 1.25rem;
		letter-spacing: -0.01em;
	}

	.hstack__sub {
		font-size: 1.0625rem;
		color: var(--muted);
		font-style: italic;
		line-height: 1.6;
	}

	.hstack__sub em {
		font-style: normal;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-size: 0.95em;
		color: var(--accent);
	}

	/* Timeline */
	.hstack__timeline {
		display: flex;
		flex-direction: column;
	}

	.hstack__step {
		display: grid;
		grid-template-columns: 72px 1fr;
		gap: 0 2.5rem;
	}

	/* Left column: large number + connector line */
	.hstack__left {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hstack__num {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: 2.5rem;
		line-height: 1;
		color: var(--accent);
		flex-shrink: 0;
		padding-top: 0.125rem;
	}

	.hstack__line {
		width: 1px;
		flex: 1;
		min-height: 2rem;
		background: var(--border);
		margin: 0.75rem 0;
	}

	/* Right column: label + body */
	.hstack__right {
		padding-bottom: 4rem;
		padding-top: 0.25rem;
	}

	.hstack__step:last-child .hstack__right {
		padding-bottom: 0;
	}

	.hstack__label {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		font-weight: 600;
		margin-bottom: 1rem;
	}

	.hstack__body {
		font-size: 0.9375rem;
		line-height: 1.78;
		color: var(--muted);
	}

	@media (max-width: 768px) {
		.hstack__inner {
			padding: 0 1.5rem;
		}

		.hstack__step {
			grid-template-columns: 52px 1fr;
			gap: 0 1.5rem;
		}

		.hstack__num {
			font-size: 1.875rem;
		}
	}
</style>
