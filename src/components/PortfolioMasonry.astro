---
import SanityImage from '../components/SanityImage.astro';

const { galleryImages, theme = 'classic-cream' } = Astro.props;

const images = galleryImages?.length ? galleryImages.slice(0, 6) : [];
---

<section class="pmasonry" data-theme={theme}>
	<hr />
	<div class="pmasonry__grid">
		{images.map((img: any) => (
			<div class="pmasonry__item">
				<SanityImage
					image={img}
					sizes="(max-width: 600px) 100vw, (max-width: 900px) 50vw, 33vw"
				/>
			</div>
		))}
	</div>
	<div class="pmasonry__footer">
		<a href="#" class="pmasonry__cta">View Full Portfolio</a>
	</div>
</section>

<style>
	.pmasonry {
		padding-bottom: 6rem;
	}

	.pmasonry__grid {
		columns: 3;
		column-gap: 15px;
		padding: 4rem 3rem 0;
		max-width: 1100px;
		margin: 0 auto;
	}

	.pmasonry__item {
		break-inside: avoid;
		margin-bottom: 15px;
		overflow: hidden;
	}

	.pmasonry__item img {
		width: 100%;
		display: block;
		transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.pmasonry__item:hover img {
		transform: scale(1.03);
	}

	.pmasonry__footer {
		max-width: 1100px;
		margin: 2rem auto 0;
		padding: 0 3rem;
		text-align: center;
	}

	.pmasonry__cta {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--text);
		padding: 0.7rem 2rem;
		display: inline-block;
	}

	.pmasonry__cta:hover {
		background: var(--text);
		color: var(--bg);
	}

	@media (max-width: 900px) {
		.pmasonry__grid {
			columns: 2;
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}

		.pmasonry__footer {
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.pmasonry__grid {
			columns: 1;
		}
	}
</style>
