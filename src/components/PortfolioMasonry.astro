---
const { theme = 'classic-cream' } = Astro.props;

// TODO:NICHE — fallback images are dog photos; swap for your niche
const images = [
	{ src: 'https://images.pexels.com/photos/1108099/pexels-photo-1108099.jpeg?auto=compress&cs=tinysrgb&w=700&h=1050&fit=crop', alt: 'Golden retriever in warm afternoon light' }, // TODO:NICHE
	{ src: 'https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=700&h=560&fit=crop',  alt: 'Dog exploring in golden afternoon light' }, // TODO:NICHE
	{ src: 'https://images.pexels.com/photos/825949/pexels-photo-825949.jpeg?auto=compress&cs=tinysrgb&w=700&h=900&fit=crop',   alt: 'Dog portrait in natural light' },            // TODO:NICHE
	{ src: 'https://images.pexels.com/photos/1805164/pexels-photo-1805164.jpeg?auto=compress&cs=tinysrgb&w=700&h=620&fit=crop',  alt: 'Playful dog in soft afternoon light' },       // TODO:NICHE
	{ src: 'https://images.pexels.com/photos/3726314/pexels-photo-3726314.jpeg?auto=compress&cs=tinysrgb&w=700&h=980&fit=crop',  alt: 'Dog looking curiously at the camera' },      // TODO:NICHE
	{ src: 'https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=700&h=700&fit=crop',  alt: 'Dog in golden light, close-up portrait' },   // TODO:NICHE
];
---

<section class="pmasonry" data-theme={theme}>
	<hr />
	<div class="pmasonry__grid">
		{images.map((img) => (
			<div class="pmasonry__item">
				<img src={img.src} alt={img.alt} loading="lazy" />
			</div>
		))}
	</div>
	<div class="pmasonry__footer">
		<a href="#" class="pmasonry__cta">View Full Portfolio</a>
	</div>
</section>

<style>
	.pmasonry {
		padding-bottom: 6rem;
	}

	.pmasonry__grid {
		columns: 3;
		column-gap: 15px;
		padding: 4rem 3rem 0;
		max-width: 1400px;
		margin: 0 auto;
	}

	.pmasonry__item {
		break-inside: avoid;
		margin-bottom: 15px;
		overflow: hidden;
	}

	.pmasonry__item img {
		width: 100%;
		display: block;
		transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.pmasonry__item:hover img {
		transform: scale(1.03);
	}

	.pmasonry__footer {
		max-width: 1400px;
		margin: 2rem auto 0;
		padding: 0 3rem;
		text-align: center;
	}

	.pmasonry__cta {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--text);
		padding: 0.7rem 2rem;
		display: inline-block;
		transition: background 0.2s, color 0.2s;
	}

	.pmasonry__cta:hover {
		background: var(--text);
		color: var(--bg);
	}

	@media (max-width: 900px) {
		.pmasonry__grid {
			columns: 2;
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}

		.pmasonry__footer {
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.pmasonry__grid {
			columns: 1;
		}
	}
</style>
