---
// Slim top banner — only renders when siteSettings.demo.isDemo is true.
// Shows a niche label + link back to the demo hub. Safe by construction:
// default isDemo=false means this file renders nothing on any real client
// site regardless of palette, theme, or nav variant. See siteSettings
// schema's "Demo Showcase" fieldset.
interface Props {
  demo?: {
    isDemo?: boolean;
    nicheLabel?: string;
    hubUrl?: string;
    hubLinkLabel?: string;
  } | null;
}

const { demo } = Astro.props;

if (!demo?.isDemo) {
  // Render nothing. The entire file is a no-op on non-demo deploys.
}

const nicheLabel = demo?.nicheLabel || 'Template demo';
const hubUrl = demo?.hubUrl || '';
const hubLinkLabel = demo?.hubLinkLabel || 'View all demos';
---

{demo?.isDemo && (
  <div class="demo-banner" role="region" aria-label="Demo site notice">
    <div class="demo-banner__inner">
      <span class="demo-banner__label">
        <span class="demo-banner__pill">Demo</span>
        <span class="demo-banner__niche">{nicheLabel}</span>
      </span>
      {hubUrl && (
        <a class="demo-banner__link" href={hubUrl}>
          {hubLinkLabel}
          <span class="demo-banner__arrow" aria-hidden="true">&rarr;</span>
        </a>
      )}
    </div>
  </div>
)}

<style>
  .demo-banner {
    background: #111;
    color: #f5f3ef;
    font-family: var(--font-sans, var(--font-body), system-ui);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    position: relative;
    z-index: 200;
  }
  .demo-banner__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.55rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .demo-banner__label {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }
  .demo-banner__pill {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    background: #f5f3ef;
    color: #111;
    border-radius: 2px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.65rem;
  }
  .demo-banner__niche {
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.92;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .demo-banner__link {
    color: #f5f3ef;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }
  .demo-banner__arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }
  .demo-banner__link:hover { opacity: 0.85; }
  .demo-banner__link:hover .demo-banner__arrow { transform: translateX(3px); }

  @media (max-width: 600px) {
    .demo-banner__inner {
      padding: 0.5rem 1rem;
      gap: 0.75rem;
    }
    .demo-banner__niche {
      font-size: 0.7rem;
    }
  }
</style>
