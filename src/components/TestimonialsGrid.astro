---
const { theme = 'classic-cream' } = Astro.props;

// TODO:NICHE — fallback testimonials reference dogs/breeds; update for your niche
const testimonials = [
	{
		photoUrl: 'https://images.pexels.com/photos/1108099/pexels-photo-1108099.jpeg?auto=compress&cs=tinysrgb&w=160&h=160&fit=crop',
		photoAlt: 'Golden retriever in warm afternoon light', // TODO:NICHE
		quote: "Hazel captured something in Biscuit that we'd been trying to capture ourselves for years. Every single image is breathtaking. We have them printed throughout our home and can't stop looking at them.", // TODO:NICHE
		name: 'Sarah & Tom K.',
		pet: 'Biscuit, Golden Retriever', // TODO:NICHE
	},
	{
		photoUrl: 'https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=160&h=160&fit=crop',
		photoAlt: 'Dog exploring outdoors with a stick', // TODO:NICHE
		quote: "I was skeptical that Penny would cooperate for even five minutes. Hazel had her completely at ease within seconds. The patience and genuine love for dogs she brings to every session is unlike anything I've experienced.", // TODO:NICHE
		name: 'Marcus R.',
		pet: 'Penny, Rescue Mix', // TODO:NICHE
	},
	{
		photoUrl: 'https://images.pexels.com/photos/825949/pexels-photo-825949.jpeg?auto=compress&cs=tinysrgb&w=160&h=160&fit=crop',
		photoAlt: 'Dog portrait in natural light', // TODO:NICHE
		quote: "Three sessions in and each gallery is more beautiful than the last. Hazel has a gift for capturing the soul of a dog — not just their face, but everything that makes them who they are.", // TODO:NICHE
		name: 'Jess & Olivia M.',
		pet: 'Chester, Labrador', // TODO:NICHE
	},
];
---

<section class="tgrid" data-theme={theme}>
	<hr />
	<div class="tgrid__inner">
		<p class="tgrid__heading">Kind Words from Kind Clients</p>
		<div class="tgrid__cards">
			{testimonials.map((t) => (
				<div class="tgrid__card">
					<div class="tgrid__photo-wrap">
						<img src={t.photoUrl} alt={t.photoAlt} loading="lazy" />
					</div>
					<blockquote class="tgrid__quote">&ldquo;{t.quote}&rdquo;</blockquote>
					<p class="tgrid__name">{t.name}</p>
					<p class="tgrid__pet">{t.pet}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.tgrid {
		padding-bottom: 6rem;
	}

	.tgrid__inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 3rem;
	}

	.tgrid__heading {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: clamp(1.5rem, 2.5vw, 2.25rem);
		color: var(--text);
		text-align: center;
		padding: 5rem 0 4rem;
	}

	.tgrid__cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.tgrid__card {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		padding: 2.5rem 2rem 2rem;
		background: var(--bg-alt);
	}

	.tgrid__photo-wrap {
		width: 64px;
		height: 64px;
		border-radius: 50%;
		overflow: hidden;
		margin-bottom: 1.75rem;
		flex-shrink: 0;
	}

	.tgrid__photo-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.tgrid__quote {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: 1rem;
		line-height: 1.8;
		color: var(--text);
		margin: 0 0 1.5rem;
		flex: 1;
	}

	.tgrid__name {
		font-family: var(--font-sans);
		font-variant: small-caps;
		font-size: 0.8125rem;
		letter-spacing: 0.08em;
		color: var(--text);
		margin-bottom: 0.25rem;
	}

	.tgrid__pet {
		font-family: var(--font-sans);
		font-size: 0.75rem;
		letter-spacing: 0.06em;
		color: var(--muted);
	}

	@media (max-width: 900px) {
		.tgrid__cards {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 560px) {
		.tgrid__inner {
			padding: 0 1.5rem;
		}

		.tgrid__cards {
			grid-template-columns: 1fr;
		}
	}
</style>
