---
/**
 * SanityImage — use this for ALL content images throughout the site.
 * Never use a plain <img> tag for Sanity-sourced images.
 * Handles: srcset, sizes, width/height (CLS prevention), lazy loading, WebP via Sanity CDN.
 *
 * Usage:
 *   <SanityImage image={sanityImageObject} sizes="(max-width: 900px) 100vw, 50vw" />
 */
import { buildSrc, buildSrcset, getDimensions } from '../lib/image';

interface Props {
  image: any;
  sizes: string;
  loading?: 'lazy' | 'eager';
  class?: string;
  widths?: number[];
  displayWidth?: number;
  displayHeight?: number;
  quality?: number;
}

const {
  image,
  sizes,
  loading = 'lazy',
  class: className,
  widths,
  displayWidth,
  displayHeight,
  quality,
} = Astro.props;

if (!image?.asset) return;

// Above-fold images (loading="eager") render at quality 85 by default for
// visible sharpness. Lazy images stay at 80. An explicit quality prop wins.
const effectiveQuality = quality ?? (loading === 'eager' ? 85 : 80);

const src    = buildSrc(image, 1200, effectiveQuality);
const srcset = buildSrcset(image, widths, effectiveQuality);
const { width, height } = getDimensions(image);
const attrWidth  = displayWidth  ?? Math.min(width, 1200);
const attrHeight = displayHeight ?? Math.round((attrWidth / width) * height);
const alt = image.alt ?? '';
---

<img
  src={src}
  srcset={srcset}
  sizes={sizes}
  width={attrWidth}
  height={attrHeight}
  alt={alt}
  loading={loading}
  decoding={loading === 'eager' ? 'sync' : 'async'}
  fetchpriority={loading === 'eager' ? 'high' : undefined}
  class={className}
/>
