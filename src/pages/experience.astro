---
import Layout from '../layouts/Layout.astro';

// TODO:NICHE — update FAQ answers, pricing, and copy for your niche
const faqs = [
	{
		q: 'How do I book a session?',
		a: 'Reach out via the contact form or email and we\'ll set up a quick call to chat through your vision, location options, and timing. Once we\'ve confirmed the details, a deposit and signed agreement will secure your date.',
	},
	{
		q: 'Do you work with shy, reactive, or senior subjects?',
		a: 'Absolutely. Sessions are led entirely by the subject\'s comfort level. There\'s no pressure to perform, and we move at whatever pace feels right. Some of the most beautiful sessions have come from the quietest moments.',
	},
	{
		q: 'When will I receive my images?',
		a: 'Your private online gallery will be delivered within three weeks of your session. You\'ll have time to review everything before choosing your favorites for prints, albums, or digital downloads.',
	},
	{
		q: 'Can I be in the photos too?',
		a: 'Yes — and I encourage it. The relationship and connection between you and your subject is often the most meaningful thing to document. Just let me know when you book and we\'ll plan for it.',
	},
	{
		q: 'Where do sessions take place?',
		a: 'Sessions can take place anywhere that feels meaningful to you — a favourite park, your home, a special location. I\'m happy to suggest spots with beautiful light if you\'d prefer a recommendation.',
	},
	{
		q: 'How long does a session last?',
		a: 'Most sessions run between 60 and 90 minutes. This gives us enough time to warm up, explore the space, and capture a range of natural moments without anyone feeling rushed or tired.',
	},
	{
		q: 'What if my subject isn\'t trained or doesn\'t sit still?',
		a: 'That\'s completely fine — and very normal. I don\'t work with rigid shot lists or expect perfect behaviour. Movement, chaos, and personality make for the best photographs. We\'ll work with whatever the session gives us.',
	},
];
---

<Layout>
	<main>

		<!-- ══ SECTION 1: Full-Bleed Hero Image ══ -->
		<section class="hero">
			<img
				class="hero__img"
				src="https://images.pexels.com/photos/1629781/pexels-photo-1629781.jpeg?auto=compress&cs=tinysrgb&w=1600"
				alt="Dog running through an open field in warm afternoon light"
				loading="eager"
			/>
			<div class="hero__overlay" aria-hidden="true"></div>
			<div class="hero__content">
				<h1 class="hero__heading">The Experience &amp; Investment</h1>
				<p class="hero__sub">What working together looks like, from your session to finished artwork.</p>
			</div>
		</section>

		<!-- ══ SECTION 2: Intro Text ══ -->
		<section class="intro" data-theme="classic-cream">
			<div class="intro__inner">
				<p class="intro__body">Every session is designed to feel relaxed, subject-led, and pressure-free. From planning your session to choosing your final images, you'll be guided through each step so the experience feels easy and enjoyable.</p>{/* TODO:NICHE */}
				<p class="intro__body intro__body--bold">There's no need for perfect behavior or posing — the focus is on creating space for natural moments to unfold.</p>{/* TODO:NICHE */}
			</div>
		</section>

		<!-- ══ SECTION 3: Sessions ══ -->
		<section class="sessions" data-theme="warm-studio">
			<hr />
			<div class="sessions__inner">
				<div class="sessions__img-wrap">
					<img
						src="https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=900&h=900&fit=crop"
						alt="Session photograph in golden afternoon light"
						loading="lazy"
					/>
				</div>
				<div class="sessions__content">
					<h2 class="sessions__heading">Sessions</h2>
					<p class="sessions__sub">The session fee covers the time, care, and preparation that go into creating your photography experience.</p>{/* TODO:NICHE */}
					<p class="sessions__includes"><em><strong>This includes:</strong></em></p>
					<ul class="sessions__list">
						<li>Pre-session guidance to help you feel prepared</li>
						<li>A relaxed, unhurried photo session</li>
						<li>A curated online gallery to view and select your images</li>
					</ul>
					<p class="sessions__price"><strong>Session fee begins at $XXX</strong></p>{/* TODO:NICHE — update pricing */}
					<p class="sessions__caption"><em>(Artwork and images purchased separately.)</em></p>
				</div>
			</div>
		</section>

		<!-- ══ SECTION 4: Artwork / Images ══ -->
		<section class="artwork" data-theme="classic-cream">
			<hr />
			<div class="artwork__inner">
				<div class="artwork__content">
					<h2 class="artwork__heading">Artwork / Images</h2>
					<p class="artwork__body">After your gallery is delivered, you'll choose the images you'd like to keep — whether that's a small digital collection or a fully curated set of wall artwork. There's no pressure to decide on the day; you'll have time to sit with your gallery and choose what feels right.</p>{/* TODO:NICHE */}
					<p class="artwork__includes"><em><strong>Options may include:</strong></em></p>
					<ul class="artwork__list">
						<li>Digital image collections</li>
						<li>Fine art prints</li>
						<li>Wall artwork</li>
						<li>Albums or keepsake pieces</li>
					</ul>
					<p class="artwork__statement"><strong>You're never locked into a one-size-fits-all package — selections are flexible and based on what matters most to you.</strong></p>{/* TODO:NICHE */}
				</div>
				<div class="artwork__img-wrap">
					<img
						src="https://images.pexels.com/photos/1805164/pexels-photo-1805164.jpeg?auto=compress&cs=tinysrgb&w=800"
						alt="Candid portrait session in soft natural light"
						loading="lazy"
					/>
				</div>
			</div>
		</section>

		<!-- ══ SECTION 5: Next Steps (Full-Bleed Background) ══ -->
		<section class="next">
			<img
				class="next__bg"
				src="https://images.pexels.com/photos/3726314/pexels-photo-3726314.jpeg?auto=compress&cs=tinysrgb&w=1600"
				alt=""
				aria-hidden="true"
				loading="lazy"
			/>
			<div class="next__overlay" aria-hidden="true"></div>
			<div class="next__box">
				<h2 class="next__heading">Next Steps</h2>
				<p class="next__body">Ready to get started? Reach out and tell me a little about yourself and what you're hoping to create. I'll be in touch within 48 hours to arrange a quick call and start planning your session.</p>{/* TODO:NICHE */}
				<p class="next__body">Sessions fill up quickly, especially during spring and autumn — so if you have a time of year in mind, it's worth reaching out sooner rather than later.</p>{/* TODO:NICHE */}
				<a href="/contact" class="next__btn">Get In Touch</a>
			</div>
		</section>

		<!-- ══ SECTION 6: FAQs ══ -->
		<section class="faqs" data-theme="warm-studio">
			<hr />
			<div class="faqs__inner">
				<div class="faqs__label-col" aria-hidden="true">
					<span class="faqs__label">FAQs</span>
				</div>
				<div class="faqs__list">
					{faqs.map((faq, i) => (
						<div class="faqs__item" id={`faq-${i}`}>
							<button
								class="faqs__question"
								aria-expanded="false"
								aria-controls={`faq-answer-${i}`}
							>
								{faq.q}
								<span class="faqs__icon" aria-hidden="true">+</span>
							</button>
							<div class="faqs__answer" id={`faq-answer-${i}`} role="region">
								<blockquote class="faqs__answer-text">{faq.a}</blockquote>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

	</main>
</Layout>

<script>
	document.querySelectorAll<HTMLButtonElement>('.faqs__question').forEach((btn) => {
		btn.addEventListener('click', () => {
			const isOpen = btn.getAttribute('aria-expanded') === 'true';
			// Close all
			document.querySelectorAll<HTMLButtonElement>('.faqs__question').forEach((b) => {
				b.setAttribute('aria-expanded', 'false');
				b.closest('.faqs__item')?.classList.remove('faqs__item--open');
			});
			// Open clicked item if it was closed
			if (!isOpen) {
				btn.setAttribute('aria-expanded', 'true');
				btn.closest('.faqs__item')?.classList.add('faqs__item--open');
			}
		});
	});
</script>

<style>
	/* ══ SECTION 1: Hero ══ */
	.hero {
		position: relative;
		height: 60vh;
		min-height: 400px;
		overflow: hidden;
		display: flex;
		align-items: flex-end;
		justify-content: flex-end;
	}

	.hero__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 40%;
		display: block;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to right,
			rgba(0, 0, 0, 0.1) 0%,
			rgba(0, 0, 0, 0.55) 100%
		);
	}

	.hero__content {
		position: relative;
		z-index: 1;
		max-width: 580px;
		padding: 4rem 4rem 4rem 3rem;
		text-align: right;
	}

	.hero__heading {
		font-size: clamp(2rem, 4vw, 3.5rem);
		color: #ffffff;
		letter-spacing: -0.01em;
		margin-bottom: 1.25rem;
		line-height: 1.15;
		text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
	}

	.hero__sub {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.725rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.85);
		line-height: 1.7;
	}

	/* ══ SECTION 2: Intro ══ */
	.intro {
		border-bottom: 1px solid var(--border);
	}

	.intro__inner {
		max-width: 600px;
		margin: 0 auto;
		padding: 5.5rem 3rem;
		text-align: center;
	}

	.intro__body {
		font-style: italic;
		font-size: 1.0625rem;
		line-height: 1.82;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.intro__body:last-child {
		margin-bottom: 0;
	}

	.intro__body--bold {
		font-weight: 500;
	}

	/* ══ SECTION 3: Sessions ══ */
	.sessions {
		padding-bottom: 6rem;
	}

	.sessions__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		align-items: center;
		max-width: 1200px;
		margin: 0 auto;
		padding: 5rem 3rem 0;
	}

	.sessions__img-wrap {
		overflow: hidden;
	}

	.sessions__img-wrap img {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		display: block;
	}

	.sessions__heading {
		font-size: clamp(2.25rem, 4vw, 3.5rem);
		color: var(--text);
		margin-bottom: 1.25rem;
		letter-spacing: -0.01em;
	}

	.sessions__sub {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.75rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		line-height: 1.7;
		margin-bottom: 2rem;
	}

	.sessions__includes {
		font-size: 1rem;
		color: var(--text);
		margin-bottom: 0.75rem;
	}

	.sessions__list {
		list-style: none;
		margin-bottom: 2rem;
	}

	.sessions__list li {
		font-size: 0.9375rem;
		color: var(--muted);
		padding: 0.45rem 0 0.45rem 1.25rem;
		position: relative;
		border-bottom: 1px solid var(--border);
		line-height: 1.6;
	}

	.sessions__list li::before {
		content: '—';
		position: absolute;
		left: 0;
		color: var(--accent);
		font-size: 0.75rem;
	}

	.sessions__price {
		font-size: 1.0625rem;
		color: var(--text);
		margin-bottom: 0.5rem;
	}

	.sessions__caption {
		font-size: 0.875rem;
		color: var(--muted);
	}

	/* ══ SECTION 4: Artwork ══ */
	.artwork {
		padding-bottom: 6rem;
	}

	.artwork__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		align-items: center;
		max-width: 1200px;
		margin: 0 auto;
		padding: 5rem 3rem 0;
	}

	.artwork__heading {
		font-size: clamp(2.25rem, 4vw, 3.5rem);
		color: var(--text);
		margin-bottom: 1.5rem;
		letter-spacing: -0.01em;
	}

	.artwork__body {
		font-style: italic;
		font-size: 1.0625rem;
		line-height: 1.82;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.artwork__includes {
		font-size: 1rem;
		color: var(--text);
		margin-bottom: 0.75rem;
	}

	.artwork__list {
		list-style: none;
		margin-bottom: 2rem;
	}

	.artwork__list li {
		font-size: 0.9375rem;
		color: var(--muted);
		padding: 0.45rem 0 0.45rem 1.25rem;
		position: relative;
		border-bottom: 1px solid var(--border);
		line-height: 1.6;
	}

	.artwork__list li::before {
		content: '—';
		position: absolute;
		left: 0;
		color: var(--accent);
		font-size: 0.75rem;
	}

	.artwork__statement {
		font-size: 1.0625rem;
		color: var(--text);
		line-height: 1.65;
	}

	.artwork__img-wrap {
		overflow: hidden;
		align-self: stretch;
	}

	.artwork__img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	/* ══ SECTION 5: Next Steps ══ */
	.next {
		position: relative;
		min-height: 520px;
		display: flex;
		align-items: center;
	}

	.next__bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	.next__overlay {
		position: absolute;
		inset: 0;
		background: rgba(44, 24, 16, 0.5);
	}

	.next__box {
		position: relative;
		z-index: 1;
		background: var(--bg, #f5f3ef);
		max-width: 460px;
		margin: 4rem 0 4rem 6vw;
		padding: 3.5rem;
	}

	.next__heading {
		font-size: clamp(2rem, 3.5vw, 3rem);
		color: var(--text, #1a2744);
		margin-bottom: 1.25rem;
		letter-spacing: -0.01em;
	}

	.next__body {
		font-style: italic;
		font-size: 1rem;
		line-height: 1.82;
		color: var(--text, #1a2744);
		margin-bottom: 1.25rem;
	}

	.next__body:last-of-type {
		margin-bottom: 2rem;
	}

	.next__btn {
		display: inline-block;
		font-family: var(--font-sans, system-ui, sans-serif);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text, #1a2744);
		text-decoration: none;
		border: 1px solid var(--text, #1a2744);
		padding: 0.7rem 1.75rem;
		transition: background 0.2s, color 0.2s;
	}

	.next__btn:hover {
		background: var(--text, #1a2744);
		color: var(--bg, #f5f3ef);
	}

	/* ══ SECTION 6: FAQs ══ */
	.faqs {
		padding-bottom: 7rem;
	}

	.faqs__inner {
		display: grid;
		grid-template-columns: 100px 1fr;
		max-width: 1100px;
		margin: 0 auto;
		padding: 5rem 3rem 0;
		gap: 2rem;
	}

	.faqs__label-col {
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding-top: 0.5rem;
	}

	.faqs__label {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: clamp(1.5rem, 2.5vw, 2.25rem);
		letter-spacing: 0.12em;
		color: var(--border);
		writing-mode: vertical-rl;
		transform: rotate(180deg);
		white-space: nowrap;
		user-select: none;
	}

	.faqs__list {
		display: flex;
		flex-direction: column;
	}

	.faqs__item {
		border-top: 1px solid var(--border);
	}

	.faqs__item:last-child {
		border-bottom: 1px solid var(--border);
	}

	.faqs__question {
		width: 100%;
		background: none;
		border: none;
		padding: 1.5rem 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		cursor: pointer;
		font-family: var(--font-serif);
		font-style: italic;
		font-size: 1.125rem;
		color: var(--text);
		text-align: left;
		line-height: 1.4;
		transition: color 0.2s;
	}

	.faqs__question:hover {
		color: var(--accent);
	}

	.faqs__icon {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 1.25rem;
		font-weight: 300;
		color: var(--accent);
		flex-shrink: 0;
		transition: transform 0.25s ease;
		line-height: 1;
	}

	.faqs__item--open .faqs__icon {
		transform: rotate(45deg);
	}

	.faqs__answer {
		display: none;
		padding-bottom: 1.75rem;
	}

	.faqs__item--open .faqs__answer {
		display: block;
	}

	.faqs__answer-text {
		font-size: 0.9375rem;
		line-height: 1.78;
		color: var(--muted);
		border-left: 2px solid var(--accent);
		padding-left: 1.25rem;
		margin: 0;
	}

	/* ══ Responsive ══ */
	@media (max-width: 900px) {
		.hero__content {
			padding: 2rem 1.5rem;
			max-width: none;
			text-align: left;
		}

		.hero__overlay {
			background: rgba(0, 0, 0, 0.4);
		}

		.intro__inner {
			padding: 4rem 1.5rem;
		}

		.sessions__inner,
		.artwork__inner {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}

		.artwork__img-wrap img {
			height: 55vw;
			min-height: 280px;
		}

		.next__box {
			margin: 3rem 1.5rem;
			padding: 2.5rem 2rem;
			max-width: none;
		}

		.faqs__inner {
			grid-template-columns: 1fr;
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}

		.faqs__label-col {
			display: none;
		}
	}
</style>
