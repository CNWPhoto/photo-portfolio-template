---
import Layout from '../layouts/Layout.astro';

// TODO:NICHE — update FAQ answers and pricing for your niche
const faqs = [
	{
		q: 'How do I book a session?',
		a: "Simply reach out through the contact form to start the conversation. You'll be guided through the next steps from there.",
	},
	{
		q: 'Do you work with shy, reactive, or senior dogs?',
		a: 'Absolutely. Sessions are approached with patience and flexibility, and every dog is photographed at their own pace.',
	},
	{
		q: 'When will I receive my images?',
		a: "You'll receive a curated online gallery within a few weeks of your session, featuring thoughtfully edited images ready to enjoy and share.",
	},
	{
		q: 'Can I be in the photos with my dog?',
		a: 'Yes — pet and owner photos are always welcome and focus on natural connection rather than posed moments.',
	},
	{
		q: 'Where do dog photography sessions take place?',
		a: "Sessions take place at quiet, dog-friendly outdoor locations chosen with your dog's comfort and safety in mind.",
	},
	{
		q: 'How long does a session last?',
		a: 'Most sessions last about an hour, allowing enough time to settle in, explore, and capture natural moments without rushing.',
	},
	{
		q: "What if my dog isn't trained or doesn't sit still?",
		a: "That's completely okay. Sessions are relaxed and dog-led, with plenty of time for movement, breaks, and patience so your dog can be themselves.",
	},
];
---

<Layout>
	<main>

		<!-- ══ SECTION 1: Full-Bleed Hero Image ══ -->
		<section class="hero">
			<img
				class="hero__img"
				src="https://images.pexels.com/photos/1629781/pexels-photo-1629781.jpeg?auto=compress&cs=tinysrgb&w=1600"
				alt="Dog running through an open field in warm afternoon light"
				loading="eager" decoding="async"
			/>
			<div class="hero__overlay" aria-hidden="true"></div>
			<div class="hero__content">
				<h1 class="hero__heading">The Experience &amp; Investment</h1>
				<p class="hero__sub">Relaxed, natural dog portraits designed to celebrate your dog</p>
			</div>
		</section>

		<!-- ══ SECTION 2: Intro ══ -->
		<section class="intro" data-theme="classic-cream">
			<div class="intro__inner">
				<p class="intro__body reveal reveal-delay-1">Every dog photography session is designed to feel relaxed, dog-led, and pressure-free. From planning your session to choosing your final images, you'll be guided through each step so the experience feels easy and enjoyable for both you and your dog.</p>
				<p class="intro__body intro__body--bold reveal reveal-delay-2">There's no need for perfect behavior or posing — the focus is on creating space for natural moments to unfold.</p>
				<p class="intro__includes reveal reveal-delay-3"><em>This includes:</em></p>
				<ul class="intro__list reveal reveal-delay-4">
					<li>Pre-session guidance to help you feel prepared</li>
					<li>A relaxed, unhurried photo session</li>
					<li>A curated online gallery to view and select your images</li>
				</ul>
				<p class="intro__price reveal reveal-delay-5">Session fee begins at $XXX<br /><em>(Artwork and images purchased separately.)</em></p>{/* TODO:NICHE — update pricing */}
				<p class="intro__closing reveal reveal-delay-5">The session fee covers the time, care, and preparation that go into creating your dog's photography experience.</p>
			</div>
		</section>

		<!-- ══ SECTION 3: Sessions ══ -->
		<section class="sessions" data-theme="warm-studio">
			<hr />
			<div class="sessions__inner">
				<div class="sessions__img-wrap reveal-fade reveal-delay-1">
					<img
						src="https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=900&h=900&fit=crop"
						alt="Session photograph in golden afternoon light"
						loading="lazy" decoding="async"
					/>
				</div>
				<div class="sessions__content">
					<p class="sessions__eyebrow">Sessions</p>
					<h2 class="sessions__heading">$XXX</h2>{/* TODO:NICHE — update pricing */}
					<p class="sessions__sub">Session fee begins at</p>
					<p class="sessions__body reveal reveal-delay-2">The session includes a relaxed, unhurried photo experience designed around your dog's pace and comfort. Sessions are unhurried and dog-led, with time built in for your pup to settle, explore, and be themselves.</p>
					<ul class="sessions__list reveal reveal-delay-3">
						<li>Relaxed outdoor setting</li>
						<li>Dog-led pacing and comfort</li>
						<li>Natural, unposed moments</li>
						<li>Professional guidance throughout</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- ══ SECTION 4: Artwork / Images ══ -->
		<section class="artwork" data-theme="classic-cream">
			<hr />
			<div class="artwork__inner">
				<div class="artwork__content reveal reveal-delay-1">
					<h2 class="artwork__heading">After your session, you'll select your favorite images from an online gallery. A variety of digital image and artwork options are available, allowing you to choose how you'd like to enjoy your photos.</h2>
					<p class="artwork__includes"><em>Options may include:</em></p>
					<ul class="artwork__list">
						<li>Digital image collections</li>
						<li>Fine art prints</li>
						<li>Wall artwork</li>
						<li>Albums or keepsake pieces</li>
					</ul>
					<p class="artwork__statement">You're never locked into a one-size-fits-all package — selections are flexible and based on what matters most to you.</p>
				</div>
				<div class="artwork__img-wrap reveal-fade reveal-delay-2">
					<img
						src="https://images.pexels.com/photos/1805164/pexels-photo-1805164.jpeg?auto=compress&cs=tinysrgb&w=800"
						alt="Candid portrait session in soft natural light"
						loading="lazy" decoding="async"
					/>
				</div>
			</div>
		</section>

		<!-- ══ SECTION 5: Next Steps ══ -->
		<section class="next">
			<img
				class="next__bg"
				src="https://images.pexels.com/photos/3726314/pexels-photo-3726314.jpeg?auto=compress&cs=tinysrgb&w=1600"
				alt=""
				aria-hidden="true"
				loading="lazy" decoding="async"
			/>
			<div class="next__overlay" aria-hidden="true"></div>
			<div class="next__box">
				<p class="next__label reveal reveal-delay-1">Next Steps</p>
				<h2 class="next__heading reveal reveal-delay-2">Get in touch</h2>
				<p class="next__body reveal reveal-delay-3">If this experience feels like the right fit for you and your dog, the next step is simply reaching out to start the conversation.</p>
				<p class="next__body reveal reveal-delay-4">I'm happy to answer questions, talk through options, and help you decide if this is the right experience for you.</p>
				<a href="/contact" class="next__btn reveal reveal-delay-5">Get in touch</a>
			</div>
		</section>

		<!-- ══ SECTION 6: FAQs ══ -->
		<section class="faqs" id="faqs" data-theme="warm-studio">
			<hr />
			<div class="faqs__inner">
				<div class="faqs__label-col" aria-hidden="true">
					<span class="faqs__label">FAQs</span>
				</div>
				<div class="faqs__list">
					{faqs.map((faq, i) => (
						<div class={`faqs__item reveal reveal-delay-${Math.min(i + 1, 5)}`} id={`faq-${i}`}>
							<button
								class="faqs__question"
								aria-expanded="false"
								aria-controls={`faq-answer-${i}`}
							>
								{faq.q}
								<span class="faqs__icon" aria-hidden="true">+</span>
							</button>
							<div class="faqs__answer" id={`faq-answer-${i}`} role="region">
								<blockquote class="faqs__answer-text">{faq.a}</blockquote>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

	</main>
</Layout>

<script>
	document.querySelectorAll<HTMLButtonElement>('.faqs__question').forEach((btn) => {
		btn.addEventListener('click', () => {
			const isOpen = btn.getAttribute('aria-expanded') === 'true';
			// Close all
			document.querySelectorAll<HTMLButtonElement>('.faqs__question').forEach((b) => {
				b.setAttribute('aria-expanded', 'false');
				b.closest('.faqs__item')?.classList.remove('faqs__item--open');
			});
			// Open clicked item if it was closed
			if (!isOpen) {
				btn.setAttribute('aria-expanded', 'true');
				btn.closest('.faqs__item')?.classList.add('faqs__item--open');
			}
		});
	});
</script>

<style>
	/* ══ SECTION 1: Hero ══ */
	.hero {
		position: relative;
		height: 60vh;
		min-height: 400px;
		overflow: hidden;
		display: flex;
		align-items: flex-end;
		justify-content: flex-end;
	}

	.hero__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 40%;
		display: block;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to right,
			rgba(0, 0, 0, 0.1) 0%,
			rgba(0, 0, 0, 0.6) 100%
		);
	}

	.hero__content {
		position: relative;
		z-index: 1;
		max-width: 580px;
		padding: 4rem 4rem 4rem 3rem;
		text-align: right;
	}

	.hero__heading {
		font-size: clamp(2rem, 4vw, 3.5rem);
		color: #ffffff;
		letter-spacing: -0.01em;
		margin-bottom: 1.25rem;
		line-height: 1.15;
		text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
	}

	.hero__sub {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.725rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.85);
		line-height: 1.7;
	}

	/* ══ SECTION 2: Intro ══ */
	.intro {
		border-bottom: 1px solid var(--border);
	}

	.intro__inner {
		max-width: 620px;
		margin: 0 auto;
		padding: 5.5rem 3rem;
		text-align: center;
	}

	.intro__body {
		font-style: italic;
		font-size: 1.0625rem;
		line-height: 1.82;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.intro__body--bold {
		font-weight: 500;
	}

	.intro__includes {
		font-size: 1rem;
		color: var(--text);
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}

	.intro__list {
		list-style: none;
		margin: 0 auto 2rem;
		text-align: left;
		max-width: 420px;
	}

	.intro__list li {
		font-size: 1rem;
		color: var(--muted);
		padding: 0.45rem 0 0.45rem 1.25rem;
		position: relative;
		border-bottom: 1px solid var(--border);
		line-height: 1.6;
	}

	.intro__list li::before {
		content: '—';
		position: absolute;
		left: 0;
		color: var(--accent);
		font-size: 0.75rem;
	}

	.intro__price {
		font-size: 1.0625rem;
		color: var(--text);
		line-height: 1.7;
		margin-bottom: 1.25rem;
	}

	.intro__closing {
		font-style: italic;
		font-size: 0.9375rem;
		color: var(--muted);
		line-height: 1.75;
	}

	/* ══ SECTION 3: Sessions ══ */
	.sessions {
		padding-bottom: 6rem;
	}

	.sessions__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		align-items: center;
		max-width: 1100px;
		margin: 0 auto;
		padding: 5rem 3rem 0;
	}

	.sessions__img-wrap {
		overflow: hidden;
	}

	.sessions__img-wrap img {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		display: block;
	}

	.sessions__eyebrow {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 0.75rem;
	}

	.sessions__heading {
		font-size: clamp(3rem, 6vw, 5rem);
		color: var(--text);
		letter-spacing: -0.02em;
		line-height: 1;
		margin-bottom: 0.5rem;
	}

	.sessions__sub {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.75rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 2rem;
	}

	.sessions__body {
		font-style: italic;
		font-size: 1.0625rem;
		line-height: 1.82;
		color: var(--text);
		margin-bottom: 2rem;
	}

	.sessions__list {
		list-style: none;
	}

	.sessions__list li {
		font-size: 1rem;
		color: var(--muted);
		padding: 0.45rem 0 0.45rem 1.25rem;
		position: relative;
		border-bottom: 1px solid var(--border);
		line-height: 1.6;
	}

	.sessions__list li::before {
		content: '—';
		position: absolute;
		left: 0;
		color: var(--accent);
		font-size: 0.75rem;
	}

	/* ══ SECTION 4: Artwork ══ */
	.artwork {
		padding-bottom: 6rem;
	}

	.artwork__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		align-items: center;
		max-width: 1100px;
		margin: 0 auto;
		padding: 5rem 3rem 0;
	}

	.artwork__heading {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: clamp(1.125rem, 2vw, 1.5rem);
		line-height: 1.6;
		color: var(--text);
		letter-spacing: -0.01em;
		margin-bottom: 2rem;
		font-weight: 400;
	}

	.artwork__includes {
		font-size: 1rem;
		color: var(--text);
		margin-bottom: 0.75rem;
	}

	.artwork__list {
		list-style: none;
		margin-bottom: 2rem;
	}

	.artwork__list li {
		font-size: 0.9375rem;
		color: var(--muted);
		padding: 0.45rem 0 0.45rem 1.25rem;
		position: relative;
		border-bottom: 1px solid var(--border);
		line-height: 1.6;
	}

	.artwork__list li::before {
		content: '—';
		position: absolute;
		left: 0;
		color: var(--accent);
		font-size: 0.75rem;
	}

	.artwork__statement {
		font-style: italic;
		font-size: 1.0625rem;
		color: var(--text);
		line-height: 1.65;
	}

	.artwork__img-wrap {
		overflow: hidden;
		align-self: stretch;
	}

	.artwork__img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	/* ══ SECTION 5: Next Steps ══ */
	.next {
		position: relative;
		min-height: 520px;
		display: flex;
		align-items: center;
	}

	.next__bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	.next__overlay {
		position: absolute;
		inset: 0;
		background: rgba(44, 24, 16, 0.5);
	}

	.next__box {
		position: relative;
		z-index: 1;
		background: var(--bg);
		max-width: 460px;
		margin: 4rem 0 4rem 6vw;
		padding: 3.5rem;
	}

	.next__label {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1rem;
	}

	.next__heading {
		font-size: clamp(2rem, 3.5vw, 3rem);
		color: var(--text);
		margin-bottom: 1.5rem;
		letter-spacing: -0.01em;
	}

	.next__body {
		font-style: italic;
		font-size: 1rem;
		line-height: 1.82;
		color: var(--text);
		margin-bottom: 1.25rem;
	}

	.next__body:last-of-type {
		margin-bottom: 2rem;
	}

	.next__btn {
		display: inline-block;
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--text);
		padding: 0.7rem 1.75rem;
		transition: background 0.25s, color 0.25s, transform 0.2s, box-shadow 0.25s;
	}

	.next__btn:hover {
		background: var(--text);
		color: var(--bg);
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(26, 39, 68, 0.18);
	}

	/* ══ SECTION 6: FAQs ══ */
	.faqs {
		padding-bottom: 7rem;
	}

	.faqs__inner {
		display: grid;
		grid-template-columns: 100px 1fr;
		max-width: 1100px;
		margin: 0 auto;
		padding: 5rem 3rem 0;
		gap: 2rem;
	}

	.faqs__label-col {
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding-top: 0.5rem;
	}

	.faqs__label {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: clamp(1.5rem, 2.5vw, 2.25rem);
		letter-spacing: 0.12em;
		color: var(--border);
		writing-mode: horizontal-tb;
		transform: rotate(-90deg);
		transform-origin: center center;
		white-space: nowrap;
		user-select: none;
	}

	.faqs__list {
		display: flex;
		flex-direction: column;
	}

	.faqs__item {
		border-top: 1px solid var(--border);
	}

	.faqs__item:last-child {
		border-bottom: 1px solid var(--border);
	}

	.faqs__question {
		width: 100%;
		background: none;
		border: none;
		padding: 1.5rem 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		cursor: pointer;
		font-family: var(--font-serif);
		font-style: italic;
		font-size: 1.125rem;
		color: var(--text);
		text-align: left;
		line-height: 1.4;
		transition: color 0.2s;
	}

	.faqs__question:hover {
		color: var(--accent);
	}

	.faqs__icon {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 1.25rem;
		font-weight: 300;
		color: var(--accent);
		flex-shrink: 0;
		transition: transform 0.25s ease;
		line-height: 1;
	}

	.faqs__item--open .faqs__icon {
		transform: rotate(45deg);
	}

	.faqs__answer {
		display: none;
		padding-bottom: 1.75rem;
	}

	.faqs__item--open .faqs__answer {
		display: block;
	}

	.faqs__answer-text {
		font-size: 0.9375rem;
		line-height: 1.78;
		color: var(--muted);
		border-left: 2px solid var(--accent);
		padding-left: 1.25rem;
		margin: 0;
	}

	/* ══ Responsive ══ */
	@media (max-width: 900px) {
		.hero__content {
			padding: 2rem 1.5rem;
			max-width: none;
			text-align: left;
		}

		.hero__overlay {
			background: rgba(0, 0, 0, 0.45);
		}

		.intro__inner {
			padding: 4rem 1.5rem;
		}

		.intro__list {
			max-width: none;
		}

		.sessions__inner,
		.artwork__inner {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}

		.artwork__img-wrap img {
			height: 55vw;
			min-height: 280px;
		}

		.next__box {
			margin: 3rem 1.5rem;
			padding: 2.5rem 2rem;
			max-width: none;
		}

		.faqs__inner {
			grid-template-columns: 1fr;
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}

		.faqs__label-col {
			display: none;
		}
	}
</style>
