---
import Layout from '../layouts/Layout.astro';
import { getClient, urlFor } from '../lib/sanity.js';

const expDoc = await getClient(Astro.locals.isPreview).fetch(
  `*[_type == "experiencePage"][0]{
    pageTitle,
    seo { seoTitle, seoDescription, socialImage { asset->{ url } } },
    "sections": sections[] {
      _type, enabled,
      image { ..., asset-> },
      heading, subtext,
      bodyFirst, bodySecond,
      sub,
      "includesList": includesList[].text,
      price, caption,
      bodyText,
      "optionsList": optionsList[].text,
      statement,
      backgroundImage { ..., asset-> },
      label, bodyFirst, bodySecond, ctaText, ctaLink,
      "faqs": faqs[] { question, answer }
    }
  }`,
  {},
  { cache: 'no-store' }
);

const getSection = (type: string) => expDoc?.sections?.find((s: any) => s._type === type);

const seoTitle       = expDoc?.seo?.seoTitle       || expDoc?.pageTitle || null;
const seoDescription = expDoc?.seo?.seoDescription || null;
const ogImage        = expDoc?.seo?.socialImage?.asset?.url || null;

const hero      = getSection('experienceHero');
const intro     = getSection('experienceIntro');
const sessions  = getSection('experienceSessions');
const artwork   = getSection('experienceArtwork');
const nextSteps = getSection('experienceNextSteps');
const faqsSec   = getSection('experienceFaqs');

// ── Fallback content (used until Sanity is populated) ─────────────────────
const heroImgSrc = hero?.image
  ? urlFor(hero.image).width(1600).auto('format').url()
  : 'https://images.pexels.com/photos/1629781/pexels-photo-1629781.jpeg?auto=compress&cs=tinysrgb&w=1600';
const heroImgAlt  = hero?.image?.alt  || 'Dog running through an open field in warm afternoon light';
const heroHeading = hero?.heading     || 'The Experience & Investment';
const heroSub     = hero?.subtext     || 'What working together looks like, from your session to finished artwork.';

const introBody1 = intro?.bodyFirst  || 'Every dog photography session is designed to feel relaxed, dog-led, and pressure-free. From planning your session to choosing your final images, you\'ll be guided through each step so the experience feels easy and enjoyable for both you and your dog.';
const introBody2 = intro?.bodySecond || 'There\'s no need for perfect behavior or posing — the focus is on creating space for natural moments to unfold.';

const sessionsImgSrc  = sessions?.image
  ? urlFor(sessions.image).width(900).height(900).fit('crop').auto('format').url()
  : 'https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=900&h=900&fit=crop';
const sessionsImgAlt  = sessions?.image?.alt || 'Session photograph in golden afternoon light';
const sessionsHeading = sessions?.heading    || 'Sessions';
const sessionsSub     = sessions?.sub        || "The session fee covers the time, care, and preparation that go into creating your dog's photography experience.";
const sessionsIncludes = sessions?.includesList?.length
  ? sessions.includesList
  : ['Pre-session guidance to help you feel prepared', 'A relaxed, unhurried photo session', 'A curated online gallery to view and select your images'];
const sessionsPrice   = sessions?.price   || 'Session fee begins at $XXX'; // TODO:NICHE — update pricing
const sessionsCaption = sessions?.caption || '(Artwork and images purchased separately.)';

const artworkHeading  = artwork?.heading   || 'Artwork/Images';
const artworkBody     = artwork?.bodyText  || "After your session, you'll select your favorite images from an online gallery. A variety of digital image and artwork options are available, allowing you to choose how you'd like to enjoy your photos.";
const artworkOptions  = artwork?.optionsList?.length
  ? artwork.optionsList
  : ['Digital image collections', 'Fine art prints', 'Wall artwork', 'Albums or keepsake pieces'];
const artworkStatement = artwork?.statement || "You're never locked into a one-size-fits-all package — selections are flexible and based on what matters most to you.";
const artworkImgSrc   = artwork?.image
  ? urlFor(artwork.image).width(800).auto('format').url()
  : 'https://images.pexels.com/photos/1805164/pexels-photo-1805164.jpeg?auto=compress&cs=tinysrgb&w=800';
const artworkImgAlt   = artwork?.image?.alt || 'Candid portrait session in soft natural light';

const nextBgSrc   = nextSteps?.backgroundImage
  ? urlFor(nextSteps.backgroundImage).width(1600).auto('format').url()
  : 'https://images.pexels.com/photos/3726314/pexels-photo-3726314.jpeg?auto=compress&cs=tinysrgb&w=1600';
const nextLabel   = nextSteps?.label      || 'Next Steps';
const nextHeading = nextSteps?.heading    || 'Get in touch';
const nextBody1   = nextSteps?.bodyFirst  || 'If this experience feels like the right fit for you and your dog, the next step is simply reaching out to start the conversation.';
const nextBody2   = nextSteps?.bodySecond || "I'm happy to answer questions, talk through options, and help you decide if this is the right experience for you.";
const nextCtaText = nextSteps?.ctaText    || 'Get in touch';
const nextCtaLink = nextSteps?.ctaLink    || '/contact';

// ── Schema ───────────────────────────────────────────────────────────────────
const faqsForSchema = faqsSec?.faqs?.length ? faqsSec.faqs : null;
const faqSchemaData = faqsForSchema
	? [{ '@type': 'FAQPage', mainEntity: faqsForSchema.map((f: any) => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } })) }]
	: undefined;

// TODO:NICHE — update FAQ answers for your niche
const faqs = faqsSec?.faqs?.length ? faqsSec.faqs.map((f: any) => ({q: f.question, a: f.answer})) : [
  { q: 'How do I book a session?', a: "Simply reach out through the contact form to start the conversation. You'll be guided through the next steps from there." },
  { q: 'Do you work with shy, reactive, or senior dogs?', a: 'Absolutely. Sessions are approached with patience and flexibility, and every dog is photographed at their own pace.' },
  { q: 'When will I receive my images?', a: "You'll receive a curated online gallery within a few weeks of your session, featuring thoughtfully edited images ready to enjoy and share." },
  { q: 'Can I be in the photos with my dog?', a: 'Yes — pet and owner photos are always welcome and focus on natural connection rather than posed moments.' },
  { q: 'Where do dog photography sessions take place?', a: "Sessions take place at quiet, dog-friendly outdoor locations chosen with your dog's comfort and safety in mind." },
  { q: 'How long does a session last?', a: 'Most sessions last about an hour, allowing enough time to settle in, explore, and capture natural moments without rushing.' },
  { q: "What if my dog isn't trained or doesn't sit still?", a: "That's completely okay. Sessions are relaxed and dog-led, with plenty of time for movement, breaks, and patience so your dog can be themselves." },
];
---

<Layout pageTitle={seoTitle} seoDescription={seoDescription} ogImage={ogImage} breadcrumb="Experience" schemaData={faqSchemaData}>
	<main>

		<!-- ══ SECTION 1: Full-Bleed Hero Image ══ -->
		<section class="hero">
			<img
				class="hero__img"
				src={heroImgSrc}
				alt={heroImgAlt}
				loading="eager" decoding="async"
			/>
			<div class="hero__overlay" aria-hidden="true"></div>
			<div class="hero__content">
				<h1 class="hero__heading">{heroHeading}</h1>
				<p class="hero__sub">{heroSub}</p>
			</div>
		</section>

		<!-- ══ SECTION 2: Intro ══ -->
		<section class="intro">
			<div class="intro__inner">
				<p class="intro__body reveal reveal-delay-1">{introBody1}</p>
				<p class="intro__body intro__body--bold reveal reveal-delay-2">{introBody2}</p>
			</div>
		</section>

		<!-- ══ SECTION 3: Sessions ══ -->
		<section class="sessions">
			<div class="sessions__inner">
				<div class="sessions__img-wrap reveal-fade reveal-delay-1">
					<img
						src={sessionsImgSrc}
						alt={sessionsImgAlt}
						loading="lazy" decoding="async"
					/>
				</div>
				<div class="sessions__content">
					<h2 class="sessions__heading reveal reveal-delay-1">{sessionsHeading}</h2>
					<p class="sessions__sub reveal reveal-delay-2">{sessionsSub}</p>
					<p class="sessions__includes reveal reveal-delay-2"><em><strong>This includes:</strong></em></p>
					<ul class="sessions__list reveal reveal-delay-3">
						{sessionsIncludes.map((item: string) => <li>{item}</li>)}
					</ul>
					<p class="sessions__price reveal reveal-delay-4"><strong>{sessionsPrice}</strong></p>
					<p class="sessions__caption reveal reveal-delay-4"><em>{sessionsCaption}</em></p>
				</div>
			</div>
		</section>

		<!-- ══ SECTION 4: Artwork / Images ══ -->
		<section class="artwork">
			<div class="artwork__inner">
				<div class="artwork__content reveal reveal-delay-1">
					<h2 class="artwork__title">{artworkHeading}</h2>
					<p class="artwork__heading">{artworkBody}</p>
					<p class="artwork__includes"><strong>Options may include:</strong></p>
					<ul class="artwork__list">
						{artworkOptions.map((item: string) => <li>{item}</li>)}
					</ul>
					<p class="artwork__statement">{artworkStatement}</p>
				</div>
				<div class="artwork__img-wrap reveal-fade reveal-delay-2">
					<img
						src={artworkImgSrc}
						alt={artworkImgAlt}
						loading="lazy" decoding="async"
					/>
				</div>
			</div>
		</section>

		<!-- ══ SECTION 5: Next Steps ══ -->
		<section class="next">
			<img
				class="next__bg"
				src={nextBgSrc}
				alt=""
				aria-hidden="true"
				loading="lazy" decoding="async"
			/>
			<div class="next__overlay" aria-hidden="true"></div>
			<div class="next__box">
				<p class="next__label reveal reveal-delay-1">{nextLabel}</p>
				<h2 class="next__heading reveal reveal-delay-2">{nextHeading}</h2>
				<p class="next__body reveal reveal-delay-3">{nextBody1}</p>
				<p class="next__body reveal reveal-delay-4">{nextBody2}</p>
				<a href={nextCtaLink} class="next__btn reveal reveal-delay-5">{nextCtaText}</a>
			</div>
		</section>

		<!-- ══ SECTION 6: FAQs ══ -->
		<section class="faqs" id="faqs">
			<hr />
			<div class="faqs__inner">
				<div class="faqs__label-col" aria-hidden="true">
					<span class="faqs__label">FAQs</span>
				</div>
				<div class="faqs__list">
					{faqs.map((faq, i) => (
						<div class={`faqs__item reveal reveal-delay-${Math.min(i + 1, 5)}`} id={`faq-${i}`}>
							<button
								class="faqs__question"
								aria-expanded="false"
								aria-controls={`faq-answer-${i}`}
							>
								{faq.q}
								<span class="faqs__icon" aria-hidden="true">+</span>
							</button>
							<div class="faqs__answer" id={`faq-answer-${i}`} role="region">
								<blockquote class="faqs__answer-text">{faq.a}</blockquote>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

	</main>
</Layout>

<script>
	document.querySelectorAll<HTMLButtonElement>('.faqs__question').forEach((btn) => {
		btn.addEventListener('click', () => {
			const isOpen = btn.getAttribute('aria-expanded') === 'true';
			// Close all
			document.querySelectorAll<HTMLButtonElement>('.faqs__question').forEach((b) => {
				b.setAttribute('aria-expanded', 'false');
				b.closest('.faqs__item')?.classList.remove('faqs__item--open');
			});
			// Open clicked item if it was closed
			if (!isOpen) {
				btn.setAttribute('aria-expanded', 'true');
				btn.closest('.faqs__item')?.classList.add('faqs__item--open');
			}
		});
	});
</script>

<style>
	/* ══ SECTION 1: Hero ══ */
	.hero {
		position: sticky;
		top: 0;
		z-index: 0;
		height: 75vh;
		overflow: hidden;
		display: flex;
		align-items: flex-start;
		justify-content: flex-end;
	}

	/* Sections scroll over the sticky hero */
	.intro, .sessions, .artwork, .next, .faqs {
		position: relative;
		z-index: 1;
		background: var(--bg);
	}

	.hero__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 40%;
		display: block;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to right,
			rgba(0, 0, 0, 0.1) 0%,
			rgba(0, 0, 0, 0.6) 100%
		);
	}

	.hero__content {
		position: relative;
		z-index: 1;
		max-width: 580px;
		padding: 150px 4rem 4rem 3rem;
		text-align: right;
	}

	.hero__heading {
		font-size: clamp(2.5rem, 5vw, 4.375rem);
		font-weight: 700;
		color: var(--white);
		letter-spacing: -0.01em;
		margin-bottom: 1.25rem;
		line-height: 1.15;
		text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
	}

	.hero__sub {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.906rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.85);
		line-height: 1.7;
	}

	/* ══ SECTION 2: Intro ══ */
	.intro {
		border-bottom: 1px solid var(--border);
	}

	.intro__inner {
		max-width: 620px;
		margin: 0 auto;
		padding: 1.1rem 3rem;
		text-align: left;
	}

	.intro__body {
		font-style: normal;
		font-weight: 500;
		font-size: 1.0625rem;
		line-height: 1.82;
		color: var(--text);
		margin-bottom: 1.5rem;
	}

	.intro__body--bold {
		font-weight: 600;
	}

	/* ══ SECTION 3: Sessions ══ */
	.sessions {
		padding-top: 50px;
		padding-bottom: 50px;
	}

	.sessions__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		align-items: center;
		max-width: 1100px;
		margin: 0 auto;
		padding: 5rem 3rem;
	}

	.sessions__img-wrap {
		overflow: hidden;
	}

	.sessions__img-wrap img {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		display: block;
	}

	.sessions__heading {
		font-size: clamp(2.25rem, 4vw, 3.5rem);
		font-weight: 700;
		color: var(--text);
		letter-spacing: -0.01em;
		margin-bottom: 1.25rem;
	}

	.sessions__sub {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.9rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		line-height: 1.7;
		margin-bottom: 2rem;
	}

	.sessions__includes {
		font-size: 1.2rem;
		color: var(--text);
		margin-bottom: 0.75rem;
	}

	.sessions__list {
		list-style: none;
		margin-bottom: 2rem;
	}

	.sessions__list li {
		font-size: 1.125rem;
		color: var(--muted);
		padding: 0.45rem 0;
		position: relative;
		border-bottom: 1px solid var(--border);
		line-height: 1.6;
	}

	.sessions__list li::before {
		content: none;
	}

	.sessions__price {
		font-size: 1.275rem;
		color: var(--text);
		margin-bottom: 0.15rem;
	}

	.sessions__caption {
		font-size: 1.05rem;
		color: var(--muted);
	}

	/* ══ SECTION 4: Artwork ══ */
	.artwork {
		padding-top: 0;
		padding-bottom: 0;
		overflow: hidden;
	}

	.artwork__inner {
		display: grid;
		grid-template-columns: minmax(0, 550px) 1fr;
		gap: 5rem;
		align-items: center;
		min-height: 680px;
		max-height: 680px;
		/* Left padding keeps content aligned with the rest of the page.
		   On large screens it matches the offset of a centered 1100px container. */
		padding: 0 0 0 max(3rem, calc((100vw - 1100px) / 2 + 3rem));
	}

	.artwork__content {
		padding-top: 100px;
		padding-bottom: 100px;
	}

	.artwork__title {
		font-size: clamp(2.25rem, 4vw, 3.5rem);
		font-weight: 700;
		color: var(--text);
		letter-spacing: -0.01em;
		margin-bottom: 1.25rem;
		margin-left: -25px;
	}

	.artwork__heading {
		font-family: var(--font-body);
		font-style: normal;
		font-size: clamp(0.844rem, 1.5vw, 1.125rem);
		line-height: 1.45;
		color: var(--text);
		letter-spacing: 0;
		margin-bottom: 2rem;
		font-weight: 400;
	}

	.artwork__includes {
		font-size: 1rem;
		color: var(--text);
		margin-bottom: 0.75rem;
	}

	.artwork__list {
		list-style: none;
		margin-bottom: 2rem;
	}

	.artwork__list li {
		font-size: 0.9375rem;
		color: var(--muted);
		padding: 0.45rem 0;
		position: relative;
		border-bottom: 1px solid var(--border);
		line-height: 1.6;
	}

	.artwork__list li::before {
		content: none;
	}

	.artwork__statement {
		font-style: normal;
		font-weight: 600;
		font-size: 1.0625rem;
		color: var(--text);
		line-height: 1.65;
	}

	.artwork__img-wrap {
		overflow: hidden;
		align-self: stretch;
	}

	.artwork__img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	/* ══ SECTION 5: Next Steps ══ */
	.next {
		position: relative;
		min-height: 520px;
		display: flex;
		align-items: center;
	}

	.next__bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	.next__overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
	}

	.next__box {
		position: relative;
		z-index: 1;
		background: var(--bg);
		max-width: 460px;
		margin: 4rem 0 4rem 6vw;
		padding: 3.5rem;
	}

	.next__label {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1rem;
	}

	.next__heading {
		font-size: clamp(2rem, 3.5vw, 3rem);
		color: var(--text);
		margin-bottom: 1.5rem;
		letter-spacing: -0.01em;
	}

	.next__body {
		font-style: italic;
		font-size: 1rem;
		line-height: 1.82;
		color: var(--text);
		margin-bottom: 1.25rem;
	}

	.next__body:last-of-type {
		margin-bottom: 2rem;
	}

	.next__btn {
		display: inline-block;
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--text);
		padding: 0.7rem 1.75rem;
		transition: background 0.25s, color 0.25s, transform 0.2s, box-shadow 0.25s;
	}

	.next__btn:hover {
		background: var(--text);
		color: var(--bg);
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
	}

	/* ══ SECTION 6: FAQs ══ */
	.faqs {
		padding-top: 0;
		padding-bottom: 7rem;
	}

	.faqs__inner {
		display: grid;
		grid-template-columns: 100px 1fr;
		max-width: 1100px;
		margin: 0 auto;
		padding: 5rem 3rem 0;
		gap: 2rem;
	}

	.faqs__label-col {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.faqs__label {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 700;
		font-size: clamp(1.875rem, 3.125vw, 2.8125rem);
		letter-spacing: 0.09em;
		color: var(--border);
		writing-mode: horizontal-tb;
		transform: rotate(-90deg);
		transform-origin: center center;
		white-space: nowrap;
		user-select: none;
	}

	.faqs__list {
		display: flex;
		flex-direction: column;
	}

	.faqs__item {
		border-top: 1px solid var(--border);
	}

	.faqs__item:last-child {
		border-bottom: 1px solid var(--border);
	}

	.faqs__question {
		width: 100%;
		background: none;
		border: none;
		padding: 1.5rem 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		cursor: pointer;
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 500;
		font-size: 1.406rem;
		color: var(--text);
		text-align: left;
		line-height: 1.4;
		transition: color 0.2s;
	}

	.faqs__question:hover {
		color: var(--accent);
	}

	.faqs__icon {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 1.25rem;
		font-weight: 300;
		color: var(--accent);
		flex-shrink: 0;
		transition: transform 0.25s ease;
		line-height: 1;
	}

	.faqs__item--open .faqs__icon {
		transform: rotate(45deg);
	}

	.faqs__answer {
		display: none;
		padding-bottom: 1.75rem;
	}

	.faqs__item--open .faqs__answer {
		display: block;
	}

	.faqs__answer-text {
		font-size: 1.172rem;
		line-height: 1.78;
		color: var(--muted);
		border-left: 2px solid var(--accent);
		padding-left: 1.25rem;
		margin: 0;
	}

	/* ══ Responsive ══ */
	@media (max-width: 900px) {
		.hero__content {
			padding: 80px 1.5rem 2rem;
			max-width: none;
			text-align: left;
		}

		.hero__overlay {
			background: rgba(0, 0, 0, 0.45);
		}

		.intro__inner {
			padding: 0.8rem 1.5rem;
		}

		.sessions__inner {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}

		.artwork__inner {
			grid-template-columns: 1fr;
			gap: 0;
			padding: 0;
			min-height: 0;
			max-height: none;
		}

