---
import Layout from '../layouts/Layout.astro';
import { getClient, urlFor } from '../lib/sanity.js';

const doc = await getClient(Astro.locals.isPreview).fetch(
  `*[_type == "contactPage"][0]{
    pageTitle,
    seo { seoTitle, seoDescription, socialImage { asset->{ url } } },
    heroImage { ..., asset-> },
    heroHeading,
    heroSubtext,
    infoHeading,
    infoBody,
    embedCode,
    formSettings {
      web3formsKey,
      submitButtonText,
      successMessage,
      customField1 { enabled, label },
      customField2 { enabled, label },
      customField3 { enabled, label }
    }
  }`
);

const seoTitle       = doc?.seo?.seoTitle       || doc?.pageTitle || 'Contact';
const seoDescription = doc?.seo?.seoDescription || null;
const ogImage        = doc?.seo?.socialImage?.asset?.url || null;

const heroImgUrl = doc?.heroImage
  ? urlFor(doc.heroImage).width(1600).auto('format').url()
  : 'https://images.pexels.com/photos/3726314/pexels-photo-3726314.jpeg?auto=compress&cs=tinysrgb&w=1600';

const heroHeading = doc?.heroHeading || 'Inquire';
const heroSubtext  = doc?.heroSubtext  || "I'd love to hear about your subject and what you're hoping to capture — just fill out the form below and I'll get back to you within 24–48 hours."; // TODO:NICHE

const infoHeading = doc?.infoHeading || "I can't wait to meet you and your pup(s)!"; // TODO:NICHE
const infoBody    = doc?.infoBody    || "If you'd rather email directly, you can reach me at yourname@domain.com or find me on Instagram @YourHandle."; // TODO:NICHE

const embedCode      = doc?.embedCode || null;
const web3formsKey   = doc?.formSettings?.web3formsKey   || '';
const submitText     = doc?.formSettings?.submitButtonText || 'Send Message';
const successMessage = doc?.formSettings?.successMessage   || "Thank you! I'll be in touch soon.";

const cf1 = doc?.formSettings?.customField1 ?? null;
const cf2 = doc?.formSettings?.customField2 ?? null;
const cf3 = doc?.formSettings?.customField3 ?? null;
---

<Layout pageTitle={seoTitle} seoDescription={seoDescription} ogImage={ogImage}>
  <main>

    <!-- ══ SECTION 1: Hero ══ -->
    <section class="hero">
      <img
        class="hero__img"
        src={heroImgUrl}
        alt={heroHeading}
        loading="eager" decoding="async"
      />
      <div class="hero__overlay" aria-hidden="true"></div>
      <div class="hero__content">
        <h1 class="hero__heading">{heroHeading}</h1>
        <p class="hero__sub">{heroSubtext}</p>
      </div>
    </section>

    <!-- ══ SECTION 2: Contact ══ -->
    <section class="contact" style="background: var(--bg-alt)">
      <hr />
      <div class="contact__inner">

        <!-- Left: info -->
        <div class="contact__info">
          <h2 class="contact__heading reveal reveal-delay-1">{infoHeading}</h2>
          <p class="contact__body">{infoBody}</p>
        </div>

        <!-- Right: embed or built-in form -->
        <div class="contact__form-wrap">
          {embedCode ? (
            <div class="contact__embed">
              <Fragment set:html={embedCode} />
            </div>
          ) : (
            <>
              <form class="contact__form" id="contact-form" novalidate>
                {/* Web3Forms fields */}
                <input type="hidden" name="access_key" value={web3formsKey} />
                <input type="hidden" name="subject" value="New enquiry from your website" />
                {/* Honeypot — bots fill this, humans don't */}
                <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

                {/* Default fields */}
                <div class="contact__field reveal reveal-delay-2">
                  <label class="contact__label" for="name">Full Name</label>
                  <input class="contact__input" type="text" id="name" name="name" placeholder="Your name" required />
                </div>

                <div class="contact__field reveal reveal-delay-3">
                  <label class="contact__label" for="email">Email</label>
                  <input class="contact__input" type="email" id="email" name="email" placeholder="your@email.com" required />
                </div>

                <div class="contact__field reveal reveal-delay-4">
                  <label class="contact__label" for="message">Message</label>
                  <textarea class="contact__textarea" id="message" name="message" placeholder="Tell me a little about your subject and what you're hoping to capture…" rows="6" required></textarea>{/* TODO:NICHE */}
                </div>

                {/* Custom fields */}
                {cf1?.enabled && cf1?.label && (
                  <div class="contact__field reveal">
                    <label class="contact__label" for="custom1">{cf1.label}</label>
                    <input class="contact__input" type="text" id="custom1" name={cf1.label} />
                  </div>
                )}
                {cf2?.enabled && cf2?.label && (
                  <div class="contact__field reveal">
                    <label class="contact__label" for="custom2">{cf2.label}</label>
                    <input class="contact__input" type="text" id="custom2" name={cf2.label} />
                  </div>
                )}
                {cf3?.enabled && cf3?.label && (
                  <div class="contact__field reveal">
                    <label class="contact__label" for="custom3">{cf3.label}</label>
                    <input class="contact__input" type="text" id="custom3" name={cf3.label} />
                  </div>
                )}

                <button class="contact__submit reveal reveal-delay-5" type="submit">
                  {submitText} &rarr;
                </button>
              </form>

              <p class="contact__status" id="form-status" aria-live="polite"></p>
            </>
          )}
        </div>

      </div>
    </section>

  </main>
</Layout>

<script define:vars={{ web3formsKey, submitText, successMessage }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  if (!form || !status) return; // embed mode — no form

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('[type="submit"]');

    // Basic client-side validation
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Guard: no key configured
    if (!web3formsKey) {
      status.textContent = 'Form is not configured yet. Please check back soon.';
      status.className = 'contact__status contact__status--error';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending…';
    status.textContent = '';
    status.className = 'contact__status';

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const json = await res.json();

      if (json.success) {
        form.style.display = 'none';
        status.textContent = successMessage;
        status.className = 'contact__status contact__status--success';
      } else {
        throw new Error(json.message || 'Submission failed');
      }
    } catch (err) {
      btn.disabled = false;
      btn.textContent = submitText + ' →';
      status.textContent = 'Something went wrong — please try again or email directly.';
      status.className = 'contact__status contact__status--error';
    }
  });
</script>

<style>
  /* ══ SECTION 1: Hero ══ */
  .hero {
    position: relative;
    height: calc(55vh + 100px);
    min-height: 460px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
  }

  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.42);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 560px;
    padding: 3.5rem 4rem;
    text-align: right;
  }

  .hero__heading {
    font-size: clamp(2.875rem, 6.9vw, 5.75rem);
    font-weight: 600;
    color: #ffffff;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
  }

  .hero__sub {
    font-family: var(--font-sans, system-ui, sans-serif);
    font-style: normal;
    font-size: 0.84rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.75;
  }

  /* ══ SECTION 2: Contact ══ */
  .contact {
    padding-top: 0;
    padding-bottom: 7rem;
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
    max-width: 1100px;
    margin: 0 auto;
    padding: 5.5rem 3rem 0;
  }

  /* Left: info */
  .contact__info {
    max-width: calc(100% - 75px);
  }

  .contact__heading {
    font-family: var(--font-serif);
    font-style: normal;
    font-weight: 600;
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    color: var(--accent);
    line-height: 1.25;
    margin-bottom: 1.25rem;
    letter-spacing: -0.04em;
  }

  .contact__body {
    font-size: 0.9375rem;
    line-height: 1.78;
    color: var(--muted);
    white-space: pre-line;
  }

  /* Right: form */
  .contact__form-wrap {
    display: flex;
    flex-direction: column;
  }

  .contact__embed {
    width: 100%;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact__label {
    font-family: var(--font-sans);
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text);
  }

  .contact__input,
  .contact__textarea {
    background: #ffffff;
    border: 1px solid var(--border);
    padding: 0.625rem 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--text);
    outline: none;
    width: 100%;
    transition: border-color 0.2s;
    resize: none;
  }

  .contact__input::placeholder,
  .contact__textarea::placeholder {
    color: var(--muted-light);
  }

  .contact__input:focus,
  .contact__textarea:focus {
    border-color: var(--accent);
  }

  .contact__textarea {
    min-height: 150px;
    line-height: 1.7;
  }

  .contact__submit {
    width: 100%;
    background: none;
    border: 1px solid var(--accent);
    padding: 0.9rem 1.75rem;
    font-family: var(--font-sans);
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    cursor: pointer;
    transition: background 0.25s, color 0.25s, border-color 0.25s, transform 0.25s ease, box-shadow 0.25s;
    margin-top: 0.5rem;
  }

  .contact__submit:hover:not(:disabled) {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(26, 39, 68, 0.18);
  }

  .contact__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .contact__status {
    margin-top: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .contact__status--success {
    color: var(--accent);
    font-size: 1.1rem;
  }

  .contact__status--error {
    color: #c0392b;
  }

  /* ══ Responsive ══ */
  @media (max-width: 900px) {
    .hero__content {
      max-width: none;
      padding: 2rem 1.5rem;
      text-align: left;
    }

    .hero__overlay {
      background: rgba(0, 0, 0, 0.48);
    }

    .contact__info {
      max-width: 100%;
    }

    .contact__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }
</style>
