---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

// TODO:NICHE — replace with real blog posts (or Sanity fetch)
const posts = [
	{
		category: 'On Location',
		title: 'Captured High in the Mountains',
		excerpt: 'Your blog post description will automatically pull into here for whatever you write — simple as that.',
		pexelsId: '3726314',
	},
	{
		category: 'Portraits',
		title: 'Swimming with Spot',
		excerpt: 'Your blog post description will automatically pull into here for whatever you write — simple as that.',
		pexelsId: '2253275',
	},
	{
		category: 'On Location',
		title: 'Rocky on the Ridgetop',
		excerpt: 'Your blog post description will automatically pull into here for whatever you write — simple as that.',
		pexelsId: '825949',
	},
	{
		category: 'Behind the Scenes',
		title: 'A Morning in the Studio',
		excerpt: 'Your blog post description will automatically pull into here for whatever you write — simple as that.',
		pexelsId: '1805164',
	},
];
---

<Layout>
	<Nav />
	<main>

		<!-- ══ SECTION 1: Hero Image ══ -->
		<section class="hero">
			<img
				class="hero__img"
				src="https://images.pexels.com/photos/1629781/pexels-photo-1629781.jpeg?auto=compress&cs=tinysrgb&w=1600"
				alt="Dog running through an open field"
				loading="eager"
			/>
			<div class="hero__content">
				<h1 class="hero__title">Dog Tails</h1>{/* TODO:NICHE — blog name */}
				<p class="hero__sub">Dogs, Love, and Tails of Photography</p>{/* TODO:NICHE */}
			</div>
		</section>

		<!-- ══ SECTION 2: Post List ══ -->
		<section class="posts" data-theme="warm-studio">
			<div class="posts__list">
				{posts.map((post, i) => (
					<article class={`posts__item ${i % 2 === 1 ? 'posts__item--reversed' : ''}`}>
						<div class="posts__item-inner">
							<div class="posts__img-col">
								<img
									src={`https://images.pexels.com/photos/${post.pexelsId}/pexels-photo-${post.pexelsId}.jpeg?auto=compress&cs=tinysrgb&w=900&h=700&fit=crop`}
									alt={post.title}
									loading="lazy"
								/>
							</div>
							<div class="posts__content">
								<p class="posts__category">{post.category}</p>
								<h2 class="posts__title">{post.title}</h2>
								<p class="posts__excerpt">{post.excerpt}</p>
							</div>
						</div>
						{i < posts.length - 1 && <hr class="posts__divider" />}
					</article>
				))}
			</div>
		</section>

	</main>
</Layout>

<style>
	/* ══ SECTION 1: Hero ══ */
	.hero {
		position: relative;
		height: 55vh;
		min-height: 360px;
		overflow: hidden;
		display: flex;
		align-items: flex-end;
		justify-content: flex-end;
	}

	.hero__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 30%;
		display: block;
	}

	.hero__content {
		position: relative;
		z-index: 1;
		padding: 3rem 4rem;
		text-align: right;
	}

	.hero__title {
		font-size: clamp(2.5rem, 6vw, 5.5rem);
		font-style: normal;
		color: var(--accent, #8b2635);
		letter-spacing: -0.01em;
		line-height: 1;
		margin-bottom: 0.75rem;
		text-shadow: 0 1px 4px rgba(255, 255, 255, 0.4);
	}

	.hero__sub {
		font-family: var(--font-sans, system-ui, sans-serif);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text, #1a2744);
		text-shadow: 0 1px 3px rgba(255, 255, 255, 0.5);
	}

	/* ══ SECTION 2: Posts ══ */
	.posts {
		padding-bottom: 6rem;
	}

	.posts__list {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 3rem;
	}

	.posts__item {
		padding: 4rem 0;
	}

	.posts__item-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 400px;
	}

	/* Reversed layout for even posts */
	.posts__item--reversed .posts__img-col {
		order: 2;
	}

	.posts__item--reversed .posts__content {
		order: 1;
	}

	.posts__img-col {
		overflow: hidden;
	}

	.posts__img-col img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.posts__img-col:hover img {
		transform: scale(1.03);
	}

	.posts__content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 3rem 4rem;
		background: var(--bg-alt);
	}

	/* Even posts: text is on left, so swap padding emphasis */
	.posts__item--reversed .posts__content {
		padding: 3rem 4rem 3rem 0;
		background: transparent;
	}

	.posts__category {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1.25rem;
	}

	.posts__title {
		font-size: clamp(1.75rem, 3vw, 2.75rem);
		color: var(--text);
		letter-spacing: -0.01em;
		margin-bottom: 1.5rem;
		line-height: 1.2;
	}

	.posts__excerpt {
		font-size: 0.9375rem;
		line-height: 1.78;
		color: var(--muted);
	}

	.posts__divider {
		margin-top: 0;
		border-top-color: var(--border);
	}

	/* ══ Responsive ══ */
	@media (max-width: 900px) {
		.hero__content {
			padding: 2rem 1.5rem;
		}

		.posts__list {
			padding: 0 1.5rem;
		}

		.posts__item-inner {
			grid-template-columns: 1fr;
			min-height: auto;
		}

		.posts__img-col img {
			height: 55vw;
			min-height: 240px;
		}

		.posts__item--reversed .posts__img-col {
			order: 0;
		}

		.posts__item--reversed .posts__content {
			order: 0;
			padding: 2rem 0;
			background: transparent;
		}

		.posts__content {
			padding: 2rem 0;
			background: transparent;
		}
	}
</style>
