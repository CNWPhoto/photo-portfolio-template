---
import Layout from '../layouts/Layout.astro';
import SectionRenderer from '../components/SectionRenderer.astro';
import { getClient } from '../lib/sanity.js';
import { SECTION_PROJECTION, SITE_PALETTES_QUERY } from '../lib/sectionsQuery.js';
import { buildFaqSchema } from '../lib/faqSchema.js';

const client = getClient(Astro.locals.isPreview);

const [homepageDoc, siteData] = await Promise.all([
	client.fetch(`*[_type == "homepagePage"][0]{
		pageTitle,
		seo { seoTitle, seoDescription, socialImage { asset->{ url } } },
		"sections": sections[]{ ${SECTION_PROJECTION} }
	}`),
	client.fetch(SITE_PALETTES_QUERY),
]);

const palettes = siteData?.palettes ?? [];
const sitePaletteSlug = siteData?.defaultPalette ?? null;

const sections = homepageDoc?.sections ?? [];

const seoTitle       = homepageDoc?.seo?.seoTitle       || homepageDoc?.pageTitle || null;
const seoDescription = homepageDoc?.seo?.seoDescription || null;
const ogImage        = homepageDoc?.seo?.socialImage?.asset?.url || null;

// Unified hero pattern: the hero (if any) lives as the first item in
// the sections array, just like on every other page route. Transparent
// nav overlays it only when it's a hero with variant 'image-full'.
const firstSection = sections[0];
const heroOverlay =
	firstSection?._type === 'heroSection' &&
	firstSection?.enabled !== false &&
	firstSection?.variant === 'image-full';

const faqSchemaData = buildFaqSchema(sections);
---

<Layout pageTitle={seoTitle} seoDescription={seoDescription} ogImage={ogImage} schemaData={faqSchemaData} {heroOverlay}>
	<main>
		{sections.map((section: any, i: number) => (
			<SectionRenderer
				section={section}
				isFirst={i === 0}
				sitePaletteSlug={sitePaletteSlug}
				palettes={palettes}
			/>
		))}
	</main>
</Layout>
