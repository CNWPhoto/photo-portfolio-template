---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhyChoose from '../components/WhyChoose.astro';
import FAQs from '../components/FAQs.astro';

// Section variants — all imported statically; conditional rendering selects the active one
import TestimonialsSlider from '../components/testimonials/TestimonialsSlider.astro';
import TestimonialsGrid from '../components/testimonials/TestimonialsGrid.astro';
import IntroSplit from '../components/intro/IntroSplit.astro';
import IntroCentered from '../components/intro/IntroCentered.astro';
import PortfolioGrid from '../components/portfolio/PortfolioGrid.astro';
import PortfolioMasonry from '../components/portfolio/PortfolioMasonry.astro';
import HowItWorksColumns from '../components/howitworks/HowItWorksColumns.astro';
import HowItWorksStacked from '../components/howitworks/HowItWorksStacked.astro';

import { getClient, urlFor } from '../lib/sanity.js';

const client = getClient(Astro.locals.isPreview);

const [homepageDoc, testimonials] = await Promise.all([
	client.fetch(
		`*[_type == "homepagePage"][0]{
			pageTitle,
			seo { seoTitle, seoDescription, socialImage { asset->{ url } } },
			"sections": sections[] {
				_type,
				variant,
				images[] { ..., asset-> },
				nicheKeyword, tagline,
				eyebrow, body, bodySecondary, ctaText, ctaLink,
				image { ..., asset-> },
				imageVertical { ..., asset-> },
				imageHorizontal { ..., asset-> },
				heading, step1Title, step1Body, step2Title, step2Body, step3Title, step3Body,
				bodyFirst, bodySecond, caption,
				faqs[] { question, answer }
			}
		}`
	),
	client.fetch(`*[_type == "testimonial"] | order(order asc)`),
]);

const homepageSections = homepageDoc?.sections ?? [];
const getSection = (type: string) => homepageSections.find((s: any) => s._type === type);

const seoTitle       = homepageDoc?.seo?.seoTitle       || homepageDoc?.pageTitle || null;
const seoDescription = homepageDoc?.seo?.seoDescription || null;
const ogImage        = homepageDoc?.seo?.socialImage?.asset?.url || null;

// ── Schema ───────────────────────────────────────────────────────────────────
const rawFaqs = getSection('homepageFaqs')?.faqs ?? null;
const faqSchemaData = rawFaqs?.length
	? [{ '@type': 'FAQPage', mainEntity: rawFaqs.map((f: any) => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } })) }]
	: undefined;

const isEnabled = (type: string) => getSection(type)?.enabled !== false;

const heroSliderSection   = getSection('heroSlider');
const heroSlider          = heroSliderSection?.images ?? null;
const showHero            = heroSliderSection?.enabled !== false;
const heroCaptionSection  = getSection('heroCaption');
const heroCaption         = heroCaptionSection ?? null;
const showHeroCaption     = heroCaptionSection?.enabled !== false;
const welcomeSection      = isEnabled('welcomeSection')   ? getSection('welcomeSection')   ?? null : null;
const featuredSection     = isEnabled('featuredSection')  ? getSection('featuredSection')  ?? null : null;
const processSection      = isEnabled('processSection')   ? getSection('processSection')   ?? null : null;
const soloHeroImage       = isEnabled('soloHeroImage')    ? getSection('soloHeroImage')    ?? null : null;
const whyChooseSection    = isEnabled('whyChooseSection') ? getSection('whyChooseSection') ?? null : null;
const showTestimonials    = isEnabled('testimonialsSection');
const faqsSection         = getSection('homepageFaqs');
const faqs                = isEnabled('homepageFaqs') ? (faqsSection?.faqs ?? null) : null;

// Layout variants — read from each section's own variant field
const introVariant        = welcomeSection?.variant  || 'classic';
const testimonialsVariant = getSection('testimonialsSection')?.variant || 'slider';
const portfolioVariant    = featuredSection?.variant  || 'classic';
const howItWorksVariant   = processSection?.variant   || 'columns';
---

<Layout pageTitle={seoTitle} seoDescription={seoDescription} ogImage={ogImage} schemaData={faqSchemaData}>
	{showHero && <Hero heroImages={heroSlider} heroCaption={showHeroCaption ? heroCaption : null} {urlFor} />}
	<main>
		<!-- Intro -->
		{welcomeSection && (introVariant === 'centered'
			? <IntroCentered {welcomeSection} {urlFor} />
			: <IntroSplit    {welcomeSection} {urlFor} />
		)}

		<!-- Testimonials -->
		{showTestimonials && (testimonialsVariant === 'grid'
			? <TestimonialsGrid   testimonials={testimonials} {urlFor} />
			: <TestimonialsSlider testimonials={testimonials} {urlFor} />
		)}

		<!-- Portfolio preview -->
		{featuredSection && (portfolioVariant === 'masonry'
			? <PortfolioMasonry {featuredSection} {urlFor} />
			: <PortfolioGrid    {featuredSection} {urlFor} />
		)}

		<!-- How It Works -->
		{processSection && (howItWorksVariant === 'stacked'
			? <HowItWorksStacked {processSection} />
			: <HowItWorksColumns {processSection} />
		)}

		{(soloHeroImage || whyChooseSection) && <WhyChoose theme="dark-editorial" {soloHeroImage} {whyChooseSection} {urlFor} />}
		{faqs && <FAQs {faqs} />}
	</main>
</Layout>
