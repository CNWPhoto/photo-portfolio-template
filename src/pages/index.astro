---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhyChoose from '../components/WhyChoose.astro';
import FAQs from '../components/FAQs.astro';

// Section variants — all imported statically; conditional rendering selects the active one
import TestimonialsSlider from '../components/testimonials/TestimonialsSlider.astro';
import TestimonialsGrid from '../components/testimonials/TestimonialsGrid.astro';
import IntroSplit from '../components/intro/IntroSplit.astro';
import IntroCentered from '../components/intro/IntroCentered.astro';
import PortfolioGrid from '../components/portfolio/PortfolioGrid.astro';
import PortfolioMasonry from '../components/portfolio/PortfolioMasonry.astro';
import HowItWorksColumns from '../components/howitworks/HowItWorksColumns.astro';
import HowItWorksStacked from '../components/howitworks/HowItWorksStacked.astro';

import { sanityClient, urlFor } from '../lib/sanity.js';

const SANITY_API = 'https://hx5xgigp.api.sanity.io/v2023-05-03/data/query/production';
const _layoutQuery = encodeURIComponent(
	`*[_type == "homepageSettings"][0]{introVariant, testimonialsVariant, portfolioPreviewVariant, howItWorksVariant}`
);

const [heroSlider, heroCaption, welcomeSection, featuredSection, processSection, soloHeroImage, whyChooseSection, testimonials, faqs, pageSections, layoutSettings, siteSettings] = await Promise.all([
	sanityClient.fetch(`*[_type == "heroSlider" && _id == "heroSlider"][0].images`, {}, { cache: 'no-store' }),
	sanityClient.fetch(`*[_type == "heroCaption" && _id == "heroCaption"][0]`, {}, { cache: 'no-store' }),
	sanityClient.fetch(`*[_type == "welcomeSection" && _id == "welcomeSection"][0]`, {}, { cache: 'no-store' }),
	sanityClient.fetch(`*[_type == "featuredSection" && _id == "featuredSection"][0]`, {}, { cache: 'no-store' }),
	sanityClient.fetch(`*[_type == "processSection" && _id == "processSection"][0]`, {}, { cache: 'no-store' }),
	sanityClient.fetch(`*[_type == "soloHeroImage" && _id == "soloHeroImage"][0]`, {}, { cache: 'no-store' }),
	sanityClient.fetch(`*[_type == "whyChooseSection" && _id == "whyChooseSection"][0]`, {}, { cache: 'no-store' }),
	sanityClient.fetch(`*[_type == "testimonial"] | order(order asc)`, {}, { cache: 'no-store' }),
	sanityClient.fetch(`*[_type == "faq"] | order(order asc)`, {}, { cache: 'no-store' }),
	sanityClient.fetch(`*[_type == "pageSection"]`, {}, { cache: 'no-store' }),
	fetch(`${SANITY_API}?query=${_layoutQuery}`, { cache: 'no-store' }).then(r => r.json()).then(d => d.result),
	sanityClient.fetch(`*[_type == "siteSettings" && _id == "siteSettings"][0].typographyOverrides`, {}, { cache: 'no-store' }),
]);

const overrides = siteSettings ?? {};

// Section theme from pageSection documents (per-section colour overrides)
const sectionTheme = (type: string, defaultTheme?: string) => {
	const s = pageSections?.find((p: any) => p.sectionType === type);
	return s?.colorTheme ?? defaultTheme;
};

// Layout variants from homepageSettings singleton (fallback to defaults)
const introVariant        = layoutSettings?.introVariant           || 'classic';
const testimonialsVariant = layoutSettings?.testimonialsVariant    || 'slider';
const portfolioVariant    = layoutSettings?.portfolioPreviewVariant || 'grid';
const howItWorksVariant   = layoutSettings?.howItWorksVariant      || 'columns';
---

<Layout>
	<Hero heroImages={heroSlider} {heroCaption} {urlFor} {overrides} />
	<main>
		<!-- Intro -->
		{introVariant === 'centered'
			? <IntroCentered {welcomeSection} {urlFor} theme={sectionTheme('intro')} {overrides} />
			: <IntroSplit    {welcomeSection} {urlFor} theme={sectionTheme('intro')} {overrides} />
		}

		<!-- Testimonials -->
		{testimonialsVariant === 'grid'
			? <TestimonialsGrid   testimonials={testimonials} {urlFor} theme={sectionTheme('testimonials')} {overrides} />
			: <TestimonialsSlider testimonials={testimonials} {urlFor} theme={sectionTheme('testimonials')} {overrides} />
		}

		<!-- Portfolio preview -->
		{portfolioVariant === 'masonry'
			? <PortfolioMasonry {featuredSection} {urlFor} theme={sectionTheme('portfolio')} />
			: <PortfolioGrid    {featuredSection} {urlFor} theme={sectionTheme('portfolio')} />
		}

		<!-- How It Works -->
		{howItWorksVariant === 'stacked'
			? <HowItWorksStacked {processSection} theme={sectionTheme('howItWorks', 'warm-studio')} />
			: <HowItWorksColumns {processSection} theme={sectionTheme('howItWorks', 'warm-studio')} />
		}

		<WhyChoose theme="dark-editorial" {soloHeroImage} {whyChooseSection} {urlFor} {overrides} />
		<FAQs faqs={faqs} {overrides} />
	</main>
</Layout>
