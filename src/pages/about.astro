---
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity.js';
import SanityImage from '../components/SanityImage.astro';

const [introDoc, wteDoc, personalDoc, quoteDoc] = await Promise.all([
	sanityClient.fetch(
		`*[_type == "aboutIntro"][0]{
			enabled, image { ..., asset->{ _id, metadata { dimensions { width, height } } } },
			heading, subtext, bodyParagraph1, bodyParagraph2
		}`,
		{}, { cache: 'no-store' }
	),
	sanityClient.fetch(
		`*[_type == "aboutWhatToExpect"][0]{
			enabled, sectionLabel,
			columns[] {
				image { ..., asset->{ _id, metadata { dimensions { width, height } } } },
				title, body
			}
		}`,
		{}, { cache: 'no-store' }
	),
	sanityClient.fetch(
		`*[_type == "aboutPersonal"][0]{
			enabled, image { ..., asset->{ _id, metadata { dimensions { width, height } } } },
			bodyParagraph1, bodyParagraph2
		}`,
		{}, { cache: 'no-store' }
	),
	sanityClient.fetch(
		`*[_type == "aboutQuote"][0]{ enabled, quoteText }`,
		{}, { cache: 'no-store' }
	),
]);

const showIntro    = introDoc?.enabled    !== false;
const showWte      = wteDoc?.enabled      !== false;
const showPersonal = personalDoc?.enabled !== false;
const showQuote    = quoteDoc?.enabled    !== false;

const personal = personalDoc ?? {};
const personalImage  = personal.image ?? null;
const personalBody1  = personal.bodyParagraph1 || 'Photography found me at a time when I needed it most. A camera in hand became a reason to look closely at the world — to slow down, notice the small things, and find beauty in the ordinary.';
const personalBody2  = personal.bodyParagraph2 || "That sense of attention is something I bring to every session. I'm not here to manufacture a perfect image. I'm here to find the one that's already there, waiting.";

const quoteText = quoteDoc?.quoteText || 'I believe photographs should feel honest, timeless, and personal.';

const intro = introDoc ?? {};

const introHeading      = intro.heading       || "Hi, I'm Connor";
const introSubtext      = intro.subtext        || 'A photographer based in [City], here to help you document your story in a way that feels natural and stress-free.';
const introBody1        = intro.bodyParagraph1 || "I've spent the last decade photographing the moments that matter most — the quiet ones, the joyful ones, the ones you don't even notice are happening until the camera catches them. My approach is unhurried and entirely led by you.";
const introBody2        = intro.bodyParagraph2 || 'What started as a personal project became a calling. I believe every person, every family, every bond deserves to be documented beautifully — not in a stiff, posed way, but in a way that is completely, unmistakably them.';
const introImage        = intro.image ?? null;

const wte = wteDoc ?? {};
const wteLabel = wte.sectionLabel || 'What to Expect';
const wteColumns = wte.columns?.length ? wte.columns : [
	{
		_fallback: true,
		image: null,
		imageSrc: 'https://images.pexels.com/photos/2253275/pexels-photo-2253275.jpeg?auto=compress&cs=tinysrgb&w=600&h=600&fit=crop',
		imageAlt: 'Subject-led session in golden afternoon light',
		title: 'Subject-Led Sessions',
		body: 'Every session moves at your pace. There are no forced poses or rigid shot lists — just space for you to be yourself while I follow the light and the moments as they unfold.',
	},
	{
		_fallback: true,
		image: null,
		imageSrc: 'https://images.pexels.com/photos/825949/pexels-photo-825949.jpeg?auto=compress&cs=tinysrgb&w=600&h=600&fit=crop',
		imageAlt: 'Calm and supportive direction during a session',
		title: 'Calm Supportive Direction',
		body: "I'll gently guide you through the session so you never feel unsure of what to do. Most people tell me they forget the camera is there — that's exactly the point.",
	},
	{
		_fallback: true,
		image: null,
		imageSrc: 'https://images.pexels.com/photos/1108099/pexels-photo-1108099.jpeg?auto=compress&cs=tinysrgb&w=600&h=600&fit=crop',
		imageAlt: 'A genuine moment of connection',
		title: 'Connection',
		body: 'The best photographs come from real connection. I invest time before every session getting to know you so that what we create together feels personal, not generic.',
	},
];
---

<Layout>
	<main>

		<!-- ══ SECTION 1: Intro Split ══ -->
		{showIntro && <section class="intro" data-theme="classic-cream">
			<div class="intro__image reveal-fade">
				{introImage ? (
					<SanityImage
						image={introImage}
						sizes="(max-width: 900px) 100vw, 500px"
						class="intro__img"
						loading="eager"
					/>
				) : (
					<img
						src="https://images.pexels.com/photos/1704488/pexels-photo-1704488.jpeg?auto=compress&cs=tinysrgb&w=900"
						alt="Photographer portrait"
						width="900" height="600"
						loading="eager" decoding="async"
					/>
				)}
			</div>
			<div class="intro__content">
				<div class="intro__text-wrap">
					<h1 class="intro__heading">{introHeading}</h1>
					<p class="intro__sub reveal reveal-delay-1">{introSubtext}</p>
					<p class="intro__body reveal reveal-delay-2">{introBody1}</p>
					<p class="intro__body reveal reveal-delay-3">{introBody2}</p>
				</div>
			</div>
		</section>}

		<!-- ══ SECTION 2: What to Expect ══ -->
		{showWte && <section class="expect" data-theme="warm-studio">
			<hr />
			<div class="expect__inner">
				<div class="expect__label-col" aria-hidden="true">
					<span class="expect__label">{wteLabel}</span>
				</div>
				<div class="expect__cols">
					{wteColumns.map((col: any, i: number) => (
						<div class={`expect__col reveal reveal-delay-${i + 1}`}>
							<div class="expect__img-wrap">
								{col._fallback ? (
									<img
										src={col.imageSrc}
										alt={col.imageAlt}
										width="600" height="600"
										loading="lazy" decoding="async"
									/>
								) : (
									<SanityImage
										image={col.image}
										sizes="250px"
										class="expect__col-img"
										loading="lazy"
									/>
								)}
							</div>
							<p class="expect__col-label">{col.title}</p>
							<p class="expect__col-body">{col.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>}

		<!-- ══ SECTION 3: Personal Split ══ -->
		{showPersonal && <section class="personal" data-theme="classic-cream">
			<div class="personal__inner">
				<div class="personal__text reveal reveal-delay-1">
					<p class="personal__body">{personalBody1}</p>
					<p class="personal__body">{personalBody2}</p>
				</div>
				<div class="personal__image">
					{personalImage ? (
						<SanityImage
							image={personalImage}
							sizes="(max-width: 900px) 100vw, 550px"
							class="personal__img"
							loading="lazy"
						/>
					) : (
						<img
							src="https://images.pexels.com/photos/1805164/pexels-photo-1805164.jpeg?auto=compress&cs=tinysrgb&w=900"
							alt="Candid moment captured during a photography session"
							width="900" height="600"
							loading="lazy" decoding="async"
						/>
					)}
				</div>
			</div>
		</section>}

		<!-- ══ SECTION 4: Pull Quote ══ -->
		{showQuote && <section class="pullquote" data-theme="classic-cream">
			<hr />
			<div class="pullquote__inner">
				<blockquote class="pullquote__text reveal reveal-delay-1">
					&ldquo;{quoteText}&rdquo;
				</blockquote>
			</div>
		</section>}

		<!-- ══ SECTION 5: Let's Do This CTA ══ -->
		<section class="cta" data-theme="warm-studio">
			<hr />
			<div class="cta__inner">
				<div class="cta__images">
					<div class="cta__img-back">
						<img
							src="https://images.pexels.com/photos/3726314/pexels-photo-3726314.jpeg?auto=compress&cs=tinysrgb&w=600&h=750&fit=crop"
							alt="Photography session moment"
							width="600" height="750"
							loading="lazy" decoding="async"
						/>
					</div>
					<div class="cta__img-front">
						<img
							src="https://images.pexels.com/photos/1254140/pexels-photo-1254140.jpeg?auto=compress&cs=tinysrgb&w=500&h=640&fit=crop"
							alt="Another moment from a photography session"
							width="500" height="640"
							loading="lazy" decoding="async"
						/>
					</div>
				</div>
				<div class="cta__content">
					<h2 class="cta__heading reveal reveal-delay-1">Let's Do This!</h2>{/* TODO:NICHE */}
					<p class="cta__body reveal reveal-delay-2">If you're ready to have photographs that actually look and feel like you, I'd love to hear from you. Get in touch and let's start planning something special.</p>{/* TODO:NICHE */}
					<a href="/contact" class="cta__btn reveal reveal-delay-3">Get In Touch</a>
					<p class="cta__caption">Serving [City] and surrounding areas.</p>{/* TODO:NICHE */}
				</div>
			</div>
		</section>

	</main>
</Layout>

<style>
	/* ══ SECTION 1: Intro ══ */
	.intro {
		display: grid;
		grid-template-columns: 500px 1fr;
		max-width: 1100px;
		margin-left: auto;
		margin-right: auto;
		box-sizing: border-box;
	}

	.intro__image {
		overflow: hidden;
		aspect-ratio: 2 / 3;
		padding-left: 3rem;
	}

	.intro__image img,
	.intro__image :global(.intro__img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
	}

	.intro__content {
		display: flex;
		align-items: center;
		padding: 6rem 5rem 6rem 6rem;
	}

	.intro__text-wrap {
		max-width: 560px;
	}

	.intro__heading {
		font-size: clamp(2.1rem, 4.2vw, 3.78rem);
		color: var(--text);
		margin-bottom: 2rem;
		letter-spacing: -0.02em;
		line-height: 1.12;
	}

	.intro__sub {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.75rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		line-height: 1.7;
		margin-bottom: 2.5rem;
	}

	.intro__body {
		font-style: normal;
		font-size: 1.0625rem;
		line-height: 1.82;
		color: var(--muted);
		margin-bottom: 1.25rem;
	}

	/* ══ SECTION 2: What to Expect ══ */
	.expect {
		padding: 0 0 6rem;
	}

	.expect__inner {
		display: grid;
		grid-template-columns: 100px 1fr;
		padding: 0 3rem;
		max-width: 1100px;
		margin: 0 auto;
		gap: 2rem;
	}

	.expect__label-col {
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.expect__label {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 500;
		font-size: clamp(2rem, 3.2vw, 3rem);
		letter-spacing: 0.12em;
		color: #1a2744;
		writing-mode: horizontal-tb;
		transform: rotate(-90deg);
		transform-origin: center center;
		white-space: nowrap;
		user-select: none;
	}

	.expect__cols {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2.5rem;
		padding-top: 5rem;
	}

	.expect__img-wrap {
		overflow: hidden;
		margin-bottom: 1.5rem;
		height: 250px;
		width: 250px;
		max-width: 100%;
	}

	.expect__img-wrap img,
	.expect__img-wrap :global(.expect__col-img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.expect__img-wrap:hover img {
		transform: scale(1.04);
	}

	.expect__col-label {
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		font-weight: 600;
		margin-bottom: 1rem;
	}

	.expect__col-body {
		font-size: 0.9375rem;
		line-height: 1.78;
		color: var(--muted);
	}

	/* ══ SECTION 3: Personal Split ══ */
	.personal {
		padding: 0;
	}

	.personal__inner {
		max-width: 1100px;
		margin: 0 auto;
		height: 500px;
		display: grid;
		grid-template-columns: 1fr 1fr;
	}

	.personal__text {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		padding: 4rem;
		text-align: center;
		border-right: 1px solid var(--border);
	}

	.personal__body {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: clamp(1.0625rem, 1.75vw, 1.25rem);
		line-height: 1.82;
		color: var(--text);
		max-width: 380px;
		margin-bottom: 1.5rem;
	}

	.personal__body:last-child {
		margin-bottom: 0;
	}

	.personal__image {
		overflow: hidden;
		height: 500px;
	}

	.personal__image img,
	.personal__image :global(.personal__img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	/* ══ SECTION 4: Pull Quote ══ */
	.pullquote {
		padding: 0 0 6rem;
	}

	.pullquote__inner {
		max-width: 900px;
		margin: 0 auto;
		padding: 5rem 3rem 0;
		text-align: center;
	}

	.pullquote__text {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: clamp(1.5rem, 3vw, 2.5rem);
		line-height: 1.45;
		color: var(--text);
		margin-bottom: 2.5rem;
	}

	.pullquote__link {
		font-style: italic;
		font-size: 1rem;
		color: var(--accent);
		text-decoration: none;
		letter-spacing: 0.01em;
		display: block;
		text-align: right;
		transition: opacity 0.2s, letter-spacing 0.25s;
	}

	.pullquote__link:hover {
		opacity: 1;
		letter-spacing: 0.04em;
	}

	/* ══ SECTION 5: CTA ══ */
	.cta {
		padding: 0 0 7rem;
	}

	.cta__inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 6rem 3rem 0;
	}

	/* Images span from 25% of section width to right edge, sitting above text */
	.cta__images {
		position: relative;
		margin-left: 25%;
		height: 560px;
		margin-bottom: 3.5rem;
	}

	/* Back image: landscape, fills full width of images container */
	.cta__img-back {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		overflow: hidden;
		border: 20px solid white;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
	}

	.cta__img-back img {
		width: 100%;
		display: block;
		height: 320px;
		object-fit: cover;
	}

	/* Front image: portrait, starts 1/5 into back image, 1/2 way up into it */
	.cta__img-front {
		position: absolute;
		top: 160px;
		left: 20%;
		width: 44%;
		overflow: hidden;
		border: 20px solid white;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.14);
	}

	.cta__img-front img {
		width: 100%;
		display: block;
		height: 400px;
		object-fit: cover;
	}

	.cta__content {
		padding-left: 25%;
	}

	.cta__heading {
		font-size: clamp(2.25rem, 4vw, 3.75rem);
		color: var(--text);
		margin-bottom: 1.5rem;
		letter-spacing: -0.01em;
	}

	.cta__body {
		font-style: italic;
		font-size: 1.0625rem;
		line-height: 1.82;
		color: var(--text);
		margin-bottom: 2.5rem;
		max-width: 420px;
	}

	.cta__btn {
		display: inline-block;
		font-family: var(--font-sans);
		font-style: normal;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--text);
		padding: 0.7rem 1.75rem;
		transition: background 0.25s, color 0.25s, transform 0.2s, box-shadow 0.25s;
		margin-bottom: 1.5rem;
	}

	.cta__btn:hover {
		background: var(--text);
		color: var(--bg);
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(26, 39, 68, 0.18);
	}

	.cta__caption {
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		color: var(--muted);
		letter-spacing: 0.04em;
	}

	/* ══ Responsive ══ */
	@media (max-width: 900px) {
		.intro {
			grid-template-columns: 1fr;
		}

		.intro__image {
			padding-left: 1.5rem;
			aspect-ratio: 2 / 3;
		}

		.intro__image img,
		.intro__image :global(.intro__img) {
			height: 100%;
		}

		.intro__content {
			padding: 4rem 2rem;
			border-top: 1px solid var(--border);
		}

		.intro__text-wrap {
			max-width: none;
		}

		.expect__inner {
			grid-template-columns: 1fr;
			padding: 0 1.5rem;
		}

		.expect__label-col {
			display: none;
		}

		.expect__cols {
			grid-template-columns: 1fr;
			padding-top: 3rem;
		}

		.personal__inner {
			grid-template-columns: 1fr;
			height: auto;
		}

		.personal__text {
			padding: 4rem 2rem;
			border-right: none;
			border-bottom: 1px solid var(--border);
		}

		.personal__image {
			height: 60vw;
			min-height: 300px;
		}

		.personal__image img,
		.personal__image :global(.personal__img) {
			height: 100%;
		}

		.pullquote__inner {
			padding: 4rem 1.5rem 0;
		}

		.cta__inner {
			padding: 4rem 1.5rem 0;
		}

		.cta__images {
			margin-left: 0;
			height: 380px;
			margin-bottom: 2.5rem;
		}

		.cta__img-back img {
			height: 220px;
		}

		.cta__img-front {
			top: 110px;
		}

		.cta__img-front img {
			height: 280px;
		}

		.cta__content {
			padding-left: 0;
		}
	}
</style>
