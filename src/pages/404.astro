---
import Layout from '../layouts/Layout.astro';
import SectionRenderer from '../components/SectionRenderer.astro';
import { getClient } from '../lib/sanity.js';
import { SECTION_PROJECTION, SITE_PALETTES_QUERY } from '../lib/sectionsQuery.js';

const client = getClient(false);

const [doc, siteData] = await Promise.all([
	client.fetch(
		`*[_type == "notFoundPage" && _id == "notFoundPage"][0]{
			seo { seoTitle, seoDescription, socialImage { asset->{ url } } },
			"sections": sections[]{ ${SECTION_PROJECTION} }
		}`,
	),
	client.fetch(SITE_PALETTES_QUERY),
]);

const palettes = siteData?.palettes ?? [];
const sitePaletteSlug = siteData?.defaultPalette ?? null;
const sections = doc?.sections ?? [];

const seoTitle       = doc?.seo?.seoTitle       || '404 — Page Not Found';
const seoDescription = doc?.seo?.seoDescription || null;
---

<Layout pageTitle={seoTitle} seoDescription={seoDescription}>
	<main>
		{sections.map((section: any, i: number) => (
			<SectionRenderer
				section={section}
				isFirst={i === 0}
				pagePaletteSlug={null}
				sitePaletteSlug={sitePaletteSlug}
				palettes={palettes}
			/>
		))}
	</main>
</Layout>
