---
import Layout from '../layouts/Layout.astro';
import GalleryTabs from '../components/GalleryTabs.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import { getClient, urlFor } from '../lib/sanity.js';

const portfolioDoc = await getClient(
  Astro.locals.isPreview,
  (Astro.locals as any).runtime?.env,
).fetch(
  `*[_type == "portfolio"][0]{
    pageTitle,
    seo { seoTitle, seoDescription, socialImage { asset->{ url } } },
    title,
    byline,
    galleryColumns,
    images[]{ ..., asset->{ _id, metadata { dimensions { width, height } } } },
    additionalGalleries[]{
      name,
      "slug": slug.current,
      byline,
      galleryColumns,
    }
  }`,
  {},
  { cache: 'no-store' },
);

const seoTitle       = portfolioDoc?.seo?.seoTitle       || portfolioDoc?.pageTitle || null;
const seoDescription = portfolioDoc?.seo?.seoDescription || null;
const ogImage        = portfolioDoc?.seo?.socialImage?.asset?.url || null;
const pageTitle      = portfolioDoc?.title          || 'Portfolio';
const byline         = portfolioDoc?.byline         || 'A collection of recent dog photography sessions';
const galleryColumns = portfolioDoc?.galleryColumns || 3;
const portfolio      = portfolioDoc?.images;

// TODO:NICHE — swap fallback Pexels IDs and alt text for your niche
const fallbackImages = [
	{ id: '1108099',  alt: 'Golden retriever in warm afternoon light',    w: 800, h: 1067 },
	{ id: '2253275',  alt: 'Dog exploring in golden afternoon light',     w: 800, h: 533  },
	{ id: '825949',   alt: 'Dog portrait in natural light',               w: 800, h: 1067 },
	{ id: '1254140',  alt: 'Dog running through an open field',           w: 800, h: 533  },
	{ id: '3726314',  alt: 'Dog looking curiously at the camera',         w: 800, h: 1067 },
	{ id: '1805164',  alt: 'Playful dog in soft afternoon light',         w: 800, h: 533  },
	{ id: '2607544',  alt: 'Dog portrait with soft bokeh background',     w: 800, h: 1067 },
	{ id: '3196887',  alt: 'Happy dog outdoors in sunshine',              w: 800, h: 533  },
	{ id: '4587998',  alt: 'Close-up dog portrait outdoors',              w: 800, h: 1067 },
	{ id: '4587991',  alt: 'Dog at rest in warm natural light',           w: 800, h: 533  },
	{ id: '1633794',  alt: 'Dog in dappled forest light',                 w: 800, h: 1067 },
	{ id: '2607546',  alt: 'Dog portrait, candid expression',             w: 800, h: 533  },
].map(({ id, alt, w, h }) => ({
	src: `https://images.pexels.com/photos/${id}/pexels-photo-${id}.jpeg?auto=compress&cs=tinysrgb&w=${w}&h=${h}&fit=crop`,
	fullSrc: `https://images.pexels.com/photos/${id}/pexels-photo-${id}.jpeg?auto=compress&cs=tinysrgb&w=1600`,
	alt, w, h,
}));

// Filter out images without a resolved asset — editors can leave empty
// upload slots in Studio, which would otherwise crash urlFor() and
// bubble up as a 404/500 on the whole portfolio page.
const validPortfolio = (portfolio ?? []).filter((img: any) => img?.asset?._id);
const images = validPortfolio.length
	? validPortfolio.map((img: any) => {
			const naturalW = img.asset?.metadata?.dimensions?.width ?? 1200;
			const naturalH = img.asset?.metadata?.dimensions?.height ?? 800;
			const displayW = Math.min(naturalW, 800);
			const displayH = Math.round((displayW / naturalW) * naturalH);
			return {
				src: urlFor(img).width(800).auto('format').url(),
				fullSrc: urlFor(img).width(2000).auto('format').url(),
				alt: img.alt ?? img.title ?? '',
				w: displayW,
				h: displayH,
			};
	  })
	: fallbackImages;

// Tabs: default (/portfolio) + each additionalGallery with a slug.
const extraGalleries = (portfolioDoc?.additionalGalleries ?? []).filter(
  (g: any) => g?.slug && g?.name,
);
const tabs = [
  { label: pageTitle, href: '/portfolio', slug: '' },
  ...extraGalleries.map((g: any) => ({
    label: g.name,
    href: `/portfolio/${g.slug}`,
    slug: g.slug,
  })),
];
---

<Layout pageTitle={seoTitle} seoDescription={seoDescription} ogImage={ogImage} breadcrumb="Portfolio">
	<main class="portfolio-main">
		<div class="portfolio__header">
			<p class="portfolio__byline">{byline}</p>
			<h1 class="portfolio__title">{pageTitle}</h1>
		</div>
		<GalleryTabs tabs={tabs} activeSlug="" />
		<GalleryGrid images={images} galleryColumns={galleryColumns} />
	</main>
</Layout>

<style>
	/* Portfolio overrides the palette ONLY inside .portfolio-main so
	   photography pops against pure white. Nav and footer are siblings of
	   main, so they keep the site-wide cream palette from :root. */
	.portfolio-main {
		--bg: #ffffff;
		--bg-alt: #f5f5f5;
		--surface: #ffffff;
		--border: #ececec;
		background: #ffffff;
		min-height: 100vh;
		width: 100%;
		overflow-x: hidden;
	}

	.portfolio__header {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 2rem;
		padding: 3rem 3rem 0;
		width: 100%;
		box-sizing: border-box;
		border-bottom: none;
	}

	.portfolio__byline {
		font-family: var(--font-sans);
		font-size: 0.65rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		text-align: right;
		line-height: 1.8;
		max-width: 180px;
	}

	.portfolio__title {
		font-size: clamp(2.45rem, 5.6vw, 4.9rem);
		letter-spacing: -0.02em;
		line-height: 1;
		text-align: right;
		color: var(--text);
		margin: 0;
		white-space: nowrap;
	}

	@media (max-width: 900px) {
		.portfolio__header {
			padding-left: 1.5rem;
			padding-right: 1.5rem;
			gap: 1.25rem;
		}
	}

	@media (max-width: 480px) {
		.portfolio__header {
			flex-direction: column;
			align-items: flex-end;
			gap: 0.5rem;
		}
		.portfolio__byline { max-width: 100%; }
	}
</style>
