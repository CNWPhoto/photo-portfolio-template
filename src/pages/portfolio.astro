---
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity.js';

const portfolioDoc = await sanityClient.fetch(`*[_type == "portfolio"][0]{ title, byline, images }`, {}, { cache: 'no-store' });

const pageTitle  = portfolioDoc?.title  || 'Portfolio';
const byline     = portfolioDoc?.byline || 'A collection of recent dog photography sessions';
const portfolio  = portfolioDoc?.images;

// TODO:NICHE — swap fallback Pexels IDs and alt text for your niche
const fallbackImages = [
	{ id: '1108099',  alt: 'Golden retriever in warm afternoon light' },
	{ id: '2253275',  alt: 'Dog exploring in golden afternoon light' },
	{ id: '825949',   alt: 'Dog portrait in natural light' },
	{ id: '1805164',  alt: 'Playful dog in soft afternoon light' },
	{ id: '3726314',  alt: 'Dog looking curiously at the camera' },
	{ id: '1254140',  alt: 'Dog running through an open field' },
	{ id: '2607544',  alt: 'Dog portrait with soft bokeh background' },
	{ id: '4587991',  alt: 'Dog at rest in warm natural light' },
	{ id: '4587998',  alt: 'Close-up dog portrait outdoors' },
	{ id: '1633794',  alt: 'Dog in dappled forest light' },
	{ id: '3196887',  alt: 'Happy dog outdoors in sunshine' },
	{ id: '2607546',  alt: 'Dog portrait, candid expression' },
].map(({ id, alt }) => ({
	src: `https://images.pexels.com/photos/${id}/pexels-photo-${id}.jpeg?auto=compress&cs=tinysrgb&w=800`,
	alt,
}));

const images = portfolio?.length
	? portfolio.map((img: any) => ({
			src: urlFor(img).width(800).auto('format').url(),
			alt: img.alt ?? img.title ?? '',
	  }))
	: fallbackImages;
---

<Layout>
	<main data-theme="classic-cream">
		<div class="portfolio__header">
			<p class="portfolio__byline">{byline}</p>
			<h1 class="portfolio__title">{pageTitle}</h1>
		</div>
		<div class="portfolio__grid">
			{images.map((img, i) => (
				<div class={`portfolio__item reveal-fade reveal-delay-${Math.min((i % 5) + 1, 5)}`}>
					<img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
				</div>
			))}
		</div>
	</main>
</Layout>

<style>
	main {
		min-height: 100vh;
	}

	/* Header row — byline + large title, right-aligned */
	.portfolio__header {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 2rem;
		padding: 3rem 3rem 0;
		max-width: 100%;
		border-bottom: none;
	}

	/* Small uppercase byline, accent color */
	.portfolio__byline {
		font-family: var(--font-sans);
		font-size: 0.65rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		text-align: right;
		line-height: 1.8;
		max-width: 180px;
	}

	/* Large page title */
	.portfolio__title {
		font-size: clamp(3.5rem, 8vw, 7rem);
		letter-spacing: -0.02em;
		line-height: 1;
		text-align: right;
		color: var(--text);
		margin: 0;
		white-space: nowrap;
	}

	/* Full-width masonry grid, edge to edge */
	.portfolio__grid {
		columns: 3;
		column-gap: 8px;
		max-width: 100%;
		margin: 0;
		padding: 1.5rem 0 0;
	}

	.portfolio__item {
		break-inside: avoid;
		margin-bottom: 8px;
		overflow: hidden;
	}

	.portfolio__item img {
		width: 100%;
		display: block;
		transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.portfolio__item:hover img {
		transform: scale(1.03);
	}

	@media (max-width: 900px) {
		.portfolio__header {
			padding-left: 1.5rem;
			padding-right: 1.5rem;
			gap: 1.25rem;
		}

		.portfolio__grid {
			columns: 2;
		}
	}

	@media (max-width: 480px) {
		.portfolio__header {
			flex-direction: column;
			align-items: flex-end;
			gap: 0.5rem;
		}

		.portfolio__byline {
			max-width: 100%;
		}

		.portfolio__grid {
			columns: 1;
		}
	}
</style>
