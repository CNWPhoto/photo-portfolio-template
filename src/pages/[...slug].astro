---
import Layout from '../layouts/Layout.astro';
import SectionRenderer from '../components/SectionRenderer.astro';
import { getClient } from '../lib/sanity.js';
import { SECTION_PROJECTION, SITE_PALETTES_QUERY } from '../lib/sectionsQuery.js';
import { buildFaqSchema } from '../lib/faqSchema.js';

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : (slugParam || '');

const client = getClient(Astro.locals.isPreview);

const [page, siteData] = await Promise.all([
	client.fetch(
		`*[_type == "page" && slug.current == $slug][0]{
			title,
			"slug": slug.current,
			seo { seoTitle, seoDescription, hideFromSearch, socialImage { asset->{ url } } },
			navThemeOverHero,
			"sections": sections[]{ ${SECTION_PROJECTION} }
		}`,
		{ slug },
	),
	client.fetch(SITE_PALETTES_QUERY),
]);

if (!page) {
	return new Response(null, { status: 404 });
}

const palettes = siteData?.palettes ?? [];
const sitePaletteSlug = siteData?.defaultPalette ?? null;

const sections = page.sections ?? [];

const seoTitle       = page.seo?.seoTitle       || page.title || null;
const seoDescription = page.seo?.seoDescription || null;
const ogImage        = page.seo?.socialImage?.asset?.url || null;
// "Hide from search" toggle → emit noindex (and the sitemap excludes it too).
const robots = page.seo?.hideFromSearch ? 'noindex, follow' : undefined;

// Transparent nav variant should only overlay when the first rendered
// section is a hero in the `image-full` variant. Any other first section
// means we render the nav opaque (same as classic variant) so its text
// stays legible against the page background.
const firstSection = sections[0];
const heroOverlay =
	firstSection?._type === 'heroSection' &&
	firstSection?.enabled !== false &&
	firstSection?.variant === 'image-full';

const faqSchemaData = buildFaqSchema(sections);
---

<Layout pageTitle={seoTitle} seoDescription={seoDescription} ogImage={ogImage} schemaData={faqSchemaData} breadcrumb={page.title} {robots} {heroOverlay}>
	<main>
		{sections.map((section: any, i: number) => (
			<SectionRenderer
				section={section}
				isFirst={i === 0}
				sitePaletteSlug={sitePaletteSlug}
				palettes={palettes}
			/>
		))}
	</main>
</Layout>
