---
import Layout from '../../layouts/Layout.astro';
import { urlFor } from '../../lib/sanity.js';
import { toHTML } from '@portabletext/to-html';

const SANITY_API = 'https://hx5xgigp.api.sanity.io/v2023-05-03/data/query/production'

export async function getStaticPaths() {
  const SANITY_API = 'https://hx5xgigp.api.sanity.io/v2023-05-03/data/query/production'
  const query = encodeURIComponent(`*[_type == "blogPost"]{ "slug": slug.current }`)
  const res = await fetch(`${SANITY_API}?query=${query}`, { cache: 'no-store' })
  const { result: posts } = await res.json()
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;

const postQuery = encodeURIComponent(
  `*[_type == "blogPost" && slug.current == $slug][0]{ title, publishDate, excerpt, coverImage, body, category }`
)
const slugParam = encodeURIComponent(JSON.stringify(slug))
const postRes = await fetch(
  `${SANITY_API}?query=${postQuery}&$slug=${slugParam}`,
  { cache: 'no-store' }
)
const { result: post } = await postRes.json()

if (!post) {
  return Astro.redirect('/blog');
}

const publishFormatted = post.publishDate
  ? new Date(post.publishDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const bodyHTML = post.body
  ? toHTML(post.body, {
      components: {
        types: {
          image: ({ value }) => {
            const src = urlFor(value).width(800).auto('format').url();
            const alt = value.alt || '';
            const caption = value.caption || '';
            return `<figure class="body-image">
              <img src="${src}" alt="${alt}" loading="lazy" />
              ${caption ? `<figcaption class="body-image__caption">${caption}</figcaption>` : ''}
            </figure>`;
          },
        },
        block: {
          h2: ({ children }) => `<h2>${children}</h2>`,
          h3: ({ children }) => `<h3>${children}</h3>`,
          blockquote: ({ children }) => `<blockquote>${children}</blockquote>`,
          normal: ({ children }) => `<p>${children}</p>`,
        },
        marks: {
          link: ({ children, value }) =>
            `<a href="${value.href}" target="_blank" rel="noopener noreferrer">${children}</a>`,
        },
      },
    })
  : '';
---

<Layout>
  <main>
    <article class="post">
      <div class="post__header">
        {post.category && <p class="post__category">{post.category}</p>}
        <h1 class="post__title">{post.title}</h1>
        {publishFormatted && <p class="post__date">{publishFormatted}</p>}
        <hr class="post__rule" />
      </div>

      {post.coverImage && (
        <div class="post__cover">
          <img
            src={urlFor(post.coverImage).width(1100).auto('format').url()}
            alt={post.coverImage.alt || post.title}
            loading="eager"
          />
        </div>
      )}

      <div class="post__body" set:html={bodyHTML} />
    </article>
  </main>
</Layout>

<style>
  .post {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem 8rem;
  }

  /* ══ Header ══ */
  .post__header {
    margin-bottom: 2.5rem;
  }

  .post__category {
    font-family: var(--font-sans, system-ui, sans-serif);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent, #8b2635);
    margin-bottom: 1.25rem;
  }

  .post__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-style: italic;
    color: var(--text, #1a2744);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }

  .post__date {
    font-family: var(--font-sans, system-ui, sans-serif);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted, #7a7670);
    margin-bottom: 1.75rem;
  }

  .post__rule {
    border: none;
    border-top: 1px solid var(--border, #d4cfc6);
    margin: 0;
  }

  /* ══ Cover image ══ */
  .post__cover {
    max-width: 1100px;
    margin: 2.5rem auto 0;
  }

  .post__cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ══ Body ══ */
  .post__body {
    margin-top: 3rem;
  }

  .post__body :global(p) {
    font-family: var(--font-body, Georgia, serif);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--text, #1a2744);
    margin-bottom: 1.5rem;
  }

  .post__body :global(h2) {
    font-family: var(--font-heading, Georgia, serif);
    font-style: italic;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--text, #1a2744);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .post__body :global(h3) {
    font-family: var(--font-heading, Georgia, serif);
    font-style: italic;
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    color: var(--text, #1a2744);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .post__body :global(blockquote) {
    border-left: 3px solid var(--accent, #8b2635);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--muted, #7a7670);
  }

  .post__body :global(blockquote p) {
    margin-bottom: 0;
  }

  .post__body :global(.body-image) {
    margin: 2rem 0;
  }

  .post__body :global(.body-image img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .post__body :global(.body-image__caption) {
    font-size: 0.8rem;
    font-style: italic;
    color: var(--muted, #7a7670);
    margin-top: 0.6rem;
    text-align: center;
  }

  .post__body :global(ul),
  .post__body :global(ol) {
    padding-left: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .post__body :global(li) {
    font-family: var(--font-body, Georgia, serif);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--text, #1a2744);
    margin-bottom: 0.4rem;
  }

  .post__body :global(a) {
    color: var(--accent, #8b2635);
    text-decoration: none;
  }

  .post__body :global(a:hover) {
    text-decoration: underline;
  }

  .post__body :global(strong) {
    font-weight: 700;
  }

  .post__body :global(em) {
    font-style: italic;
  }

  /* ══ Responsive ══ */
  @media (max-width: 600px) {
    .post {
      padding: 2.5rem 1.25rem 5rem;
    }
  }
</style>
