---
import Layout from '../../layouts/Layout.astro';
import { toHTML } from '@portabletext/to-html';
import SanityImage from '../../components/SanityImage.astro';
import { buildSrc, buildSrcset } from '../../lib/image';
import { getClient } from '../../lib/sanity.js';

const { slug } = Astro.params;
const client = getClient(Astro.locals.isPreview);

const [post, siteSettings] = await Promise.all([
  client.fetch(
    `*[_type == "blogPost" && slug.current == $slug][0]{
      title, publishDate, _updatedAt, excerpt,
      coverImage { asset->{ _id, metadata { dimensions { width, height, aspectRatio }, lqip } }, alt },
      body,
      "categories": categories[]->{ name, "slug": slug.current }
    }`,
    { slug }
  ),
  client.fetch(`*[_type == "siteSettings" && _id == "siteSettings"][0]{ siteName, photographerName }`),
]);

if (!post) {
  return Astro.redirect('/blog');
}

const publishFormatted = post.publishDate
  ? new Date(post.publishDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

// ── Schema ───────────────────────────────────────────────────────────────────
const coverImageUrl = post.coverImage?.asset
	? buildSrc(post.coverImage, 1200)
	: undefined;

const authorName = siteSettings?.photographerName || siteSettings?.siteName || 'Photographer';
const blogPostingSchema = [{
	'@type': 'BlogPosting',
	headline: post.title,
	...(post.publishDate  ? { datePublished:  post.publishDate  } : {}),
	...(post._updatedAt   ? { dateModified:   post._updatedAt   } : {}),
	...(post.excerpt      ? { description:    post.excerpt      } : {}),
	...(coverImageUrl     ? { image:          coverImageUrl     } : {}),
	author: { '@type': 'Person', name: authorName },
	publisher: {
		'@type': 'Organization',
		name: siteSettings?.siteName || authorName,
		...(coverImageUrl ? { logo: { '@type': 'ImageObject', url: coverImageUrl } } : {}),
	},
}];

const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
const safeHref = (href: string) => /^(https?:|mailto:|\/)/i.test(href) ? href : '#';

const bodyHTML = post.body
  ? toHTML(post.body, {
      components: {
        types: {
          image: ({ value }) => {
            const src = buildSrc(value, 800);
            const srcset = buildSrcset(value, [400, 800, 1200]);
            const alt = esc(value.alt || '');
            const caption = esc(value.caption || '');
            return `<figure class="body-image">
              <img src="${src}" srcset="${srcset}" sizes="(max-width: 900px) 100vw, 60vw" alt="${alt}" loading="lazy" decoding="async" />
              ${caption ? `<figcaption class="body-image__caption">${caption}</figcaption>` : ''}
            </figure>`;
          },
          videoEmbed: ({ value }) => {
            if (!value?.url) return '';
            const url = value.url as string;
            let embedUrl = '';
            const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]+)/);
            if (yt) embedUrl = `https://www.youtube.com/embed/${yt[1]}`;
            const vimeo = url.match(/vimeo\.com\/(\d+)/);
            if (vimeo) embedUrl = `https://player.vimeo.com/video/${vimeo[1]}`;
            if (!embedUrl) return '';
            const caption = esc(value.caption || '');
            return `<figure class="body-video">
              <div class="body-video__wrap">
                <iframe src="${embedUrl}" title="${caption || 'Video'}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
              </div>
              ${caption ? `<figcaption class="body-image__caption">${caption}</figcaption>` : ''}
            </figure>`;
          },
        },
        block: {
          h2: ({ children }) => `<h2>${children}</h2>`,
          h3: ({ children }) => `<h3>${children}</h3>`,
          blockquote: ({ children }) => `<blockquote>${children}</blockquote>`,
          normal: ({ children }) => `<p>${children}</p>`,
        },
        marks: {
          link: ({ children, value }) =>
            `<a href="${esc(safeHref(value.href || ''))}" target="_blank" rel="noopener noreferrer">${children}</a>`,
        },
      },
    })
  : '';
---

<Layout
  pageTitle={post.title}
  seoDescription={post.excerpt || undefined}
  ogImage={coverImageUrl}
  breadcrumb={post.title}
  schemaData={blogPostingSchema}
  publishDate={post.publishDate || undefined}
  updatedAt={post._updatedAt || undefined}
>
  <main>
    <article class="post">
      <div class="post__header">
        {post.categories?.length > 0 && (
          <ul class="post__categories">
            {post.categories.map((c: any) => (
              <li>
                <a class="post__category" href={`/blog/category/${c.slug}`}>{c.name}</a>
              </li>
            ))}
          </ul>
        )}
        <h1 class="post__title">{post.title}</h1>
        {publishFormatted && <p class="post__date">{publishFormatted}</p>}
        <hr class="post__rule" />
      </div>

      {post.coverImage && (
        <div
          class="post__cover"
          style={post.coverImage?.asset?.metadata?.lqip
            ? `background-image:url('${post.coverImage.asset.metadata.lqip}');background-size:cover;background-position:center;`
            : ''}
        >
          <SanityImage
            image={post.coverImage}
            sizes="(max-width: 900px) 100vw, 60vw"
            loading="eager"
            class="post__cover-img"
          />
        </div>
      )}

      <div class="post__body" set:html={bodyHTML} />
    </article>
  </main>
</Layout>

<style>
  .post {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem 8rem;
  }

  /* ══ Header ══ */
  .post__header {
    margin-bottom: 2.5rem;
  }

  .post__categories {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .post__category {
    display: inline-block;
    font-family: var(--font-sans, system-ui, sans-serif);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    padding: 0.35rem 0.75rem;
    transition: background 0.2s, color 0.2s;
  }
  .post__category:hover {
    background: var(--accent);
    color: var(--btn-text);
  }

  .post__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-style: italic;
    color: var(--text);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }

  .post__date {
    font-family: var(--font-sans, system-ui, sans-serif);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.75rem;
  }

  .post__rule {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0;
  }

  /* ══ Cover image ══ */
  .post__cover {
    max-width: 1100px;
    margin: 2.5rem auto 0;
  }

  .post__cover :global(.post__cover-img) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ══ Body ══ */
  .post__body {
    margin-top: 3rem;
  }

  .post__body :global(p) {
    font-family: var(--font-body, Georgia, serif);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .post__body :global(h2) {
    font-family: var(--font-heading, Georgia, serif);
    font-style: italic;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .post__body :global(h3) {
    font-family: var(--font-heading, Georgia, serif);
    font-style: italic;
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .post__body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--muted);
  }

  .post__body :global(blockquote p) {
    margin-bottom: 0;
  }

  .post__body :global(.body-image),
  .post__body :global(.body-video) {
    margin: 2rem 0;
  }

  .post__body :global(.body-image img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .post__body :global(.body-video__wrap) {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
  }

  .post__body :global(.body-video__wrap iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .post__body :global(.body-image__caption) {
    font-size: 0.8rem;
    font-style: italic;
    color: var(--muted);
    margin-top: 0.6rem;
    text-align: center;
  }

  .post__body :global(ul),
  .post__body :global(ol) {
    padding-left: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .post__body :global(li) {
    font-family: var(--font-body, Georgia, serif);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .post__body :global(a) {
    color: var(--accent);
    text-decoration: none;
  }

  .post__body :global(a:hover) {
    text-decoration: underline;
  }

  .post__body :global(strong) {
    font-weight: 700;
  }

  .post__body :global(em) {
    font-style: italic;
  }

  /* ══ Responsive ══ */
  @media (max-width: 600px) {
    .post {
      padding: 2.5rem 1.25rem 5rem;
    }
  }
</style>
