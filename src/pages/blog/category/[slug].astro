---
import Layout from '../../../layouts/Layout.astro';
import SanityImage from '../../../components/SanityImage.astro';
import { getClient } from '../../../lib/sanity.js';

const { slug } = Astro.params;
const client = getClient(Astro.locals.isPreview, (Astro.locals as any).runtime?.env);

const [category, posts] = await Promise.all([
  client.fetch(
    `*[_type == "blogCategory" && slug.current == $slug][0]{ name, description }`,
    { slug },
  ),
  client.fetch(
    `*[_type == "blogPost" && defined(slug.current) && $slug in categories[]->slug.current]
      | order(publishDate desc){
        _id, title, "slug": slug.current, publishDate, excerpt,
        coverImage { ..., asset->{ _id, metadata { dimensions { width, height } } } }
      }`,
    { slug },
  ),
]);

if (!category) {
  return new Response(null, { status: 404 });
}

const dateFmt = (d?: string) => {
  if (!d) return '';
  try {
    return new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
  } catch {
    return d;
  }
};

const pageTitle = `${category.name} — Blog Category`;
---

<Layout
  pageTitle={pageTitle}
  seoDescription={category.description || `Blog posts in the ${category.name} category.`}
  breadcrumb={category.name}
  robots="noindex, follow"
>
  <main class="cat">
    <header class="cat__header">
      <p class="cat__crumb"><a href="/blog">Blog</a> &rsaquo; Category</p>
      <h1 class="cat__title">{category.name}</h1>
      {category.description && <p class="cat__desc">{category.description}</p>}
    </header>

    {posts.length === 0 ? (
      <p class="cat__empty">No posts in this category yet.</p>
    ) : (
      <ul class="cat__grid">
        {posts.map((post: any) => (
          <li class="cat__card">
            <a class="cat__anchor" href={`/blog/${post.slug}`}>
              {post?.coverImage?.asset && (
                <div class="cat__img-wrap">
                  <SanityImage
                    image={post.coverImage}
                    sizes="(max-width:900px) 100vw, 33vw"
                    loading="lazy"
                    class="cat__img"
                  />
                </div>
              )}
              <div class="cat__body">
                <h2 class="cat__post-title">{post.title}</h2>
                {post.publishDate && <p class="cat__date">{dateFmt(post.publishDate)}</p>}
                {post.excerpt && <p class="cat__excerpt">{post.excerpt}</p>}
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>

<style>
  .cat {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }
  .cat__header { margin-bottom: 3rem; }
  .cat__crumb {
    font-family: var(--font-sans, var(--font-body));
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }
  .cat__crumb a { color: var(--accent); text-decoration: none; }
  .cat__title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    margin: 0 0 0.75rem;
  }
  .cat__desc {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--muted);
    max-width: 640px;
    margin: 0;
  }
  .cat__empty {
    color: var(--muted);
    font-style: italic;
  }
  .cat__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .cat__anchor { color: inherit; text-decoration: none; display: block; }
  .cat__img-wrap {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    margin-bottom: 1rem;
  }
  .cat__img-wrap :global(.cat__img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-image);
  }
  .cat__card:hover .cat__img-wrap :global(.cat__img) { transform: scale(1.04); }
  .cat__post-title {
    font-size: 1.35rem;
    line-height: 1.3;
    margin: 0 0 0.5rem;
  }
  .cat__date {
    font-family: var(--font-sans, var(--font-body));
    font-size: 0.8rem;
    color: var(--muted-light);
    margin: 0 0 0.5rem;
  }
  .cat__excerpt {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
  }
  @media (max-width: 900px) {
    .cat__grid { grid-template-columns: 1fr; }
  }
</style>
