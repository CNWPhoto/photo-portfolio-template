	/* ══════════════════════════════════════════════════
	   SCROLL REVEAL ANIMATIONS
	══════════════════════════════════════════════════ */

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(22px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@keyframes fadeIn {
		from { opacity: 0; }
		to   { opacity: 1; }
	}

	.reveal {
		opacity: 0;
		transform: translateY(22px);
		will-change: opacity, transform;
	}

	.reveal.revealed {
		animation: fadeUp 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.reveal-fade {
		opacity: 0;
		will-change: opacity;
	}

	.reveal-fade.revealed {
		animation: fadeIn 0.8s ease both;
	}

	.reveal-delay-1 { animation-delay: 0.08s; }
	.reveal-delay-2 { animation-delay: 0.16s; }
	.reveal-delay-3 { animation-delay: 0.24s; }
	.reveal-delay-4 { animation-delay: 0.32s; }
	.reveal-delay-5 { animation-delay: 0.40s; }

	@media (prefers-reduced-motion: reduce) {
		.reveal, .reveal-fade { opacity: 1 !important; transform: none !important; }
		.reveal.revealed, .reveal-fade.revealed { animation: none !important; }
	}

	/* ══════════════════════════════════════════════════
	   INTERACTION STANDARDS
	   Hover micro-interactions for all interactive elements.
	   Uses only transform, opacity, and letter-spacing —
	   compositor-only properties with zero layout impact.
	   All transitions respect prefers-reduced-motion.
	══════════════════════════════════════════════════ */

	/* ── BORDERED / SOLID BUTTONS ─────────────────────────────
	   Matches any element using __cta, __btn, __submit, __button.
	   ⚠️  ATTRIBUTE-WILDCARD GOTCHA — READ BEFORE ADDING A NEW BUTTON.
	   The selector below uses [class*="__cta"], which substring-matches
	   ANY class containing "__cta" — including wrapper / row / footer
	   divs that happen to include "cta" in their name. A wrapper named
	   `section__cta-wrap` will satisfy this selector and lift the entire
	   wrapper width on hover, not just the button.
	   Rule when adding a button:
	     - The button itself: name it `section__cta` (or __btn, __submit,
	       __button) so it picks up this hover treatment.
	     - The button's wrapper / row: name it WITHOUT any of those four
	       substrings — `section__footer`, `section__actions`,
	       `section__row`, etc. Never `section__cta-wrap` or similar.
	   See RichTextSection.astro and CtaBandSection.astro for examples
	   of the correct pattern (`__footer` wrapper, `__cta` anchor inside). */
	[class*="__cta"],
	[class*="__btn"],
	[class*="__submit"],
	[class*="__button"] {
		transition: background 0.25s, color 0.25s, transform 0.2s, box-shadow 0.25s;
	}
	[class*="__cta"]:hover,
	[class*="__btn"]:hover,
	[class*="__submit"]:hover,
	[class*="__button"]:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
	}

	/* ── ITALIC / ARROW TEXT LINKS ─────────────────────────────
	   Matches any element using __link.
	   Same attribute-wildcard gotcha as the __cta block above —
	   wrappers / containers must not contain "__link" in their class
	   name or they'll pick up the letter-spacing tightening on hover.
	   Use `__link-arrow`-shaped child class names freely (already
	   inside the link), but name PARENTS without "link" in the BEM
	   suffix. GalleryTabs.astro hits this with .gallery-tabs__link
	   itself being the link — fine — but if you ever wrap a link in
	   `section__link-row` or similar, that wrapper inherits the
	   tracking change. */
	[class*="__link"] {
		transition: opacity 0.2s, letter-spacing 0.25s;
	}
	[class*="__link"]:hover {
		opacity: 1;
		letter-spacing: 0.04em;
	}

	/* ── CARD / ITEM HOVER ─────────────────────────────────────
	   Matches blog post cards, portfolio items, gallery tiles  */
	[class*="__item-inner"],
	[class*="__card"] {
		transition: transform 0.2s, box-shadow 0.25s;
	}
	[class*="__item-inner"]:hover,
	[class*="__card"]:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
	}

	/* ── SLIDER / CAROUSEL ARROWS ──────────────────────────────
	   Matches testimonial arrows, hero prev/next arrows        */
	[class*="__arrow"] {
		transition: border-color 0.2s, color 0.2s, transform 0.18s;
	}
	[class*="__arrow"]:hover:not(:disabled) {
		transform: scale(1.08);
	}

	/* ── REDUCED MOTION ────────────────────────────────────────
	   Disables all transitions for users who prefer it         */
	@media (prefers-reduced-motion: reduce) {
		[class*="__cta"],
		[class*="__btn"],
		[class*="__submit"],
		[class*="__button"],
		[class*="__link"],
		[class*="__item-inner"],
		[class*="__card"],
		[class*="__arrow"] {
			transition: none !important;
			transform: none !important;
		}
	}

