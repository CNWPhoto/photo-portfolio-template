---
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';

const SANITY_API = 'https://hx5xgigp.api.sanity.io/v2023-05-03/data/query/production';

const [_settingsRes, _codeRes] = await Promise.all([
  fetch(`${SANITY_API}?query=${encodeURIComponent(`*[_type == "siteSettings" && _id == "siteSettings"][0]{ colorTheme, fontTheme, siteName, logoType, logoImage, favicon }`)}`, { cache: 'no-store' }),
  fetch(`${SANITY_API}?query=${encodeURIComponent(`*[_type == "codeSettings" && _id == "codeSettings"][0]{ headScripts, bodyScripts }`)}`, { cache: 'no-store' }),
]);

const { result: settings } = await _settingsRes.json();
const { result: code }     = await _codeRes.json();

const colorTheme  = settings?.colorTheme || 'classic-cream';
const fontTheme   = settings?.fontTheme  || 'classic-editorial';
const siteName    = settings?.siteName   || 'Pet Photography';
const logoType    = settings?.logoType   || 'text';
const logoImage   = settings?.logoImage  ?? null;
const headScripts = code?.headScripts    || '';
const bodyScripts = code?.bodyScripts    || '';
const faviconUrl  = settings?.favicon?.asset?._ref
  ? `https://cdn.sanity.io/images/hx5xgigp/production/${settings.favicon.asset._ref.replace('image-', '').replace(/-([a-z]+)$/, '.$1')}`
  : null;
---

<!doctype html>
<html lang="en" data-theme={colorTheme} data-font={fontTheme}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		{faviconUrl
			? <link rel="icon" href={faviconUrl} />
			: <>
				<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
				<link rel="icon" href="/favicon.ico" />
			</>
		}
		<meta name="generator" content={Astro.generator} />
		<title>Pet Photography — Natural, Stress-Free Dog Portraits</title>
		<!-- Google Fonts preconnect -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<!-- All font theme families loaded upfront; only the active theme's fonts render -->
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Jost:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&family=Fraunces:ital,wght@0,300;0,400;1,300;1,400&family=Nunito+Sans:ital,wght@0,300;0,400;0,600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Libre+Franklin:wght@300;400;500&family=Tenor+Sans&family=Raleway:wght@300;400;500&display=swap"
			rel="stylesheet"
		/>
		{headScripts && <Fragment set:html={headScripts} />}
	</head>
	<body>
		<Nav siteName={siteName} logoType={logoType} logoImage={logoImage} />
		<slot />
		<Footer {siteName} />
		<script>
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('revealed');
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
			document.querySelectorAll('.reveal, .reveal-fade').forEach(el => observer.observe(el));
		</script>
		{bodyScripts && <Fragment set:html={bodyScripts} />}
	</body>
</html>

<style is:global>
	/* ══════════════════════════════════════════════════
	   FONT THEMES
	   Applied via data-font on <html>.
	   Components reference --font-heading and --font-body.
	   Legacy aliases --font-serif / --font-sans resolve
	   through var() substitution at compute time.
	══════════════════════════════════════════════════ */

	/* Font Theme 1: Classic Editorial */
	html[data-font='classic-editorial'] {
		--font-heading: 'Cormorant Garamond', Georgia, serif;
		--font-body: 'Jost', system-ui, sans-serif;
	}

	/* Font Theme 2: Romantic Script */
	html[data-font='romantic-script'] {
		--font-heading: 'Playfair Display', Georgia, serif;
		--font-body: 'Lato', system-ui, sans-serif;
	}

	/* Font Theme 3: Modern Luxury */
	html[data-font='modern-luxury'] {
		--font-heading: 'DM Serif Display', Georgia, serif;
		--font-body: 'DM Sans', system-ui, sans-serif;
	}

	/* Font Theme 4: Soft Contemporary */
	html[data-font='soft-contemporary'] {
		--font-heading: 'Fraunces', Georgia, serif;
		--font-body: 'Nunito Sans', system-ui, sans-serif;
	}

	/* Font Theme 5: Bold Editorial */
	html[data-font='bold-editorial'] {
		--font-heading: 'Libre Baskerville', Georgia, serif;
		--font-body: 'Libre Franklin', system-ui, sans-serif;
	}

	/* Font Theme 6: Airy Minimal */
	html[data-font='airy-minimal'] {
		--font-heading: 'Tenor Sans', Georgia, serif;
		--font-body: 'Raleway', system-ui, sans-serif;
	}

	/* ══════════════════════════════════════════════════
	   COLOUR THEMES
	   Default applied via data-theme on <html>.
	   Individual sections can override with their own data-theme.
	   All components consume: --bg, --bg-alt, --text,
	   --accent, --accent-dark, --muted, --muted-light, --border.
	   --surface aliases --bg-alt within a themed section.
	══════════════════════════════════════════════════ */

	/* Theme 1: Classic Cream (site default)
	   html[data-theme] specificity (0,1,1) beats :root (0,1,0) so the
	   active theme always wins regardless of stylesheet order. Plain
	   [data-theme] selectors are kept alongside so section-level
	   overrides (e.g. <section data-theme="warm-studio">) still work. */
	:root,
	html[data-theme='classic-cream'],
	[data-theme='classic-cream'] {
		--bg: #f5f3ef;
		--text: #1a2744;
		--accent: #8b2635;
		--surface: #edeae4;
		--bg-alt: #edeae4;
		--accent-dark: #6b1c28;
		--muted: #4a5568;
		--muted-light: #8a94a6;
		--border: #d4cfc6;
		--section-alt: #edeae4;
		--section-dark: #1a2744;
		--section-dark-text: #f5f3ef;
		--btn-bg: #8b2635;
		--btn-text: #ffffff;
	}

	/* Theme 2: Warm Studio */
	html[data-theme='warm-studio'],
	[data-theme='warm-studio'] {
		--bg: #fdf6ee;
		--text: #2c1810;
		--accent: #c9702a;
		--surface: #f5ead9;
		--bg-alt: #f5ead9;
		--accent-dark: #a85a20;
		--muted: #6b4c3b;
		--muted-light: #a88070;
		--border: #e8d5c0;
		--section-alt: #f5ead9;
		--section-dark: #2c1810;
		--section-dark-text: #fdf6ee;
		--btn-bg: #c9702a;
		--btn-text: #ffffff;
	}

	/* Theme 3: Dark Editorial */
	html[data-theme='dark-editorial'],
	[data-theme='dark-editorial'] {
		--bg: #1a1a1a;
		--text: #f0ede8;
		--accent: #c9a96e;
		--surface: #252525;
		--bg-alt: #252525;
		--accent-dark: #a8895a;
		--muted: #a0998e;
		--muted-light: #6b645c;
		--border: #3a3a3a;
		--section-alt: #252525;
		--section-dark: #111111;
		--section-dark-text: #f0ede8;
		--btn-bg: #c9a96e;
		--btn-text: #1a1a1a;
	}

	/* Theme 4: Cool Minimal */
	html[data-theme='cool-minimal'],
	[data-theme='cool-minimal'] {
		--bg: #f8f9fa;
		--text: #1c2b3a;
		--accent: #4a7c9e;
		--surface: #eef1f4;
		--bg-alt: #eef1f4;
		--accent-dark: #3a6480;
		--muted: #4a5e6e;
		--muted-light: #8a99a6;
		--border: #d0d8de;
		--section-alt: #eef1f4;
		--section-dark: #1c2b3a;
		--section-dark-text: #f8f9fa;
		--btn-bg: #4a7c9e;
		--btn-text: #ffffff;
	}

	/* Theme 5: Forest Sage */
	html[data-theme='forest-sage'],
	[data-theme='forest-sage'] {
		--bg: #f2f4f0;
		--text: #1e2d1f;
		--accent: #5a7a4e;
		--surface: #e4ebe0;
		--bg-alt: #e4ebe0;
		--accent-dark: #456040;
		--muted: #4a5e4b;
		--muted-light: #8a9e8b;
		--border: #ccd6c8;
		--section-alt: #e4ebe0;
		--section-dark: #1e2d1f;
		--section-dark-text: #f2f4f0;
		--btn-bg: #5a7a4e;
		--btn-text: #ffffff;
	}

	/* Any themed element gets its own background/color scope */
	[data-theme] {
		background: var(--bg);
		color: var(--text);
	}

	/* ══════════════════════════════════════════════════
	   GLOBAL TOKENS & BASE RESET
	══════════════════════════════════════════════════ */

	:root {
		--white: #ffffff;
		/*
		 * Legacy aliases — resolve through var() substitution at compute time.
		 * Component scoped styles that reference --font-serif / --font-sans
		 * will pick up whatever --font-heading / --font-body the active
		 * font theme has set on <html>.
		 */
		--font-serif: var(--font-heading);
		--font-sans: var(--font-body);
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--text);
		font-family: var(--font-body);
		font-size: 1.328rem;
		line-height: 1.8;
		-webkit-font-smoothing: antialiased;
	}

	img {
		display: block;
		max-width: 100%;
	}

	a {
		color: inherit;
	}

	h1,
	h2,
	h3,
	h4 {
		font-family: var(--font-heading);
		font-weight: normal;
		font-style: italic;
		line-height: 1.2;
		margin: 0;
	}

	p {
		margin: 0;
	}

	ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	hr {
		border: none;
		border-top: 1px solid var(--border);
		margin: 0;
	}

	button {
		font-family: var(--font-body);
	}

	section {
		padding-top: 100px;
		padding-bottom: 100px;
	}

	/* ══════════════════════════════════════════════════
	   SCROLL REVEAL ANIMATIONS
	══════════════════════════════════════════════════ */

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(22px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@keyframes fadeIn {
		from { opacity: 0; }
		to   { opacity: 1; }
	}

	.reveal {
		opacity: 0;
		transform: translateY(22px);
		will-change: opacity, transform;
	}

	.reveal.revealed {
		animation: fadeUp 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.reveal-fade {
		opacity: 0;
		will-change: opacity;
	}

	.reveal-fade.revealed {
		animation: fadeIn 0.8s ease both;
	}

	.reveal-delay-1 { animation-delay: 0.08s; }
	.reveal-delay-2 { animation-delay: 0.16s; }
	.reveal-delay-3 { animation-delay: 0.24s; }
	.reveal-delay-4 { animation-delay: 0.32s; }
	.reveal-delay-5 { animation-delay: 0.40s; }

	@media (prefers-reduced-motion: reduce) {
		.reveal, .reveal-fade { opacity: 1 !important; transform: none !important; }
		.reveal.revealed, .reveal-fade.revealed { animation: none !important; }
	}

	/* ══════════════════════════════════════════════════
	   INTERACTION STANDARDS
	   Hover micro-interactions for all interactive elements.
	   Uses only transform, opacity, and letter-spacing —
	   compositor-only properties with zero layout impact.
	   All transitions respect prefers-reduced-motion.
	══════════════════════════════════════════════════ */

	/* ── BORDERED / SOLID BUTTONS ─────────────────────────────
	   Matches any element using __cta, __btn, __submit, __button */
	[class*="__cta"],
	[class*="__btn"],
	[class*="__submit"],
	[class*="__button"] {
		transition: background 0.25s, color 0.25s, transform 0.2s, box-shadow 0.25s;
	}
	[class*="__cta"]:hover,
	[class*="__btn"]:hover,
	[class*="__submit"]:hover,
	[class*="__button"]:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(26, 39, 68, 0.18);
	}

	/* ── ITALIC / ARROW TEXT LINKS ─────────────────────────────
	   Matches any element using __link                         */
	[class*="__link"] {
		transition: opacity 0.2s, letter-spacing 0.25s;
	}
	[class*="__link"]:hover {
		opacity: 1;
		letter-spacing: 0.04em;
	}

	/* ── CARD / ITEM HOVER ─────────────────────────────────────
	   Matches blog post cards, portfolio items, gallery tiles  */
	[class*="__item-inner"],
	[class*="__card"] {
		transition: transform 0.2s, box-shadow 0.25s;
	}
	[class*="__item-inner"]:hover,
	[class*="__card"]:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 24px rgba(26, 39, 68, 0.12);
	}

	/* ── SLIDER / CAROUSEL ARROWS ──────────────────────────────
	   Matches testimonial arrows, hero prev/next arrows        */
	[class*="__arrow"] {
		transition: border-color 0.2s, color 0.2s, transform 0.18s;
	}
	[class*="__arrow"]:hover:not(:disabled) {
		transform: scale(1.08);
	}

	/* ── REDUCED MOTION ────────────────────────────────────────
	   Disables all transitions for users who prefer it         */
	@media (prefers-reduced-motion: reduce) {
		[class*="__cta"],
		[class*="__btn"],
		[class*="__submit"],
		[class*="__button"],
		[class*="__link"],
		[class*="__item-inner"],
		[class*="__card"],
		[class*="__arrow"] {
			transition: none !important;
			transform: none !important;
		}
	}
</style>
