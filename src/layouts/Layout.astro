---
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import DemoBanner from '../components/DemoBanner.astro';
import '../styles/palette.css';
import { getClient } from '../lib/sanity.js';
import { stegaClean } from '@sanity/client/stega';

interface Props {
  pageTitle?: string;
  seoDescription?: string;
  ogImage?: string;
  schemaData?: Record<string, any>[];
  breadcrumb?: string;
  publishDate?: string;  // ISO date — triggers article OG tags
  updatedAt?: string;    // ISO date — article:modified_time
  prevUrl?: string;      // blog pagination rel="prev"
  nextUrl?: string;      // blog pagination rel="next"
  robots?: string;       // override robots meta (e.g. "noindex, follow" for category pages)
  heroOverlay?: boolean; // page leads with a hero--image-full section; transparent nav overlays it
}

const { pageTitle, seoDescription, ogImage, schemaData, breadcrumb, publishDate, updatedAt, prevUrl, nextUrl, robots, heroOverlay } = Astro.props;
const isPreview = Astro.locals.isPreview ?? false;
const client = getClient(isPreview, (Astro.locals as any).runtime?.env);

const [settings, seo, code, nav, blogConfig, social] = await Promise.all([
  client.fetch(`*[_type == "siteSettings" && _id == "siteSettings"][0]{
    fontTheme, siteName, photographerName, logoType, logoImage, favicon,
    accentColorOverride, textColorPreset, defaultPalette,
    demo,
    "palettes": palettes[]{
      "slug": slug.current,
      bg, bgAlt, surface, text, textMuted, textMutedLight,
      accent, accentDark, border, sectionAlt, sectionDark,
      sectionDarkText, btnBg, btnText
    }
  }`),
  client.fetch(`*[_type == "seoSettings" && _id == "seoSettings"][0]{ siteUrl, businessPhone, businessEmail, businessCity, businessState, priceRange, areaServed, twitterHandle }`),
  client.fetch(`*[_type == "codeSettings" && _id == "codeSettings"][0]{ headScripts, bodyScripts }`),
  client.fetch(`*[_type == "navSettings" && _id == "navSettings"][0]{
    navVariant,
    stickyNav,
    links[] {
      label, url, enabled, openInNewTab, isButton, linkType,
      "internalRef": internalRef->{ _type, "slug": slug.current },
      children[] {
        label, url, openInNewTab, linkType,
        "internalRef": internalRef->{ _type, "slug": slug.current }
      }
    }
  }`),
  client.fetch(`*[_type == "blogPage" && _id == "blogPage"][0]{ blogEnabled }`),
  client.fetch(`*[_type == "socialSettings" && _id == "socialSettings"][0]{ instagram, facebook, youtube, tiktok }`),
]);

// Every query result in preview mode is stega-contaminated — invisible
// markers inside string fields break map lookups (FONT_MAP[fontTheme]),
// array inclusion checks (LIGHT_THEMES.includes(colorTheme)), equality
// checks (logoType === 'image'), and CSS parsing (hex values). Clean the
// whole settings/seo/code/social objects up front so every downstream
// consumer just sees plain strings. Nav is cleaned separately below so
// it can stay close to where it's used.
const cleanSettings = settings ? stegaClean(settings) : null;
const cleanSeo = seo ? stegaClean(seo) : null;
const cleanCode = code ? stegaClean(code) : null;
const cleanSocial = social ? stegaClean(social) : null;


const colorTheme  = cleanSettings?.defaultPalette || 'classic-cream';
const fontTheme   = cleanSettings?.fontTheme  || 'classic-editorial';
const siteName    = cleanSettings?.siteName   || 'Pet Photography';
const logoType    = cleanSettings?.logoType   || 'text';
const logoImage   = cleanSettings?.logoImage  ?? null;
const headScripts = cleanCode?.headScripts    || '';
const bodyScripts = cleanCode?.bodyScripts    || '';
const faviconUrl  = cleanSettings?.favicon?.asset?._ref
  ? `https://cdn.sanity.io/images/hx5xgigp/production/${cleanSettings.favicon.asset._ref.replace('image-', '').replace(/-([a-z]+)$/, '.$1')}`
  : null;
const photographerName  = cleanSettings?.photographerName || siteName;
const demoSettings      = cleanSettings?.demo ?? null;
const accentOverride    = cleanSettings?.accentColorOverride || null;
const textColorPreset   = cleanSettings?.textColorPreset || null;
const twitterHandle     = cleanSeo?.twitterHandle ? cleanSeo.twitterHandle.replace(/^@/, '') : null;
const sameAs            = [cleanSocial?.instagram, cleanSocial?.facebook, cleanSocial?.youtube, cleanSocial?.tiktok].filter(Boolean);

// Palettes were already cleaned by cleanSettings above; keep the same alias.
const palettesArr = (cleanSettings?.palettes ?? []) as Array<Record<string, string>>;
const activePaletteSlug = cleanSettings?.defaultPalette || colorTheme || null;
const activePalette =
  (activePaletteSlug && palettesArr.find((p) => p?.slug === activePaletteSlug)) ||
  palettesArr[0] ||
  null;

const themeColor = activePalette?.bg || '#f5f3ef';

const PALETTE_TO_VAR: Array<[string, string]> = [
  ['bg', '--bg'],
  ['bgAlt', '--bg-alt'],
  ['surface', '--surface'],
  ['text', '--text'],
  ['textMuted', '--muted'],
  ['textMutedLight', '--muted-light'],
  ['accent', '--accent'],
  ['accentDark', '--accent-dark'],
  ['border', '--border'],
  ['sectionAlt', '--section-alt'],
  ['sectionDark', '--section-dark'],
  ['sectionDarkText', '--section-dark-text'],
  ['btnBg', '--btn-bg'],
  ['btnText', '--btn-text'],
];
const rootPaletteCss = activePalette
  ? `:root {\n${PALETTE_TO_VAR
      .map(([key, cssVar]) => (activePalette[key] ? `  ${cssVar}: ${activePalette[key]};` : null))
      .filter(Boolean)
      .join('\n')}\n}`
  : '';

const FONT_MAP: Record<string, string> = {
  'classic-editorial': 'family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Jost:wght@300;400;500;600;700',
  'romantic-script':   'family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Lato:wght@300;400;700',
  'modern-luxury':     'family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700',
  'soft-contemporary': 'family=Fraunces:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600;1,700&family=Nunito+Sans:ital,wght@0,300;0,400;0,600;0,700',
  'bold-editorial':    'family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Libre+Franklin:wght@300;400;500;600;700',
  'airy-minimal':      'family=Tenor+Sans&family=Raleway:wght@300;400;500;600;700',
};
const fontUrl    = `https://fonts.googleapis.com/css2?${FONT_MAP[fontTheme] ?? FONT_MAP['classic-editorial']}&display=swap`;

// Text color preset palette — only applied on light themes
const LIGHT_THEMES = ['classic-cream', 'warm-studio', 'cool-minimal', 'forest-sage'];
const TEXT_PRESETS: Record<string, { text: string; muted: string; mutedLight: string }> = {
  'charcoal':  { text: '#2d2d2d', muted: '#5a5a5a', mutedLight: '#9a9a9a' },
  'black':     { text: '#0d0d0d', muted: '#444444', mutedLight: '#888888' },
  'warm-gray': { text: '#3a3530', muted: '#6b6560', mutedLight: '#a09a94' },
  'cool-gray': { text: '#2e3440', muted: '#5c6370', mutedLight: '#9099a6' },
};
const textPresetColors = (textColorPreset && LIGHT_THEMES.includes(colorTheme))
  ? TEXT_PRESETS[textColorPreset] ?? null
  : null;
// Nav + site settings go through the preview client in Presentation mode,
// so every string carries stega markers that break class names, CSS attribute
// selectors, and equality checks (e.g. `navVariant === 'centered'`). Clean
// the whole nav object — links are used for hrefs, labels, and type checks.
const cleanNav = nav ? stegaClean(nav) : null;
const navVariant     = cleanNav?.navVariant || 'classic';
const stickyNav      = !!cleanNav?.stickyNav;
const navLinks       = cleanNav?.links ?? null;
const blogEnabled    = blogConfig?.blogEnabled !== false;

// ── Structured data (JSON-LD @graph) ─────────────────────────────────────────
const canonicalBase = (cleanSeo?.siteUrl || '').replace(/\/$/, '');
const canonicalUrl  = canonicalBase ? `${canonicalBase}${Astro.url.pathname}` : null;
const schemaGraph: Record<string, any>[] = [];

if (canonicalBase) {
  // WebSite node — always present when siteUrl is set
  schemaGraph.push({
    '@type': 'WebSite',
    '@id': `${canonicalBase}/#website`,
    name: siteName,
    url: canonicalBase,
  });

  // LocalBusiness / ProfessionalService — photographer
  const biz: Record<string, any> = {
    '@type': 'ProfessionalService',
    '@id': `${canonicalBase}/#business`,
    name: siteName,
    url: canonicalBase,
  };
  if (cleanSeo?.businessPhone) biz.telephone = cleanSeo.businessPhone;
  if (cleanSeo?.businessEmail) biz.email      = cleanSeo.businessEmail;
  if (cleanSeo?.businessCity || cleanSeo?.businessState) {
    biz.address = {
      '@type': 'PostalAddress',
      ...(cleanSeo?.businessCity  ? { addressLocality: cleanSeo.businessCity  } : {}),
      ...(cleanSeo?.businessState ? { addressRegion:    cleanSeo.businessState } : {}),
    };
  }
  if (ogImage) biz.image = ogImage;
  if (cleanSeo?.priceRange) biz.priceRange = cleanSeo.priceRange;
  if (cleanSeo?.areaServed) biz.areaServed = cleanSeo.areaServed.split(',').map((s: string) => s.trim()).filter(Boolean);
  if (sameAs.length)   biz.sameAs     = sameAs;
  schemaGraph.push(biz);

  // Person — the photographer (E-A-T signal)
  schemaGraph.push({
    '@type': 'Person',
    '@id': `${canonicalBase}/#photographer`,
    name: photographerName,
    url: `${canonicalBase}/about`,
    jobTitle: 'Photographer',
    worksFor: { '@id': `${canonicalBase}/#business` },
    ...(sameAs.length ? { sameAs } : {}),
  });

  // BreadcrumbList — auto-generated from URL path + breadcrumb label
  const urlPath = Astro.url.pathname;
  if (breadcrumb && urlPath && urlPath !== '/') {
    const segments = urlPath.split('/').filter(Boolean);
    const crumbs: Record<string, any>[] = [
      { '@type': 'ListItem', position: 1, name: 'Home', item: canonicalBase },
    ];
    if (segments.length > 1) {
      // e.g. /blog/my-post → Home > Blog > Post Title
      const parentLabel = segments[0].charAt(0).toUpperCase() + segments[0].slice(1);
      crumbs.push({ '@type': 'ListItem', position: 2, name: parentLabel, item: `${canonicalBase}/${segments[0]}` });
      crumbs.push({ '@type': 'ListItem', position: 3, name: breadcrumb,  item: `${canonicalBase}${urlPath}` });
    } else {
      crumbs.push({ '@type': 'ListItem', position: 2, name: breadcrumb, item: `${canonicalBase}${urlPath}` });
    }
    schemaGraph.push({ '@type': 'BreadcrumbList', itemListElement: crumbs });
  }
}

// Merge any page-level schema nodes (FAQPage, BlogPosting, etc.)
if (schemaData?.length) schemaGraph.push(...schemaData);

const schemaJSON = schemaGraph.length
  ? JSON.stringify({ '@context': 'https://schema.org', '@graph': schemaGraph })
  : null;

---

<!doctype html>
<html lang="en" data-theme={colorTheme} data-font={fontTheme}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		{faviconUrl
			? <link rel="icon" href={faviconUrl} />
			: <>
				<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
				<link rel="icon" href="/favicon.ico" />
			</>
		}
		<title>{pageTitle ? `${pageTitle} | ${siteName}` : siteName}</title>
		{seoDescription && <meta name="description" content={seoDescription} />}
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		{prevUrl && <link rel="prev" href={prevUrl} />}
		{nextUrl && <link rel="next" href={nextUrl} />}
		{isPreview && <meta name="robots" content="noindex, nofollow" />}
		{!isPreview && robots && <meta name="robots" content={robots} />}
		<meta property="og:title" content={pageTitle ? `${pageTitle} | ${siteName}` : siteName} />
		{seoDescription && <meta property="og:description" content={seoDescription} />}
		{ogImage && <meta property="og:image" content={ogImage} />}
		<meta property="og:type" content={publishDate ? 'article' : 'website'} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content="en_US" />
		{publishDate && <meta property="article:published_time" content={publishDate} />}
		{updatedAt && <meta property="article:modified_time" content={updatedAt} />}
		<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={pageTitle ? `${pageTitle} | ${siteName}` : siteName} />
		{seoDescription && <meta name="twitter:description" content={seoDescription} />}
		{ogImage && <meta name="twitter:image" content={ogImage} />}
		{twitterHandle && <meta name="twitter:site" content={`@${twitterHandle}`} />}
		{twitterHandle && <meta name="twitter:creator" content={`@${twitterHandle}`} />}
		<meta name="theme-color" content={themeColor} data-sanity-head="theme-color" />
		<link rel="manifest" href="/manifest.json" />
		{/* Head elements tagged with data-sanity-head are swapped in place by
		    visualEditingBridge.js when Sanity settings change (font theme,
		    palette, accent, text color preset) so edits reflect without a
		    full page reload. */}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href={fontUrl} rel="stylesheet" data-sanity-head="fonts" />
		{rootPaletteCss && <style set:html={rootPaletteCss} data-sanity-head="palette" />}
		{accentOverride && (
			<style data-sanity-head="accent" set:html={`
				:root, [data-theme] {
					--accent: ${accentOverride} !important;
					--accent-dark: color-mix(in srgb, ${accentOverride} 80%, black) !important;
					--btn-bg: ${accentOverride} !important;
				}
			`} />
		)}
		{textPresetColors && (
			<style data-sanity-head="text-preset" set:html={`
				:root,
				html[data-theme='${colorTheme}'],
				[data-theme='${colorTheme}'] {
					--text: ${textPresetColors.text} !important;
					--muted: ${textPresetColors.muted} !important;
					--muted-light: ${textPresetColors.mutedLight} !important;
				}
			`} />
		)}
		{schemaJSON && <script type="application/ld+json" set:html={schemaJSON} />}
		{headScripts && <Fragment set:html={headScripts} />}
	</head>
	<body data-nav-variant={navVariant} data-hero-overlay={heroOverlay ? 'true' : undefined}>
		{isPreview && (
			<div class="preview-banner">
				<span>Preview mode — draft content visible</span>
				<a href="/api/disable-preview">Exit preview</a>
			</div>
		)}
		<DemoBanner demo={demoSettings} />
		<Nav siteName={siteName} logoType={logoType} logoImage={logoImage} navVariant={navVariant} navLinks={navLinks} {blogEnabled} {stickyNav} />
		<slot />
		<Footer {siteName} {blogEnabled} />
		<script>
			// Protect images from casual right-click saving
			document.addEventListener('contextmenu', (e) => {
				if (e.target instanceof HTMLImageElement) e.preventDefault();
			});
		</script>
		<script>
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('revealed');
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
			function bindReveals() {
				document.querySelectorAll('.reveal, .reveal-fade').forEach(el => {
					if (!el.classList.contains('revealed')) observer.observe(el);
				});
			}
			bindReveals();
			// Visual editing fetch-and-swap replaces <main> in place, so the
			// freshly inserted nodes need a fresh observer pass.
			document.addEventListener('visual-editing:swapped', bindReveals);
		</script>
		{bodyScripts && <Fragment set:html={bodyScripts} />}
		{/* Visual editing bridge — iframe-gated so the @sanity/visual-editing
		    bundle is never loaded for public visitors. Detection by parent
		    frame is more reliable than the preview cookie (which can be
		    blocked by browser cross-site cookie policies). */}
		<script>
			if (window.self !== window.top) {
				import('../lib/visualEditingBridge.js').then((m) => m.mount());
			}
		</script>
	</body>
</html>

<style is:global>
	/* ══════════════════════════════════════════════════
	   FONT THEMES
	   Applied via data-font on <html>.
	   Components reference --font-heading and --font-body.
	   Legacy aliases --font-serif / --font-sans resolve
	   through var() substitution at compute time.
	══════════════════════════════════════════════════ */

	/* Font Theme 1: Classic Editorial */
	html[data-font='classic-editorial'] {
		--font-heading: 'Cormorant Garamond', Georgia, serif;
		--font-body: 'Jost', system-ui, sans-serif;
	}

	/* Font Theme 2: Romantic Script */
	html[data-font='romantic-script'] {
		--font-heading: 'Playfair Display', Georgia, serif;
		--font-body: 'Lato', system-ui, sans-serif;
	}

	/* Font Theme 3: Modern Luxury */
	html[data-font='modern-luxury'] {
		--font-heading: 'DM Serif Display', Georgia, serif;
		--font-body: 'DM Sans', system-ui, sans-serif;
	}

	/* Font Theme 4: Soft Contemporary */
	html[data-font='soft-contemporary'] {
		--font-heading: 'Fraunces', Georgia, serif;
		--font-body: 'Nunito Sans', system-ui, sans-serif;
	}

	/* Font Theme 5: Bold Editorial */
	html[data-font='bold-editorial'] {
		--font-heading: 'Libre Baskerville', Georgia, serif;
		--font-body: 'Libre Franklin', system-ui, sans-serif;
	}

	/* Font Theme 6: Airy Minimal */
	html[data-font='airy-minimal'] {
		--font-heading: 'Tenor Sans', Georgia, serif;
		--font-body: 'Raleway', system-ui, sans-serif;
	}

	/* DM Serif Display (modern-luxury) and Tenor Sans (airy-minimal) are
	   single-weight display fonts — Google Fonts only serves weight 400.
	   Component CSS that asks for 500/600/700 would trigger browser-synthesized
	   bold, which renders fuzzy on retina. Tenor Sans also has no italic.
	   Disable synthesis so requested weights/styles fall back to the real 400
	   glyphs instead of being faked. */
	html[data-font='modern-luxury'],
	html[data-font='airy-minimal'] {
		font-synthesis: none;
	}

	/* ══════════════════════════════════════════════════
	   GLOBAL TOKENS & BASE RESET
	══════════════════════════════════════════════════ */

	:root {
		--white: #ffffff;
		--error: #c0392b;
		/*
		 * Legacy aliases — resolve through var() substitution at compute time.
		 * Component scoped styles that reference --font-serif / --font-sans
		 * will pick up whatever --font-heading / --font-body the active
		 * font theme has set on <html>.
		 */
		--font-serif: var(--font-heading);
		--font-sans: var(--font-body);
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
		/* Prevent a horizontal scroll sliver from sections that use
		   `width: 100vw` full-bleed pseudo-elements (e.g. SplitSection's
		   ::before). On desktop browsers, `100vw` includes the vertical
		   scrollbar track, so such elements are ~15px wider than the
		   visible viewport. `clip` (not `hidden`) prevents scrolling
		   without creating a scroll container, so `position: sticky`
		   children keep working. */
		overflow-x: clip;
	}

	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--text);
		font-family: var(--font-body);
		font-size: 1.328rem;
		line-height: 1.8;
		-webkit-font-smoothing: antialiased;
	}

	img {
		display: block;
		max-width: 100%;
	}

	a {
		color: inherit;
	}

	h1,
	h2,
	h3,
	h4 {
		font-family: var(--font-heading);
		font-weight: normal;
		font-style: italic;
		line-height: 1.2;
		margin: 0;
	}

	p {
		margin: 0;
	}

	ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	hr {
		border: none;
		border-top: 1px solid var(--border);
		margin: 0;
	}

	button {
		font-family: var(--font-body);
	}

	section {
		padding-top: 100px;
		padding-bottom: 100px;
	}

	/* ══════════════════════════════════════════════════
	   SCROLL REVEAL ANIMATIONS
	══════════════════════════════════════════════════ */

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(22px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@keyframes fadeIn {
		from { opacity: 0; }
		to   { opacity: 1; }
	}

	.reveal {
		opacity: 0;
		transform: translateY(22px);
		will-change: opacity, transform;
	}

	.reveal.revealed {
		animation: fadeUp 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.reveal-fade {
		opacity: 0;
		will-change: opacity;
	}

	.reveal-fade.revealed {
		animation: fadeIn 0.8s ease both;
	}

	.reveal-delay-1 { animation-delay: 0.08s; }
	.reveal-delay-2 { animation-delay: 0.16s; }
	.reveal-delay-3 { animation-delay: 0.24s; }
	.reveal-delay-4 { animation-delay: 0.32s; }
	.reveal-delay-5 { animation-delay: 0.40s; }

	@media (prefers-reduced-motion: reduce) {
		.reveal, .reveal-fade { opacity: 1 !important; transform: none !important; }
		.reveal.revealed, .reveal-fade.revealed { animation: none !important; }
	}

	/* ══════════════════════════════════════════════════
	   INTERACTION STANDARDS
	   Hover micro-interactions for all interactive elements.
	   Uses only transform, opacity, and letter-spacing —
	   compositor-only properties with zero layout impact.
	   All transitions respect prefers-reduced-motion.
	══════════════════════════════════════════════════ */

	/* ── BORDERED / SOLID BUTTONS ─────────────────────────────
	   Matches any element using __cta, __btn, __submit, __button */
	[class*="__cta"],
	[class*="__btn"],
	[class*="__submit"],
	[class*="__button"] {
		transition: background 0.25s, color 0.25s, transform 0.2s, box-shadow 0.25s;
	}
	[class*="__cta"]:hover,
	[class*="__btn"]:hover,
	[class*="__submit"]:hover,
	[class*="__button"]:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
	}

	/* ── ITALIC / ARROW TEXT LINKS ─────────────────────────────
	   Matches any element using __link                         */
	[class*="__link"] {
		transition: opacity 0.2s, letter-spacing 0.25s;
	}
	[class*="__link"]:hover {
		opacity: 1;
		letter-spacing: 0.04em;
	}

	/* ── CARD / ITEM HOVER ─────────────────────────────────────
	   Matches blog post cards, portfolio items, gallery tiles  */
	[class*="__item-inner"],
	[class*="__card"] {
		transition: transform 0.2s, box-shadow 0.25s;
	}
	[class*="__item-inner"]:hover,
	[class*="__card"]:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
	}

	/* ── SLIDER / CAROUSEL ARROWS ──────────────────────────────
